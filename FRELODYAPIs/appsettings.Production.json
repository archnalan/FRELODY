{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedOrigins": [
    "https://frelody.com",
    "https://www.frelody.com"
  ],
  "PesaPal": {
    "UseSandbox": false
  },
  "AppSettings": {
    "BaseUrl": "https://frelody.com"
  },
  "OpenTelemetry": {
    "ServiceName": "frelody-api",
    "ServiceVersion": "1.0.0",
    "Endpoint": "https://logs.frelody.com",
    "EnableConsole": false
  }
}
