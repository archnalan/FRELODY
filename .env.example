# ============================================================
# FRELODY Production Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to git.
# ============================================================

# Server hostname or IP (used in CORS origins)
SERVER_HOST=136.113.195.101

# SQL Server SA password (change to something strong!)
SA_PASSWORD=YourStrongProd@Password1

# JWT signing key (use a long random string)
JWT_KEY=G#?fjlb4d$eJ#8rksgdR$eJ#v4wd$eJ#8drRh$epaJo#

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# PesaPal payment gateway
PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret

# AI API Keys
NVIDIA_API_KEY=your-nvidia-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# SMTP mail server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Open Exchange Rates
OPENEXCHANGE_APP_ID=your-app-id

# ── OpenTelemetry: push to logs.frelody.com ──────────────────────────
# The OTLP endpoint (defaults to http://otel-collector:4318 if not set)
OTEL_ENDPOINT=http://otel-collector:4318
# Explicit OTLP headers (e.g. "x-api-key=xyz"). If empty, Basic Auth is
# auto-computed from SUPERUSER_NAME and SUPERUSER_PASSWORD below.
OTEL_HEADERS=
# Superuser credentials used to authenticate against logs.frelody.com
SUPERUSER_NAME=superuser
SUPERUSER_PASSWORD=YourStrongPasswordHere
