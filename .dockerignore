# ── Build outputs ────────────────────────────────────────────
**/bin/
**/obj/

# ── Windows executables (excluded from Release publish anyway,
#    but belt-and-suspenders to keep the build context clean) ──
**/*.exe
**/*.pdb
**/*.mdb

# ── IDE / tooling artefacts ──────────────────────────────────
**/.vs/
**/.idea/
**/*.user
**/*.suo
**/*.DotSettings
**/*.DotSettings.user

# ── Git ──────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── NuGet local cache ────────────────────────────────────────
**/*.nupkg
**/packages/

# ── Logs & temp ──────────────────────────────────────────────
**/Logs/
**/logs/
**/*.log
**/tmp/

# ── Node / front-end (not needed for the API build) ─────────
**/node_modules/

# ── Projects not needed by either build ──────────────────────
# NOTE: The per-Dockerfile .dockerignore convention (e.g.
# Dockerfile.web.dockerignore) requires BuildKit. On servers
# using the legacy builder, only THIS file is read for ALL
# builds. So we can only exclude projects that NEITHER the
# API nor the Web build needs.
SongalUI/
FRELODYUI/FRELODYUI/
FRELODYAPP/

# ── Docs / README ────────────────────────────────────────────
*.md
*.txt
docs/

# ── Docker compose overrides ─────────────────────────────────
docker-compose*.override.yml
