@*
    NavMenuItem
    -----------
    Recursive renderer for a single navigation item.
    A group renders as an expand/collapse button followed by its children.
    A leaf renders as a NavLink-style button that triggers navigation.
    Items above the current user's audience are hidden; gated items the
    current user can see are tagged with a small lock badge.
*@
@implements IDisposable
@inject AuthService Auth

@if (!IsVisible)
{
    // Item is above the current user's audience tier — render nothing.
}
else if (Item.HasChildren)
{
    <button class="nav-group @(ContainsActive(Item) ? "is-trail" : "") @(IsExpanded ? "is-expanded" : "")"
            style="--depth:@Depth"
            @onclick="ToggleSelf"
            aria-expanded="@IsExpanded">
        <span class="nav-group-caret" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
        <span class="nav-group-title">@Item.Title</span>
        @if (LockLabel(Item) is { } gl)
        {
            <span class="nav-lock nav-lock-@gl.ToLowerInvariant()" title="@gl" aria-label="@gl">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </span>
        }
    </button>
    @if (IsExpanded)
    {
        <div class="nav-children" style="--depth:@(Depth + 1)">
            @foreach (var child in Item.Children)
            {
                <NavMenuItem Item="child"
                             Depth="Depth + 1"
                             CurrentSlug="CurrentSlug"
                             Expanded="Expanded"
                             OnNavigate="OnNavigate" />
            }
        </div>
    }
}
else
{
    @* Use Blazor's NavLink so the active class is driven by the live URL,
       not a parameter we propagate by hand. NavLinkMatch.All ensures the
       full path must match, so each leaf only activates on its own page. *@
    <NavLink class="nav-link"
             ActiveClass="is-active"
             Match="NavLinkMatch.All"
             href="@($"docs/{Item.Slug}")"
             style="@($"--depth:{Depth}")"
             @onclick="HandleClick">
        <span class="nav-link-dot" aria-hidden="true"></span>
        <span class="nav-link-text">@Item.Title</span>
        @if (LockLabel(Item) is { } ll)
        {
            <span class="nav-lock nav-lock-@ll.ToLowerInvariant()" title="@ll" aria-label="@ll">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </span>
        }
    </NavLink>
}

@code {
    [Parameter, EditorRequired] public NavItem Item { get; set; } = default!;
    [Parameter] public int Depth { get; set; }
    [Parameter] public string CurrentSlug { get; set; } = string.Empty;
    [Parameter, EditorRequired] public HashSet<string> Expanded { get; set; } = default!;
    [Parameter] public EventCallback<NavItem> OnNavigate { get; set; }

    private string Key => Item.Title;
    private bool IsExpanded => Expanded.Contains(Key);

    private bool IsVisible
    {
        get
        {
            var current = Auth.CurrentAudience;
            // For groups, show if at least one descendant is visible.
            return Item.HasChildren ? Item.EffectiveAudience <= current : Item.Audience <= current;
        }
    }

    /// <summary>
    /// Returns a short label ("Premium" / "Admin" / "Sign in") for the lock badge, or
    /// null for no badge. Premium and Admin always show; Member shows only to anonymous
    /// visitors so the lock reads as "you need to sign in".
    /// </summary>
    private string? LockLabel(NavItem item)
    {
        var a = item.HasChildren ? item.EffectiveAudience : item.Audience;
        return a switch
        {
            Audience.Admin => "Admin",
            Audience.Premium => "Premium",
            Audience.Member => Auth.IsAuthenticated ? null : "Sign in",
            _ => null,
        };
    }

    protected override void OnInitialized()
    {
        Auth.OnChanged += OnAuthChanged;
    }

    private void OnAuthChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Auth.OnChanged -= OnAuthChanged;
    }

    private bool ContainsActive(NavItem item)
    {
        if (!string.IsNullOrEmpty(item.Slug) &&
            string.Equals(item.Slug, CurrentSlug, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        foreach (var c in item.Children)
        {
            if (ContainsActive(c)) return true;
        }
        return false;
    }

    private void ToggleSelf()
    {
        if (!Expanded.Add(Key)) Expanded.Remove(Key);
    }

    private async Task HandleClick()
    {
        if (OnNavigate.HasDelegate)
        {
            await OnNavigate.InvokeAsync(Item);
        }
    }
}
