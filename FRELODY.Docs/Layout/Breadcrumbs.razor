@inject NavigationDataService NavData
@inject NavigationManager Nav

@if (_trail.Count > 0)
{
    <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
            <li class="breadcrumb-item">
                <a href="/" class="breadcrumb-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="breadcrumb-icon"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                    <span>Home</span>
                </a>
            </li>
            @for (var i = 0; i < _trail.Count; i++)
            {
                var item = _trail[i];
                var isLast = i == _trail.Count - 1;
                <li class="breadcrumb-sep" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </li>
                <li class="breadcrumb-item @(isLast ? "is-current" : "")">
                    @if (isLast || string.IsNullOrEmpty(item.Slug))
                    {
                        <span class="breadcrumb-current" aria-current="@(isLast ? "page" : null)">@item.Title</span>
                    }
                    else
                    {
                        <a class="breadcrumb-link" href="/docs/@item.Slug">@item.Title</a>
                    }
                </li>
            }
        </ol>
    </nav>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private List<NavItem> _trail = new();

    protected override void OnParametersSet()
    {
        _trail = NavData.GetBreadcrumbTrail(Slug);
    }
}
