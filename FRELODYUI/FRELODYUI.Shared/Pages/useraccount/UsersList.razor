@page "/users"
@attribute [Authorize]
@inject NavigationManager _nav
@inject GlobalAuthStateProvider _globalAuth

<PageTitle>Members - FRELODY</PageTitle>

@code {
    protected override async Task OnInitializedAsync()
    {
        var userResult = await _globalAuth.GetAuthenticatedUserAsync();
        var canAdmin = false;
        if (userResult.IsSuccess && userResult.Data?.OrgRoles is { Count: > 0 } orgRoles)
        {
            canAdmin = orgRoles.Any(r =>
                string.Equals(r, UserRoles.Owner, StringComparison.OrdinalIgnoreCase)
                || string.Equals(r, UserRoles.Admin, StringComparison.OrdinalIgnoreCase)
                || string.Equals(r, UserRoles.Manager, StringComparison.OrdinalIgnoreCase));
        }
        _nav.NavigateTo(canAdmin ? "/admin/members" : "/dashboard", replace: true);
    }
}
