@inject ILogger<SettingsSection> _logger

<div class="ss-container">
    @if (IsLoading)
    {
        <div class="ss-loading">
            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            <span>Loading settings...</span>
        </div>
    }
    else
    {
        <div class="ss-layout">
        <div class="ss-settings-col">

        <!-- Appearance -->
        <div class="ss-group">
            <div class="ss-group-title"><i class="bi bi-palette me-1"></i>Appearance</div>

            <div class="ss-row">
                <label class="ss-label"><i class="bi bi-moon-stars"></i> Theme</label>
                <select class="ss-select" @bind="userSettings.Theme">
                    @foreach (var theme in Enum.GetValues<Theme>())
                    {
                        <option value="@theme">@theme</option>
                    }
                </select>
            </div>

            <div class="ss-row">
                <label class="ss-label" for="notifyToggle"><i class="bi bi-bell"></i> Notify</label>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch"
                           id="notifyToggle"
                           checked="@showNotification"
                           @onchange="e => showNotification = (bool)(e.Value ?? false)" />
                </div>
            </div>
        </div>

        <!-- Display -->
        <div class="ss-group">
            <div class="ss-group-title"><i class="bi bi-eye me-1"></i>Display</div>

            <div class="ss-row">
                <label class="ss-label"><i class="bi bi-eye"></i> Mode</label>
                <div class="segmented-control">
                    <button class="segment-btn @(userSettings.SongDisplay == SongDisplay.LyricsAndChordsAndCharts ? "active" : "")"
                            @onclick="() => SetDisplayMode(SongDisplay.LyricsAndChordsAndCharts)" title="Full">
                        <i class="bi bi-music-note-list"></i>
                        <span class="seg-label">Full</span>
                    </button>
                    <button class="segment-btn @(userSettings.SongDisplay == SongDisplay.LyricsAndChords ? "active" : "")"
                            @onclick="() => SetDisplayMode(SongDisplay.LyricsAndChords)" title="Chords + Lyrics">
                        <i class="bi bi-music-note-beamed"></i>
                        <span class="seg-label">Chords</span>
                    </button>
                    <button class="segment-btn @(userSettings.SongDisplay == SongDisplay.LyricsOnly ? "active" : "")"
                            @onclick="() => SetDisplayMode(SongDisplay.LyricsOnly)" title="Lyrics only">
                        <i class="bi bi-text-left"></i>
                        <span class="seg-label">Lyrics</span>
                    </button>
                </div>
            </div>

            @if (userSettings.SongDisplay != SongDisplay.LyricsOnly)
            {
                <div class="ss-row">
                    <label class="ss-label"><i class="bi bi-music-note"></i> Pos</label>
                    <div class="segmented-control segmented-sm">
                        <button class="segment-btn @(userSettings.ChordDisplay == ChordDisplay.Above ? "active" : "")"
                                @onclick="() => userSettings.ChordDisplay = ChordDisplay.Above">
                            Above
                        </button>
                        <button class="segment-btn @(userSettings.ChordDisplay == ChordDisplay.Inline ? "active" : "")"
                                @onclick="() => userSettings.ChordDisplay = ChordDisplay.Inline">
                            Inline
                        </button>
                    </div>
                </div>
            }

            <div class="ss-row">
                <label class="ss-label" for="verseTitlesToggle"><i class="bi bi-card-heading"></i> Titles</label>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch"
                           id="verseTitlesToggle"
                           checked="@(userSettings.ShowVerseTitles ?? false)"
                           @onchange="e => userSettings.ShowVerseTitles = (bool)(e.Value ?? false)" />
                </div>
            </div>
        </div>

        <!-- Typography -->
        <div class="ss-group">
            <div class="ss-group-title"><i class="bi bi-fonts me-1"></i>Typography</div>

            <div class="ss-row">
                <label class="ss-label"><i class="bi bi-fonts"></i> Font</label>
                <select class="ss-select" @bind="userSettings.ChordFont" @bind:after="SyncLyricFont">
                    <option value="system-ui, -apple-system, 'Segoe UI'">System</option>
                    <option value="'Georgia', serif">Georgia</option>
                    <option value="'Arial', sans-serif">Arial</option>
                    <option value="'Courier New', monospace">Courier</option>
                    <option value="'Times New Roman', serif">Times</option>
                    <option value="'Kanit','Helvetica Neue', 'Helvetica', 'Arial', 'sans-serif'">Kanit</option>
                    <option value="'Montserrat', sans-serif">Montserrat</option>
                </select>
            </div>

            <div class="ss-row">
                <label class="ss-label"><i class="bi bi-type"></i> Chord</label>
                <div class="ss-inline-control">
                    <input type="range" class="ss-range" min="10" max="32" step="1"
                           value="@chordFontSize"
                           @oninput="OnChordFontSizeInput"
                           disabled="@(userSettings.SongDisplay == SongDisplay.LyricsOnly)" />
                    <span class="slider-value">@(chordFontSize)px</span>
                </div>
            </div>

            <div class="ss-row">
                <label class="ss-label"><i class="bi bi-text-paragraph"></i> Lyric</label>
                <div class="ss-inline-control">
                    <input type="range" class="ss-range" min="12" max="40" step="1"
                           value="@lyricFontSize"
                           @oninput="OnLyricFontSizeInput" />
                    <span class="slider-value">@(lyricFontSize)px</span>
                </div>
            </div>
        </div>

        <!-- Colors -->
        <div class="ss-group">
            <div class="ss-group-title"><i class="bi bi-palette2 me-1"></i>Colors</div>

            @if (userSettings.SongDisplay != SongDisplay.LyricsOnly)
            {
                <div class="ss-row">
                    <label class="ss-label"><i class="bi bi-palette"></i> Chord</label>
                    <div class="color-picker-control">
                        <div class="color-swatch-wrapper">
                            <input type="color" class="color-input"
                                   value="@GetChordColorValue()"
                                   @oninput="e => userSettings.ChordColor = e.Value?.ToString()"
                                   @onchange="e => userSettings.ChordColor = e.Value?.ToString()" />
                            <span class="color-swatch" style="background: @GetChordColorValue();"></span>
                        </div>
                        <span class="color-hex-label">@(string.IsNullOrEmpty(userSettings.ChordColor) ? "Theme" : userSettings.ChordColor)</span>
                        @if (!string.IsNullOrEmpty(userSettings.ChordColor))
                        {
                            <button class="color-reset-btn" @onclick="() => userSettings.ChordColor = null" title="Reset to theme default">
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </button>
                        }
                    </div>
                </div>
            }

            <div class="ss-row">
                <label class="ss-label"><i class="bi bi-palette2"></i> Lyric</label>
                <div class="color-picker-control">
                    <div class="color-swatch-wrapper">
                        <input type="color" class="color-input"
                               value="@GetLyricColorValue()"
                               @oninput="e => userSettings.LyricColor = e.Value?.ToString()"
                               @onchange="e => userSettings.LyricColor = e.Value?.ToString()" />
                        <span class="color-swatch" style="background: @GetLyricColorValue();"></span>
                    </div>
                    <span class="color-hex-label">@(string.IsNullOrEmpty(userSettings.LyricColor) ? "Theme" : userSettings.LyricColor)</span>
                    @if (!string.IsNullOrEmpty(userSettings.LyricColor))
                    {
                        <button class="color-reset-btn" @onclick="() => userSettings.LyricColor = null" title="Reset to theme default">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Play Preferences -->
        <div class="ss-group">
            <div class="ss-group-title"><i class="bi bi-controller me-1"></i>Play Preferences</div>

            <div class="ss-row">
                <label class="ss-label"><i class="bi bi-bar-chart"></i> Level</label>
                <select class="ss-select" @bind="userSettings.PlayLevel">
                    @foreach (var level in Enum.GetValues<PlayLevel>())
                    {
                        <option value="@level">@GetPlayLevelName(level)</option>
                    }
                </select>
            </div>

            <div class="ss-row">
                <label class="ss-label"><i class="bi bi-music-note"></i> Diff</label>
                <select class="ss-select" @bind="userSettings.ChordDifficulty">
                    @foreach (var difficulty in Enum.GetValues<ChordDifficulty>())
                    {
                        <option value="@difficulty">@GetDifficultyName(difficulty)</option>
                    }
                </select>
            </div>
        </div>

        </div><!-- /ss-settings-col -->

        <!-- Live Preview -->
        <div class="ss-preview">
            <div class="ss-preview-header"><i class="bi bi-eye me-1"></i>Preview</div>
            <div class="ss-preview-body" style="font-family: @userSettings.ChordFont">
                @{
                    // Sample segments mirroring Song.razor's lyric-segment structure
                    var pvLines = new[]
                    {
                        new[] {
                            (chord: "G",  lyric: "Amazing "),
                            (chord: "C",  lyric: "grace, "),
                            (chord: "G",  lyric: "how sweet "),
                            (chord: (string?)null, lyric: "the sound"),
                        },
                        new[] {
                            (chord: "Em", lyric: "That "),
                            (chord: (string?)null, lyric: "saved a "),
                            (chord: "D",  lyric: "wretch "),
                            (chord: (string?)null, lyric: "like me"),
                        }
                    };
                    var showChords = userSettings.SongDisplay != SongDisplay.LyricsOnly;
                    var segClass   = userSettings.ChordDisplay == ChordDisplay.Inline ? "chord-inline" : "chord-above";
                    // Match Song.razor: only apply color when the user has explicitly set one
                    var chordStyle = string.IsNullOrEmpty(userSettings.ChordColor)
                        ? $"font-size:{chordFontSize}px;"
                        : $"font-size:{chordFontSize}px;color:{userSettings.ChordColor}";
                    var lyricStyle = string.IsNullOrEmpty(userSettings.LyricColor)
                        ? $"font-size:{lyricFontSize}px;"
                        : $"font-size:{lyricFontSize}px;color:{userSettings.LyricColor}";
                }

                @if (userSettings.ShowVerseTitles == true)
                {
                    <div class="ss-pv-verse-title">Verse 1</div>
                }

                @foreach (var line in pvLines)
                {
                    <div class="lyric-line">
                        @foreach (var seg in line)
                        {
                            <div class="lyric-segment @(showChords && seg.chord != null ? segClass : "chord-above")">
                                @if (showChords && seg.chord != null)
                                {
                                    @if (userSettings.ChordDisplay == ChordDisplay.Inline)
                                    {
                                        <span class="chord" style="@chordStyle">[@seg.chord]</span>
                                    }
                                    else
                                    {
                                        <span class="chord" style="@chordStyle">@seg.chord</span>
                                    }
                                }
                                <span class="lyric" style="@lyricStyle">@seg.lyric</span>
                            </div>
                        }
                    </div>
                }

                @if (userSettings.SongDisplay == SongDisplay.LyricsAndChordsAndCharts)
                {
                    <div class="ss-pv-chart-badge"><i class="bi bi-grid-3x3 me-1"></i>Chord charts included</div>
                }
            </div>
        </div><!-- /ss-preview -->

        </div><!-- /ss-layout -->

        <div class="ss-footer">
            <button class="ss-save-btn" @onclick="SaveUserSettings" disabled="@IsSaving">
                @if (IsSaving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-check-circle me-1"></i>
                }
                Save Settings
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;

    private SettingDto userSettings { get; set; } = new();
    private bool IsSaving { get; set; }
    private bool IsLoading { get; set; }
    private bool showNotification = false;

    // Local numeric state for sliders (SettingDto stores as strings)
    private int chordFontSize = 14;
    private int lyricFontSize = 18;

    // Fallback shown in the color swatch when no custom color is saved
    private const string SwatchFallbackChord = "#3b82f6";
    private const string SwatchFallbackLyric = "#6b7280";

    protected override async Task OnInitializedAsync()
    {
        await LoadUserSettings();
    }

    private async Task LoadUserSettings()
    {
        try
        {
            IsLoading = true;
            var response = await _settingsApi.GetUserSettings(UserId);

            if (response.IsSuccessStatusCode && response.Content != null)
            {
                userSettings = response.Content;
                showNotification = userSettings.ShowNotifications ?? false;
            }
            else
            {
                userSettings = new SettingDto
                {
                    ChordFont = "system-ui, -apple-system, 'Segoe UI'",
                    LyricFont = "system-ui, -apple-system, 'Segoe UI'",
                    ChordFontSize = "14",
                    LyricFontSize = "18",
                    SongDisplay = SongDisplay.LyricsAndChords,
                    Theme = Theme.Light,
                    ChordDisplay = ChordDisplay.Above,
                    ChordDifficulty = ChordDifficulty.Medium,
                    PlayLevel = PlayLevel.Medium
                };
            }

            // Sync theme from localStorage — NavMenu toggles save to localStorage but not DB
            var storedTheme = await _storageService.GetItemAsync<string>("Theme");
            if (!string.IsNullOrEmpty(storedTheme))
            {
                userSettings.Theme = storedTheme.Equals("dark", StringComparison.OrdinalIgnoreCase)
                    ? Theme.Dark
                    : Theme.Light;
            }

            chordFontSize = int.TryParse(userSettings.ChordFontSize, out var cfs) ? cfs : 14;
            lyricFontSize = int.TryParse(userSettings.LyricFontSize, out var lfs) ? lfs : 18;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading user settings");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void SetDisplayMode(SongDisplay mode)
    {
        userSettings.SongDisplay = mode;
    }

    private void OnChordFontSizeInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            chordFontSize = Math.Clamp(val, 10, 32);
            userSettings.ChordFontSize = chordFontSize.ToString();
        }
    }

    private void OnLyricFontSizeInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            lyricFontSize = Math.Clamp(val, 12, 40);
            userSettings.LyricFontSize = lyricFontSize.ToString();
        }
    }

    private void SyncLyricFont()
    {
        userSettings.LyricFont = userSettings.ChordFont;
    }

    // Used only by color picker swatches — gives a visual hint when no colour is saved
    private string GetChordColorValue() =>
        string.IsNullOrEmpty(userSettings.ChordColor) ? SwatchFallbackChord : userSettings.ChordColor;

    private string GetLyricColorValue() =>
        string.IsNullOrEmpty(userSettings.LyricColor) ? SwatchFallbackLyric : userSettings.LyricColor;

    private async Task SaveUserSettings()
    {
        try
        {
            IsSaving = true;
            userSettings.ShowNotifications = showNotification;
            userSettings.CreatedBy = UserId;
            var response = await _settingsApi.CreateOrUpdateUserSettings(userSettings);

            if (response.IsSuccessStatusCode)
            {
                // Keep localStorage in sync so NavMenu theme toggle reflects the saved choice
                var themeStr = userSettings.Theme == Theme.Dark ? "dark" : "light";
                await _storageService.SetItemAsync("Theme", themeStr);
                await JsRt.InvokeVoidAsync("eval",
                    $"document.documentElement.setAttribute('data-bs-theme', '{themeStr}')");
                _toastService.Show("Settings saved!", ToastType.Success);
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                ShowErrorModal($"Failed to save settings: {errorMessage}");
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error saving settings");
            ShowErrorModal("Failed to save settings");
        }
        finally
        {
            IsSaving = false;
        }
    }

    private string GetDifficultyName(ChordDifficulty difficulty) => difficulty switch
    {
        ChordDifficulty.Easy => "Beginner",
        ChordDifficulty.Medium => "Intermediate",
        ChordDifficulty.Advanced => "Advanced",
        ChordDifficulty.Expert => "Expert",
        _ => difficulty.ToString()
    };

    private string GetPlayLevelName(PlayLevel level) => level switch
    {
        PlayLevel.Easy => "Beginner",
        PlayLevel.Medium => "Intermediate",
        PlayLevel.Advanced => "Advanced",
        _ => level.ToString()
    };

    private void ShowErrorModal(string message)
    {
        _modalService.Show(new ModalOptionDto
        {
            Title = "Error",
            Message = message,
            ButtonText = "OK",
            OptionType = OptionType.Error,
            Context = new ModalContext { ActionType = "Error" }
        });
    }
}