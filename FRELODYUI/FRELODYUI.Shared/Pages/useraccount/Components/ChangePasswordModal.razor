@using FRELODYAPP.Dtos.AuthDtos
@inject ILogger<ChangePasswordModal> _logger

@if (IsVisible)
{
    <div class="cp-overlay" @onclick="HandleCancel">
        <div class="cp-modal" @onclick:stopPropagation="true">
            <div class="cp-header">
                <h3 class="cp-title">Change Password</h3>
                <button type="button" class="cp-close" @onclick="HandleCancel" aria-label="Close">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <p class="cp-desc">Enter your current password and choose a new one.</p>

            <EditForm Model="@model" OnValidSubmit="HandleSubmit" FormName="changePasswordForm">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="cp-alert cp-alert-error" role="alert">@errorMessage</div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="cp-alert cp-alert-success" role="status">@successMessage</div>
                }

                <!-- Current Password -->
                <div class="cp-field">
                    <label class="cp-label" for="cp-old-password">Current Password</label>
                    <div class="cp-input-wrapper">
                        <input id="cp-old-password"
                               type="@(showOldPassword ? "text" : "password")"
                               class="cp-input"
                               @bind="model.OldPassword"
                               @onfocusout="ValidateOldPassword"
                               placeholder="Enter current password"
                               disabled="@isSubmitting" />
                        <button type="button" class="cp-toggle-pw" @onclick="() => showOldPassword = !showOldPassword" tabindex="-1">
                            <i class="bi @(showOldPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => model.OldPassword)" class="cp-validation" />
                    @if (!string.IsNullOrEmpty(oldPasswordError))
                    {
                        <span class="cp-validation">@oldPasswordError</span>
                    }
                </div>

                <!-- New Password -->
                <div class="cp-field">
                    <label class="cp-label" for="cp-new-password">New Password</label>
                    <div class="cp-input-wrapper">
                        <input id="cp-new-password"
                               type="@(showNewPassword ? "text" : "password")"
                               class="cp-input"
                               @bind="model.NewPassword"
                               @bind:event="oninput"
                               placeholder="Enter new password"
                               disabled="@isSubmitting" />
                        <button type="button" class="cp-toggle-pw" @onclick="() => showNewPassword = !showNewPassword" tabindex="-1">
                            <i class="bi @(showNewPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => model.NewPassword)" class="cp-validation" />
                </div>

                @if (!string.IsNullOrEmpty(model.NewPassword))
                {
                    <div class="cp-strength">
                        <div class="cp-strength-bar">
                            @for (int i = 0; i < 4; i++)
                            {
                                var idx = i;
                                <div class="cp-strength-segment @(idx < PasswordStrengthScore ? $"cp-strength-{PasswordStrengthLevel}" : "")"></div>
                            }
                        </div>
                        <span class="cp-strength-label cp-strength-text-@PasswordStrengthLevel">@PasswordStrengthLabel</span>
                    </div>

                    <ul class="cp-requirements">
                        <li class="@(model.NewPassword.Length >= 8 ? "cp-req-met" : "cp-req-unmet")">At least 8 characters</li>
                        <li class="@(System.Text.RegularExpressions.Regex.IsMatch(model.NewPassword, @"[A-Z]") ? "cp-req-met" : "cp-req-unmet")">One uppercase letter</li>
                        <li class="@(System.Text.RegularExpressions.Regex.IsMatch(model.NewPassword, @"[a-z]") ? "cp-req-met" : "cp-req-unmet")">One lowercase letter</li>
                        <li class="@(System.Text.RegularExpressions.Regex.IsMatch(model.NewPassword, @"\d") ? "cp-req-met" : "cp-req-unmet")">One number</li>
                        <li class="@(System.Text.RegularExpressions.Regex.IsMatch(model.NewPassword, @"[^a-zA-Z0-9]") ? "cp-req-met" : "cp-req-unmet")">One special character</li>
                    </ul>
                }

                <!-- Confirm Password -->
                <div class="cp-field">
                    <label class="cp-label" for="cp-confirm-password">Confirm New Password</label>
                    <div class="cp-input-wrapper">
                        <input id="cp-confirm-password"
                               type="@(showConfirmPassword ? "text" : "password")"
                               class="cp-input"
                               @bind="model.ConfirmPassword"
                               @bind:event="oninput"
                               placeholder="Confirm new password"
                               disabled="@isSubmitting" />
                        <button type="button" class="cp-toggle-pw" @onclick="() => showConfirmPassword = !showConfirmPassword" tabindex="-1">
                            <i class="bi @(showConfirmPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => model.ConfirmPassword)" class="cp-validation" />
                    @if (!string.IsNullOrEmpty(model.NewPassword) && !string.IsNullOrEmpty(model.ConfirmPassword) && model.NewPassword != model.ConfirmPassword)
                    {
                        <span class="cp-validation">Passwords do not match</span>
                    }
                </div>

                <div class="cp-actions">
                    <button type="button" class="cp-btn secondary" @onclick="HandleCancel" disabled="@isSubmitting">
                        Cancel
                    </button>
                    <button type="submit" class="cp-btn primary" disabled="@(isSubmitting || !IsPasswordValid)">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Change Password
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string? Email { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }

    private ChangePasswordModel model = new();
    private bool isSubmitting;
    private bool showOldPassword;
    private bool showNewPassword;
    private bool showConfirmPassword;
    private string? errorMessage;
    private string? successMessage;
    private string? oldPasswordError;

    private int PasswordStrengthScore
    {
        get
        {
            if (string.IsNullOrEmpty(model.NewPassword)) return 0;
            int score = 0;
            if (model.NewPassword.Length >= 8) score++;
            if (System.Text.RegularExpressions.Regex.IsMatch(model.NewPassword, @"[A-Z]")
                && System.Text.RegularExpressions.Regex.IsMatch(model.NewPassword, @"[a-z]")) score++;
            if (System.Text.RegularExpressions.Regex.IsMatch(model.NewPassword, @"\d")) score++;
            if (System.Text.RegularExpressions.Regex.IsMatch(model.NewPassword, @"[^a-zA-Z0-9]")) score++;
            return score;
        }
    }

    private string PasswordStrengthLevel => PasswordStrengthScore switch
    {
        0 => "weak",
        1 => "weak",
        2 => "medium",
        3 => "strong",
        4 => "very-strong",
        _ => "weak"
    };

    private string PasswordStrengthLabel => PasswordStrengthScore switch
    {
        0 => "Too weak",
        1 => "Weak",
        2 => "Fair",
        3 => "Strong",
        4 => "Very strong",
        _ => ""
    };

    private bool IsPasswordValid =>
        !string.IsNullOrEmpty(model.OldPassword)
        && !string.IsNullOrEmpty(model.NewPassword) && model.NewPassword.Length >= 8
        && model.NewPassword == model.ConfirmPassword && PasswordStrengthScore >= 2;

    private void ValidateOldPassword()
    {
        if (string.IsNullOrWhiteSpace(model.OldPassword))
        {
            oldPasswordError = "Current password is required.";
        }
        else if (model.OldPassword.Length < 6)
        {
            oldPasswordError = "Password seems too short.";
        }
        else
        {
            oldPasswordError = null;
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            if (model.NewPassword != model.ConfirmPassword)
            {
                errorMessage = "New password and confirmation do not match.";
                return;
            }

            if (string.IsNullOrEmpty(Email))
            {
                errorMessage = "User email is not available. Please try again.";
                return;
            }

            isSubmitting = true;
            StateHasChanged();

            var resetDto = new ResetPasswordDto
            {
                EmailAddress = Email,
                Password = model.NewPassword,
                OldPassword = model.OldPassword
            };

            var response = await _authApi.ResetPassword(resetDto);

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Password changed successfully!";
                StateHasChanged();

                await Task.Delay(1500);
                await OnSuccess.InvokeAsync();
                ResetForm();
            }
            else
            {
                errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error changing password");
            errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task HandleCancel()
    {
        ResetForm();
        await OnClose.InvokeAsync();
    }

    private void ResetForm()
    {
        model = new();
        errorMessage = null;
        successMessage = null;
        oldPasswordError = null;
        showOldPassword = false;
        showNewPassword = false;
        showConfirmPassword = false;
    }

    public class ChangePasswordModel
    {
        [Required(ErrorMessage = "Current password is required")]
        public string OldPassword { get; set; } = "";

        [Required(ErrorMessage = "New password is required")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your new password")]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";
    }
}
