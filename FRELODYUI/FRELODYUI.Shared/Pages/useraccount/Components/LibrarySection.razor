@inject ILogger<LibrarySection> _logger

<!-- Search -->
<div class="lib-search">
    <i class="bi bi-search lib-search-icon"></i>
    <input type="text" class="lib-search-input" placeholder="Search your library..."
           @bind-value="searchQuery" @bind-value:event="oninput" @bind-value:after="SearchChanged" />
</div>

@if (IsLoading)
{
    <FRELODYUI.Shared.Pages.PlaceHolders.LibrarySectionPlaceholder Count="3" />
}
else if (selectedCollection != null)
{
    <!-- Playlist Detail View -->
    <div class="lib-card">
        <div class="lib-card-header" style="border-bottom:1px solid var(--border-light);">
            <button class="lib-back-btn" @onclick="GoBackToCollections">
                <i class="bi bi-chevron-left"></i>
            </button>
            <span style="font-weight:600;color:var(--text-primary);">@selectedCollection.Playlist.Title</span>
        </div>

        @if (!string.IsNullOrEmpty(selectedCollection.Playlist.Description))
        {
            <p class="lib-desc">@selectedCollection.Playlist.Description</p>
        }

        @if (selectedCollection.Songs?.Any() == true)
        {
            <div class="lib-list">
                @foreach (var song in selectedCollection.Songs.OrderBy(s => s.SortOrder ?? int.MaxValue))
                {
                    <div class="lib-item" @onclick="() => ViewSong(song.Id)">
                        <div class="lib-item-info">
                            @if (song.SongNumber.HasValue)
                            {
                                <span class="lib-badge">@song.SongNumber.Value</span>
                            }
                            <div>
                                <div class="lib-item-title">@song.Title</div>
                                @if (!string.IsNullOrEmpty(song.WrittenBy))
                                {
                                    <div class="lib-item-sub">By @song.WrittenBy</div>
                                }
                            </div>
                        </div>
                        <i class="bi bi-play-fill lib-play-icon"></i>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="lib-empty-small">
                <i class="bi bi-music-note"></i>
                <span>No songs in this playlist</span>
            </div>
        }
    </div>
}
else
{
    <div class="lib-grid">
        <!-- Favorites -->
        <div class="lib-card">
            <div class="lib-card-header">
                <i class="bi bi-heart-fill" style="color:#ef4444"></i>
                <span>Favorites</span>
                @if (FavoriteSongs?.Count > MAX_HIST_ITEMS)
                {
                    <span class="lib-count">@FavoriteSongs.Count</span>
                }
            </div>

            @if (FavoriteSongs?.Any() == true)
            {
                <div class="lib-list">
                    @foreach (var song in FavoriteSongs.Take(MAX_HIST_ITEMS))
                    {
                        <div class="lib-item" @onclick="@(() => ViewSong(song.IdString ?? ""))">
                            <span class="lib-item-title">@song.ValueText</span>
                            <i class="bi bi-play-fill lib-play-icon"></i>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="lib-empty-small">
                    <i class="bi bi-heart"></i>
                    <span>No favorites yet</span>
                </div>
            }
        </div>

        <!-- Recent Plays -->
        <div class="lib-card">
            <div class="lib-card-header">
                <i class="bi bi-clock-history" style="color:var(--gradient-primary-start)"></i>
                <span>Recent</span>
            </div>

            @if (RecentPlays?.Any() == true)
            {
                <div class="lib-list">
                    @foreach (var play in RecentPlays.Take(MAX_HIST_ITEMS))
                    {
                        <div class="lib-item" @onclick="@(() => ViewSong(play.SongId))">
                            <div class="lib-item-info">
                                <div>
                                    <div class="lib-item-title">@play.SongTitle</div>
                                    <div class="lib-item-sub">@play.PlayedAt.ToLocalTime().ToString("MMM dd, hh:mm tt")</div>
                                </div>
                            </div>
                            <i class="bi bi-play-fill lib-play-icon"></i>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="lib-empty-small">
                    <i class="bi bi-clock"></i>
                    <span>No recent plays</span>
                </div>
            }
        </div>

        <!-- Playlists -->
        <div class="lib-card">
            <div class="lib-card-header">
                <i class="bi bi-collection-fill" style="color:var(--gradient-primary-end)"></i>
                <span>Playlists</span>
                @if (Collections?.Count > 5)
                {
                    <span class="lib-count">@Collections.Count</span>
                }
            </div>

            @if (Collections?.Any() == true)
            {
                <div class="lib-list">
                    @foreach (var collection in Collections.Take(5))
                    {
                        <div class="lib-item" @onclick="() => ViewPlaylistDetails(collection)">
                            <div class="lib-item-info">
                                <div>
                                    <div class="lib-item-title">@collection.Playlist.Title</div>
                                    <div class="lib-item-sub">@collection.Songs.Count @(collection.Songs.Count == 1 ? "song" : "songs")</div>
                                </div>
                            </div>
                            <i class="bi bi-chevron-right lib-play-icon"></i>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="lib-empty-small">
                    <i class="bi bi-collection"></i>
                    <span>No playlists yet</span>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public List<ComboBoxDto>? FavoriteSongs { get; set; }
    [Parameter] public List<SongPlayHistoryDto>? RecentPlays { get; set; }
    [Parameter] public List<PlaylistSongs>? Collections { get; set; }
    [Parameter] public EventCallback<string> OnSearchChanged { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    private string searchQuery = "";
    private int MAX_HIST_ITEMS = 5;
    private PlaylistSongs? selectedCollection = null;

    private async Task SearchChanged()
    {
        await OnSearchChanged.InvokeAsync(searchQuery);
    }

    private void ViewPlaylistDetails(PlaylistSongs collection)
    {
        selectedCollection = collection;
        StateHasChanged();
    }

    private void GoBackToCollections()
    {
        selectedCollection = null;
        StateHasChanged();
    }

    private void ViewSong(string songId)
    {
        _ = Task.Run(async () =>
           {
               try
               {
                   await _playHistoryApi.LogSongPlay(songId, "SongList");
               }
               catch (Exception ex)
               {
                   _logger.LogWarning(ex, "Failed to log song play from list for song {SongId}", songId);
               }
           });
        _navManager.NavigateTo($"/songs/{songId}");
    }
}