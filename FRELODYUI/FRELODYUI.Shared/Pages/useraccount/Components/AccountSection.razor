<div class="acct-container">
    <!-- Security Settings -->
    <div class="acct-card">
        <div class="acct-card-header">
            <i class="bi bi-shield-lock"></i>
            <span>Security</span>
        </div>
        <div class="acct-card-body">
            <div class="acct-row">
                <div class="acct-row-info">
                    <h6 class="acct-row-title">Password</h6>
                    <small class="acct-row-sub">Change your account password</small>
                </div>
                <button class="acct-btn primary" @onclick="OnPasswordChange">
                    <i class="bi bi-key"></i>
                    <span>Change</span>
                </button>
            </div>

            <div class="acct-divider"></div>

            <div class="acct-row">
                <div class="acct-row-info">
                    <h6 class="acct-row-title">Two-Factor Authentication</h6>
                    <small class="acct-row-sub">Add an extra layer of security (Coming Soon)</small>
                </div>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" disabled>
                </div>
            </div>
        </div>
    </div>

    <!-- Account Information -->
    <div class="acct-card">
        <div class="acct-card-header">
            <i class="bi bi-person-lines-fill"></i>
            <span>Account Information</span>
        </div>
        <div class="acct-card-body">
            <div class="acct-info-grid">
                <div class="acct-info-item">
                    <label class="acct-info-label">Username</label>
                    <p class="acct-info-value">@UserProfile?.UserName</p>
                </div>
                <div class="acct-info-item">
                    <label class="acct-info-label">Full Name</label>
                    <p class="acct-info-value">@UserProfile?.FirstName @UserProfile?.LastName</p>
                </div>
                <div class="acct-info-item acct-info-full">
                    <label class="acct-info-label">Account ID</label>
                    <div class="acct-id-row">
                        <input type="text" class="acct-id-input" value="@UserProfile?.Id" readonly />
                        <button class="acct-btn icon-only" type="button" title="Copy ID">
                            <i class="bi bi-copy"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Management -->
    <div class="acct-card">
        <div class="acct-card-header">
            <i class="bi bi-database"></i>
            <span>Data Management</span>
        </div>
        <div class="acct-card-body">
            <div class="acct-row">
                <div class="acct-row-info">
                    <h6 class="acct-row-title">Export Data</h6>
                    <small class="acct-row-sub">Download all your data (Coming Soon)</small>
                </div>
                <button class="acct-btn muted" @onclick="OnExportData" disabled>
                    <i class="bi bi-download"></i>
                    <span>Export</span>
                </button>
            </div>

            <div class="acct-divider"></div>

            <div class="acct-row">
                <div class="acct-row-info">
                    <h6 class="acct-row-title">Connected Accounts</h6>
                    <small class="acct-row-sub">Manage your connected social accounts (Coming Soon)</small>
                </div>
                <button class="acct-btn muted" disabled>
                    <i class="bi bi-link-45deg"></i>
                    <span>Manage</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Danger Zone -->
    @if (!isSuperAdmin)
    {
        <div class="acct-card danger">
            <div class="acct-card-header danger">
                <i class="bi bi-exclamation-triangle"></i>
                <span>Danger Zone</span>
            </div>
            <div class="acct-card-body">
                <div class="acct-row">
                    <div class="acct-row-info">
                        <h6 class="acct-row-title danger">Delete Account</h6>
                        <small class="acct-row-sub">
                            Permanently delete your account and all associated data.
                            This action cannot be undone.
                        </small>
                    </div>
                    <button class="acct-btn danger" @onclick="OnDeleteAccount">
                        <i class="bi bi-trash"></i>
                        <span>Delete</span>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public UpdateUserProfileOutDto? UserProfile { get; set; }
    [Parameter] public EventCallback OnPasswordChange { get; set; }
    [Parameter] public EventCallback OnExportData { get; set; }
    [Parameter] public EventCallback OnDeleteAccount { get; set; }

    private bool isSuperAdmin;

    protected override async Task OnInitializedAsync()
    {
        var user = await _globalAuth.GetAuthenticatedUserAsync();
        if (user.IsSuccess && user.Data != null)
        {
            isSuperAdmin = user.Data.UserType == UserType.SuperAdmin;
        }
    }
}