
<!-- Cover -->
<div class="vph-cover">
    @if (!string.IsNullOrEmpty(UserProfile?.CoverPhotoUrl))
    {
        <img src="@UserProfile.CoverPhotoUrl" alt="Cover" class="vph-cover-img" />
    }
    <button class="vph-edit-btn" @onclick="OnEdit" title="Edit profile">
        <i class="bi bi-pencil"></i>
    </button>
</div>

<!-- Avatar + Info -->
<div class="vph-body">
    <div class="vph-avatar-wrap">
        @if (!string.IsNullOrEmpty(UserProfile?.ProfilePicUrl))
        {
            <img src="@UserProfile.ProfilePicUrl"
                 alt="@UserProfile.FirstName @UserProfile.LastName"
                 class="vph-avatar" />
        }
        else
        {
            <div class="vph-avatar vph-avatar-initials">
                @(UserProfile?.FirstName?.FirstOrDefault())@(UserProfile?.LastName?.FirstOrDefault())
            </div>
        }
    </div>

    <h2 class="vph-name">@UserProfile?.FirstName @UserProfile?.LastName</h2>
    <p class="vph-username">@@@UserProfile?.UserName</p>

    @if (!string.IsNullOrEmpty(UserProfile?.AboutMe))
    {
        <p class="vph-bio">@UserProfile.AboutMe</p>
    }

    <div class="vph-stats">
        <span class="vph-stat">
            <i class="bi bi-music-note-beamed"></i>@UserProfile?.TotalSongs songs
        </span>
        @if (!string.IsNullOrEmpty(UserProfile?.Address))
        {
            <span class="vph-stat">
                <i class="bi bi-geo-alt"></i>@UserProfile.Address
            </span>
        }
        @if (!string.IsNullOrEmpty(UserProfile?.Profession))
        {
            <span class="vph-stat">
                <i class="bi bi-briefcase"></i>@UserProfile.Profession
            </span>
        }
    </div>
</div>

@code {
    [Parameter] public UpdateUserProfileOutDto? UserProfile { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
}