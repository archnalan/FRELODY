@inject ILogger<EmailVerificationModal> _logger

<div class="reg-modal-overlay" @onclick="HandleOverlayClick">
    <div class="reg-modal" @onclick:stopPropagation="true">
        <div class="reg-modal-header">
            <h3 class="reg-modal-title">Verify your email</h3>
            <button type="button" class="reg-modal-close" @onclick="Close" aria-label="Close" disabled="@isVerifying">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>

        <p class="reg-modal-desc">
            We sent a 6-digit code to <strong>@Email</strong>. Enter it below to continue.
        </p>

        <!-- Progress bar during sending/verifying -->
        @if (isSending || isVerifying)
        {
            <div class="reg-otp-progress-container">
                <div class="reg-otp-progress-bar">
                    <div class="reg-otp-progress-fill @(isVerifying ? "reg-otp-progress-verify" : "")"></div>
                </div>
                <span class="reg-otp-progress-text">@(isSending ? "Sending code..." : "Verifying...")</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="reg-alert reg-alert-error" role="alert">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="reg-alert reg-alert-success" role="status">@successMessage</div>
        }

        <!-- OTP Input -->
        <div class="reg-otp-group">
            @for (int i = 0; i < 6; i++)
            {
                var idx = i;
                <input type="text"
                       inputmode="numeric"
                       pattern="[0-9]*"
                       class="reg-otp-input @(hasError ? "reg-otp-error" : "")"
                       value="@otpDigits[idx]"
                       disabled="@(isVerifying || isSending)"
                       @oninput="(e) => HandleOtpInput(idx, e)"
                       @onkeydown="(e) => HandleOtpKeyDown(idx, e)"
                       @ref="otpInputs[idx]"
                       autocomplete="one-time-code" />
            }
        </div>

        <!-- Actions -->
        <div class="reg-modal-actions">
            <button type="button"
                    class="reg-btn-verify"
                    @onclick="VerifyCode"
                    disabled="@(isVerifying || isSending || string.Join("", otpDigits).Length < 6)">
                @if (isVerifying)
                {
                    <span class="reg-spinner" aria-hidden="true"></span>
                    <span>Verifying...</span>
                }
                else
                {
                    <span>Verify</span>
                }
            </button>
        </div>

        <div class="reg-resend-row">
            @if (resendCountdown > 0)
            {
                <span class="reg-resend-timer">Resend in @resendCountdown s</span>
            }
            else
            {
                <button type="button" class="reg-resend-link" @onclick="ResendCode" disabled="@isSending">
                    @if (isSending)
                    {
                        <span class="reg-spinner-sm" aria-hidden="true"></span>
                    }
                    Resend code
                </button>
            }
        </div>
    </div>
</div>

<style>
    .reg-otp-progress-container {
        margin: 0 0 16px;
        text-align: center;
    }

    .reg-otp-progress-bar {
        width: 100%;
        height: 4px;
        background: #e8e8f0;
        border-radius: 2px;
        overflow: hidden;
        margin-bottom: 8px;
    }

    .reg-otp-progress-fill {
        height: 100%;
        width: 30%;
        background: linear-gradient(90deg, #667eea, #764ba2);
        border-radius: 2px;
        animation: reg-otp-progress-anim 1.5s ease-in-out infinite;
    }

    .reg-otp-progress-verify {
        animation: reg-otp-progress-verify-anim 0.8s ease-in-out infinite;
    }

    .reg-otp-progress-text {
        font-size: 13px;
        color: #667eea;
        font-weight: 500;
    }

    @@keyframes reg-otp-progress-anim {
        0% { width: 10%; margin-left: 0; }
        50% { width: 60%; margin-left: 20%; }
        100% { width: 10%; margin-left: 90%; }
    }

    @@keyframes reg-otp-progress-verify-anim {
        0% { width: 20%; margin-left: 0; }
        50% { width: 80%; margin-left: 10%; }
        100% { width: 20%; margin-left: 80%; }
    }
</style>

@code {
    [Parameter, EditorRequired] public string Email { get; set; } = "";
    [Parameter] public string? FullName { get; set; }
    [Parameter] public string? TenantName { get; set; }
    [Parameter] public EventCallback<VerifyOtpResponseDto> OnVerified { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>
    /// When true, SendOtp was already called from the parent and we only need to verify.
    /// </summary>
    [Parameter] public bool OtpAlreadySent { get; set; }

    private string[] otpDigits = new string[6];
    private ElementReference[] otpInputs = new ElementReference[6];

    private bool isVerifying;
    private bool isSending;
    private bool hasError;
    private string errorMessage = "";
    private string successMessage = "";
    private int resendCountdown;
    private Timer? resendTimer;

    protected override async Task OnInitializedAsync()
    {
        if (OtpAlreadySent)
        {
            successMessage = "Code sent! Check your inbox.";
            StartResendTimer();
        }
        else
        {
            await SendCode();
        }
    }

    private async Task SendCode()
    {
        try
        {
            isSending = true;
            errorMessage = "";
            StateHasChanged();

            var request = new SendOtpRequestDto
            {
                Email = Email,
                FullName = FullName,
                TenantName = TenantName
            };

            var result = await _otpApi.SendOtp(request);
            if (result.IsSuccessStatusCode && result.Content != null)
            {
                successMessage = result.Content.Message;
                StartResendTimer();
            }
            else
            {
                errorMessage = GetErrorMessage(result);
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error sending verification code to {Email}", Email);
            errorMessage = "Something went wrong. Please try again.";
        }
        finally
        {
            isSending = false;
            StateHasChanged();
        }
    }

    private async Task VerifyCode()
    {
        var entered = string.Join("", otpDigits);
        if (entered.Length < 6)
        {
            errorMessage = "Please enter the full 6-digit code.";
            return;
        }

        isVerifying = true;
        hasError = false;
        errorMessage = "";
        StateHasChanged();

        try
        {
            var request = new VerifyOtpRequestDto
            {
                Email = Email,
                OtpCode = entered
            };

            var result = await _otpApi.VerifyOtp(request);
            if (result.IsSuccessStatusCode && result.Content != null && result.Content.Verified)
            {
                await OnVerified.InvokeAsync(result.Content);
            }
            else
            {
                hasError = true;
                errorMessage = GetErrorMessage(result);
                isVerifying = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error verifying code for {Email}", Email);
            hasError = true;
            errorMessage = "Verification failed. Please try again.";
            isVerifying = false;
            StateHasChanged();
        }
    }

    private void HandleOtpInput(int index, ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        var digits = new string(value.Where(char.IsDigit).ToArray());

        if (digits.Length > 1)
        {
            for (int i = 0; i < 6; i++)
            {
                var offset = i - index;
                otpDigits[i] = (offset >= 0 && offset < digits.Length)
                    ? digits[offset].ToString()
                    : otpDigits[i];
            }
            hasError = false;
            var focusIdx = Math.Min(index + digits.Length, 5);
            _ = FocusInput(focusIdx);
            StateHasChanged();
            return;
        }

        if (digits.Length == 1)
        {
            otpDigits[index] = digits;
            hasError = false;
            if (index < 5)
            {
                _ = FocusInput(index + 1);
            }
        }
        else
        {
            otpDigits[index] = "";
        }

        StateHasChanged();
    }

    private void HandleOtpKeyDown(int index, KeyboardEventArgs e)
    {
        if (e.Key == "Backspace" && string.IsNullOrEmpty(otpDigits[index]) && index > 0)
        {
            otpDigits[index - 1] = "";
            _ = FocusInput(index - 1);
            StateHasChanged();
        }
        else if (e.Key == "Enter")
        {
            _ = VerifyCode();
        }
    }

    private async Task FocusInput(int index)
    {
        await Task.Yield();
        try { await otpInputs[index].FocusAsync(); } catch { }
    }

    private async Task ResendCode()
    {
        otpDigits = new string[6];
        hasError = false;
        successMessage = "";
        errorMessage = "";
        isSending = true;
        StateHasChanged();

        try
        {
            var result = await _otpApi.ResendOtp(Email);
            if (result.IsSuccessStatusCode && result.Content != null)
            {
                successMessage = result.Content.Message;
                StartResendTimer();
            }
            else
            {
                errorMessage = GetErrorMessage(result);
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error resending code to {Email}", Email);
            errorMessage = "Failed to resend code. Please try again.";
        }
        finally
        {
            isSending = false;
            StateHasChanged();
        }
    }

    private void StartResendTimer()
    {
        resendCountdown = 45;
        resendTimer?.Dispose();
        resendTimer = new Timer(_ =>
        {
            resendCountdown--;
            if (resendCountdown <= 0)
            {
                resendTimer?.Dispose();
            }
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private void Close()
    {
        resendTimer?.Dispose();
        OnClose.InvokeAsync();
    }

    private void HandleOverlayClick()
    {
        if (!isVerifying && !isSending)
            Close();
    }

    public void Dispose()
    {
        resendTimer?.Dispose();
    }

    private string GetErrorMessage<T>(Refit.IApiResponse<T> response)
    {
        try
        {
            return _apiResponseHandler.GetApiErrorMessage(response);
        }
        catch
        {
            return "An error occurred. Please try again.";
        }
    }
}
