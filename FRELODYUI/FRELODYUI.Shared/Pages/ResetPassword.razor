@page "/resetpassword/{Token}"
@layout LandingLayout
@using FRELODYAPP.Dtos.AuthDtos
@using Microsoft.AspNetCore.WebUtilities
@inject ILogger<ResetPassword> _logger

<PageTitle>Reset Password - FRELODY</PageTitle>

<div class="rp-page">
    <div class="rp-container">
        <!-- Branding -->
        <div class="rp-branding">
            <div class="rp-logo" aria-hidden="true">
                <span class="rp-logo-icon">
                    <i class="bi bi-music-note-beamed"></i>
                </span>
            </div>
            <h1 class="rp-app-name">FRELODY</h1>
            <p class="rp-tagline">Set your new password</p>
        </div>

        <!-- Card -->
        <div class="rp-card">
            @if (isComplete)
            {
                <div class="rp-success-state">
                    <i class="bi bi-check-circle-fill rp-success-icon"></i>
                    <h2 class="rp-card-heading">Password Reset</h2>
                    <p class="rp-desc">Your password has been changed successfully. You can now sign in with your new password.</p>
                    <button class="rp-btn primary" @onclick="NavigateToLogin">
                        <i class="bi bi-box-arrow-in-right me-1"></i>
                        Go to Login
                    </button>
                </div>
            }
            else
            {
                <h2 class="rp-card-heading">Create New Password</h2>
                <p class="rp-desc">Choose a new password for your account.</p>

                <EditForm Model="@model" OnValidSubmit="HandleResetPassword" FormName="resetPasswordForm">
                    <DataAnnotationsValidator />

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="rp-alert error" role="alert">@errorMessage</div>
                    }

                    <!-- Email (readonly, pre-filled from reset link) -->
                    <div class="rp-field">
                        <label class="rp-label" for="rp-email">Email Address</label>
                        <div class="rp-input-wrapper">
                            <i class="bi bi-envelope rp-input-icon"></i>
                            <input id="rp-email" type="email"
                                   class="rp-input"
                                   value="@model.Email"
                                   readonly
                                   tabindex="-1" />
                        </div>
                    </div>

                    <!-- New Password -->
                    <div class="rp-field">
                        <label class="rp-label" for="rp-password">New Password</label>
                        <div class="rp-input-wrapper">
                            <i class="bi bi-lock rp-input-icon"></i>
                            <input id="rp-password"
                                   type="@(showPassword ? "text" : "password")"
                                   class="rp-input"
                                   @bind="model.Password"
                                   @bind:event="oninput"
                                   placeholder="Enter new password"
                                   disabled="@isSubmitting" />
                            <button type="button" class="rp-toggle-pw" @onclick="() => showPassword = !showPassword" tabindex="-1">
                                <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                        <ValidationMessage For="@(() => model.Password)" class="rp-validation" />
                    </div>

                    @if (!string.IsNullOrEmpty(model.Password))
                    {
                        <div class="rp-strength">
                            <div class="rp-strength-bar">
                                @for (int i = 0; i < 4; i++)
                                {
                                    var idx = i;
                                    <div class="rp-strength-segment @(idx < PasswordStrengthScore ? $"rp-strength-{PasswordStrengthLevel}" : "")"></div>
                                }
                            </div>
                            <span class="rp-strength-label rp-strength-text-@PasswordStrengthLevel">@PasswordStrengthLabel</span>
                        </div>

                        <ul class="rp-requirements">
                            <li class="@(model.Password.Length >= 8 ? "rp-req-met" : "rp-req-unmet")">At least 8 characters</li>
                            <li class="@(System.Text.RegularExpressions.Regex.IsMatch(model.Password, @"[A-Z]") ? "rp-req-met" : "rp-req-unmet")">One uppercase letter</li>
                            <li class="@(System.Text.RegularExpressions.Regex.IsMatch(model.Password, @"[a-z]") ? "rp-req-met" : "rp-req-unmet")">One lowercase letter</li>
                            <li class="@(System.Text.RegularExpressions.Regex.IsMatch(model.Password, @"\d") ? "rp-req-met" : "rp-req-unmet")">One number</li>
                            <li class="@(System.Text.RegularExpressions.Regex.IsMatch(model.Password, @"[^a-zA-Z0-9]") ? "rp-req-met" : "rp-req-unmet")">One special character</li>
                        </ul>
                    }

                    <!-- Confirm Password -->
                    <div class="rp-field">
                        <label class="rp-label" for="rp-confirm">Confirm Password</label>
                        <div class="rp-input-wrapper">
                            <i class="bi bi-lock-fill rp-input-icon"></i>
                            <input id="rp-confirm"
                                   type="@(showConfirmPassword ? "text" : "password")"
                                   class="rp-input"
                                   @bind="model.ConfirmPassword"
                                   @bind:event="oninput"
                                   placeholder="Confirm new password"
                                   disabled="@isSubmitting" />
                            <button type="button" class="rp-toggle-pw" @onclick="() => showConfirmPassword = !showConfirmPassword" tabindex="-1">
                                <i class="bi @(showConfirmPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                        <ValidationMessage For="@(() => model.ConfirmPassword)" class="rp-validation" />
                        @if (!string.IsNullOrEmpty(model.Password) && !string.IsNullOrEmpty(model.ConfirmPassword) && model.Password != model.ConfirmPassword)
                        {
                            <span class="rp-validation">Passwords do not match</span>
                        }
                    </div>

                    <button type="submit" class="rp-btn primary w-100" disabled="@(isSubmitting || !IsPasswordValid)">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Reset Password
                    </button>
                </EditForm>

                <div class="rp-footer-link">
                    <span>Remember your password? </span>
                    <a href="/login">Sign in</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Token { get; set; } = "";

    private ResetPasswordFormModel model = new();

    protected override void OnInitialized()
    {
        var uri = _navManager.ToAbsoluteUri(_navManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("email", out var email))
        {
            model.Email = email.ToString();
        }
    }
    private bool isSubmitting;
    private bool isComplete;
    private bool showPassword;
    private bool showConfirmPassword;
    private string? errorMessage;

    private int PasswordStrengthScore
    {
        get
        {
            if (string.IsNullOrEmpty(model.Password)) return 0;
            int score = 0;
            if (model.Password.Length >= 8) score++;
            if (System.Text.RegularExpressions.Regex.IsMatch(model.Password, @"[A-Z]")
                && System.Text.RegularExpressions.Regex.IsMatch(model.Password, @"[a-z]")) score++;
            if (System.Text.RegularExpressions.Regex.IsMatch(model.Password, @"\d")) score++;
            if (System.Text.RegularExpressions.Regex.IsMatch(model.Password, @"[^a-zA-Z0-9]")) score++;
            return score;
        }
    }

    private string PasswordStrengthLevel => PasswordStrengthScore switch
    {
        0 => "weak",
        1 => "weak",
        2 => "medium",
        3 => "strong",
        4 => "very-strong",
        _ => "weak"
    };

    private string PasswordStrengthLabel => PasswordStrengthScore switch
    {
        0 => "Too weak",
        1 => "Weak",
        2 => "Fair",
        3 => "Strong",
        4 => "Very strong",
        _ => ""
    };

    private bool IsPasswordValid =>
        !string.IsNullOrEmpty(model.Password) && model.Password.Length >= 8
        && model.Password == model.ConfirmPassword && PasswordStrengthScore >= 2;

    private async Task HandleResetPassword()
    {
        try
        {
            errorMessage = null;

            if (model.Password != model.ConfirmPassword)
            {
                errorMessage = "Passwords do not match.";
                return;
            }

            isSubmitting = true;
            StateHasChanged();

            var resetDto = new ResetPasswordDto
            {
                EmailAddress = model.Email,
                Password = model.Password,
                ResetToken = Token
            };

            var response = await _authApi.ResetPassword(resetDto);

            if (response.IsSuccessStatusCode)
            {
                isComplete = true;
            }
            else
            {
                errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error resetting password");
            errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private void NavigateToLogin()
    {
        _navManager.NavigateTo("/login");
    }

    public class ResetPasswordFormModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Enter a valid email address")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";
    }
}
