<!-- Top bar skeleton -->
<div class="placeholder-glow" style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;padding:0.5rem 0;">
    <span class="placeholder" style="width:2.25rem;height:2.25rem;border-radius:10px;opacity:0.2"></span>
    <span class="placeholder" style="width:6rem;height:1rem;border-radius:6px"></span>
    <span class="placeholder ms-auto" style="width:2.25rem;height:2.25rem;border-radius:10px;opacity:0.2"></span>
</div>

<!-- Hero skeleton -->
<div class="placeholder-glow" style="display:flex;align-items:flex-start;gap:1rem;padding:1.5rem;margin-bottom:1rem;background:var(--card-bg);border:1px solid var(--border-light);border-radius:16px;">
    <span class="placeholder" style="width:4rem;height:4rem;border-radius:14px;opacity:0.15;flex-shrink:0"></span>
    <div style="flex:1;min-width:0;">
        <span class="placeholder d-block" style="width:3.5rem;height:0.85rem;border-radius:6px;margin-bottom:0.5rem"></span>
        <span class="placeholder d-block" style="width:65%;height:1.35rem;border-radius:6px;margin-bottom:0.4rem"></span>
        <span class="placeholder d-block" style="width:35%;height:0.85rem;border-radius:6px;margin-bottom:0.5rem"></span>
        <div class="d-flex gap-1">
            @for (var i = 0; i < 5; i++)
            {
                <span class="placeholder" style="width:0.9rem;height:0.9rem;border-radius:2px;opacity:0.15"></span>
            }
        </div>
    </div>
</div>

<!-- Metadata card skeleton -->
<div class="placeholder-glow" style="background:var(--card-bg);border:1px solid var(--border-light);border-radius:14px;padding:0.25rem 0;margin-bottom:1rem;">
    @for (var i = 0; i < 5; i++)
    {
        <div style="display:flex;align-items:center;gap:0.75rem;padding:0.75rem 1.25rem;@(i > 0 ? "border-top:1px solid var(--border-light);" : "")">
            <span class="placeholder" style="width:2rem;height:2rem;border-radius:8px;opacity:0.15;flex-shrink:0"></span>
            <span class="placeholder" style="width:@(25 + i * 5)%;height:0.8rem;border-radius:6px"></span>
            <span class="placeholder ms-auto" style="width:@(30 + i * 7 % 20)%;height:0.8rem;border-radius:6px"></span>
        </div>
    }
</div>

<!-- History card skeleton -->
<div class="placeholder-glow" style="background:var(--card-bg);border:1px solid var(--border-light);border-radius:14px;padding:1.25rem;margin-bottom:1rem;">
    <div class="d-flex align-items-center gap-2 mb-3">
        <span class="placeholder" style="width:1rem;height:1rem;border-radius:4px;opacity:0.15"></span>
        <span class="placeholder" style="width:4.5rem;height:1rem;border-radius:6px"></span>
    </div>
    <span class="placeholder d-block" style="width:100%;height:0.85rem;border-radius:4px;margin-bottom:0.5rem"></span>
    <span class="placeholder d-block" style="width:90%;height:0.85rem;border-radius:4px;margin-bottom:0.5rem"></span>
    <span class="placeholder d-block" style="width:65%;height:0.85rem;border-radius:4px"></span>
</div>

<!-- Actions skeleton -->
<div class="placeholder-glow" style="display:flex;gap:0.75rem;padding:1rem 0;">
    <span class="placeholder" style="flex:1;height:2.75rem;border-radius:12px;opacity:0.15"></span>
    <span class="placeholder" style="flex:1;height:2.75rem;border-radius:12px;opacity:0.1"></span>
</div>
