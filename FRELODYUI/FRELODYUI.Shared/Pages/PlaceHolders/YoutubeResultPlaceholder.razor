<div class="yt-grid placeholder-glow">
    @for (int i = 0; i < Count; i++)
    {
        <div class="yt-skel-card">
            <div class="yt-skel-thumb placeholder"></div>
            <div class="yt-skel-body">
                <span class="yt-skel-title placeholder"></span>
                <span class="yt-skel-title yt-skel-title--short placeholder"></span>
                <span class="yt-skel-channel placeholder"></span>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Count { get; set; } = 8;
}
