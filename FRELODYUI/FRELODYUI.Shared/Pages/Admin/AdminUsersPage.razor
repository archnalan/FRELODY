@page "/admin/users"
@layout AdminLayout
@using Refit
@using FRELODYLIB.ServiceHandler

<PageTitle>Users - FRELODY</PageTitle>

<AuthGuard RequirePremium="false">
    @if (!_isSuperAdmin)
    {
        <div class="admin-card admin-card-pad">
            <h2 class="admin-title">Not authorized</h2>
            <p class="text-muted mb-3">Only platform administrators can manage users.</p>
            <a class="admin-btn primary" href="/dashboard">Back to dashboard</a>
        </div>
    }
    else
    {
        <div class="admin-header">
            <div>
                <h1 class="admin-title">Users</h1>
                <p class="admin-subtitle">Every Frelody account — search, status, and access.</p>
            </div>
            <a class="admin-btn" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>
        </div>

        @* ── Filter tabs ── *@
        <div class="au-tabs" role="tablist" aria-label="User account filter">
            <button class="au-tab @(_filter == UserAccountFilter.Active ? "au-tab--active" : "")"
                    role="tab"
                    aria-selected="@(_filter == UserAccountFilter.Active)"
                    @onclick="() => SetFilter(UserAccountFilter.Active)">
                <i class="bi bi-person-check"></i> Active
            </button>
            <button class="au-tab @(_filter == UserAccountFilter.Blocked ? "au-tab--active" : "")"
                    role="tab"
                    aria-selected="@(_filter == UserAccountFilter.Blocked)"
                    @onclick="() => SetFilter(UserAccountFilter.Blocked)">
                <i class="bi bi-slash-circle"></i> Blocked
            </button>
            <button class="au-tab @(_filter == UserAccountFilter.Deleted ? "au-tab--active" : "")"
                    role="tab"
                    aria-selected="@(_filter == UserAccountFilter.Deleted)"
                    @onclick="() => SetFilter(UserAccountFilter.Deleted)">
                <i class="bi bi-trash3"></i> Soft-deleted
            </button>
        </div>

        @* ── Search + sort bar ── *@
        <div class="au-toolbar admin-card admin-card-pad">
            <div class="au-search-wrap">
                <i class="bi bi-search au-search-icon"></i>
                <input class="au-search-input" type="search" placeholder="Search by name, email, username…"
                       value="@_searchTerm" @oninput="OnSearchInput" />
            </div>
            <div class="au-sort-wrap">
                <label class="au-sort-label">Sort by</label>
                <select class="au-sort-select" @bind="_sortByColumn" @bind:after="OnSortChanged">
                    <option value="FirstName">First name</option>
                    <option value="Email">Email</option>
                    <option value="DateCreated">Joined</option>
                    <option value="LastLoginDate">Last seen</option>
                </select>
                <button class="admin-btn icon-only" title="Toggle sort direction" @onclick="ToggleSortDirection">
                    <i class="bi @(_sortAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                </button>
            </div>
        </div>

        @* ── Table card ── *@
        <div class="au-table-card admin-card">
            @if (_isInitialLoading)
            {
                <div class="admin-card-pad">
                    @for (int i = 0; i < 8; i++)
                    {
                        <div class="admin-skeleton mb-2" style="height:44px;"></div>
                    }
                </div>
            }
            else if (_users.Count == 0)
            {
                <div class="au-empty">
                    <i class="bi bi-people"></i>
                    <p class="mb-0">@(string.IsNullOrWhiteSpace(_searchTerm)
                        ? EmptyStateMessage()
                        : $"No results for \"{_searchTerm}\".")</p>
                </div>
            }
            else
            {
                <div class="au-tbl-scroll @(_isPageLoading ? "is-loading" : "")">
                    <table class="au-tbl">
                        <thead>
                            <tr>
                                <th class="au-col-user">
                                    <button class="au-th-btn @(_sortByColumn == "FirstName" ? "au-th-btn--active" : "")"
                                            @onclick='() => SetSort("FirstName")'>
                                        <span class="au-th">
                                            User
                                            @if (_sortByColumn == "FirstName")
                                            {
                                                <i class="bi @(_sortAscending ? "bi-arrow-up" : "bi-arrow-down")"></i>
                                            }
                                        </span>
                                    </button>
                                </th>
                                <th class="au-col-email au-col-md">
                                    <button class="au-th-btn @(_sortByColumn == "Email" ? "au-th-btn--active" : "")"
                                            @onclick='() => SetSort("Email")'>
                                        <span class="au-th">
                                            Email
                                            @if (_sortByColumn == "Email")
                                            {
                                                <i class="bi @(_sortAscending ? "bi-arrow-up" : "bi-arrow-down")"></i>
                                            }
                                        </span>
                                    </button>
                                </th>
                                <th class="au-col-status">
                                    <span class="au-th">Status</span>
                                </th>
                                <th class="au-col-date au-col-lg">
                                    <button class="au-th-btn @(_sortByColumn == "DateCreated" ? "au-th-btn--active" : "")"
                                            @onclick='() => SetSort("DateCreated")'>
                                        <span class="au-th">
                                            Joined
                                            @if (_sortByColumn == "DateCreated")
                                            {
                                                <i class="bi @(_sortAscending ? "bi-arrow-up" : "bi-arrow-down")"></i>
                                            }
                                        </span>
                                    </button>
                                </th>
                                <th class="au-col-date au-col-md">
                                    <button class="au-th-btn @(_sortByColumn == "LastLoginDate" ? "au-th-btn--active" : "")"
                                            @onclick='() => SetSort("LastLoginDate")'>
                                        <span class="au-th">
                                            Last seen
                                            @if (_sortByColumn == "LastLoginDate")
                                            {
                                                <i class="bi @(_sortAscending ? "bi-arrow-up" : "bi-arrow-down")"></i>
                                            }
                                        </span>
                                    </button>
                                </th>
                                <th class="au-col-actions">
                                    <span class="au-th"></span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in _users)
                            {
                                <tr @key="u.UserId">
                                    <td class="au-col-user">
                                        <div class="au-user-cell">
                                            <div class="user-avatar-circle au-avatar">
                                                <span>@(u.Initials ?? "?")</span>
                                            </div>
                                            <div class="au-user-info">
                                                <div class="au-name">@(u.FullName?.Trim() is { Length: > 0 } n ? n : "(no name)")</div>
                                                @* Fold email + username under name on small screens *@
                                                <div class="au-name-sub d-md-none">
                                                    @if (!string.IsNullOrWhiteSpace(u.Email))
                                                    {
                                                        <span>@u.Email</span>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(u.UserName))
                                                    {
                                                        <span class="au-username">@@@u.UserName</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(u.UserName))
                                                {
                                                    <div class="au-username d-none d-md-block">@@@u.UserName</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="au-col-email au-col-md au-email">@(u.Email ?? "—")</td>
                                    <td class="au-col-status">
                                        <div class="au-badges">
                                            @{
                                                bool isPremium = u.BillingStatus is BillingStatus.PremiumTrial
                                                    or BillingStatus.ActiveRecurring
                                                    or BillingStatus.ActiveLifetime
                                                    && (u.BillingExpiresAt == null || u.BillingExpiresAt > DateTimeOffset.UtcNow);
                                            }
                                            @if (isPremium)
                                            {
                                                <span class="admin-pill au-pill-premium"><i class="bi bi-star-fill"></i> Premium</span>
                                            }
                                            else
                                            {
                                                <span class="admin-chip au-chip-free">Free</span>
                                            }
                                            @if (u.IsActive == false)
                                            {
                                                <span class="admin-pill au-pill-disabled"><i class="bi bi-slash-circle"></i> Blocked</span>
                                            }
                                            @if (u.UserType is UserType.SuperAdmin or UserType.TenantAdmin)
                                            {
                                                <span class="admin-chip au-chip-role">@u.UserType</span>
                                            }
                                            @if (u.DateCreated.HasValue && u.DateCreated.Value > DateTimeOffset.UtcNow.AddDays(-7))
                                            {
                                                <span class="admin-pill au-pill-new">New</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="au-col-date au-col-lg au-date">@RelativeTime(u.DateCreated)</td>
                                    <td class="au-col-date au-col-md au-date">@RelativeTime(u.LastLoginDate)</td>
                                    <td class="au-col-actions">
                                        <span class="au-row-actions">
                                            <a class="admin-btn icon-only" title="View profile"
                                               href="/user-profile/@u.UserId">
                                                <i class="bi bi-person"></i>
                                            </a>
                                            @if (_filter == UserAccountFilter.Active)
                                            {
                                                @if (!(u.UserType is UserType.SuperAdmin or UserType.TenantAdmin))
                                                {
                                                    <button class="admin-btn icon-only danger" title="Block user"
                                                            @onclick="() => OpenBlock(u)">
                                                        <i class="bi bi-slash-circle"></i>
                                                    </button>
                                                }
                                            }
                                            else if (_filter == UserAccountFilter.Blocked)
                                            {
                                                <button class="admin-btn icon-only" title="Unblock user"
                                                        @onclick="() => OpenUnblock(u)">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            }
                                            else if (_filter == UserAccountFilter.Deleted)
                                            {
                                                <button class="admin-btn icon-only" title="Restore account"
                                                        @onclick="() => OpenRestore(u)">
                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                </button>
                                            }
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* ── Numbered pager ── *@
                <div class="au-pager">
                    <div class="au-pager__info">
                        @if (_isPageLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                        }
                        <span>
                            <strong>@RangeStart.ToString("N0")</strong>–<strong>@RangeEnd.ToString("N0")</strong>
                            of <strong>@_totalItems.ToString("N0")</strong>
                        </span>
                    </div>

                    @if (_totalPages > 1)
                    {
                        <div class="au-pager__nav" role="navigation" aria-label="Pagination">
                            <button class="au-pager-btn" title="First page"
                                    disabled="@(_currentPage <= 1 || _isPageLoading)"
                                    @onclick="() => GoToPage(1)">
                                <i class="bi bi-chevron-double-left"></i>
                            </button>
                            <button class="au-pager-btn" title="Previous page"
                                    disabled="@(_currentPage <= 1 || _isPageLoading)"
                                    @onclick="() => GoToPage(_currentPage - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>

                            @foreach (var p in GetPageWindow())
                            {
                                @if (p < 0)
                                {
                                    <span class="au-pager-ellipsis">…</span>
                                }
                                else
                                {
                                    <button class="au-pager-btn @(p == _currentPage ? "au-pager-btn--active" : "")"
                                            disabled="@_isPageLoading"
                                            @onclick="() => GoToPage(p)">
                                        @p
                                    </button>
                                }
                            }

                            <button class="au-pager-btn" title="Next page"
                                    disabled="@(_currentPage >= _totalPages || _isPageLoading)"
                                    @onclick="() => GoToPage(_currentPage + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                            <button class="au-pager-btn" title="Last page"
                                    disabled="@(_currentPage >= _totalPages || _isPageLoading)"
                                    @onclick="() => GoToPage(_totalPages)">
                                <i class="bi bi-chevron-double-right"></i>
                            </button>
                        </div>
                    }

                    <div class="au-pager__size">
                        <label for="au-page-size">Rows</label>
                        <select id="au-page-size" @bind="PageSize" disabled="@_isPageLoading">
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="admin-alert danger mt-3">@_error</div>
        }
    }
</AuthGuard>

@* ── Block confirm dialog ── *@
<ConfirmDialog Visible="_showBlock"
               Title="Block user"
               Icon="bi-slash-circle"
               Destructive="true"
               ConfirmLabel="Block"
               Busy="_saving"
               OnCancel="@(() => _showBlock = false)"
               OnConfirm="ConfirmBlock">
    <BodyContent>
        <p class="mb-0">Block <strong>@_actionTarget?.FullName</strong>? They will be unable to sign in or re-register until unblocked.</p>
    </BodyContent>
</ConfirmDialog>

@* ── Unblock confirm dialog ── *@
<ConfirmDialog Visible="_showUnblock"
               Title="Unblock user"
               Icon="bi-check-circle"
               Destructive="false"
               ConfirmLabel="Unblock"
               Busy="_saving"
               OnCancel="@(() => _showUnblock = false)"
               OnConfirm="ConfirmUnblock">
    <BodyContent>
        <p class="mb-0">Unblock <strong>@_actionTarget?.FullName</strong>? They will be able to sign in again.</p>
    </BodyContent>
</ConfirmDialog>

@* ── Restore confirm dialog ── *@
<ConfirmDialog Visible="_showRestore"
               Title="Restore account"
               Icon="bi-arrow-counterclockwise"
               Destructive="false"
               ConfirmLabel="Restore"
               Busy="_saving"
               OnCancel="@(() => _showRestore = false)"
               OnConfirm="ConfirmRestore">
    <BodyContent>
        <p class="mb-0">Restore <strong>@_actionTarget?.FullName</strong>'s account? They will be able to sign in again.</p>
    </BodyContent>
</ConfirmDialog>

@code {
    // ── Pagination state ──────────────────────────────────────────────────
    private int _currentPage = 1;
    private int _pageSize = 25;
    private int _totalItems;
    private bool _isInitialLoading = true;
    private bool _isPageLoading;

    private int _totalPages => _totalItems <= 0 ? 0 : (int)Math.Ceiling(_totalItems / (double)_pageSize);
    private int RangeStart => _totalItems == 0 ? 0 : ((_currentPage - 1) * _pageSize) + 1;
    private int RangeEnd => Math.Min(_currentPage * _pageSize, _totalItems);

    private int PageSize
    {
        get => _pageSize;
        set
        {
            if (value == _pageSize) return;
            _pageSize = value <= 0 ? 25 : value;
            _ = LoadPage(1);
        }
    }

    // ── Data ─────────────────────────────────────────────────────────────
    private List<AppUserDto> _users = new();
    private bool _isSuperAdmin;
    private string? _error;
    private string _searchTerm = string.Empty;
    private string _sortByColumn = "DateCreated";
    private bool _sortAscending = false;
    private UserAccountFilter _filter = UserAccountFilter.Active;

    // ── Action modal state ────────────────────────────────────────────────
    private bool _showBlock;
    private bool _showUnblock;
    private bool _showRestore;
    private bool _saving;
    private AppUserDto? _actionTarget;

    // ── Search debounce ───────────────────────────────────────────────────
    private CancellationTokenSource? _searchCts;

    // ─────────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var userResult = await _globalAuth.GetAuthenticatedUserAsync();
        _isSuperAdmin = userResult.IsSuccess && userResult.Data?.UserType == UserType.SuperAdmin;
        if (_isSuperAdmin)
            await LoadPage(1);
        else
            _isInitialLoading = false;
    }

    // ── Page loading ──────────────────────────────────────────────────────
    private async Task LoadPage(int page)
    {
        if (page < 1) page = 1;

        _isPageLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var offset = (page - 1) * _pageSize;
            IApiResponse<PaginationDetails<AppUserDto>> resp;

            if (!string.IsNullOrWhiteSpace(_searchTerm))
                resp = await _usersApi.SearchForUsers(_searchTerm, offset, _pageSize, _sortByColumn, _sortAscending, _filter);
            else
                resp = await _usersApi.GetAllUsers(offset, _pageSize, _sortByColumn, _sortAscending, _filter);

            if (resp.IsSuccessStatusCode && resp.Content is not null)
            {
                var items = resp.Content.Data ?? new();
                var total = resp.Content.TotalSize;

                // Snap to last page if the requested page fell off the end (e.g. after an action)
                if (items.Count == 0 && total > 0 && page > 1)
                {
                    var lastPage = (int)Math.Ceiling(total / (double)_pageSize);
                    if (page > lastPage)
                    {
                        await LoadPage(lastPage);
                        return;
                    }
                }

                _users = items;
                _totalItems = total;
                _currentPage = page;
            }
            else
            {
                _error = _apiResponseHandler.GetApiErrorMessage(resp);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isInitialLoading = false;
            _isPageLoading = false;
            StateHasChanged();
        }
    }

    // ── Pager helpers ─────────────────────────────────────────────────────
    private async Task GoToPage(int page)
    {
        if (page < 1) page = 1;
        if (_totalPages > 0 && page > _totalPages) page = _totalPages;
        if (page == _currentPage || _isPageLoading) return;
        await LoadPage(page);
    }

    private IEnumerable<int> GetPageWindow()
    {
        var total = _totalPages;
        if (total <= 0) yield break;

        var shown = new SortedSet<int> { 1, total };
        for (var p = _currentPage - 1; p <= _currentPage + 1; p++)
        {
            if (p >= 1 && p <= total) shown.Add(p);
        }

        var prev = 0;
        foreach (var p in shown)
        {
            if (prev != 0 && p - prev > 1) yield return -1; // ellipsis marker
            yield return p;
            prev = p;
        }
    }

    // ── Search + sort ─────────────────────────────────────────────────────
    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? string.Empty;
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(350, _searchCts.Token);
            await LoadPage(1);
        }
        catch (TaskCanceledException) { /* debounced */ }
    }

    private async Task OnSortChanged() => await LoadPage(1);

    private async Task SetSort(string column)
    {
        if (_sortByColumn == column)
            _sortAscending = !_sortAscending;
        else
        {
            _sortByColumn = column;
            _sortAscending = true;
        }
        await LoadPage(1);
    }

    private async Task ToggleSortDirection()
    {
        _sortAscending = !_sortAscending;
        await LoadPage(1);
    }

    // ── Tab filter ────────────────────────────────────────────────────────
    private async Task SetFilter(UserAccountFilter filter)
    {
        if (_filter == filter) return;
        _filter = filter;
        _searchTerm = string.Empty;
        await LoadPage(1);
    }

    // ── Row actions ───────────────────────────────────────────────────────
    private void OpenBlock(AppUserDto u)
    {
        _actionTarget = u;
        _showBlock = true;
    }

    private async Task ConfirmBlock()
    {
        if (_actionTarget?.UserId is null) return;
        _saving = true;
        try
        {
            var resp = await _usersApi.DisableUser(_actionTarget.UserId);
            if (resp.IsSuccessStatusCode)
            {
                _toastService.Show("User blocked.", ToastType.Success);
                _showBlock = false;
                await LoadPage(_currentPage);
            }
            else
            {
                _toastService.Show(_apiResponseHandler.GetApiErrorMessage(resp), ToastType.Error);
            }
        }
        catch (Exception ex)
        {
            _toastService.Show(ex.Message, ToastType.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void OpenUnblock(AppUserDto u)
    {
        _actionTarget = u;
        _showUnblock = true;
    }

    private async Task ConfirmUnblock()
    {
        if (_actionTarget?.UserId is null) return;
        _saving = true;
        try
        {
            var resp = await _usersApi.EnableUser(_actionTarget.UserId);
            if (resp.IsSuccessStatusCode)
            {
                _toastService.Show("User unblocked.", ToastType.Success);
                _showUnblock = false;
                await LoadPage(_currentPage);
            }
            else
            {
                _toastService.Show(_apiResponseHandler.GetApiErrorMessage(resp), ToastType.Error);
            }
        }
        catch (Exception ex)
        {
            _toastService.Show(ex.Message, ToastType.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void OpenRestore(AppUserDto u)
    {
        _actionTarget = u;
        _showRestore = true;
    }

    private async Task ConfirmRestore()
    {
        if (_actionTarget?.UserId is null) return;
        _saving = true;
        try
        {
            var resp = await _usersApi.RestoreUser(_actionTarget.UserId);
            if (resp.IsSuccessStatusCode)
            {
                _toastService.Show("Account restored.", ToastType.Success);
                _showRestore = false;
                await LoadPage(_currentPage);
            }
            else
            {
                _toastService.Show(_apiResponseHandler.GetApiErrorMessage(resp), ToastType.Error);
            }
        }
        catch (Exception ex)
        {
            _toastService.Show(ex.Message, ToastType.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────
    private string EmptyStateMessage() => _filter switch
    {
        UserAccountFilter.Blocked => "No blocked accounts.",
        UserAccountFilter.Deleted => "No soft-deleted accounts.",
        _ => "No users in the system yet."
    };

    private static string RelativeTime(DateTimeOffset? dt)
    {
        if (dt is null) return "—";
        var diff = DateTimeOffset.UtcNow - dt.Value;
        if (diff.TotalSeconds < 60) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        if (diff.TotalDays < 30) return $"{(int)(diff.TotalDays / 7)}w ago";
        if (diff.TotalDays < 365) return $"{(int)(diff.TotalDays / 30)}mo ago";
        return $"{(int)(diff.TotalDays / 365)}y ago";
    }
}
