@page "/admin/users"
@layout AdminLayout
@using Refit
@using FRELODYLIB.ServiceHandler

<PageTitle>Users - FRELODY</PageTitle>

<AuthGuard RequirePremium="false">
    @if (!_isSuperAdmin)
    {
        <div class="admin-card admin-card-pad">
            <h2 class="admin-title">Not authorized</h2>
            <p class="text-muted mb-3">Only platform administrators can manage users.</p>
            <a class="admin-btn primary" href="/dashboard">Back to dashboard</a>
        </div>
    }
    else
    {
        <div class="admin-header">
            <div>
                <h1 class="admin-title">Users</h1>
                <p class="admin-subtitle">Every Frelody account — search, status, and access.</p>
            </div>
            <a class="admin-btn" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>
        </div>

        @* ── Search + sort bar ── *@
        <div class="au-toolbar admin-card admin-card-pad">
            <div class="au-search-wrap">
                <i class="bi bi-search au-search-icon"></i>
                <input class="au-search-input" type="search" placeholder="Search by name, email, username…"
                       value="@_searchTerm" @oninput="OnSearchInput" />
            </div>
            <div class="au-sort-wrap">
                <label class="au-sort-label">Sort by</label>
                <select class="au-sort-select" @bind="_sortByColumn" @bind:after="OnSortChanged">
                    <option value="FirstName">First name</option>
                    <option value="Email">Email</option>
                    <option value="DateCreated">Joined</option>
                    <option value="LastLoginDate">Last seen</option>
                </select>
                <button class="admin-btn icon-only" title="Toggle sort direction" @onclick="ToggleSortDirection">
                    <i class="bi @(_sortAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                </button>
            </div>
        </div>

        @if (_loading && _users.Count == 0)
        {
            <div class="admin-card">
                <div class="admin-card-pad">
                    @for (int i = 0; i < 5; i++)
                    {
                        <div class="admin-skeleton mb-2" style="height:52px;"></div>
                    }
                </div>
            </div>
        }
        else if (!_loading && _users.Count == 0)
        {
            <div class="admin-card admin-empty">
                <div class="admin-empty-title">No users found</div>
                <p class="mb-0">@(string.IsNullOrWhiteSpace(_searchTerm) ? "No users in the system yet." : $"No results for \"{_searchTerm}\".")</p>
            </div>
        }
        else
        {
            <div class="admin-card au-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>
                                <button class="au-sort-header @(_sortByColumn == "FirstName" ? "active" : "")"
                                        @onclick='() => SetSort("FirstName")'>
                                    User
                                    @if (_sortByColumn == "FirstName")
                                    {
                                        <i class="bi @(_sortAscending ? "bi-caret-up-fill" : "bi-caret-down-fill")"></i>
                                    }
                                </button>
                            </th>
                            <th>
                                <button class="au-sort-header @(_sortByColumn == "Email" ? "active" : "")"
                                        @onclick='() => SetSort("Email")'>
                                    Email
                                    @if (_sortByColumn == "Email")
                                    {
                                        <i class="bi @(_sortAscending ? "bi-caret-up-fill" : "bi-caret-down-fill")"></i>
                                    }
                                </button>
                            </th>
                            <th>Status</th>
                            <th>
                                <button class="au-sort-header @(_sortByColumn == "DateCreated" ? "active" : "")"
                                        @onclick='() => SetSort("DateCreated")'>
                                    Joined
                                    @if (_sortByColumn == "DateCreated")
                                    {
                                        <i class="bi @(_sortAscending ? "bi-caret-up-fill" : "bi-caret-down-fill")"></i>
                                    }
                                </button>
                            </th>
                            <th>
                                <button class="au-sort-header @(_sortByColumn == "LastLoginDate" ? "active" : "")"
                                        @onclick='() => SetSort("LastLoginDate")'>
                                    Last seen
                                    @if (_sortByColumn == "LastLoginDate")
                                    {
                                        <i class="bi @(_sortAscending ? "bi-caret-up-fill" : "bi-caret-down-fill")"></i>
                                    }
                                </button>
                            </th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in _users)
                        {
                            <tr data-label-user="User" data-label-email="Email" data-label-status="Status"
                                data-label-joined="Joined" data-label-seen="Last seen">
                                <td data-label="User">
                                    <div class="au-user-cell">
                                        <div class="user-avatar-circle au-avatar">
                                            <span>@(u.Initials ?? "?")</span>
                                        </div>
                                        <div>
                                            <div class="au-name">@(u.FullName?.Trim() is { Length: > 0 } n ? n : "(no name)")</div>
                                            @if (!string.IsNullOrWhiteSpace(u.UserName))
                                            {
                                                <div class="au-username">@@@u.UserName</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Email" class="au-email">@(u.Email ?? "—")</td>
                                <td data-label="Status">
                                    <div class="au-badges">
                                        @* Premium / Free badge *@
                                        @{
                                            bool isPremium = u.BillingStatus is BillingStatus.PremiumTrial
                                                or BillingStatus.ActiveRecurring
                                                or BillingStatus.ActiveLifetime
                                                && (u.BillingExpiresAt == null || u.BillingExpiresAt > DateTimeOffset.UtcNow);
                                        }
                                        @if (isPremium)
                                        {
                                            <span class="admin-pill au-pill-premium"><i class="bi bi-star-fill"></i> Premium</span>
                                        }
                                        else
                                        {
                                            <span class="admin-chip au-chip-free">Free</span>
                                        }
                                        @* Disabled badge *@
                                        @if (u.IsActive == false)
                                        {
                                            <span class="admin-pill au-pill-disabled"><i class="bi bi-slash-circle"></i> Disabled</span>
                                        }
                                        @* Role pill (only non-User roles) *@
                                        @if (u.UserType is UserType.SuperAdmin or UserType.TenantAdmin)
                                        {
                                            <span class="admin-chip au-chip-role">@u.UserType</span>
                                        }
                                        @* New badge *@
                                        @if (u.DateCreated.HasValue && u.DateCreated.Value > DateTimeOffset.UtcNow.AddDays(-7))
                                        {
                                            <span class="admin-pill au-pill-new">New</span>
                                        }
                                    </div>
                                </td>
                                <td data-label="Joined" class="au-date">@RelativeTime(u.DateCreated)</td>
                                <td data-label="Last seen" class="au-date">@RelativeTime(u.LastLoginDate)</td>
                                <td class="text-end" data-label="Actions">
                                    <span class="admin-row-actions">
                                        <a class="admin-btn icon-only" title="View profile"
                                           href="/user-profile/@u.UserId">
                                            <i class="bi bi-person"></i>
                                        </a>
                                        @if (u.IsActive == false)
                                        {
                                            <button class="admin-btn icon-only" title="Enable user"
                                                    @onclick="() => EnableUser(u)">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="admin-btn icon-only danger" title="Disable user"
                                                    @onclick="() => OpenDisable(u)">
                                                <i class="bi bi-slash-circle"></i>
                                            </button>
                                        }
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* ── Load-more sentinel + button ── *@
            <div class="au-load-more-area" @ref="_sentinelRef">
                @if (_loading)
                {
                    <div class="admin-skeleton" style="height:36px;width:120px;margin:0 auto;"></div>
                }
                else if (_hasMore)
                {
                    <button class="admin-btn au-load-more-btn" @onclick="LoadMore">
                        <i class="bi bi-chevron-down"></i> Load more
                    </button>
                }
                else if (_users.Count > 0)
                {
                    <p class="au-count-label">Showing @_users.Count of @_totalSize</p>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="admin-alert danger mt-3">@_error</div>
        }
    }
</AuthGuard>

@* ── Disable confirm dialog ── *@
<ConfirmDialog Visible="_showDisable"
               Title="Disable user"
               Icon="bi-slash-circle"
               Destructive="true"
               ConfirmLabel="Disable"
               Busy="_saving"
               OnCancel="@(() => _showDisable = false)"
               OnConfirm="ConfirmDisable">
    <BodyContent>
        <p class="mb-0">Disable <strong>@_disableTarget?.FullName</strong>? They will be unable to log in until re-enabled.</p>
    </BodyContent>
</ConfirmDialog>

@code {
    private const int PageSize = 20;

    private List<AppUserDto> _users = new();
    private bool _loading;
    private bool _isSuperAdmin;
    private bool _hasMore;
    private int _offset;
    private int _totalSize;
    private string? _error;
    private string _searchTerm = string.Empty;
    private string _sortByColumn = "DateCreated";
    private bool _sortAscending = false;

    // Disable modal
    private bool _showDisable;
    private bool _saving;
    private AppUserDto? _disableTarget;

    // Sentinel ref for IntersectionObserver
    private ElementReference _sentinelRef;
    private DotNetObjectReference<AdminUsersPage>? _selfRef;
    private bool _observerAttached;

    // Search debounce
    private CancellationTokenSource? _searchCts;

    protected override async Task OnInitializedAsync()
    {
        var userResult = await _globalAuth.GetAuthenticatedUserAsync();
        _isSuperAdmin = userResult.IsSuccess && userResult.Data?.UserType == UserType.SuperAdmin;
        if (_isSuperAdmin)
            await LoadPage(reset: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isSuperAdmin && _hasMore && !_observerAttached && _selfRef is not null)
        {
            try
            {
                await JsRt.InvokeVoidAsync("eval", @"
                    if (!window.__setupAdminUsersScroll) {
                        window.__setupAdminUsersScroll = function(dotNetRef, sentinel) {
                            if (!sentinel || sentinel.__auObserved) return;
                            sentinel.__auObserved = true;
                            const observer = new IntersectionObserver(function(entries) {
                                entries.forEach(function(e) {
                                    if (e.isIntersecting) dotNetRef.invokeMethodAsync('OnSentinelVisible');
                                });
                            }, { rootMargin: '200px' });
                            observer.observe(sentinel);
                            sentinel.__auObserver = observer;
                        };
                    }");
                await JsRt.InvokeVoidAsync("__setupAdminUsersScroll", _selfRef, _sentinelRef);
                _observerAttached = true;
            }
            catch { /* SSR / prerender */ }
        }
    }

    [JSInvokable]
    public async Task OnSentinelVisible()
    {
        if (!_loading && _hasMore)
            await LoadPage(reset: false);
    }

    private async Task LoadPage(bool reset)
    {
        _loading = true;
        _error = null;
        if (reset) { _offset = 0; _users.Clear(); _observerAttached = false; }
        StateHasChanged();

        try
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            IApiResponse<PaginationDetails<AppUserDto>> resp;

            if (!string.IsNullOrWhiteSpace(_searchTerm))
                resp = await _usersApi.SearchForUsers(_searchTerm, _offset, PageSize, _sortByColumn, _sortAscending);
            else
                resp = await _usersApi.GetAllUsers(_offset, PageSize, _sortByColumn, _sortAscending);

            if (resp.IsSuccessStatusCode && resp.Content is not null)
            {
                _users.AddRange(resp.Content.Data ?? new());
                _offset = _users.Count;
                _hasMore = resp.Content.HasMore;
                _totalSize = resp.Content.TotalSize;
            }
            else
            {
                _error = _apiResponseHandler.GetApiErrorMessage(resp);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            _observerAttached = false; // re-attach after render
            StateHasChanged();
        }
    }

    private async Task LoadMore() => await LoadPage(reset: false);

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? string.Empty;
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(350, _searchCts.Token);
            await LoadPage(reset: true);
        }
        catch (TaskCanceledException) { /* debounced */ }
    }

    private async Task OnSortChanged()
    {
        await LoadPage(reset: true);
    }

    private async Task SetSort(string column)
    {
        if (_sortByColumn == column)
            _sortAscending = !_sortAscending;
        else
        {
            _sortByColumn = column;
            _sortAscending = true;
        }
        await LoadPage(reset: true);
    }

    private async Task ToggleSortDirection()
    {
        _sortAscending = !_sortAscending;
        await LoadPage(reset: true);
    }

    private void OpenDisable(AppUserDto u)
    {
        _disableTarget = u;
        _showDisable = true;
    }

    private async Task ConfirmDisable()
    {
        if (_disableTarget?.UserId is null) return;
        _saving = true;
        try
        {
            var resp = await _usersApi.DisableUser(_disableTarget.UserId);
            if (resp.IsSuccessStatusCode)
            {
                _toastService.Show("User disabled.", ToastType.Success);
                _showDisable = false;
                await LoadPage(reset: true);
            }
            else
            {
                _toastService.Show(_apiResponseHandler.GetApiErrorMessage(resp), ToastType.Error);
            }
        }
        catch (Exception ex)
        {
            _toastService.Show(ex.Message, ToastType.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task EnableUser(AppUserDto u)
    {
        if (u.UserId is null) return;
        try
        {
            var resp = await _usersApi.EnableUser(u.UserId);
            if (resp.IsSuccessStatusCode)
            {
                _toastService.Show("User enabled.", ToastType.Success);
                await LoadPage(reset: true);
            }
            else
            {
                _toastService.Show(_apiResponseHandler.GetApiErrorMessage(resp), ToastType.Error);
            }
        }
        catch (Exception ex)
        {
            _toastService.Show(ex.Message, ToastType.Error);
        }
    }

    private static string RelativeTime(DateTimeOffset? dt)
    {
        if (dt is null) return "—";
        var diff = DateTimeOffset.UtcNow - dt.Value;
        if (diff.TotalSeconds < 60) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        if (diff.TotalDays < 30) return $"{(int)(diff.TotalDays / 7)}w ago";
        if (diff.TotalDays < 365) return $"{(int)(diff.TotalDays / 30)}mo ago";
        return $"{(int)(diff.TotalDays / 365)}y ago";
    }
}
