@page "/admin/feedback"
@layout AdminLayout
@using Refit
@using FRELODYLIB.ServiceHandler

<PageTitle>Feedback - FRELODY</PageTitle>

<AuthGuard RequirePremium="false">
    @if (!_isSuperAdmin)
    {
        <div class="admin-card admin-card-pad">
            <h2 class="admin-title">Not authorized</h2>
            <p class="text-muted mb-3">Only platform administrators can manage feedback.</p>
            <a class="admin-btn primary" href="/dashboard">Back to dashboard</a>
        </div>
    }
    else
    {
        <div class="admin-header">
            <div>
                <h1 class="admin-title">Feedback</h1>
                <p class="admin-subtitle">Reply to users and track every request to resolution.</p>
            </div>
            <a class="admin-btn" href="dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>
        </div>

        @* ── Filter + search bar ── *@
        <div class="af-toolbar admin-card admin-card-pad">
            <div class="af-status-chips">
                @foreach (var chip in StatusChips)
                {
                    var c = chip;
                    <button class="af-chip @(_filterStatus == c.Value ? "active" : "")"
                            @onclick="() => SetStatusFilter(c.Value)">
                        @c.Label
                    </button>
                }
            </div>
            <div class="af-search-wrap">
                <i class="bi bi-search af-search-icon"></i>
                <input class="af-search-input" type="search" placeholder="Search subject, comment, sender…"
                       value="@_searchTerm" @oninput="OnSearchInput" />
            </div>
        </div>

        @if (_isInitialLoading)
        {
            <div class="admin-card">
                <div class="admin-card-pad">
                    @for (int i = 0; i < 5; i++)
                    {
                        <div class="admin-skeleton mb-2" style="height:52px;"></div>
                    }
                </div>
            </div>
        }
        else if (!_isInitialLoading && _items.Count == 0)
        {
            <div class="admin-card admin-empty">
                <div class="admin-empty-title">No feedback found</div>
                <p class="mb-0">
                    @if (!string.IsNullOrWhiteSpace(_searchTerm))
                    {
                        <span>No results for "@_searchTerm".</span>
                    }
                    else if (_filterStatus.HasValue)
                    {
                        <span>No feedback with this status.</span>
                    }
                    else
                    {
                        <span>No feedback submissions yet.</span>
                    }
                </p>
            </div>
        }
        else
        {
            <div class="admin-card af-table-wrap @(_isPageLoading ? "is-loading" : "")">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Feedback</th>
                            <th>From</th>
                            <th>Status</th>
                            <th>Received</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fb in _items)
                        {
                            <tr>
                                <td data-label="Feedback">
                                    <div class="af-subject">@fb.Subject</div>
                                    <div class="af-preview">@TruncateComment(fb.Comment)</div>
                                    @if (fb.Song is not null)
                                    {
                                        <span class="admin-chip af-song-chip"><i class="bi bi-music-note af-mini-icon"></i> @fb.Song.Title</span>
                                    }
                                </td>
                                <td data-label="From">
                                    <div class="af-sender-name">@(fb.FullName is { Length: > 0 } fn ? fn : "(anonymous)")</div>
                                    @if (!string.IsNullOrWhiteSpace(fb.Email))
                                    {
                                        <div class="af-sender-email">@fb.Email</div>
                                    }
                                </td>
                                <td data-label="Status">
                                    <span class="admin-chip @StatusChipClass(fb.Status)">@StatusLabel(fb.Status)</span>
                                </td>
                                <td data-label="Received" class="af-date">@RelativeTime(fb.DateCreated)</td>
                                <td class="text-end" data-label="Actions">
                                    <span class="admin-row-actions">
                                        <button class="admin-btn icon-only" title="View / Reply"
                                                @onclick="() => OpenThread(fb.Id)">
                                            <i class="bi bi-chat-left-text"></i>
                                        </button>
                                        <button class="admin-btn icon-only danger" title="Delete"
                                                @onclick="() => OpenDelete(fb)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @* ── Numbered pager ── *@
                <div class="af-pager">
                    <div class="af-pager__info">
                        @if (_isPageLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                        }
                        <span>
                            <strong>@AfRangeStart.ToString("N0")</strong>–<strong>@AfRangeEnd.ToString("N0")</strong>
                            of <strong>@_totalItems.ToString("N0")</strong>
                        </span>
                    </div>

                    @if (_totalPages > 1)
                    {
                        <div class="af-pager__nav" role="navigation" aria-label="Pagination">
                            <button class="af-pager-btn" title="First page"
                                    disabled="@(_currentPage <= 1 || _isPageLoading)"
                                    @onclick="() => GoToPage(1)">
                                <i class="bi bi-chevron-double-left"></i>
                            </button>
                            <button class="af-pager-btn" title="Previous page"
                                    disabled="@(_currentPage <= 1 || _isPageLoading)"
                                    @onclick="() => GoToPage(_currentPage - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>

                            @foreach (var p in GetPageWindow())
                            {
                                @if (p < 0)
                                {
                                    <span class="af-pager-ellipsis">…</span>
                                }
                                else
                                {
                                    <button class="af-pager-btn @(p == _currentPage ? "af-pager-btn--active" : "")"
                                            disabled="@_isPageLoading"
                                            @onclick="() => GoToPage(p)">
                                        @p
                                    </button>
                                }
                            }

                            <button class="af-pager-btn" title="Next page"
                                    disabled="@(_currentPage >= _totalPages || _isPageLoading)"
                                    @onclick="() => GoToPage(_currentPage + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                            <button class="af-pager-btn" title="Last page"
                                    disabled="@(_currentPage >= _totalPages || _isPageLoading)"
                                    @onclick="() => GoToPage(_totalPages)">
                                <i class="bi bi-chevron-double-right"></i>
                            </button>
                        </div>
                    }

                    <div class="af-pager__size">
                        <label for="af-page-size">Rows</label>
                        <select id="af-page-size" @bind="AfPageSize" disabled="@_isPageLoading">
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="admin-alert danger mt-3">@_error</div>
        }
    }
</AuthGuard>

@* ══════════════════════════
   Thread / Reply modal
   ══════════════════════════ *@
<ConfirmDialog Visible="_showThread"
               Title="@(_thread?.Subject ?? "Feedback")"
               Icon="bi-chat-left-text"
               ConfirmLabel="Apply changes"
               CancelLabel="Cancel"
               Busy="_threadBusy"
               OnCancel="CancelThread"
               OnConfirm="ApplyThreadChanges">
    <BodyContent>
        @if (_threadLoading)
        {
            <div class="admin-skeleton mb-2" style="height:40px;"></div>
            <div class="admin-skeleton mb-2" style="height:60px;"></div>
            <div class="admin-skeleton" style="height:40px;"></div>
        }
        else if (_thread is not null)
        {
            @* ── Thread header meta ── *@
            <div class="af-thread-meta">
                <div class="af-thread-meta-row">
                    <span class="af-meta-label">From</span>
                    <span>
                        @(string.IsNullOrWhiteSpace(_thread.FullName) ? "" : _thread.FullName + " ")
                        @if (!string.IsNullOrWhiteSpace(_thread.Email))
                        {
                            <span class="af-meta-email">@_thread.Email</span>
                        }
                    </span>
                </div>
                @if (_thread.Song is not null)
                {
                    <div class="af-thread-meta-row">
                        <span class="af-meta-label">Song</span>
                        <a href="/songs/@_thread.Song.Id" class="af-song-link">@_thread.Song.Title</a>
                    </div>
                }
                <div class="af-thread-meta-row">
                    <span class="af-meta-label">Status</span>
                    @* Status select now updates only local staging state — no API call *@
                    <select class="af-status-select" value="@_pendingStatus" @onchange="OnStatusChange">
                        @foreach (var s in Enum.GetValues<FeedbackStatus>())
                        {
                            <option value="@s" selected="@(_pendingStatus == s)">@StatusLabel(s)</option>
                        }
                    </select>
                    @if (_pendingStatus != _thread.Status)
                    {
                        <span class="af-status-staged-hint">
                            (staged — was @StatusLabel(_thread.Status))
                        </span>
                    }
                </div>
            </div>

            @* ── Thread messages ── *@
            <div class="af-thread-body">
                @* Original message *@
                <div class="af-bubble af-bubble-user">
                    <div class="af-bubble-author">
                        @(string.IsNullOrWhiteSpace(_thread.FullName) ? (_thread.Email ?? "User") : _thread.FullName)
                        <span class="af-bubble-time">@RelativeTime(_thread.DateCreated)</span>
                    </div>
                    <div class="af-bubble-text">@_thread.Comment</div>
                </div>

                @* Reply thread *@
                @if (_thread.Replies is not null)
                {
                    @foreach (var r in _thread.Replies)
                    {
                        var isAdmin = r.Direction == FeedbackReplyDirection.AdminToUser;
                        <div class="af-bubble @(isAdmin ? "af-bubble-admin" : "af-bubble-user")">
                            <div class="af-bubble-author">
                                @(isAdmin ? "You" : (r.AuthorName ?? "User"))
                                <span class="af-bubble-time">@RelativeTime(r.DateCreated)</span>
                            </div>
                            <div class="af-bubble-text">@r.Body</div>
                        </div>
                    }
                }
            </div>

            @* ── Reply composer — staged, sent only on Apply ── *@
            @if (!string.IsNullOrWhiteSpace(_thread.Email))
            {
                <div class="af-composer">
                    <label class="af-composer-label">Reply to @(_thread.Email)</label>
                    <textarea class="af-composer-input" rows="3"
                              placeholder="Write a reply… (sent when you click Apply changes)"
                              @bind="_replyBody"></textarea>
                </div>
            }

            @* ── Log user reply (staged) ── *@
            <div class="af-log-section">
                @if (!_showLogUserReply)
                {
                    <button class="af-log-toggle" @onclick="@(() => _showLogUserReply = true)">
                        + Log a reply the user sent back
                    </button>
                }
                else
                {
                    <div class="af-composer">
                        <label class="af-composer-label">Paste the user's reply</label>
                        <textarea class="af-composer-input" rows="3"
                                  placeholder="Paste text from user's email… (logged when you click Apply changes)"
                                  @bind="_logBody"></textarea>
                        <div class="d-flex gap-2 mt-2">
                            <button class="admin-btn" @onclick="@(() => { _showLogUserReply = false; _logBody = string.Empty; })">Cancel</button>
                        </div>
                    </div>
                }
            </div>
        }
    </BodyContent>
</ConfirmDialog>

@* ── Delete confirm ── *@
<ConfirmDialog Visible="_showDelete"
               Title="Delete feedback"
               Icon="bi-trash"
               Destructive="true"
               ConfirmLabel="Delete"
               Busy="_deleting"
               OnCancel="@(() => _showDelete = false)"
               OnConfirm="ConfirmDelete">
    <BodyContent>
        <p class="mb-0">Delete feedback "<strong>@_deleteTarget?.Subject</strong>"? This cannot be undone.</p>
    </BodyContent>
</ConfirmDialog>

@code {
    // ── Pager state ──
    private int _currentPage = 1;
    private int _pageSize = 25;
    private int _totalItems;
    private bool _isPageLoading;
    private bool _isInitialLoading = true;

    private int _totalPages => _totalItems <= 0 ? 0 : (int)Math.Ceiling(_totalItems / (double)_pageSize);
    private int AfRangeStart => _totalItems == 0 ? 0 : ((_currentPage - 1) * _pageSize) + 1;
    private int AfRangeEnd => Math.Min(_currentPage * _pageSize, _totalItems);

    private int AfPageSize
    {
        get => _pageSize;
        set
        {
            if (value == _pageSize) return;
            _pageSize = value <= 0 ? 25 : value;
            _ = LoadPage(1);
        }
    }

    // ── List state ──
    private List<UserFeedbackDto> _items = new();
    private bool _isSuperAdmin;
    private string? _error;
    private string _searchTerm = string.Empty;
    private FeedbackStatus? _filterStatus;
    private string _sortByColumn = "DateCreated";
    private bool _sortAscending = false;

    // ── Search debounce ──
    private CancellationTokenSource? _searchCts;

    // ── Thread modal ──
    private bool _showThread;
    private bool _threadLoading;
    private bool _threadBusy;
    private UserFeedbackDto? _thread;
    // Staging state — nothing is committed until Apply is clicked
    private FeedbackStatus? _pendingStatus;
    private string _replyBody = string.Empty;
    private string _logBody = string.Empty;
    private bool _showLogUserReply;

    // ── Delete ──
    private bool _showDelete;
    private bool _deleting;
    private UserFeedbackDto? _deleteTarget;

    private static readonly (string Label, FeedbackStatus? Value)[] StatusChips = new[]
    {
        ("All", (FeedbackStatus?)null),
        ("Pending", (FeedbackStatus?)FeedbackStatus.Pending),
        ("Under review", (FeedbackStatus?)FeedbackStatus.UnderReview),
        ("Resolved", (FeedbackStatus?)FeedbackStatus.Addressed),
    };

    protected override async Task OnInitializedAsync()
    {
        var userResult = await _globalAuth.GetAuthenticatedUserAsync();
        _isSuperAdmin = userResult.IsSuccess && userResult.Data?.UserType == UserType.SuperAdmin;
        if (_isSuperAdmin)
            await LoadPage(1);
    }

    private async Task LoadPage(int page)
    {
        if (page < 1) page = 1;

        _isPageLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var offset = (page - 1) * _pageSize;
            var resp = await _feedbackApi.GetFeedbackPaged(
                _searchTerm, _filterStatus, offset, _pageSize, _sortByColumn, _sortAscending);

            if (resp.IsSuccessStatusCode && resp.Content is not null)
            {
                var data = resp.Content;
                _totalItems = data.TotalSize;

                // Snap to last page if current page fell off the end
                if ((data.Data is null || data.Data.Count == 0) && _totalItems > 0 && page > 1)
                {
                    var lastPage = (int)Math.Ceiling(_totalItems / (double)_pageSize);
                    if (page > lastPage)
                    {
                        _isPageLoading = false;
                        _isInitialLoading = false;
                        await LoadPage(lastPage);
                        return;
                    }
                }

                _items = data.Data ?? new();
                _currentPage = page;
            }
            else
            {
                _error = _apiResponseHandler.GetApiErrorMessage(resp);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isInitialLoading = false;
            _isPageLoading = false;
            StateHasChanged();
        }
    }

    private async Task GoToPage(int page)
    {
        if (page < 1) page = 1;
        if (_totalPages > 0 && page > _totalPages) page = _totalPages;
        if (page == _currentPage || _isPageLoading) return;
        await LoadPage(page);
    }

    private IEnumerable<int> GetPageWindow()
    {
        var total = _totalPages;
        if (total <= 0) yield break;

        var shown = new SortedSet<int> { 1, total };
        for (var p = _currentPage - 1; p <= _currentPage + 1; p++)
        {
            if (p >= 1 && p <= total) shown.Add(p);
        }

        var prev = 0;
        foreach (var p in shown)
        {
            if (prev != 0 && p - prev > 1) yield return -1; // ellipsis marker
            yield return p;
            prev = p;
        }
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? string.Empty;
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(350, _searchCts.Token);
            await LoadPage(1);
        }
        catch (TaskCanceledException) { /* debounced */ }
    }

    private async Task SetStatusFilter(FeedbackStatus? status)
    {
        _filterStatus = status;
        await LoadPage(1);
    }

    // ── Thread modal ──

    private async Task OpenThread(string? id)
    {
        if (id is null) return;
        _showThread = true;
        _threadLoading = true;
        _replyBody = string.Empty;
        _logBody = string.Empty;
        _showLogUserReply = false;
        _pendingStatus = null;
        _thread = null;
        StateHasChanged();

        try
        {
            var resp = await _feedbackApi.GetFeedbackById(id);
            if (resp.IsSuccessStatusCode && resp.Content is not null)
            {
                _thread = resp.Content;
                // Initialise staging state from the loaded thread
                _pendingStatus = _thread.Status;
            }
            else
            {
                _toastService.Show("Could not load feedback thread.", ToastType.Error);
            }
        }
        catch (Exception ex)
        {
            _toastService.Show(ex.Message, ToastType.Error);
        }
        finally
        {
            _threadLoading = false;
            StateHasChanged();
        }
    }

    // Updates ONLY the local staging state — no API call
    private void OnStatusChange(ChangeEventArgs e)
    {
        if (Enum.TryParse<FeedbackStatus>(e.Value?.ToString(), out var newStatus))
            _pendingStatus = newStatus;
    }

    // Cancel — discard everything, no API calls
    private void CancelThread()
    {
        _pendingStatus = null;
        _replyBody = string.Empty;
        _logBody = string.Empty;
        _showLogUserReply = false;
        _showThread = false;
    }

    // Apply — commit staged changes in prescribed order
    private async Task ApplyThreadChanges()
    {
        if (_thread?.Id is null) return;

        // If nothing changed, just close
        var hasLog = !string.IsNullOrWhiteSpace(_logBody);
        var hasReply = !string.IsNullOrWhiteSpace(_replyBody);
        var statusChanged = _pendingStatus.HasValue && _pendingStatus != _thread.Status;

        if (!hasLog && !hasReply && !statusChanged)
        {
            _showThread = false;
            return;
        }

        // Capture the original status before any mutations
        var originalStatus = _thread.Status;

        _threadBusy = true;
        StateHasChanged();
        try
        {
            // 1. Log user reply first (if provided)
            if (hasLog)
            {
                var logResp = await _feedbackApi.LogUserReply(_thread.Id,
                    new FeedbackReplyCreateDto { Body = _logBody });
                if (!logResp.IsSuccessStatusCode)
                {
                    _toastService.Show(_apiResponseHandler.GetApiErrorMessage(logResp), ToastType.Error);
                    return;
                }
                if (logResp.Content is not null)
                    _thread = logResp.Content;
            }

            // 2. Send admin reply (server may auto-advance Pending→UnderReview as side effect)
            if (hasReply)
            {
                var replyResp = await _feedbackApi.ReplyToFeedback(_thread.Id,
                    new FeedbackReplyCreateDto { Body = _replyBody });
                if (!replyResp.IsSuccessStatusCode)
                {
                    _toastService.Show(_apiResponseHandler.GetApiErrorMessage(replyResp), ToastType.Error);
                    return;
                }
                if (replyResp.Content is not null)
                    _thread = replyResp.Content;
            }

            // 3. Apply explicit status override LAST so admin's choice wins over auto-advance
            if (statusChanged && _pendingStatus.HasValue)
            {
                // Compare against the original status we captured before step 2 mutated _thread
                var statusResp = await _feedbackApi.UpdateFeedbackStatus(_thread.Id, _pendingStatus.Value);
                if (!statusResp.IsSuccessStatusCode)
                {
                    _toastService.Show(_apiResponseHandler.GetApiErrorMessage(statusResp), ToastType.Error);
                    return;
                }
                if (statusResp.Content is not null)
                    _thread = statusResp.Content;
            }

            // Update the matching list row in-place
            var row = _items.FirstOrDefault(x => x.Id == _thread.Id);
            if (row is not null)
                row.Status = _thread.Status;

            _toastService.Show("Changes applied.", ToastType.Success);
            _showThread = false;
        }
        catch (Exception ex)
        {
            _toastService.Show(ex.Message, ToastType.Error);
            // Keep dialog open so admin can retry
        }
        finally
        {
            _threadBusy = false;
            StateHasChanged();
        }
    }

    // ── Delete ──
    private void OpenDelete(UserFeedbackDto fb)
    {
        _deleteTarget = fb;
        _showDelete = true;
    }

    private async Task ConfirmDelete()
    {
        if (_deleteTarget?.Id is null) return;
        _deleting = true;
        try
        {
            var resp = await _feedbackApi.DeleteFeedback(_deleteTarget.Id);
            if (resp.IsSuccessStatusCode)
            {
                _toastService.Show("Feedback deleted.", ToastType.Success);
                _showDelete = false;
                _items.RemoveAll(x => x.Id == _deleteTarget.Id);
                _totalItems = Math.Max(0, _totalItems - 1);
                // If the current page is now empty (and not the only page), go back
                if (_items.Count == 0 && _currentPage > 1)
                    await LoadPage(_currentPage - 1);
            }
            else
            {
                _toastService.Show(_apiResponseHandler.GetApiErrorMessage(resp), ToastType.Error);
            }
        }
        catch (Exception ex)
        {
            _toastService.Show(ex.Message, ToastType.Error);
        }
        finally
        {
            _deleting = false;
        }
    }

    // ── Helpers ──
    private static string RelativeTime(DateTimeOffset? dt)
    {
        if (dt is null) return "—";
        var diff = DateTimeOffset.UtcNow - dt.Value;
        if (diff.TotalSeconds < 60) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        if (diff.TotalDays < 30) return $"{(int)(diff.TotalDays / 7)}w ago";
        if (diff.TotalDays < 365) return $"{(int)(diff.TotalDays / 30)}mo ago";
        return $"{(int)(diff.TotalDays / 365)}y ago";
    }

    private static string TruncateComment(string? comment)
    {
        if (string.IsNullOrWhiteSpace(comment)) return string.Empty;
        return comment.Length > 120 ? comment[..117] + "…" : comment;
    }

    private static string StatusLabel(FeedbackStatus? status) => status switch
    {
        FeedbackStatus.Pending => "Pending",
        FeedbackStatus.UnderReview => "Under review",
        FeedbackStatus.Addressed => "Resolved",
        _ => "Unknown"
    };

    private static string StatusChipClass(FeedbackStatus? status) => status switch
    {
        FeedbackStatus.Pending => "af-chip-pending",
        FeedbackStatus.UnderReview => "af-chip-review",
        FeedbackStatus.Addressed => "af-chip-resolved",
        _ => ""
    };
}
