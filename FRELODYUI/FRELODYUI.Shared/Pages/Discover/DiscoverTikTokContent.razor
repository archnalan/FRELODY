@using System.Net
@using FRELODYSHRD.Dtos
@using FRELODYSHRD.Dtos.CreateDtos
@using FRELODYUI.Shared.RefitApis
@using FRELODYUI.Shared.Pages.Discover
@implements IDisposable
@inject ITikTokApi TikTokApi
@inject IAnalyzedAccessApi AccessApi
@inject NavigationManager Nav

<PageTitle>@(_video?.Title ?? "Analyzing…") · FRELODY</PageTitle>

<div class="dv-page">

    <!-- Video header — always rendered so dv-card position stays stable -->
    <div class="dv-header">
        <button class="dv-back" @onclick='() => Nav.NavigateTo(BackUrl)' title="Back to Discover">
            <i class="bi bi-arrow-left"></i>
        </button>

        @if (_video is null)
        {
            <div class="dv-video-meta placeholder-glow">
                <div class="dv-thumb placeholder"></div>
                <div class="dv-video-info">
                    <span class="dv-skel-line dv-skel-line--title placeholder"></span>
                    <span class="dv-skel-line dv-skel-line--title dv-skel-line--short placeholder"></span>
                    <span class="dv-skel-line dv-skel-line--channel placeholder"></span>
                </div>
            </div>
        }
        else
        {
            <div class="dv-video-meta">
                @if (!string.IsNullOrEmpty(_video.ThumbnailUrl))
                {
                    <img class="dv-thumb" src="@_video.ThumbnailUrl" alt="@_video.Title" loading="lazy" />
                }
                <div class="dv-video-info">
                    <p class="dv-video-title">@_video.Title</p>
                    @if (!string.IsNullOrEmpty(_video.Uploader))
                    {
                        <p class="dv-video-channel">
                            <i class="bi bi-person-circle"></i>
                            @_video.Uploader
                        </p>
                    }
                </div>
            </div>
        }

        <div class="dv-header-actions">
            <AnalyzedQuotaBadge @ref="_quotaBadge" />
            <button type="button" class="dv-share" @onclick="ShareAsync"
                    title="Copy share link" aria-label="Copy share link">
                <i class="bi bi-link-45deg" aria-hidden="true"></i>
                <span class="dv-share-label">Share</span>
            </button>
        </div>
    </div>

    <div class="dv-card">

        @if (_state == AnalysisState.Complete && _result is not null)
        {
            <VideoPlaybackView
                Transcription="_result"
                PlayerApi="tiktokPlayer"
                VideoWidth="_video?.Width"
                VideoHeight="_video?.Height"
                SourceUrl="@(_video?.Url)"
                SourceName="TikTok"
                SourceIcon="bi-tiktok"
                OnReanalyze="ReanalyzeAsync" />
        }
        else if (_state == AnalysisState.Error)
        {
            <div class="dv-state dv-state--error">
                <div class="dv-state-icon-wrap dv-state-icon-wrap--error">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <p class="dv-state-heading">Analysis failed</p>
                <p class="dv-state-sub">@_errorMessage</p>
                @if (!string.IsNullOrWhiteSpace(Url))
                {
                    <button class="dv-btn dv-btn--primary" @onclick="AnalyzeAsync">
                        <i class="bi bi-arrow-clockwise"></i>
                        Try again
                    </button>
                }
            </div>
        }
        else if (_state == AnalysisState.Idle)
        {
            <div class="dv-state">
                <div class="dv-state-icon-wrap">
                    <i class="bi bi-soundwave"></i>
                </div>
                <p class="dv-state-heading">Ready to analyze</p>
                <p class="dv-state-sub">Extract chords and beats from this TikTok using AI.</p>
                <button class="dv-btn dv-btn--primary" @onclick="AnalyzeAsync">
                    <i class="bi bi-play-circle"></i>
                    Analyze chords
                </button>
            </div>
        }
        else if (_state == AnalysisState.Paywall && _access is not null)
        {
            <div class="dv-state">
                <div class="dv-state-icon-wrap">
                    <i class="bi bi-lock"></i>
                </div>
                <p class="dv-state-heading">@(_access.IsPremium ? "Locked" : "Daily limit reached")</p>
                <p class="dv-state-sub">@(_access.Reason == "unauthenticated"
                    ? "Sign in to play your first free song."
                    : "You've used today's free songs. Upgrade to keep playing.")</p>
            </div>
        }
        else if (_state == AnalysisState.TooLong)
        {
            <div class="dv-state">
                <div class="dv-state-icon-wrap">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <p class="dv-state-heading">Too long to analyze</p>
                <p class="dv-state-sub">@_tooLongMessage</p>
                @if (_tooLongUpgradeable)
                {
                    <button class="dv-btn dv-btn--primary" @onclick='() => Nav.NavigateTo("/pricing")'>
                        <i class="bi bi-unlock"></i>
                        Upgrade
                    </button>
                }
            </div>
        }
        else
        {
            <!-- Processing state — let the user watch the clip while we analyze -->
            <div class="dv-analyze">
                @if (_video is not null)
                {
                    <div class="dv-analyze-player dv-analyze-player--tiktok" style="@_analyzePlayerStyle">
                        <YoutubePlayerMount Id="@AnalyzePlayerId" />
                    </div>
                }
                <AnalysisProgress StageIndex="_stageIndex"
                                  DurationSeconds="_video?.DurationSeconds"
                                  Queued="_isQueued"
                                  Subtitle="@_progressSubtitle" />
            </div>
        }

    </div>
</div>

@if (_state == AnalysisState.Paywall && _access is not null)
{
    <AnalyzedAccessSheet Result="_access"
                         ReturnUrl="@CurrentRelativeUrl"
                         OnDismiss="DismissPaywall" />
}

@code {
    [Parameter, EditorRequired] public string? Url { get; set; }
    [Parameter] public string BackUrl { get; set; } = "/discover";

    private enum AnalysisState { Idle, Extracting, Beats, Chords, Complete, Error, Paywall, TooLong }

    private TikTokVideoDto? _video;
    private YouTubeTranscriptionDto? _result;
    private AnalysisState _state = AnalysisState.Idle;
    private string? _errorMessage;
    private AnalyzedAccessResultDto? _access;
    private AnalyzedQuotaBadge? _quotaBadge;
    private string? _tooLongMessage;
    private bool _tooLongUpgradeable;
    private int _stageIndex;
    private bool _isQueued;
    private bool _analyzePlayerMounted;
    private string _progressSubtitle = "This can take up to a minute.";
    private CancellationTokenSource? _pollCts;
    private int _pollTick;
    private const int PollIntervalMs = 2500;

    private const string AnalyzePlayerId = "dv-analyze-player";

    private string _analyzePlayerStyle =>
        (_video?.Width is > 0 && _video?.Height is > 0)
            ? $"aspect-ratio: {_video.Width} / {_video.Height};"
            : "aspect-ratio: 9 / 16;";

    private string CurrentRelativeUrl =>
        "/" + Nav.ToBaseRelativePath(Nav.Uri);

    private static readonly string[] Stages =
    [
        "Extracting audio…",
        "Detecting beats…",
        "Recognizing chords…",
        "Finalizing…"
    ];

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Url))
        {
            _errorMessage = "No TikTok link provided. Paste a TikTok URL on the Discover page.";
            _state = AnalysisState.Error;
            return;
        }

        var resolved = await TikTokApi.Resolve(new TikTokResolveRequest { Url = Url });
        if (resolved.IsSuccessStatusCode && resolved.Content is not null)
        {
            _video = resolved.Content;

            // Pre-gate over-long clips before any sign-in/analysis prompt.
            // Cache check + paywall gate handled by Analyze (OnAfterRenderAsync).
            if (_video.DurationSeconds > 0 && await CheckTooLongAsync(_video.DurationSeconds))
                return;
        }
        else
        {
            _errorMessage = AnalysisErrorMessage.FromResponse(
                resolved.Error?.StatusCode, resolved.Error?.Content, AnalysisErrorMessage.SourceKind.TikTok);
            _state = AnalysisState.Error;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Mount the TikTok player into the analysis placeholder so the user can watch the
        // clip while the (slow) pipeline runs. Fires once the player div exists.
        if (_state == AnalysisState.Extracting && !_analyzePlayerMounted && _video is not null)
        {
            _analyzePlayerMounted = true;
            try { await JsRt.InvokeVoidAsync("tiktokPlayer.initialize", _video.VideoId, AnalyzePlayerId, null); }
            catch { _analyzePlayerMounted = false; }
        }

        if (firstRender && _state == AnalysisState.Idle && !string.IsNullOrWhiteSpace(Url))
            await RunAnalysisAsync(forceRefresh: false);
    }

    private Task AnalyzeAsync() => RunAnalysisAsync(forceRefresh: false);
    private Task ReanalyzeAsync() => RunAnalysisAsync(forceRefresh: true);

    private async Task ShareAsync()
    {
        var url = Nav.ToAbsoluteUri($"/play/tiktok?Url={Uri.EscapeDataString(Url ?? string.Empty)}").ToString();
        await _clipboardService.CopyToClipboardAsync(url);
        _toastService.Show("Share link copied to clipboard!", ToastType.Success);
    }

    private async Task RunAnalysisAsync(bool forceRefresh)
    {
        if (string.IsNullOrWhiteSpace(Url)) return;

        _state = AnalysisState.Extracting;
        _stageIndex = 0;
        _analyzePlayerMounted = false;
        _progressSubtitle = "This can take up to a minute.";
        _errorMessage = null;
        StateHasChanged();

        _pollCts?.Cancel();
        _pollCts = new CancellationTokenSource();
        var token = _pollCts.Token;

        try
        {
            // Submit starts (or attaches to) a background job and returns immediately. The
            // analysis is decoupled from this request — a slow clip can't be cut by a
            // client/proxy timeout.
            var submit = await TikTokApi.Analyze(new TikTokAnalyzeRequest
            {
                Url = Url,
                ForceRefresh = forceRefresh
            });

            if (submit.Error?.StatusCode == HttpStatusCode.PaymentRequired)
            {
                ShowPaywall(submit.Error.Content);
                return;
            }
            if (!submit.IsSuccessStatusCode || submit.Content is null)
            {
                _errorMessage = AnalysisErrorMessage.FromResponse(
                    submit.Error?.StatusCode, submit.Error?.Content, AnalysisErrorMessage.SourceKind.TikTok);
                _state = AnalysisState.Error;
                if (_quotaBadge is not null) await _quotaBadge.RefreshAsync();
                return;
            }

            var status = submit.Content;
            var videoId = status.VideoId;
            ApplyStatus(status);
            StateHasChanged();

            // Poll the lightweight status endpoint until the job finishes. Short requests, so
            // no proxy/Cloudflare edge timeout can cut the long analysis.
            while (status.Stage is not (AnalysisStage.Done or AnalysisStage.Failed))
            {
                await Task.Delay(PollIntervalMs, token);
                var poll = await TikTokApi.GetAnalysisStatus(videoId);
                if (poll.IsSuccessStatusCode && poll.Content is not null)
                {
                    status = poll.Content;
                    ApplyStatus(status);
                    StateHasChanged();
                }
                // Ignore a transient poll failure — the job keeps running server-side.
            }

            if (status.Stage == AnalysisStage.Failed)
            {
                _errorMessage = !string.IsNullOrWhiteSpace(status.Error)
                    ? status.Error
                    : AnalysisErrorMessage.FromResponse(null, null, AnalysisErrorMessage.SourceKind.TikTok);
                _state = AnalysisState.Error;
                // The status poll refunds the metered slot on failure — resync the badge.
                if (_quotaBadge is not null) await _quotaBadge.RefreshAsync();
                return;
            }

            // Done — fetch the chords (gated; idempotent within the day's quota window).
            var result = status.Result;
            if (result is null)
            {
                var fetch = await TikTokApi.GetTranscription(videoId);
                if (fetch.IsSuccessStatusCode) result = fetch.Content;
            }

            if (result is not null)
            {
                _result = result;
                _state = AnalysisState.Complete;
                if (_quotaBadge is not null) await _quotaBadge.RefreshAsync();
            }
            else
            {
                _errorMessage = AnalysisErrorMessage.FromResponse(null, null, AnalysisErrorMessage.SourceKind.TikTok);
                _state = AnalysisState.Error;
            }
        }
        catch (OperationCanceledException)
        {
            // Component disposed / navigated away mid-poll — nothing to surface.
            return;
        }
        catch (Exception ex)
        {
            _errorMessage = AnalysisErrorMessage.FromException(ex, AnalysisErrorMessage.SourceKind.TikTok);
            _state = AnalysisState.Error;
            if (_quotaBadge is not null) await _quotaBadge.RefreshAsync();
        }
        finally
        {
            // On success the result view re-initializes the same player singleton (clean
            // handoff); otherwise tear the placeholder player down so it doesn't linger.
            if (_state != AnalysisState.Complete && _analyzePlayerMounted)
            {
                try { await JsRt.InvokeVoidAsync("tiktokPlayer.destroy"); } catch { }
            }
            _analyzePlayerMounted = false;
            StateHasChanged();
        }
    }

    // Map the server's real analysis stage to the placeholder checklist index, holding on
    // "Finalizing…" once reached. Driven by the live status poll — not a blind timer.
    // Drive the staged checklist + engaging, queue-aware microcopy off the live status poll.
    private void ApplyStatus(AnalysisStatusDto s)
    {
        _isQueued = s.Stage == AnalysisStage.Queued;
        if (s.Stage == AnalysisStage.Queued)
        {
            _stageIndex = 0;
            var ahead = s.QueueAhead ?? 0;
            _progressSubtitle = ahead <= 0
                ? "You're next — starting any moment…"
                : $"{ahead} {(ahead == 1 ? "clip is" : "clips are")} ahead of you — your spot is held, hang tight.";
            return;
        }

        _stageIndex = s.Stage switch
        {
            AnalysisStage.Extracting => 0,
            AnalysisStage.DetectingBeats => 1,
            AnalysisStage.RecognizingChords => 2,
            AnalysisStage.Finalizing or AnalysisStage.Done => 3,
            _ => _stageIndex
        };
        _progressSubtitle = SubtitleFor(s.Stage, _pollTick++);
    }

    private static string SubtitleFor(AnalysisStage stage, int tick) => stage switch
    {
        AnalysisStage.Extracting => "Grabbing the audio…",
        AnalysisStage.DetectingBeats => BeatMessages[(tick / 3) % BeatMessages.Length],
        AnalysisStage.RecognizingChords => "Working out the chords…",
        AnalysisStage.Finalizing or AnalysisStage.Done => "Almost there — finishing up.",
        _ => "Analyzing the music…"
    };

    private static readonly string[] BeatMessages =
    [
        "Mapping the beat grid — this is the heavy part…",
        "Quality beats a quick guess — hang tight.",
        "Still working — feel free to watch the clip while you wait.",
    ];

    private void ShowPaywall(string? body)
    {
        _access = AnalyzedAccessParser.Parse(body)
            ?? new AnalyzedAccessResultDto { LimitReached = true };
        _state = AnalysisState.Paywall;
    }

    private async Task<bool> CheckTooLongAsync(int durationSeconds)
    {
        var limitsResp = await AccessApi.Limits();
        var limits = limitsResp.IsSuccessStatusCode ? limitsResp.Content : null;
        var premium = await _globalAuth.IsPremiumUser();
        var isPremium = premium.IsSuccess && premium.Data;

        var decision = AnalyzedDurationGate.Evaluate(limits, isPremium, durationSeconds);
        if (decision.Blocked)
        {
            _tooLongMessage = decision.Message;
            _tooLongUpgradeable = decision.Upgradeable;
            _state = AnalysisState.TooLong;
            return true;
        }
        return false;
    }

    private void DismissPaywall() => Nav.NavigateTo(BackUrl);

    public void Dispose()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
    }
}
