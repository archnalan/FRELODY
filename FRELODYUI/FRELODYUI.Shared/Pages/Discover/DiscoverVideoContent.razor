@using System.Net
@using FRELODYSHRD.Dtos
@using FRELODYSHRD.Dtos.CreateDtos
@using FRELODYUI.Shared.RefitApis
@using FRELODYUI.Shared.Pages.Discover
@implements IDisposable
@inject IYouTubeApi YoutubeApi
@inject IAnalyzedAccessApi AccessApi
@inject NavigationManager Nav

<PageTitle>@(_video?.Title ?? "Analyzing…") · FRELODY</PageTitle>

<div class="dv-page">

    @if (_video is not null)
    {
        <!-- Video header -->
        <div class="dv-header">
            <button class="dv-back" @onclick='() => Nav.NavigateTo(BackUrl)' title="Back to Discover">
                <i class="bi bi-arrow-left"></i>
            </button>

            <div class="dv-video-meta">
                @if (!string.IsNullOrEmpty(_video.ThumbnailUrl))
                {
                    <img class="dv-thumb" src="@_video.ThumbnailUrl" alt="@_video.Title" loading="lazy" />
                }
                <div class="dv-video-info">
                    <p class="dv-video-title">@_video.Title</p>
                    @if (!string.IsNullOrEmpty(_video.ChannelTitle))
                    {
                        <p class="dv-video-channel">
                            <i class="bi bi-person-circle"></i>
                            @_video.ChannelTitle
                        </p>
                    }
                </div>
            </div>

            <div class="dv-header-actions">
                <AnalyzedQuotaBadge @ref="_quotaBadge" />
                <button type="button" class="dv-share" @onclick="ShareAsync"
                        title="Copy share link" aria-label="Copy share link">
                    <i class="bi bi-link-45deg" aria-hidden="true"></i>
                    <span class="dv-share-label">Share</span>
                </button>
            </div>
        </div>
    }

    <!-- Analysis card -->
    <div class="dv-card">

        @if (_state == AnalysisState.Complete && _result is not null)
        {
            <YoutubePlaybackView
                Transcription="_result"
                Video="_video"
                AllowSaveToLibrary="true"
                OnReanalyze="ReanalyzeAsync" />
        }
        else if (_state == AnalysisState.Error)
        {
            <div class="dv-state dv-state--error">
                <div class="dv-state-icon-wrap dv-state-icon-wrap--error">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <p class="dv-state-heading">Analysis failed</p>
                <p class="dv-state-sub">@_errorMessage</p>
                <button class="dv-btn dv-btn--primary" @onclick="AnalyzeAsync">
                    <i class="bi bi-arrow-clockwise"></i>
                    Try again
                </button>
            </div>
        }
        else if (_state == AnalysisState.Idle)
        {
            <div class="dv-state">
                <div class="dv-state-icon-wrap">
                    <i class="bi bi-soundwave"></i>
                </div>
                <p class="dv-state-heading">Ready to analyze</p>
                <p class="dv-state-sub">Extract chords and beats from this video using AI.</p>
                <button class="dv-btn dv-btn--primary" @onclick="AnalyzeAsync">
                    <i class="bi bi-play-circle"></i>
                    Analyze chords
                </button>
            </div>
        }
        else if (_state == AnalysisState.Paywall && _access is not null)
        {
            <div class="dv-state">
                <div class="dv-state-icon-wrap">
                    <i class="bi bi-lock"></i>
                </div>
                <p class="dv-state-heading">@(_access.IsPremium ? "Locked" : "Daily limit reached")</p>
                <p class="dv-state-sub">@(_access.Reason == "unauthenticated"
                    ? "Sign in to play your first free song."
                    : "You've used today's free songs. Upgrade to keep playing.")</p>
            </div>
        }
        else if (_state == AnalysisState.TooLong)
        {
            <div class="dv-state">
                <div class="dv-state-icon-wrap">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <p class="dv-state-heading">Too long to analyze</p>
                <p class="dv-state-sub">@_tooLongMessage</p>
                @if (_tooLongUpgradeable)
                {
                    <button class="dv-btn dv-btn--primary" @onclick='() => Nav.NavigateTo("/pricing")'>
                        <i class="bi bi-unlock"></i>
                        Upgrade
                    </button>
                }
            </div>
        }
        else
        {
            <!-- Processing state -->
            <AnalysisProgress StageIndex="_stageIndex"
                              Subtitle="This may take a minute for longer videos." />
        }

    </div>
</div>

@if (_state == AnalysisState.Paywall && _access is not null)
{
    <AnalyzedAccessSheet Result="_access"
                         ReturnUrl="@CurrentRelativeUrl"
                         OnDismiss="DismissPaywall" />
}

@code {
    [Parameter, EditorRequired] public string VideoId { get; set; } = default!;
    [Parameter] public string BackUrl { get; set; } = "/discover";

    private enum AnalysisState { Idle, Extracting, Beats, Chords, Complete, Error, Paywall, TooLong }

    private YouTubeVideoDto? _video;
    private YouTubeTranscriptionDto? _result;
    private AnalysisState _state = AnalysisState.Idle;
    private string? _errorMessage;
    private AnalyzedAccessResultDto? _access;
    private AnalyzedQuotaBadge? _quotaBadge;
    private string? _tooLongMessage;
    private bool _tooLongUpgradeable;
    private System.Threading.Timer? _stageTimer;
    private int _stageIndex;

    private string CurrentRelativeUrl =>
        "/" + Nav.ToBaseRelativePath(Nav.Uri);

    private static readonly string[] Stages =
    [
        "Extracting audio…",
        "Detecting beats…",
        "Recognizing chords…",
        "Finalizing…"
    ];

    protected override async Task OnInitializedAsync()
    {
        var resp = await YoutubeApi.GetVideo(VideoId);
        if (resp.IsSuccessStatusCode)
            _video = resp.Content;

        // Pre-gate over-long videos before any sign-in/analysis prompt.
        if (_video is { DurationSeconds: > 0 } && await CheckTooLongAsync(_video.DurationSeconds))
            return;

        var cached = await YoutubeApi.GetTranscription(VideoId);
        if (cached.IsSuccessStatusCode && cached.Content is not null)
        {
            _result = cached.Content;
            _state = AnalysisState.Complete;
        }
        else if (cached.Error?.StatusCode == HttpStatusCode.PaymentRequired)
        {
            ShowPaywall(cached.Error.Content);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _state == AnalysisState.Idle)
            await RunAnalysisAsync(forceRefresh: false);
    }

    private Task AnalyzeAsync() => RunAnalysisAsync(forceRefresh: false);
    private Task ReanalyzeAsync() => RunAnalysisAsync(forceRefresh: true);

    private async Task ShareAsync()
    {
        var url = Nav.ToAbsoluteUri($"/play/{VideoId}").ToString();
        await _clipboardService.CopyToClipboardAsync(url);
        _toastService.Show("Share link copied to clipboard!", ToastType.Success);
    }

    private async Task RunAnalysisAsync(bool forceRefresh)
    {
        _state = AnalysisState.Extracting;
        _stageIndex = 0;
        _errorMessage = null;
        StateHasChanged();

        _stageTimer = new System.Threading.Timer(_ =>
        {
            _stageIndex = Math.Min(_stageIndex + 1, Stages.Length - 1);
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(12), TimeSpan.FromSeconds(12));

        try
        {
            var resp = await YoutubeApi.Analyze(new YouTubeAnalyzeRequest
            {
                VideoId = VideoId,
                ForceRefresh = forceRefresh
            });

            if (resp.IsSuccessStatusCode && resp.Content is not null)
            {
                _result = resp.Content;
                _state = AnalysisState.Complete;
                if (_quotaBadge is not null) await _quotaBadge.RefreshAsync();
            }
            else if (resp.Error?.StatusCode == HttpStatusCode.PaymentRequired)
            {
                ShowPaywall(resp.Error.Content);
            }
            else
            {
                _errorMessage = AnalysisErrorMessage.FromResponse(
                    resp.Error?.StatusCode, resp.Error?.Content, AnalysisErrorMessage.SourceKind.YouTube);
                _state = AnalysisState.Error;
                // The server refunds the slot it metered when analysis fails, so
                // resync the badge — the user keeps their song to retry another.
                if (_quotaBadge is not null) await _quotaBadge.RefreshAsync();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = AnalysisErrorMessage.FromException(ex, AnalysisErrorMessage.SourceKind.YouTube);
            _state = AnalysisState.Error;
            if (_quotaBadge is not null) await _quotaBadge.RefreshAsync();
        }
        finally
        {
            _stageTimer?.Dispose();
            _stageTimer = null;
            StateHasChanged();
        }
    }

    private void ShowPaywall(string? body)
    {
        _access = AnalyzedAccessParser.Parse(body)
            ?? new AnalyzedAccessResultDto { LimitReached = true };
        _state = AnalysisState.Paywall;
    }

    private async Task<bool> CheckTooLongAsync(int durationSeconds)
    {
        var limitsResp = await AccessApi.Limits();
        var limits = limitsResp.IsSuccessStatusCode ? limitsResp.Content : null;
        var premium = await _globalAuth.IsPremiumUser();
        var isPremium = premium.IsSuccess && premium.Data;

        var decision = AnalyzedDurationGate.Evaluate(limits, isPremium, durationSeconds);
        if (decision.Blocked)
        {
            _tooLongMessage = decision.Message;
            _tooLongUpgradeable = decision.Upgradeable;
            _state = AnalysisState.TooLong;
            return true;
        }
        return false;
    }

    private void DismissPaywall() => Nav.NavigateTo(BackUrl);

    public void Dispose() => _stageTimer?.Dispose();
}
