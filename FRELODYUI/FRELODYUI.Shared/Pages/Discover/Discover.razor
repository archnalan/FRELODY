@page "/discover"
@using FRELODYSHRD.Dtos
@using FRELODYUI.Shared.Pages.Discover
@using FRELODYUI.Shared.Pages.PlaceHolders
@inject IYouTubeApi _youtubeApi
@inject NavigationManager _nav

<PageTitle>Discover — FRELODY</PageTitle>

<div class="dc-page">

    @* ── Hero ─────────────────────────────────────────────────────── *@
    <section class="dc-hero @(_hasSearched ? "dc-hero--compact" : "")">
        <div class="dc-hero-glow" aria-hidden="true"></div>

        <div class="dc-hero-inner">

            @* ── Source toggle (YouTube ⇆ TikTok) ──────────────────── *@
            <div class="dc-mode-toggle" role="tablist" aria-label="Choose a source">
                <button type="button" role="tab"
                        class="dc-mode @(_mode == SearchMode.YouTube ? "dc-mode--active" : "")"
                        aria-selected="@(_mode == SearchMode.YouTube)"
                        @onclick="() => SetMode(SearchMode.YouTube)">
                    <i class="bi bi-youtube" aria-hidden="true"></i> YouTube
                </button>
                <button type="button" role="tab"
                        class="dc-mode @(_mode == SearchMode.TikTok ? "dc-mode--active" : "")"
                        aria-selected="@(_mode == SearchMode.TikTok)"
                        @onclick="() => SetMode(SearchMode.TikTok)">
                    <i class="bi bi-tiktok" aria-hidden="true"></i> TikTok
                </button>
            </div>

            @if (!_hasSearched)
            {
                <h1 class="dc-heading">
                    @(_mode == SearchMode.YouTube
                        ? "Find songs. Start playing."
                        : "Hear a sound. Learn the chords.")
                </h1>
                <p class="dc-subheading">
                    @(_mode == SearchMode.YouTube
                        ? "Drop a YouTube link — chords appear synced to every beat. Slow it down, loop the hard part, master it in one sitting."
                        : "Paste a TikTok video link and get auto-detected chords, synced to every beat.")
                </p>
            }

            @* ── Search bar ───────────────────────────────────────── *@
            <form class="dc-search-form" @onsubmit="HandleSearch" @onsubmit:preventDefault>
                <div class="dc-search-wrap @(_focused ? "dc-search-wrap--focused" : "")">
                    <i class="bi bi-search dc-search-icon" aria-hidden="true"></i>
                    <input type="search"
                           class="dc-search-input"
                           placeholder="@(_mode == SearchMode.YouTube ? "Song title, artist, or YouTube URL…" : "Paste a TikTok video link…")"
                           @bind="_query"
                           @bind:event="oninput"
                           @onfocus="() => _focused = true"
                           @onblur="() => _focused = false"
                           @onkeydown="HandleKeyDown"
                           aria-label="Search YouTube"
                           autocomplete="off"
                           spellcheck="false" />
                    @if (_loading)
                    {
                        <span class="dc-search-spinner" role="status" aria-label="Searching">
                            <span class="dc-spinner-ring"></span>
                        </span>
                    }
                    else
                    {
                        <button type="submit"
                                class="dc-search-btn"
                                disabled="@(string.IsNullOrWhiteSpace(_query))"
                                aria-label="Search">
                            <i class="bi bi-arrow-right" aria-hidden="true"></i>
                        </button>
                    }
                </div>
            </form>

            @* ── Suggestion chips (YouTube landing only) ───────────── *@
            @if (!_hasSearched && _mode == SearchMode.YouTube)
            {
                <div class="dc-chips" role="group" aria-label="Suggested searches">
                    @foreach (var suggestion in _displayedSuggestions)
                    {
                        <button class="dc-chip" type="button" @onclick="() => QuickSearch(suggestion)">
                            @suggestion
                        </button>
                    }
                </div>
            }
            else if (!_hasSearched && _mode == SearchMode.TikTok)
            {
                <p class="dc-tiktok-hint">
                    <i class="bi bi-info-circle" aria-hidden="true"></i>
                    TikTok has no public search — paste a link like
                    <code>tiktok.com/@@user/video/…</code>
                </p>
            }
        </div>
    </section>

    @* ── Results area ─────────────────────────────────────────────── *@
    <section class="dc-results-section">

        @if (_loading)
        {
            <YoutubeResultPlaceholder Count="8" />
        }
        else if (_error is not null)
        {
            <div class="dc-alert" role="alert">
                <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                <span>@_error</span>
                <button class="dc-alert-retry" type="button" @onclick="HandleSearch">Retry</button>
            </div>
        }
        else if (_results is { Count: > 0 })
        {
            <div class="dc-results-meta">
                <span>@_results.Count results</span>
                <span class="dc-results-query">"@_searchedQuery"</span>
            </div>
            <YoutubeResultGrid Videos="_results" OnVideoSelected="OnVideoSelected" />
        }
        else if (_hasSearched)
        {
            <div class="dc-state dc-state--empty">
                <div class="dc-state-icon-wrap">
                    <i class="bi bi-search" aria-hidden="true"></i>
                </div>
                <p class="dc-state-heading">No results found</p>
                <p class="dc-state-sub">Try a different song title or artist name.</p>
            </div>
        }
        else
        {
            <ChordMarquee />
        }

    </section>
</div>

@code {
    [Parameter] public bool IsLanding { get; set; }
    [SupplyParameterFromQuery] public string? q { get; set; }
    [SupplyParameterFromQuery] public string? v { get; set; }

    private enum SearchMode { YouTube, TikTok }
    private SearchMode _mode = SearchMode.YouTube;
    private const string ModeKey = "discover_source_mode";

    private string _query = string.Empty;
    private string _searchedQuery = string.Empty;
    private List<YouTubeVideoDto>? _results;
    private bool _loading;
    private bool _hasSearched;
    private bool _focused;
    private string? _error;

    // Full curated pool — varied artists, genres, learning intents, instruments.
    private static readonly string[] _suggestionPool =
    [
        // Worship / Christian
        "hillsong worship", "elevation worship", "bethel music", "phil wickham",
        "chris tomlin", "crowder", "cory asbury", "brandon lake",

        // Pop singer-songwriters
        "Ed Sheeran", "Taylor Swift", "John Mayer", "Adele",
        "Olivia Rodrigo", "Billie Eilish", "Harry Styles", "Shawn Mendes",

        // Classic rock / rock
        "Coldplay", "The Beatles", "Eric Clapton", "Eagles",
        "Fleetwood Mac", "Oasis", "Red Hot Chili Peppers", "Green Day",

        // Jazz / soul / R&B
        "jazz standards", "Frank Sinatra", "norah jones", "Amy Winehouse",
        "john coltrane", "bossa nova guitar", "blues guitar",

        // Fingerstyle / acoustic / instrumental
        "fingerstyle guitar", "Tommy Emmanuel", "acoustic guitar",
        "Travis picking", "classical guitar", "ukulele songs",

        // Piano / keyboard
        "beginner piano songs", "easy piano", "Chopin nocturne",
        "lofi piano", "cinematic piano", "gospel piano",

        // Learning-intent searches
        "easy guitar songs", "beginner guitar chords", "campfire songs",
        "3 chord songs", "worship guitar tutorial", "chord progressions",

        // More artists / bands
        "Imagine Dragons", "Twenty One Pilots", "Hozier", "Ben Howard",
        "Iron & Wine", "Bon Iver", "Jack Johnson", "Jason Mraz",
    ];

    // 5 chips picked once per landing view — stable during typing.
    private List<string> _displayedSuggestions = [];

    protected override async Task OnInitializedAsync()
    {
        PickSuggestions();

        if (!string.IsNullOrWhiteSpace(v))
        {
            // Stay within the current layout family: landing (/) → /play/{v}
            // (LandingLayout), app (/discover) → /discover/{v} (MainLayout).
            _nav.NavigateTo(IsLanding ? $"/play/{v}" : $"/discover/{v}", replace: true);
            return;
        }
        if (!string.IsNullOrWhiteSpace(q))
        {
            _query = q;
            await SearchAsync();
        }
    }

    private void PickSuggestions()
    {
        // Partial Fisher–Yates: shuffle a copy and take 5 — guarantees 5 *distinct*
        // chips (GetItems samples with replacement, so it can repeat / yield < 5).
        var pool = (string[])_suggestionPool.Clone();
        var take = Math.Min(5, pool.Length);
        for (var i = 0; i < take; i++)
        {
            var j = Random.Shared.Next(i, pool.Length);
            (pool[i], pool[j]) = (pool[j], pool[i]);
        }
        _displayedSuggestions = pool.Take(take).ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Restore the last-used source toggle — but never override an in-progress
        // search (e.g. arriving via ?q=, which is always a YouTube query).
        if (!firstRender || _hasSearched) return;
        if (!await _localStorage.IsStorageAvailableAsync()) return;

        var saved = await _localStorage.GetItemAsync<string>(ModeKey);
        if (Enum.TryParse<SearchMode>(saved, out var mode) && mode != _mode)
        {
            _mode = mode;
            StateHasChanged();
        }
    }

    private void SetMode(SearchMode mode)
    {
        if (_mode == mode) return;
        _mode = mode;
        _error = null;
        _results = null;
        _hasSearched = false;
        _query = string.Empty;
        if (mode == SearchMode.YouTube) PickSuggestions();
        _ = _localStorage.SetItemAsync(ModeKey, mode.ToString());
    }

    private async Task HandleSearch()
    {
        if (_loading || string.IsNullOrWhiteSpace(_query)) return;

        var q = _query.Trim();

        // TikTok mode (or any pasted TikTok link) → hand off to the TikTok lane.
        if (_mode == SearchMode.TikTok || q.Contains("tiktok.com", StringComparison.OrdinalIgnoreCase))
        {
            if (!q.Contains("tiktok.com", StringComparison.OrdinalIgnoreCase))
            {
                _error = "Please paste a valid TikTok video link.";
                _hasSearched = true;
                return;
            }
            var tiktokRoute = IsLanding
                ? $"/play/tiktok?url={Uri.EscapeDataString(q)}"
                : $"/discover/tiktok?url={Uri.EscapeDataString(q)}";
            _nav.NavigateTo(tiktokRoute);
            return;
        }

        await SearchAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleSearch();
    }

    private async Task QuickSearch(string term)
    {
        if (_loading) return;
        _query = term;
        await SearchAsync();
    }

    private async Task SearchAsync()
    {
        _loading = true;
        _error = null;
        _hasSearched = true;
        _searchedQuery = _query.Trim();
        _results = null;
        StateHasChanged();

        var response = await _youtubeApi.Search(_searchedQuery, limit: 12);
        if (response.IsSuccessStatusCode && response.Content is not null)
            _results = response.Content;
        else
            _error = "Search failed. Please try again.";

        _loading = false;
    }

    private void OnVideoSelected(YouTubeVideoDto video) =>
        _nav.NavigateTo(IsLanding
            ? $"/play/{video.VideoId}"
            : $"/discover/{video.VideoId}");
}
