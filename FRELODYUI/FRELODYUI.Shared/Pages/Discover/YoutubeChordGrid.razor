@inject IJSRuntime JS
@implements IAsyncDisposable

@if (_measures.Count == 0)
{
    <p class="ycg-empty">No chord data available for this song yet.</p>
}
else
{
    <div class="ycg" style="--ycg-bpm: @_beatsPerMeasure" @ref="_gridEl">
        @foreach (var measure in _measures)
        {
            <div class="ycg-measure" @key="measure.StartIndex">
                @foreach (var cell in measure.Cells)
                {
                    <button type="button"
                            @key="cell.Index"
                            class="@CellClass(cell)"
                            @onclick="(e) => OnCellClick(cell, e)"
                            @onmouseenter="(e) => OnCellEnter(cell, e)"
                            @onmouseleave="OnCellLeave">
                            @* No title/tooltip: it competes with the chord label, which is what
                               we want the eye drawn to. Chord identity lives in the cell itself. *@
                        @if (cell.ShowLabel)
                        {
                            <span class="ycg-beat-label">@cell.Display</span>
                        }
                        else
                        {
                            <span class="ycg-beat-tick" aria-hidden="true"></span>
                        }
                    </button>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public List<SyncedChordDto> SyncedChords { get; set; } = [];
    [Parameter] public List<float> Beats { get; set; } = [];
    [Parameter] public int ActiveBeatIndex { get; set; } = -1;
    [Parameter] public string? TimeSignature { get; set; }
    [Parameter] public EventCallback<float> OnSeekTo { get; set; }

    // Raised when a chord cell is previewed: hover on pointer devices, tap on
    // touch (Pinned=true → parent shows a "Play here" seek button).
    [Parameter] public EventCallback<ChordPreview> OnChordPreview { get; set; }
    [Parameter] public EventCallback OnChordPreviewEnd { get; set; }

    // Semitone shift applied to the *displayed* chord shapes (capo → negative).
    // The audio is untouched; this only changes which shapes the player fingers.
    [Parameter] public int CapoShift { get; set; }
    [Parameter] public bool PreferFlat { get; set; }

    // Carries the *raw* (pre-capo) chord up so the parent resolves the same
    // capo-aware diagram it shows in the "Chord shapes" section. CellTop/CellBottom
    // are the hovered button's viewport edges so the parent can anchor the popover
    // to the button (stable) instead of the cursor; X is kept for horizontal centring.
    // CursorY is the viewport Y at the moment of entry so the parent can decide
    // whether to place the popover above or below the button.
    public record ChordPreview(string? Raw, float Time, double X, double CellTop, double CellBottom, bool Pinned, double CursorY = 0);

    private record BeatRect(double Top, double Bottom, double Left, double Right);

    private record BeatCell(int Index, string Display, bool IsRest, bool ShowLabel, bool IsDownbeat, float Time, string? Raw);

    // Whether the device supports true hover (pointer). Touch → tap interactions.
    private bool _hoverCapable = true;
    private record Measure(int StartIndex, List<BeatCell> Cells);

    private List<Measure> _measures = [];
    private int _beatsPerMeasure = 4;

    private ElementReference _gridEl;
    private IJSObjectReference? _module;
    private int _lastScrolledIndex = -1;

    // Inputs the grid layout depends on. ActiveBeatIndex changes every beat, so
    // we deliberately exclude it — only a change to the underlying data rebuilds.
    private object? _builtChordsRef;
    private object? _builtBeatsRef;
    private string? _builtTimeSignature;
    private int _builtCapoShift;
    private bool _builtPreferFlat;

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_builtChordsRef, SyncedChords)
            && ReferenceEquals(_builtBeatsRef, Beats)
            && _builtTimeSignature == TimeSignature
            && _builtCapoShift == CapoShift
            && _builtPreferFlat == PreferFlat)
            return;

        _beatsPerMeasure = 4;
        if (!string.IsNullOrEmpty(TimeSignature))
        {
            var slash = TimeSignature.IndexOf('/');
            if (slash > 0 && int.TryParse(TimeSignature[..slash], out var n) && n is >= 2 and <= 12)
                _beatsPerMeasure = n;
        }

        BuildGrid();

        _builtChordsRef = SyncedChords;
        _builtBeatsRef = Beats;
        _builtTimeSignature = TimeSignature;
        _builtCapoShift = CapoShift;
        _builtPreferFlat = PreferFlat;
    }

    // Capo-shifted display label for a raw chord; rest detection stays on the original.
    private string DisplayFor(string? raw)
        => ChordLabel.Display(ChordLabel.TransposeRaw(raw, CapoShift, PreferFlat));

    // Lay the whole song out beat-by-beat so every position is its own cell.
    // The chord label is printed only when the chord *changes*; intervening
    // beats are quiet continuation ticks — the classic lead-sheet look. Each
    // cell keeps its absolute beat index, so highlighting is position-accurate:
    // an E in the intro and an E in the chorus are distinct cells.
    private void BuildGrid()
    {
        var cells = new List<BeatCell>();

        if (Beats.Count > 0)
        {
            // Forward-fill the active chord across the full beat axis.
            var ordered = SyncedChords.OrderBy(s => s.BeatIndex).ToList();
            int ptr = 0;
            string? current = null;
            string? prevDisplay = null;

            for (int i = 0; i < Beats.Count; i++)
            {
                while (ptr < ordered.Count && ordered[ptr].BeatIndex <= i)
                    current = ordered[ptr++].Chord;

                var display = DisplayFor(current);
                var isRest = ChordLabel.IsNoChord(current);
                var showLabel = current is not null && display != prevDisplay;
                cells.Add(new BeatCell(i, display, isRest, showLabel, i % _beatsPerMeasure == 0, Beats[i], current));
                prevDisplay = display;
            }
        }
        else
        {
            // No beat grid available — fall back to one cell per chord event.
            string? prevDisplay = null;
            for (int i = 0; i < SyncedChords.Count; i++)
            {
                var sc = SyncedChords[i];
                var display = DisplayFor(sc.Chord);
                var isRest = ChordLabel.IsNoChord(sc.Chord);
                cells.Add(new BeatCell(i, display, isRest, display != prevDisplay, i % _beatsPerMeasure == 0, sc.Time, sc.Chord));
                prevDisplay = display;
            }
        }

        var measures = new List<Measure>();
        for (int i = 0; i < cells.Count; i += _beatsPerMeasure)
        {
            var slice = cells.GetRange(i, Math.Min(_beatsPerMeasure, cells.Count - i));
            measures.Add(new Measure(i, slice));
        }
        _measures = measures;
    }

    private string CellClass(BeatCell cell)
    {
        var sb = new System.Text.StringBuilder("ycg-beat");
        if (cell.IsRest) sb.Append(" ycg-beat--rest");
        if (cell.IsDownbeat) sb.Append(" ycg-beat--downbeat");
        if (cell.ShowLabel) sb.Append(" ycg-beat--label");
        if (cell.Index == ActiveBeatIndex) sb.Append(" ycg-beat--active");
        return sb.ToString();
    }

    // A cell that currently sounds a real chord (not a pre-intro gap or a rest).
    private static bool HasChord(BeatCell cell) => cell.Raw is not null && !cell.IsRest;

    // Pointer click → seek (two-way grid). Touch tap on a chord → pinned preview.
    private async Task OnCellClick(BeatCell cell, MouseEventArgs e)
    {
        if (!_hoverCapable && HasChord(cell))
        {
            await RaiseChordPreview(cell, e, pinned: true);
            return;
        }
        await OnSeekTo.InvokeAsync(cell.Time);
    }

    private async Task OnCellEnter(BeatCell cell, MouseEventArgs e)
    {
        // Only chord-change cells (ShowLabel=true) trigger the hover preview.
        // Continuation ticks and rests are kept silent to reduce popover noise
        // as the cursor moves across the grid.
        if (!_hoverCapable || !HasChord(cell) || !cell.ShowLabel) return;
        await RaiseChordPreview(cell, e, pinned: false);
    }

    // Resolve the hovered button's viewport rect so the parent can anchor the
    // popover to the cell edges (entering from the bottom no longer covers the
    // top half of the button). Falls back to cursor Y if JS isn't available yet.
    private async Task RaiseChordPreview(BeatCell cell, MouseEventArgs e, bool pinned)
    {
        double top = e.ClientY;
        double bottom = e.ClientY;
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/FRELODYUI.Shared/Pages/Discover/YoutubeChordGrid.razor.js");
            var rect = await _module.InvokeAsync<BeatRect?>("beatRectAt", e.ClientX, e.ClientY);
            if (rect is not null) { top = rect.Top; bottom = rect.Bottom; }
        }
        catch { /* JS not ready / disposed → cursor-based fallback */ }

        await OnChordPreview.InvokeAsync(new ChordPreview(cell.Raw, cell.Time, e.ClientX, top, bottom, pinned, e.ClientY));
    }

    private async Task OnCellLeave()
    {
        if (!_hoverCapable) return;
        await OnChordPreviewEnd.InvokeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/FRELODYUI.Shared/Pages/Discover/YoutubeChordGrid.razor.js");
                _hoverCapable = await _module.InvokeAsync<bool>("hoverCapable");
                StateHasChanged();
            }
            catch { /* assume hover-capable until proven otherwise */ }
        }

        // Keep the playing measure in view while the audio advances.
        if (ActiveBeatIndex < 0 || ActiveBeatIndex == _lastScrolledIndex) return;
        _lastScrolledIndex = ActiveBeatIndex;
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/FRELODYUI.Shared/Pages/Discover/YoutubeChordGrid.razor.js");
            await _module.InvokeVoidAsync("scrollActiveIntoView", _gridEl);
        }
        catch { /* JS not ready / disposed */ }
    }

    public async ValueTask DisposeAsync()
    {
        try { if (_module is not null) await _module.DisposeAsync(); } catch { }
    }
}
