<div class="ycg-grid" style="--ycg-cols: @_cols">
    @{
        var activeDisplay = ChordLabel.Display(ActiveChord);
    }
    @foreach (var chord in _uniqueChords)
    {
        <button type="button"
                class="ycg-cell @(chord.IsRest ? "ycg-cell--rest" : "") @(chord.Display == activeDisplay ? "ycg-cell--active" : "")"
                @onclick="() => OnSeekTo.InvokeAsync(chord.FirstTime)"
                title="@(chord.IsRest ? "Rest" : $"Jump to {chord.Display}") at @(chord.FirstTime.ToString("F1"))s">
            @chord.Display
        </button>
    }
</div>

@code {
    [Parameter, EditorRequired] public List<SyncedChordDto> SyncedChords { get; set; } = [];
    [Parameter] public string? ActiveChord { get; set; }
    [Parameter] public string? TimeSignature { get; set; }
    [Parameter] public EventCallback<float> OnSeekTo { get; set; }

    private record UniqueChord(string Display, float FirstTime, bool IsRest);
    private List<UniqueChord> _uniqueChords = [];
    private int _cols = 4;

    protected override void OnParametersSet()
    {
        _cols = 4;
        if (!string.IsNullOrEmpty(TimeSignature))
        {
            var slash = TimeSignature.IndexOf('/');
            if (slash > 0 && int.TryParse(TimeSignature[..slash], out var n) && n is >= 2 and <= 8)
                _cols = n;
        }

        // Build the sequence in time order, collapsing only *consecutive* repeats
        // of the same label. No-chord ("N"/"X") spans are kept as rests — they
        // carry the rhythm and the visual spacing between chords.
        _uniqueChords = [];
        string? prev = null;
        foreach (var sc in SyncedChords)
        {
            var isRest = ChordLabel.IsNoChord(sc.Chord);
            var display = ChordLabel.Display(sc.Chord);
            if (display == prev) continue;          // merge runs of the same cell
            _uniqueChords.Add(new UniqueChord(display, sc.Time, isRest));
            prev = display;
        }
    }
}
