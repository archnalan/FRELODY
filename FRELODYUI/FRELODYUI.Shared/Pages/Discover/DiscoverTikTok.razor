@page "/discover/tiktok"
@rendermode InteractiveWebAssembly
@using FRELODYSHRD.Dtos
@using FRELODYSHRD.Dtos.CreateDtos
@using FRELODYUI.Shared.RefitApis
@using FRELODYUI.Shared.Pages.Discover
@implements IDisposable
@inject ITikTokApi TikTokApi
@inject NavigationManager Nav

<PageTitle>@(_video?.Title ?? "Analyzing…") · FRELODY</PageTitle>

<div class="dv-page">

    @if (_video is not null)
    {
        <div class="dv-header">
            <button class="dv-back" @onclick='() => Nav.NavigateTo("/discover")' title="Back to Discover">
                <i class="bi bi-arrow-left"></i>
            </button>

            <div class="dv-video-meta">
                @if (!string.IsNullOrEmpty(_video.ThumbnailUrl))
                {
                    <img class="dv-thumb" src="@_video.ThumbnailUrl" alt="@_video.Title" loading="lazy" />
                }
                <div class="dv-video-info">
                    <p class="dv-video-title">@_video.Title</p>
                    @if (!string.IsNullOrEmpty(_video.Uploader))
                    {
                        <p class="dv-video-channel">
                            <i class="bi bi-person-circle"></i>
                            @_video.Uploader
                        </p>
                    }
                </div>
            </div>
        </div>
    }

    <div class="dv-card">

        @if (_state == AnalysisState.Complete && _result is not null)
        {
            <YoutubePlaybackView
                Transcription="_result"
                PlayerApi="tiktokPlayer"
                PlayerVertical="true"
                VideoWidth="_video?.Width"
                VideoHeight="_video?.Height"
                SourceUrl="@(_video?.Url)"
                SourceName="TikTok"
                SourceIcon="bi-tiktok"
                OnReanalyze="ReanalyzeAsync" />
        }
        else if (_state == AnalysisState.Error)
        {
            <div class="dv-state dv-state--error">
                <div class="dv-state-icon-wrap dv-state-icon-wrap--error">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <p class="dv-state-heading">Analysis failed</p>
                <p class="dv-state-sub">@_errorMessage</p>
                @if (!string.IsNullOrWhiteSpace(Url))
                {
                    <button class="dv-btn dv-btn--primary" @onclick="AnalyzeAsync">
                        <i class="bi bi-arrow-clockwise"></i>
                        Try again
                    </button>
                }
            </div>
        }
        else if (_state == AnalysisState.Idle)
        {
            <div class="dv-state">
                <div class="dv-state-icon-wrap">
                    <i class="bi bi-soundwave"></i>
                </div>
                <p class="dv-state-heading">Ready to analyze</p>
                <p class="dv-state-sub">Extract chords and beats from this TikTok using AI.</p>
                <button class="dv-btn dv-btn--primary" @onclick="AnalyzeAsync">
                    <i class="bi bi-play-circle"></i>
                    Analyze chords
                </button>
            </div>
        }
        else
        {
            <AnalysisProgress StageIndex="_stageIndex"
                              Subtitle="Hang tight — this usually takes a few seconds for short clips." />
        }

    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Url { get; set; }

    private enum AnalysisState { Idle, Extracting, Beats, Chords, Complete, Error }

    private TikTokVideoDto? _video;
    private YouTubeTranscriptionDto? _result;
    private AnalysisState _state = AnalysisState.Idle;
    private string? _errorMessage;
    private System.Threading.Timer? _stageTimer;
    private int _stageIndex;

    private static readonly string[] Stages =
    [
        "Extracting audio…",
        "Detecting beats…",
        "Recognizing chords…",
        "Finalizing…"
    ];

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Url))
        {
            _errorMessage = "No TikTok link provided. Paste a TikTok URL on the Discover page.";
            _state = AnalysisState.Error;
            return;
        }

        var resolved = await TikTokApi.Resolve(new TikTokResolveRequest { Url = Url });
        if (resolved.IsSuccessStatusCode && resolved.Content is not null)
        {
            _video = resolved.Content;

            var cached = await TikTokApi.GetTranscription(_video.VideoId);
            if (cached.IsSuccessStatusCode && cached.Content is not null)
            {
                _result = cached.Content;
                _state = AnalysisState.Complete;
            }
        }
        else
        {
            _errorMessage = ExtractErrorMessage(resolved.Error?.Content)
                ?? "Couldn't read that TikTok link. Check the URL and try again.";
            _state = AnalysisState.Error;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _state == AnalysisState.Idle && !string.IsNullOrWhiteSpace(Url))
            await RunAnalysisAsync(forceRefresh: false);
    }

    private Task AnalyzeAsync() => RunAnalysisAsync(forceRefresh: false);
    private Task ReanalyzeAsync() => RunAnalysisAsync(forceRefresh: true);

    private async Task RunAnalysisAsync(bool forceRefresh)
    {
        if (string.IsNullOrWhiteSpace(Url)) return;

        _state = AnalysisState.Extracting;
        _stageIndex = 0;
        _errorMessage = null;
        StateHasChanged();

        _stageTimer = new System.Threading.Timer(_ =>
        {
            _stageIndex = Math.Min(_stageIndex + 1, Stages.Length - 1);
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(8), TimeSpan.FromSeconds(8));

        try
        {
            var resp = await TikTokApi.Analyze(new TikTokAnalyzeRequest
            {
                Url = Url,
                ForceRefresh = forceRefresh
            });

            if (resp.IsSuccessStatusCode && resp.Content is not null)
            {
                _result = resp.Content;
                _state = AnalysisState.Complete;
            }
            else
            {
                _errorMessage = ExtractErrorMessage(resp.Error?.Content);
                _state = AnalysisState.Error;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _state = AnalysisState.Error;
        }
        finally
        {
            _stageTimer?.Dispose();
            _stageTimer = null;
            StateHasChanged();
        }
    }

    private static string? ExtractErrorMessage(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
            return "Analysis returned an unexpected response.";
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            if (doc.RootElement.TryGetProperty("message", out var msg))
                return msg.GetString() ?? raw;
        }
        catch { }
        return raw;
    }

    public void Dispose() => _stageTimer?.Dispose();
}
