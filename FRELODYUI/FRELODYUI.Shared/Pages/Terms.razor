@code {
    // The page body scrolls inside the layout's `.app-body` (overflow-auto) container,
    // not the document, and Blazor intercepts in-page `#hash` clicks — so a plain anchor
    // doesn't move the viewport. Mirror the Support/Privacy pages: scroll the target into
    // view via JS. `scroll-margin-top` on .ts-section keeps the heading clear of the
    // sticky header.
    private async Task ScrollToSection(string id)
    {
        try
        {
            await JsRt.InvokeVoidAsync("eval",
                $"document.getElementById('{id}')?.scrollIntoView({{behavior:'smooth',block:'start'}})");
        }
        catch
        {
            // Smooth-scroll is a nicety; ignore if the JS host is unavailable (prerender).
        }
    }
}
