@page "/account/change-password-required"
@attribute [Authorize]
@inject IAuthApi _authApi
@inject NavigationManager _nav

<PageTitle>Change password - FRELODY</PageTitle>

<div class="admin-page">
    <div class="admin-body" style="max-width: 480px;">
        <div class="admin-card admin-card-pad">
            <h1 class="admin-title mb-1">Set a new password</h1>
            <p class="admin-subtitle mb-3">
                Your account was created by your organization administrator.
                Pick a personal password before continuing.
            </p>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="admin-alert danger">@_error</div>
            }

            <div class="admin-field">
                <label class="admin-field-label">Temporary password</label>
                <input type="password" @bind="_dto.CurrentPassword" autocomplete="current-password" />
            </div>
            <div class="admin-field">
                <label class="admin-field-label">New password</label>
                <input type="password" @bind="_dto.NewPassword" autocomplete="new-password" />
                <p class="admin-field-help">At least 8 characters.</p>
            </div>
            <div class="admin-field">
                <label class="admin-field-label">Confirm new password</label>
                <input type="password" @bind="_confirm" autocomplete="new-password" />
            </div>

            <div class="d-flex justify-content-end">
                <button type="button" class="admin-btn primary" @onclick="Submit" disabled="@_busy">
                    @if (_busy)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Update password
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private ChangeOwnPasswordDto _dto = new();
    private string _confirm = string.Empty;
    private bool _busy;
    private string? _error;

    private async Task Submit()
    {
        _error = null;
        if (_dto.NewPassword.Length < 8) { _error = "New password must be at least 8 characters."; return; }
        if (_dto.NewPassword != _confirm) { _error = "Passwords don't match."; return; }
        try
        {
            _busy = true;
            var resp = await _authApi.ChangeOwnPassword(_dto);
            if (resp.IsSuccessStatusCode)
            {
                _toastService.Show("Password updated.", ToastType.Success);
                _nav.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                _error = resp.Error?.Content ?? "Could not update password.";
            }
        }
        finally { _busy = false; }
    }
}
