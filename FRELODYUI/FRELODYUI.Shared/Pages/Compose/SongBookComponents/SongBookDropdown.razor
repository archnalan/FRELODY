@inject ILogger<SongBookDropdown> _logger

<div class="dropdown" style="width: 100%;" @onfocusout="HandleFocusOut" @onfocusin="HandleFocusIn">
    <div class="position-relative">
        <input @ref="inputElement"
               class="form-control pe-4"
               role="combobox"
               type="text"
               tabindex="@TabIndex"
               placeholder="add song book..."
               autocomplete="off"
               aria-expanded="@(showDropdown ? "true" : "false")"
               aria-activedescendant="@ActiveDescendantId"
               @bind="searchTerm"
               @oninput="HandleSearch"
               @onfocus="@(() => ToggleDropdown(true))"
               @onkeydown="HandleInputKeyDown"
               @onkeydown:preventDefault="shouldPreventDefault" />

        <i class="bi bi-chevron-down position-absolute top-50 end-0 translate-middle-y me-2 text-muted"
           style="cursor: pointer;"
           tabindex="-1"
           @onclick="@(() => ToggleDropdown(!showDropdown))"></i>
    </div>

    @if (showDropdown)
    {
        <div class="dropdown-menu show w-100"
             role="listbox"
             @onkeydown:stopPropagation="true"
             style="position: absolute; max-height: 300px; overflow-y: auto; z-index:5">
            <div id="@OptionId("none")"
                 role="option"
                 class="dropdown-item text-muted @(activeIndex == 0 ? "active" : "")"
                 aria-selected="@(activeIndex == 0 ? "true" : "false")"
                 @onclick="() => SelectNone()">
                <i class="bi bi-x-circle"></i> None
            </div>
            <div class="dropdown-divider"></div>
            @for (int i = 0; i < filteredSongBooks.Count; i++)
            {
                var songBook = filteredSongBooks[i];
                var idx = i + 1;
                <div id="@OptionId(songBook.Id ?? idx.ToString())"
                     role="option"
                     class="dropdown-item @(activeIndex == idx ? "active" : "")"
                     aria-selected="@(activeIndex == idx ? "true" : "false")"
                     @onclick="() => SelectSongBook(songBook)">
                    <div class="d-flex flex-column">
                        <span class="fw-semibold">@songBook.Title</span>
                        @if (!string.IsNullOrEmpty(songBook.Author))
                        {
                            <small class="text-muted">by @songBook.Author</small>
                        }
                    </div>
                </div>
            }
            @if (!filteredSongBooks.Any())
            {
                <div class="dropdown-item text-muted">No song books found</div>
            }
            <div class="dropdown-divider"></div>
            <div id="@OptionId("customize")"
                 role="option"
                 class="dropdown-item text-primary @(activeIndex == MaxIndex ? "active" : "")"
                 aria-selected="@(activeIndex == MaxIndex ? "true" : "false")"
                 @onclick="OpenCustomizeModal">
                <i class="bi bi-plus-circle-dotted"></i> Add New
            </div>
        </div>
    }
</div>

@if (showCustomizeModal)
{
    <SongBookCustomize Show="showCustomizeModal"
                       Content="SelectedSongBook"
                       OnSave="HandleSongBookSaved" 
                       OnCancel="CloseCustomizeModal" />
}


@code {
    [Parameter] public SongBookDto SelectedSongBook { get; set; } = new();
    [Parameter] public EventCallback<SongBookDto> SelectedSongBookChanged { get; set; }
    [Parameter] public int TabIndex { get; set; } = 0;

    public string searchTerm = "";
    private bool showDropdown = false;
    private bool showCustomizeModal = false;
    private List<SongBookDto> AvailableSongBooks { get; set; } = new();
    private List<SongBookDto> filteredSongBooks = new();
    private ElementReference inputElement;
    private int activeIndex = -1;
    private bool shouldPreventDefault = false;
    private CancellationTokenSource? _focusOutCts;
    private string _instanceId = Guid.NewGuid().ToString("N")[..8];

    // Total navigable items: None (0) + items (1..N) + Customize (N+1)
    private int MaxIndex => filteredSongBooks.Count + 1;

    private string OptionId(string suffix) => $"songbook-opt-{_instanceId}-{suffix}";

    private string? ActiveDescendantId => activeIndex switch
    {
        -1 => null,
        0 => OptionId("none"),
        int i when i == MaxIndex => OptionId("customize"),
        int i => OptionId(filteredSongBooks[i - 1].Id ?? i.ToString())
    };

    protected async override Task OnInitializedAsync()
    {
        searchTerm = SelectedSongBook?.Title ?? "";
        await LoadSongBooks();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (showDropdown && activeIndex >= 0 && ActiveDescendantId != null)
        {
            await JsRt.InvokeVoidAsync("scrollIntoViewIfNeeded", ActiveDescendantId);
        }
    }

    private async Task LoadSongBooks()
    {
        var response = await _songsBooksApi.GetAllSongBooks();
        if (response.IsSuccessStatusCode)
        {
            AvailableSongBooks = response.Content!;
            filteredSongBooks = response.Content!;
        }
        else
        {
            var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = errorMessage,
                ButtonText = "Close",
                OptionType = OptionType.Error,
                Context = new ModalContext
                {
                    ActionType = "LoadSongBooks",
                    Data = errorMessage
                }
            });
        }
    }

    public async Task FocusInput()
    {
        try
        {
            await inputElement.FocusAsync();
        }
        catch
        {
            // input may not yet be in the DOM (component just remounted)
        }
    }

    private void HandleSearch(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        FilterSongBooks();
        activeIndex = -1;
    }

    private void FilterSongBooks()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredSongBooks = AvailableSongBooks;
            return;
        }

        filteredSongBooks = AvailableSongBooks
            .Where(sb => sb.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                        (!string.IsNullOrEmpty(sb.Author) && sb.Author.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                        (!string.IsNullOrEmpty(sb.Publisher) && sb.Publisher.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
            .ToList();
    }

    private async Task SelectSongBook(SongBookDto songBook)
    {
        SelectedSongBook = songBook;
        searchTerm = songBook.Title;
        showDropdown = false;
        await SelectedSongBookChanged.InvokeAsync(songBook);
    }

    private async Task SelectNone()
    {
        var emptySongBook = new SongBookDto();
        SelectedSongBook = emptySongBook;
        searchTerm = "";
        showDropdown = false;
        await SelectedSongBookChanged.InvokeAsync(emptySongBook);
    }

    private void ToggleDropdown(bool show)
    {
        showDropdown = show;
        if (show)
        {
            activeIndex = -1;
        }
    }

    private void HandleInputKeyDown(KeyboardEventArgs e)
    {
        shouldPreventDefault = false;

        if (!showDropdown && (e.Key == "ArrowDown" || e.Key == "ArrowUp"))
        {
            showDropdown = true;
            activeIndex = e.Key == "ArrowDown" ? 0 : MaxIndex;
            shouldPreventDefault = true;
            return;
        }

        if (!showDropdown) return;

        switch (e.Key)
        {
            case "ArrowDown":
                activeIndex = activeIndex < MaxIndex ? activeIndex + 1 : 0;
                shouldPreventDefault = true;
                break;

            case "ArrowUp":
                activeIndex = activeIndex > 0 ? activeIndex - 1 : MaxIndex;
                shouldPreventDefault = true;
                break;

            case "Enter":
                if (activeIndex >= 0)
                {
                    shouldPreventDefault = true;
                    _ = SelectActiveItem();
                }
                break;

            case "Escape":
                showDropdown = false;
                activeIndex = -1;
                shouldPreventDefault = true;
                break;

            case "Tab":
                showDropdown = false;
                activeIndex = -1;
                break;
        }
    }

    private async Task SelectActiveItem()
    {
        if (activeIndex == 0)
        {
            await SelectNone();
        }
        else if (activeIndex == MaxIndex)
        {
            OpenCustomizeModal();
        }
        else if (activeIndex > 0 && activeIndex <= filteredSongBooks.Count)
        {
            await SelectSongBook(filteredSongBooks[activeIndex - 1]);
        }
    }

    private async Task HandleFocusOut(FocusEventArgs e)
    {
        // Debounced close: if focus moves to another element inside this
        // component, HandleFocusIn will cancel the close.
        _focusOutCts?.Cancel();
        _focusOutCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(150, _focusOutCts.Token);
            if (showDropdown)
            {
                showDropdown = false;
                activeIndex = -1;
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }

    private void HandleFocusIn(FocusEventArgs e)
    {
        _focusOutCts?.Cancel();
    }

    private void OpenCustomizeModal()
    {
        showCustomizeModal = true;
        showDropdown = false;
        if (SelectedSongBook != null) SelectedSongBook.Title = searchTerm;
        StateHasChanged();
    }

    private void CloseCustomizeModal()
    {
        showCustomizeModal = false;
    }

    private async Task HandleSongBookSaved(SongBookDto newSongBook)
    {
        // Check if song book already exists
        newSongBook = AvailableSongBooks.FirstOrDefault(sb => 
                     sb.Title.Trim().ToLower() == newSongBook.Title.Trim().ToLower()) 
                     ?? newSongBook;
        
        if (!AvailableSongBooks.Any(sb => sb.Id == newSongBook.Id))
        {
            var response = await _songsBooksApi.CreateSongBook(newSongBook);
            if(!response.IsSuccessStatusCode)
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error,
                    Context = new ModalContext
                    {
                        ActionType = "CreateSongBook",
                        Data = errorMessage
                    }
                });
                return;
            }
            
            // Add the created song book to the list
            var createdSongBook = response.Content!;
            AvailableSongBooks.Add(createdSongBook);
            newSongBook = createdSongBook;
        }

        // Select the new song book
        await SelectSongBook(newSongBook);
        CloseCustomizeModal();
    }

}