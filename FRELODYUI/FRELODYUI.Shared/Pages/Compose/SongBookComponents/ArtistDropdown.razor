@inject ILogger<ArtistDropdown> _logger

<div class="dropdown" style="width: 100%;" @onfocusout="HandleFocusOut" @onfocusin="HandleFocusIn">
    <div class="position-relative">
        <input @ref="inputElement"
               class="form-control pe-4"
               role="combobox"
               type="text"
               tabindex="@TabIndex"
               placeholder="add artist..."
               autocomplete="off"
               aria-expanded="@(showDropdown ? "true" : "false")"
               aria-activedescendant="@ActiveDescendantId"
               @bind="searchTerm"
               @oninput="HandleSearch"
               @onfocus="@(() => ToggleDropdown(true))"
               @onkeydown="HandleInputKeyDown"
               @onkeydown:preventDefault="shouldPreventDefault" />

        <i class="bi bi-chevron-down position-absolute top-50 end-0 translate-middle-y me-2 text-muted"
           style="cursor: pointer;"
           tabindex="-1"
           @onclick="@(() => ToggleDropdown(!showDropdown))"></i>
    </div>

    @if (showDropdown)
    {
        <div class="dropdown-menu show w-100"
             role="listbox"
             @onkeydown:stopPropagation="true"
             style="position: absolute; max-height: 300px; overflow-y: auto; z-index:5">
            <div id="@OptionId("none")"
                 role="option"
                 class="dropdown-item text-muted @(activeIndex == 0 ? "active" : "")"
                 aria-selected="@(activeIndex == 0 ? "true" : "false")"
                 @onclick="() => SelectNone()">
                <i class="bi bi-x-circle"></i> None
            </div>
            <div class="dropdown-divider"></div>
            @for (int i = 0; i < filteredArtists.Count; i++)
            {
                var artist = filteredArtists[i];
                var idx = i + 1;
                <div id="@OptionId(artist.Id ?? idx.ToString())"
                     role="option"
                     class="dropdown-item @(activeIndex == idx ? "active" : "")"
                     aria-selected="@(activeIndex == idx ? "true" : "false")"
                     @onclick="() => SelectArtist(artist)">
                    <div class="d-flex flex-column">
                        <span class="fw-semibold">@artist.Name</span>
                        @if (!string.IsNullOrEmpty(artist.Country))
                        {
                            <small class="text-muted">@artist.Country</small>
                        }
                    </div>
                </div>
            }
            @if (!filteredArtists.Any())
            {
                <div class="dropdown-item text-muted">No artists found</div>
            }
            <div class="dropdown-divider"></div>
            <div id="@OptionId("customize")"
                 role="option"
                 class="dropdown-item text-primary @(activeIndex == MaxIndex ? "active" : "")"
                 aria-selected="@(activeIndex == MaxIndex ? "true" : "false")"
                 @onclick="OpenCustomizeModal">
                <i class="bi bi-plus-circle-dotted"></i> Add New Artist
            </div>
        </div>
    }
</div>

@if (showCustomizeModal)
{
    <ArtistCustomize Show="showCustomizeModal"
                     Content="SelectedArtist"
                     OnSave="HandleArtistSaved" 
                     OnCancel="CloseCustomizeModal" />
}


@code {
    [Parameter] public ArtistDto SelectedArtist { get; set; } = new();
    [Parameter] public EventCallback<ArtistDto> SelectedArtistChanged { get; set; }
    [Parameter] public int TabIndex { get; set; } = 0;

    public string searchTerm = "";
    private bool showDropdown = false;
    private bool showCustomizeModal = false;
    private List<ArtistDto> AvailableArtists { get; set; } = new();
    private List<ArtistDto> filteredArtists = new();
    private ElementReference inputElement;
    private int activeIndex = -1;
    private bool shouldPreventDefault = false;
    private CancellationTokenSource? _focusOutCts;
    private string _instanceId = Guid.NewGuid().ToString("N")[..8];

    private int MaxIndex => filteredArtists.Count + 1;

    private string OptionId(string suffix) => $"artist-opt-{_instanceId}-{suffix}";

    private string? ActiveDescendantId => activeIndex switch
    {
        -1 => null,
        0 => OptionId("none"),
        int i when i == MaxIndex => OptionId("customize"),
        int i => OptionId(filteredArtists[i - 1].Id ?? i.ToString())
    };

    protected async override Task OnInitializedAsync()
    {
        searchTerm = SelectedArtist?.Name ?? "";
        await LoadArtists();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (showDropdown && activeIndex >= 0 && ActiveDescendantId != null)
        {
            await JsRt.InvokeVoidAsync("scrollIntoViewIfNeeded", ActiveDescendantId);
        }
    }

    private async Task LoadArtists()
    {
        var response = await _artistsApi.GetAllArtists();
        if (response.IsSuccessStatusCode)
        {
            AvailableArtists = response.Content!;
            filteredArtists = response.Content!;
        }
        else
        {
            var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = errorMessage,
                ButtonText = "Close",
                OptionType = OptionType.Error,
                Context = new ModalContext
                {
                    ActionType = "LoadArtists",
                    Data = errorMessage
                }
            });
        }
    }

    public async Task FocusInput()
    {
        try
        {
            await inputElement.FocusAsync();
        }
        catch
        {
            // input may not yet be in the DOM (component just remounted)
        }
    }

    private void HandleSearch(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        FilterArtists();
        activeIndex = -1;
    }

    private void FilterArtists()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredArtists = AvailableArtists;
            return;
        }

        filteredArtists = AvailableArtists
            .Where(a => a.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                        (!string.IsNullOrEmpty(a.Country) && a.Country.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
            .ToList();
    }

    private async Task SelectArtist(ArtistDto artist)
    {
        SelectedArtist = artist;
        searchTerm = artist.Name;
        showDropdown = false;
        await SelectedArtistChanged.InvokeAsync(artist);
    }

    private async Task SelectNone()
    {
        var emptyArtist = new ArtistDto();
        SelectedArtist = emptyArtist;
        searchTerm = "";
        showDropdown = false;
        await SelectedArtistChanged.InvokeAsync(emptyArtist);
    }

    private void ToggleDropdown(bool show)
    {
        showDropdown = show;
        if (show)
        {
            activeIndex = -1;
        }
    }

    private void HandleInputKeyDown(KeyboardEventArgs e)
    {
        shouldPreventDefault = false;

        if (!showDropdown && (e.Key == "ArrowDown" || e.Key == "ArrowUp"))
        {
            showDropdown = true;
            activeIndex = e.Key == "ArrowDown" ? 0 : MaxIndex;
            shouldPreventDefault = true;
            return;
        }

        if (!showDropdown) return;

        switch (e.Key)
        {
            case "ArrowDown":
                activeIndex = activeIndex < MaxIndex ? activeIndex + 1 : 0;
                shouldPreventDefault = true;
                break;

            case "ArrowUp":
                activeIndex = activeIndex > 0 ? activeIndex - 1 : MaxIndex;
                shouldPreventDefault = true;
                break;

            case "Enter":
                if (activeIndex >= 0)
                {
                    shouldPreventDefault = true;
                    _ = SelectActiveItem();
                }
                break;

            case "Escape":
                showDropdown = false;
                activeIndex = -1;
                shouldPreventDefault = true;
                break;

            case "Tab":
                showDropdown = false;
                activeIndex = -1;
                break;
        }
    }

    private async Task SelectActiveItem()
    {
        if (activeIndex == 0)
        {
            await SelectNone();
        }
        else if (activeIndex == MaxIndex)
        {
            OpenCustomizeModal();
        }
        else if (activeIndex > 0 && activeIndex <= filteredArtists.Count)
        {
            await SelectArtist(filteredArtists[activeIndex - 1]);
        }
    }

    private async Task HandleFocusOut(FocusEventArgs e)
    {
        _focusOutCts?.Cancel();
        _focusOutCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(150, _focusOutCts.Token);
            if (showDropdown)
            {
                showDropdown = false;
                activeIndex = -1;
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }

    private void HandleFocusIn(FocusEventArgs e)
    {
        _focusOutCts?.Cancel();
    }

    private void OpenCustomizeModal()
    {
        showCustomizeModal = true;
        showDropdown = false;
        if (SelectedArtist != null) SelectedArtist.Name = searchTerm;
        StateHasChanged();
    }

    private void CloseCustomizeModal()
    {
        showCustomizeModal = false;
    }

    private async Task HandleArtistSaved(ArtistDto newArtist)
    {
        // Check if artist already exists
        newArtist = AvailableArtists.FirstOrDefault(a => 
                     a.Name.Trim().ToLower() == newArtist.Name.Trim().ToLower()) 
                     ?? newArtist;
        
        if (!AvailableArtists.Any(a => a.Id == newArtist.Id))
        {
            newArtist.Id = Guid.NewGuid().ToString();
            var response = await _artistsApi.CreateArtist(newArtist);
            if(!response.IsSuccessStatusCode)
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error,
                    Context = new ModalContext
                    {
                        ActionType = "CreateArtist",
                        Data = errorMessage
                    }
                });
                return;
            }
            
            // Add the created artist to the list
            var createdArtist = response.Content!;
            AvailableArtists.Add(createdArtist);
            newArtist = createdArtist;
        }

        // Select the new artist
        await SelectArtist(newArtist);
        CloseCustomizeModal();
    }

}