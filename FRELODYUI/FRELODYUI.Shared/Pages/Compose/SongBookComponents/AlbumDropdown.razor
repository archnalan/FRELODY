@inject ILogger<AlbumDropdown> _logger

<div class="dropdown" style="width: 100%;" @onfocusout="HandleFocusOut" @onfocusin="HandleFocusIn">
    <div class="position-relative">
        <input @ref="inputElement"
               class="form-control pe-4"
               role="combobox"
               type="text"
               tabindex="@TabIndex"
               placeholder="add album..."
               autocomplete="off"
               aria-expanded="@(showDropdown ? "true" : "false")"
               aria-activedescendant="@ActiveDescendantId"
               @bind="searchTerm"
               @oninput="HandleSearch"
               @onfocus="@(() => ToggleDropdown(true))"
               @onkeydown="HandleInputKeyDown"
               @onkeydown:preventDefault="shouldPreventDefault" />

        <i class="bi bi-chevron-down position-absolute top-50 end-0 translate-middle-y me-2 text-muted"
           style="cursor: pointer;"
           tabindex="-1"
           @onclick="@(() => ToggleDropdown(!showDropdown))"></i>
    </div>

    @if (showDropdown)
    {
        <div class="dropdown-menu show w-100"
             role="listbox"
             @onkeydown:stopPropagation="true"
             style="position: absolute; max-height: 300px; overflow-y: auto; z-index:5">
            <div id="@OptionId("none")"
                 role="option"
                 class="dropdown-item text-muted @(activeIndex == 0 ? "active" : "")"
                 aria-selected="@(activeIndex == 0 ? "true" : "false")"
                 @onclick="() => SelectNone()">
                <i class="bi bi-x-circle"></i> None
            </div>
            <div class="dropdown-divider"></div>
            @for (int i = 0; i < filteredAlbums.Count; i++)
            {
                var album = filteredAlbums[i];
                var idx = i + 1;
                <div id="@OptionId(album.Id ?? idx.ToString())"
                     role="option"
                     class="dropdown-item @(activeIndex == idx ? "active" : "")"
                     aria-selected="@(activeIndex == idx ? "true" : "false")"
                     @onclick="() => SelectAlbum(album)">
                    <div class="d-flex flex-column">
                        <span class="fw-semibold">@album.Title</span>
                        @if (album.ReleaseDate.HasValue)
                        {
                            <small class="text-muted">@album.ReleaseDate.Value.Year</small>
                        }
                    </div>
                </div>
            }
            @if (!filteredAlbums.Any())
            {
                <div class="dropdown-item text-muted">No albums found</div>
            }
            <div class="dropdown-divider"></div>
            <div id="@OptionId("customize")"
                 role="option"
                 class="dropdown-item text-primary @(activeIndex == MaxIndex ? "active" : "")"
                 aria-selected="@(activeIndex == MaxIndex ? "true" : "false")"
                 @onclick="OpenCustomizeModal">
                <i class="bi bi-plus-circle-dotted"></i> Add New Album
            </div>
        </div>
    }
</div>

@if (showCustomizeModal)
{
    <AlbumCustomize Show="showCustomizeModal"
                    Content="SelectedAlbum"
                    OnSave="HandleAlbumSaved" 
                    OnCancel="CloseCustomizeModal" />
}


@code {
    [Parameter] public AlbumDto SelectedAlbum { get; set; } = new();
    [Parameter] public EventCallback<AlbumDto> SelectedAlbumChanged { get; set; }
    [Parameter] public string? ArtistId { get; set; }
    [Parameter] public int TabIndex { get; set; } = 0;

    public string searchTerm = "";
    private bool showDropdown = false;
    private bool showCustomizeModal = false;
    private List<AlbumDto> AvailableAlbums { get; set; } = new();
    private List<AlbumDto> filteredAlbums = new();
    private ElementReference inputElement;
    private int activeIndex = -1;
    private bool shouldPreventDefault = false;
    private CancellationTokenSource? _focusOutCts;
    private string _instanceId = Guid.NewGuid().ToString("N")[..8];

    private int MaxIndex => filteredAlbums.Count + 1;

    private string OptionId(string suffix) => $"album-opt-{_instanceId}-{suffix}";

    private string? ActiveDescendantId => activeIndex switch
    {
        -1 => null,
        0 => OptionId("none"),
        int i when i == MaxIndex => OptionId("customize"),
        int i => OptionId(filteredAlbums[i - 1].Id ?? i.ToString())
    };

    protected async override Task OnInitializedAsync()
    {
        searchTerm = SelectedAlbum?.Title ?? "";
        if (!string.IsNullOrEmpty(ArtistId))
        {
            await LoadAlbums();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (showDropdown && activeIndex >= 0 && ActiveDescendantId != null)
        {
            await JsRt.InvokeVoidAsync("scrollIntoViewIfNeeded", ActiveDescendantId);
        }
    }

    public async Task FocusInput()
    {
        try
        {
            await inputElement.FocusAsync();
        }
        catch
        {
            // input may not yet be in the DOM (component just remounted)
        }
    }

    private async Task LoadAlbums()
    {
        try
        {
            Refit.IApiResponse<List<AlbumDto>> response;

            if (!string.IsNullOrEmpty(ArtistId))
            {
                // Load albums for specific artist
                response = await _albumsApi.GetAlbumsByArtistId(ArtistId);
            }
            else
            {
                // Load all albums
                response = await _albumsApi.GetAllAlbums();
            }

            if (response.IsSuccessStatusCode)
            {
                AvailableAlbums = response.Content!;
                filteredAlbums = response.Content!;
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error,
                    Context = new ModalContext
                    {
                        ActionType = "LoadAlbums",
                        Data = errorMessage
                    }
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading albums");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "An error occurred while loading albums.",
                ButtonText = "Close",
                OptionType = OptionType.Error,
                Context = new ModalContext
                {
                    ActionType = "LoadAlbums",
                    Data = ex.Message
                }
            });
        }
    }

    private void HandleSearch(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        FilterAlbums();
        activeIndex = -1;
    }

    private void FilterAlbums()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredAlbums = AvailableAlbums;
            return;
        }

        filteredAlbums = AvailableAlbums
            .Where(a => a.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private async Task SelectAlbum(AlbumDto album)
    {
        SelectedAlbum = album;
        searchTerm = album.Title;
        showDropdown = false;
        await SelectedAlbumChanged.InvokeAsync(album);
    }

    private async Task SelectNone()
    {
        var emptyAlbum = new AlbumDto();
        SelectedAlbum = emptyAlbum;
        searchTerm = "";
        showDropdown = false;
        await SelectedAlbumChanged.InvokeAsync(emptyAlbum);
    }

    private void ToggleDropdown(bool show)
    {
        showDropdown = show;
        if (show)
        {
            activeIndex = -1;
        }
    }

    private void HandleInputKeyDown(KeyboardEventArgs e)
    {
        shouldPreventDefault = false;

        if (!showDropdown && (e.Key == "ArrowDown" || e.Key == "ArrowUp"))
        {
            showDropdown = true;
            activeIndex = e.Key == "ArrowDown" ? 0 : MaxIndex;
            shouldPreventDefault = true;
            return;
        }

        if (!showDropdown) return;

        switch (e.Key)
        {
            case "ArrowDown":
                activeIndex = activeIndex < MaxIndex ? activeIndex + 1 : 0;
                shouldPreventDefault = true;
                break;

            case "ArrowUp":
                activeIndex = activeIndex > 0 ? activeIndex - 1 : MaxIndex;
                shouldPreventDefault = true;
                break;

            case "Enter":
                if (activeIndex >= 0)
                {
                    shouldPreventDefault = true;
                    _ = SelectActiveItem();
                }
                break;

            case "Escape":
                showDropdown = false;
                activeIndex = -1;
                shouldPreventDefault = true;
                break;

            case "Tab":
                showDropdown = false;
                activeIndex = -1;
                break;
        }
    }

    private async Task SelectActiveItem()
    {
        if (activeIndex == 0)
        {
            await SelectNone();
        }
        else if (activeIndex == MaxIndex)
        {
            OpenCustomizeModal();
        }
        else if (activeIndex > 0 && activeIndex <= filteredAlbums.Count)
        {
            await SelectAlbum(filteredAlbums[activeIndex - 1]);
        }
    }

    private async Task HandleFocusOut(FocusEventArgs e)
    {
        _focusOutCts?.Cancel();
        _focusOutCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(150, _focusOutCts.Token);
            if (showDropdown)
            {
                showDropdown = false;
                activeIndex = -1;
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }

    private void HandleFocusIn(FocusEventArgs e)
    {
        _focusOutCts?.Cancel();
    }

    private void OpenCustomizeModal()
    {
        showCustomizeModal = true;
        showDropdown = false;
        SelectedAlbum = new();
        SelectedAlbum.Title = searchTerm;
        SelectedAlbum.ArtistId = ArtistId;
        StateHasChanged();
    }

    private void CloseCustomizeModal()
    {
        showCustomizeModal = false;
    }

    private async Task HandleAlbumSaved(AlbumDto newAlbum)
    {
        // Check if album already exists
        newAlbum = AvailableAlbums.FirstOrDefault(a => 
                     a.Title.Trim().ToLower() == newAlbum.Title.Trim().ToLower()) 
                     ?? newAlbum;
        
        if (!AvailableAlbums.Any(a => a.Id == newAlbum.Id))
        {
            newAlbum.Id = Guid.NewGuid().ToString();
            newAlbum.ArtistId = ArtistId;
            var response = await _albumsApi.CreateAlbum(newAlbum);

            if (response.IsSuccessStatusCode)
            {
                newAlbum = response.Content!;
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error,
                    Context = new ModalContext
                    {
                        ActionType = "CreateAlbum",
                        Data = errorMessage
                    }
                });
                return;
            }
            AvailableAlbums.Add(newAlbum);
        }

        // Select the new album
        await SelectAlbum(newAlbum);
        CloseCustomizeModal();
    }

}