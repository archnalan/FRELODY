@inject ILogger<CategoriesDropdown> _logger

<div class="dropdown" style="width: 100%;" @onfocusout="HandleFocusOut" @onfocusin="HandleFocusIn">
    <div class="position-relative">
        <input @ref="inputElement"
               class="form-control pe-4"
               role="combobox"
               type="text"
               tabindex="@TabIndex"
               placeholder="add category..."
               autocomplete="off"
               aria-expanded="@(showDropdown ? "true" : "false")"
               aria-activedescendant="@ActiveDescendantId"
               @bind="searchTerm"
               @oninput="HandleSearch"
               @onfocus="@(() => ToggleDropdown(true))"
               @onkeydown="HandleInputKeyDown"
               @onkeydown:preventDefault="shouldPreventDefault" />

        <i class="bi bi-chevron-down position-absolute top-50 end-0 translate-middle-y me-2 text-muted"
           style="cursor: pointer;"
           tabindex="-1"
           @onclick="@(() => ToggleDropdown(!showDropdown))"></i>
    </div>

    @if (showDropdown)
    {
        <div class="dropdown-menu show w-100"
             role="listbox"
             @onkeydown:stopPropagation="true"
             style="position: absolute; max-height: 300px; overflow-y: auto; z-index:5">
            <div id="@OptionId("none")"
                 role="option"
                 class="dropdown-item text-muted @(activeIndex == 0 ? "active" : "")"
                 aria-selected="@(activeIndex == 0 ? "true" : "false")"
                 @onclick="() => SelectNone()">
                <i class="bi bi-x-circle"></i> None
            </div>
            <div class="dropdown-divider"></div>
            @for (int i = 0; i < filteredCategories.Count; i++)
            {
                var category = filteredCategories[i];
                var idx = i + 1;
                <div id="@OptionId(category.Id ?? idx.ToString())"
                     role="option"
                     class="dropdown-item @(activeIndex == idx ? "active" : "")"
                     aria-selected="@(activeIndex == idx ? "true" : "false")"
                     @onclick="() => SelectCategory(category)">
                    <div class="d-flex flex-column">
                        <span class="fw-semibold">@category.Name</span>
                        @if (category.Sorting.HasValue)
                        {
                            <small class="text-muted">Order: @category.Sorting.Value</small>
                        }
                    </div>
                </div>
            }
            @if (!filteredCategories.Any())
            {
                <div class="dropdown-item text-muted">No categories found</div>
            }
            <div class="dropdown-divider"></div>
            <div id="@OptionId("customize")"
                 role="option"
                 class="dropdown-item text-primary @(activeIndex == MaxIndex ? "active" : "")"
                 aria-selected="@(activeIndex == MaxIndex ? "true" : "false")"
                 @onclick="OpenCustomizeModal">
                <i class="bi bi-plus-circle-dotted"></i> Add New Category
            </div>
        </div>
    }
</div>

@if (showCustomizeModal)
{
    <CategoryCustomize Show="showCustomizeModal"
                       Content="SelectedCategory"
                       OnSave="HandleCategorySaved" 
                       OnCancel="CloseCustomizeModal" />
}


@code {
    [Parameter] public CategoryDto SelectedCategory { get; set; } = new();
    [Parameter] public EventCallback<CategoryDto> SelectedCategoryChanged { get; set; }
    [Parameter] public string? SongBookId { get; set; }
    [Parameter] public int TabIndex { get; set; } = 0;

    public string searchTerm = "";
    private bool showDropdown = false;
    private bool showCustomizeModal = false;
    private List<CategoryDto> AvailableCategories { get; set; } = new();
    private List<CategoryDto> filteredCategories = new();
    private ElementReference inputElement;
    private int activeIndex = -1;
    private bool shouldPreventDefault = false;
    private CancellationTokenSource? _focusOutCts;
    private string _instanceId = Guid.NewGuid().ToString("N")[..8];

    private int MaxIndex => filteredCategories.Count + 1;

    private string OptionId(string suffix) => $"category-opt-{_instanceId}-{suffix}";

    private string? ActiveDescendantId => activeIndex switch
    {
        -1 => null,
        0 => OptionId("none"),
        int i when i == MaxIndex => OptionId("customize"),
        int i => OptionId(filteredCategories[i - 1].Id ?? i.ToString())
    };

    protected async override Task OnInitializedAsync()
    {
        searchTerm = SelectedCategory?.Name ?? "";
        if (!string.IsNullOrEmpty(SongBookId))
        {
            await LoadCategories();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (showDropdown && activeIndex >= 0 && ActiveDescendantId != null)
        {
            await JsRt.InvokeVoidAsync("scrollIntoViewIfNeeded", ActiveDescendantId);
        }
    }

    public async Task FocusInput()
    {
        try
        {
            await inputElement.FocusAsync();
        }
        catch
        {
            // input may not yet be in the DOM (component just remounted)
        }
    }

    private async Task LoadCategories()
    {
        try
        {
            Refit.IApiResponse<List<CategoryDto>> response;

            if (!string.IsNullOrEmpty(SongBookId))
            {
                // Load categories for specific song book
                response = await _categoriesApi.GetCategoriesBySongBookId(SongBookId);
            }
            else
            {
                // Load all categories
                response = await _categoriesApi.GetAllCategories();
            }

            if (response.IsSuccessStatusCode)
            {
                AvailableCategories = response.Content!;
                filteredCategories = response.Content!;
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error,
                    Context = new ModalContext
                    {
                        ActionType = "LoadCategories",
                        Data = errorMessage
                    }
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading categories");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "An error occurred while loading categories.",
                ButtonText = "Close",
                OptionType = OptionType.Error,
                Context = new ModalContext
                {
                    ActionType = "LoadCategories",
                    Data = ex.Message
                }
            });
        }
    }

    private void HandleSearch(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        FilterCategories();
        activeIndex = -1;
    }

    private void FilterCategories()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredCategories = AvailableCategories;
            return;
        }

        filteredCategories = AvailableCategories
            .Where(c => c.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private async Task SelectCategory(CategoryDto category)
    {
        SelectedCategory = category;
        searchTerm = category.Name;
        showDropdown = false;
        await SelectedCategoryChanged.InvokeAsync(category);
    }

    private async Task SelectNone()
    {
        var emptyCategory = new CategoryDto();
        SelectedCategory = emptyCategory;
        searchTerm = "";
        showDropdown = false;
        await SelectedCategoryChanged.InvokeAsync(emptyCategory);
    }

    private void ToggleDropdown(bool show)
    {
        showDropdown = show;
        if (show)
        {
            activeIndex = -1;
        }
    }

    private void HandleInputKeyDown(KeyboardEventArgs e)
    {
        shouldPreventDefault = false;

        if (!showDropdown && (e.Key == "ArrowDown" || e.Key == "ArrowUp"))
        {
            showDropdown = true;
            activeIndex = e.Key == "ArrowDown" ? 0 : MaxIndex;
            shouldPreventDefault = true;
            return;
        }

        if (!showDropdown) return;

        switch (e.Key)
        {
            case "ArrowDown":
                activeIndex = activeIndex < MaxIndex ? activeIndex + 1 : 0;
                shouldPreventDefault = true;
                break;

            case "ArrowUp":
                activeIndex = activeIndex > 0 ? activeIndex - 1 : MaxIndex;
                shouldPreventDefault = true;
                break;

            case "Enter":
                if (activeIndex >= 0)
                {
                    shouldPreventDefault = true;
                    _ = SelectActiveItem();
                }
                break;

            case "Escape":
                showDropdown = false;
                activeIndex = -1;
                shouldPreventDefault = true;
                break;

            case "Tab":
                showDropdown = false;
                activeIndex = -1;
                break;
        }
    }

    private async Task SelectActiveItem()
    {
        if (activeIndex == 0)
        {
            await SelectNone();
        }
        else if (activeIndex == MaxIndex)
        {
            OpenCustomizeModal();
        }
        else if (activeIndex > 0 && activeIndex <= filteredCategories.Count)
        {
            await SelectCategory(filteredCategories[activeIndex - 1]);
        }
    }

    private async Task HandleFocusOut(FocusEventArgs e)
    {
        _focusOutCts?.Cancel();
        _focusOutCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(150, _focusOutCts.Token);
            if (showDropdown)
            {
                showDropdown = false;
                activeIndex = -1;
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }

    private void HandleFocusIn(FocusEventArgs e)
    {
        _focusOutCts?.Cancel();
    }

    private void OpenCustomizeModal()
    {
        showCustomizeModal = true;
        showDropdown = false;
        SelectedCategory = new();
        SelectedCategory.Name = searchTerm;
        StateHasChanged();
    }

    private void CloseCustomizeModal()
    {
        showCustomizeModal = false;
    }

    private async Task HandleCategorySaved(CategoryDto newCategory)
    {
        // Check if category already exists
        newCategory = AvailableCategories.FirstOrDefault(c => 
                     c.Name.Trim().ToLower() == newCategory.Name.Trim().ToLower()) 
                     ?? newCategory;
        
        if (!AvailableCategories.Any(c => c.Id == newCategory.Id))
        {
            newCategory.SongBookId = SongBookId;
            var response = await _categoriesApi.CreateCategory(newCategory);

            if (response.IsSuccessStatusCode)
            {
                newCategory = response.Content!;
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error,
                    Context = new ModalContext
                    {
                        ActionType = "CreateCategory",
                        Data = errorMessage
                    }
                });
                return;
            }
            AvailableCategories.Add(newCategory);
        }

        // Select the new category
        await SelectCategory(newCategory);
        CloseCustomizeModal();
    }

}