@page "/pricing"
@layout LandingLayout
@inject ICurrencyDisplayService _currencyDisplay
@using FRELODYSHRD.Dtos.PesaPalDtos
@using FRELODYSHRD.Models.PesaPal
@inject ILogger<Pricing> _logger
@inject IPesaPalApi _pesaPalApi
@inject IPayPalApi _payPalApi
@inject IApiResponseHandler _apiResponseHandler
@inject IProductsApi _productsApi
@using FRELODYUI.Shared.Pages.Payments

<PageTitle>Pricing - FRELODY</PageTitle>

<!-- Hero -->
<section class="pr-hero">
    <div class="pr-shell">
        <span class="pr-eyebrow">Pricing</span>
        <h1 class="pr-hero-title">Stop searching for tabs. Start playing.</h1>
        <p class="pr-hero-sub">
            Paste any YouTube or TikTok link and get the chords instantly — then slow the song
            down and loop the tricky bar until your fingers catch up. Start free, upgrade when
            you're hooked.
        </p>
        <div class="pr-trust">
            <span class="pr-trust-item"><i class="bi bi-x-circle"></i> No card to start</span>
            <span class="pr-trust-item"><i class="bi bi-music-note-beamed"></i> 2 free songs every day</span>
            <span class="pr-trust-item"><i class="bi bi-arrow-repeat"></i> Cancel anytime</span>
        </div>
    </div>
</section>

<!-- Plans -->
<section class="pr-plans pricing-cards">
    <div class="pr-shell">
        @if (isLoading)
        {
            <div class="pr-grid">
                @for (int i = 0; i < 2; i++)
                {
                    <div class="pr-card pr-card--skeleton">
                        <span class="pr-skeleton pr-skeleton--title"></span>
                        <span class="pr-skeleton pr-skeleton--price"></span>
                        <span class="pr-skeleton pr-skeleton--line"></span>
                        <span class="pr-skeleton pr-skeleton--line"></span>
                        <span class="pr-skeleton pr-skeleton--line"></span>
                        <span class="pr-skeleton pr-skeleton--cta"></span>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Billing toggle -->
            <div class="pr-billing" role="tablist" aria-label="Billing period">
                <button type="button" role="tab"
                        class="pr-billing-opt @(billing == "monthly" ? "is-active" : "")"
                        @onclick='() => SetBilling("monthly")'>Monthly</button>
                <button type="button" role="tab"
                        class="pr-billing-opt @(billing == "yearly" ? "is-active" : "")"
                        @onclick='() => SetBilling("yearly")'>
                    Yearly <span class="pr-billing-save">−20%</span>
                </button>
                <button type="button" role="tab"
                        class="pr-billing-opt @(billing == "lifetime" ? "is-active" : "")"
                        @onclick='() => SetBilling("lifetime")'>Lifetime</button>
            </div>

            <div class="pr-grid">
                <!-- Free -->
                <article class="pr-card">
                    <header class="pr-card-head">
                        <h2 class="pr-card-name">Free</h2>
                        <p class="pr-card-tag">Perfect for casual practice</p>
                    </header>
                    <div class="pr-price">
                        <span class="pr-price-amt">Free</span>
                        <span class="pr-price-note">forever, no card</span>
                    </div>
                    <ul class="pr-feats">
                        <li><i class="bi bi-check-lg"></i> <strong>2</strong> song analyses every day</li>
                        <li><i class="bi bi-check-lg"></i> Songs up to <strong>8 minutes</strong></li>
                        <li><i class="bi bi-check-lg"></i> Auto chords, slow-down &amp; section loop</li>
                        <li><i class="bi bi-check-lg"></i> Unlocked songs stay playable for 24 hours</li>
                    </ul>
                    <button class="pr-cta pr-cta--ghost"
                            @onclick="() => SelectPlan(Starter)"
                            disabled="@(isProcessing || Starter is null)">
                        Start free
                    </button>
                </article>

                <!-- Premium -->
                @{ var premium = Premium; var premiumPrice = premium is null ? null : GetDisplayPrice(premium); }
                <article class="pr-card pr-card--popular">
                    <span class="pr-badge"><i class="bi bi-star-fill"></i> Most popular</span>
                    <header class="pr-card-head">
                        <h2 class="pr-card-name">Premium</h2>
                        <p class="pr-card-tag">@PremiumTag</p>
                    </header>
                    <div class="pr-price">
                        @if (premium is null)
                        {
                            <span class="pr-price-amt">—</span>
                        }
                        else
                        {
                            <span class="pr-price-amt">@premiumPrice!.FormattedAmount</span>
                            <span class="pr-price-per">@PremiumPriceSuffix</span>
                            @if (premiumPrice.IsConverted)
                            {
                                <span class="pr-price-note">
                                    ≈ @premiumPrice.OriginalCurrency @premiumPrice.OriginalAmount?.ToString("N0")
                                </span>
                            }
                        }
                    </div>
                    <ul class="pr-feats">
                        <li><i class="bi bi-check-lg"></i> <strong>Unlimited</strong> song analyses</li>
                        <li><i class="bi bi-check-lg"></i> Longer songs — up to <strong>20 minutes</strong></li>
                        <li><i class="bi bi-check-lg"></i> Auto chords, slow-down &amp; section loop</li>
                        <li><i class="bi bi-check-lg"></i> Save &amp; organise into playlists</li>
                        <li><i class="bi bi-check-lg"></i> PDF export &amp; sharing</li>
                    </ul>
                    <button class="pr-cta pr-cta--primary"
                            @onclick="() => SelectPlan(premium)"
                            disabled="@(isProcessing || premium is null)">
                        @if (isProcessing && selectedProduct?.Id == premium?.Id)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        }
                        @PremiumCtaLabel
                    </button>
                    <p class="pr-card-foot">@PremiumFootNote</p>
                </article>
            </div>

            @if (Studio is not null)
            {
                <p class="pr-studio-line">
                    Running a band, church or team?
                    <button class="pr-link" @onclick="() => SelectPlan(Studio)">See the Studio plan →</button>
                </p>
            }
        }
    </div>
</section>

<!-- How it works -->
<section class="pr-how">
    <div class="pr-shell">
        <h2 class="pr-section-title">From link to learning in three steps</h2>
        <div class="pr-steps">
            <div class="pr-step">
                <span class="pr-step-num">1</span>
                <i class="bi bi-link-45deg pr-step-icon"></i>
                <h3 class="pr-step-title">Paste a link</h3>
                <p class="pr-step-text">Drop in any YouTube or TikTok song you want to learn.</p>
            </div>
            <div class="pr-step">
                <span class="pr-step-num">2</span>
                <i class="bi bi-music-note-list pr-step-icon"></i>
                <h3 class="pr-step-title">Get the chords</h3>
                <p class="pr-step-text">FRELODY detects the chords and lines them up with the audio.</p>
            </div>
            <div class="pr-step">
                <span class="pr-step-num">3</span>
                <i class="bi bi-arrow-repeat pr-step-icon"></i>
                <h3 class="pr-step-title">Slow it down &amp; loop</h3>
                <p class="pr-step-text">Drop the tempo, loop the hard bar, and play along until it sticks.</p>
            </div>
        </div>
    </div>
</section>

<!-- Compare -->
<section class="pr-compare-wrap">
    <div class="pr-shell">
        <h2 class="pr-section-title">Free vs Premium</h2>
        <div class="pr-compare-scroll">
            <table class="pr-compare">
                <thead>
                    <tr>
                        <th>What you get</th>
                        <th class="pr-compare-col">Free</th>
                        <th class="pr-compare-col pr-compare-col--hl">Premium</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Song analyses per day</td>
                        <td class="pr-compare-col">2</td>
                        <td class="pr-compare-col pr-compare-col--hl"><i class="bi bi-infinity"></i></td>
                    </tr>
                    <tr>
                        <td>Maximum song length</td>
                        <td class="pr-compare-col">8 min</td>
                        <td class="pr-compare-col pr-compare-col--hl">20 min</td>
                    </tr>
                    <tr>
                        <td>Auto chord detection</td>
                        <td class="pr-compare-col"><i class="bi bi-check-lg pr-yes"></i></td>
                        <td class="pr-compare-col pr-compare-col--hl"><i class="bi bi-check-lg pr-yes"></i></td>
                    </tr>
                    <tr>
                        <td>Slow-down &amp; section loop</td>
                        <td class="pr-compare-col"><i class="bi bi-check-lg pr-yes"></i></td>
                        <td class="pr-compare-col pr-compare-col--hl"><i class="bi bi-check-lg pr-yes"></i></td>
                    </tr>
                    <tr>
                        <td>Save songs to playlists</td>
                        <td class="pr-compare-col"><i class="bi bi-check-lg pr-yes"></i></td>
                        <td class="pr-compare-col pr-compare-col--hl"><i class="bi bi-check-lg pr-yes"></i></td>
                    </tr>
                    <tr>
                        <td>Replay your songs</td>
                        <td class="pr-compare-col">For 24 hours</td>
                        <td class="pr-compare-col pr-compare-col--hl">Anytime</td>
                    </tr>
                    <tr>
                        <td>PDF export &amp; sharing</td>
                        <td class="pr-compare-col"><i class="bi bi-dash-lg pr-no"></i></td>
                        <td class="pr-compare-col pr-compare-col--hl"><i class="bi bi-check-lg pr-yes"></i></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="pr-faq-wrap">
    <div class="pr-shell">
        <h2 class="pr-section-title">Questions, answered</h2>
        <div class="accordion pr-faq" id="faqAccordion">
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                        Can I switch plans later?
                    </button>
                </h3>
                <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        Yes. You can move between Free, Monthly, Yearly and the one-time Lifetime plan
                        anytime from your account. Upgrades take effect immediately.
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                        Is there really a free plan?
                    </button>
                </h3>
                <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        Yes — the free tier is your trial. Play <strong>2 analyzed songs every day, forever</strong>,
                        with no credit card required. Upgrade anytime for unlimited analyses.
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                        How does cancellation work?
                    </button>
                </h3>
                <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        Monthly and Yearly subscriptions can be cancelled anytime — you keep access until the
                        end of the period you've paid for. The one-time <strong>Lifetime</strong> plan never
                        expires, so there's nothing to cancel.
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                        What payment methods do you accept?
                    </button>
                </h3>
                <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        <strong>PayPal</strong> (cards, worldwide) and <strong>PesaPal</strong> — mobile money,
                        cards and bank transfer across Africa. You pick at checkout.
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5">
                        Why only 2 free songs a day?
                    </button>
                </h3>
                <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        Analysing a song takes real processing to detect the chords and line them up with
                        the audio. Two a day lets you experience the full workflow before deciding whether
                        Premium is worth it — no card, no pressure.
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq6">
                        Do songs already in FRELODY count toward my daily limit?
                    </button>
                </h3>
                <div id="faq6" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        No. Only songs you analyse from a YouTube or TikTok link count toward the daily limit.
                        Browsing and playing songs already in the public library is always free.
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq7">
                        Do you offer refunds?
                    </button>
                </h3>
                <div id="faq7" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        The Studio plan includes a 30-day money-back guarantee. For other plans, reach out to
                        our support team and we'll help you out.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Final CTA -->
<section class="pr-final">
    <div class="pr-shell pr-final-inner">
        <h2 class="pr-final-title">Got a song stuck in your head?</h2>
        <p class="pr-final-sub">Paste a link. Get the chords. Start playing — your first two are free, every day.</p>
        <button class="pr-cta pr-cta--invert"
                @onclick="() => SelectPlan(Starter)"
                disabled="@(isProcessing || Starter is null)">
            Start free
        </button>
    </div>
</section>

<!-- Legal -->
<section class="pr-legal">
    <div class="pr-shell">
        <p class="pr-legal-text">
            <i class="bi bi-info-circle"></i>
            Prices are shown in your local currency (converted from UGX); PayPal payments are settled in
            USD. By subscribing you agree to our
            <a href="/terms">Terms of Service</a>, <a href="/privacy">Privacy Policy</a> and
            <a href="/sla">SLA</a>.
        </p>
    </div>
</section>

<!-- Login Modal -->
@if (showLoginModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 1rem;">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold">Sign In to Continue</h5>
                    <button type="button" class="btn-close" @onclick="CloseLoginModal"></button>
                </div><div class="modal-body p-0 py-3">
                    <Login ShowPhoneForm="true" FullBody="true" ShowSignUpModal="true" OnLoginSuccess="HandleLoginSuccess"/>
                </div>
            </div>
        </div>
    </div>
}
<!-- Checkout (gateway selector) Modal -->
@if (showCheckoutModal && selectedProduct != null)
{
    <div class="modal fade show d-block co-modal" tabindex="-1" @onclick="CloseCheckoutModal">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content co-content">
                <div class="modal-header co-header">
                    <div class="co-heading">
                        <h5 class="modal-title co-title">Complete your upgrade</h5>
                        <p class="co-subtitle">@GetProductDisplayName(selectedProduct)</p>
                    </div>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseCheckoutModal"></button>
                </div>
                <div class="modal-body co-body">
                    <div class="co-summary">
                        <span class="co-summary-label">@GetBillingLabel(selectedProduct.Period) plan</span>
                        <span class="co-summary-price">@GetDisplayPrice(selectedProduct).FormattedAmount</span>
                    </div>

                    @* Both gateways are always shown. An unconfigured gateway renders
                       disabled with a "coming soon" tooltip rather than disappearing. *@
                    <div class="co-tabs" role="tablist">
                        <button type="button"
                                class="co-tab @(checkoutGateway == "paypal" ? "co-tab--active" : "") @(payPalEnabled ? "" : "co-tab--soon")"
                                disabled="@(!payPalEnabled)"
                                title="@(payPalEnabled ? null : "Coming soon")"
                                @onclick='() => SetGateway("paypal")'>
                            <i class="bi bi-paypal"></i><span>PayPal</span>
                            @if (!payPalEnabled)
                            {
                                <span class="co-tab-soon-badge">Soon</span>
                            }
                        </button>
                        <button type="button"
                                class="co-tab @(checkoutGateway == "pesapal" ? "co-tab--active" : "") @(pesaPalEnabled ? "" : "co-tab--soon")"
                                disabled="@(!pesaPalEnabled)"
                                title="@(pesaPalEnabled ? null : "Coming soon")"
                                @onclick='() => SetGateway("pesapal")'>
                            <i class="bi bi-phone"></i><span>Mobile / Card</span>
                            @if (!pesaPalEnabled)
                            {
                                <span class="co-tab-soon-badge">Soon</span>
                            }
                        </button>
                    </div>

                    <div class="co-panel">
                        @if (checkoutGateway == "paypal")
                        {
                            @if (payPalEnabled)
                            {
                                <PayPalButton ProductId="@selectedProduct.Id"
                                              OnSuccess="HandlePayPalSuccess"
                                              OnError="HandlePayPalError" />
                                <p class="co-fineprint">
                                    <i class="bi bi-shield-lock"></i>
                                    <span>Charged in USD. You'll confirm securely in PayPal.</span>
                                </p>
                            }
                            else
                            {
                                <button type="button" class="btn btn-primary w-100 py-3 co-pesapal-btn"
                                        disabled title="Coming soon">
                                    <i class="bi bi-paypal me-2"></i>
                                    PayPal — coming soon
                                </button>
                                <p class="co-fineprint">
                                    <i class="bi bi-hourglass-split"></i>
                                    <span>PayPal checkout isn't available yet. Use Mobile / Card for now.</span>
                                </p>
                            }
                        }
                        else
                        {
                            @if (pesaPalEnabled)
                            {
                                <button type="button" class="btn btn-primary w-100 py-3 co-pesapal-btn"
                                        @onclick="ContinueWithPesaPal" disabled="@isProcessing">
                                    @if (isProcessing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    }
                                    <i class="bi bi-credit-card-2-front me-2"></i>
                                    Continue with Mobile Money / Card
                                </button>
                                <p class="co-fineprint">
                                    <i class="bi bi-shield-lock"></i>
                                    <span>Secured by PesaPal — mobile money, cards &amp; bank transfer.</span>
                                </p>
                            }
                            else
                            {
                                <button type="button" class="btn btn-primary w-100 py-3 co-pesapal-btn"
                                        disabled title="Coming soon">
                                    <i class="bi bi-credit-card-2-front me-2"></i>
                                    Mobile / Card — coming soon
                                </button>
                                <p class="co-fineprint">
                                    <i class="bi bi-hourglass-split"></i>
                                    <span>Mobile money &amp; card checkout isn't available yet. Try PayPal.</span>
                                </p>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- PesaPal Payment Modal -->
@if (showPaymentModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content" style="border-radius: 1rem; height: 80vh;">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title text-center">Complete Your Payment</h5>
                    <button type="button" class="btn-close" @onclick="ClosePaymentModal"></button>
                </div>
                <div class="modal-body row p-0" style="height: calc(80vh - 60px);">
                    @if (!string.IsNullOrEmpty(paymentRedirectUrl))
                    {
                        <div class="col-11 col-md-9 p-md-3 border rounded-3 bg-white mx-auto mt-2 mb-4">
                            <iframe src="@paymentRedirectUrl"
                                    style="width: 100%; height: 100%; border: none;"
                                    title="PesaPal Payment Gateway"></iframe>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <div class="text-center">
                                <div class="spinner-border text-primary mb-3" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p>Initializing payment gateway...</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}


@code {
    private List<ProductDto> pricingPlans = new();
    private Dictionary<string, CurrencyDisplayInfo> displayPrices = new();
    private bool isLoading = true;
    private bool isProcessing = false;
    private bool showPaymentModal = false;
    private bool showLoginModal = false;
    private bool showCheckoutModal = false;
    private bool payPalEnabled = false;
    private bool pesaPalEnabled = true;
    private string checkoutGateway = "pesapal";
    private string billing = "monthly";
    private string paymentRedirectUrl = string.Empty;
    private ProductDto? selectedProduct;

    // ── Plan resolution ───────────────────────────────────────────────
    private ProductDto? Starter =>
        pricingPlans.FirstOrDefault(p => string.Equals(p.Name, "Starter", StringComparison.OrdinalIgnoreCase))
        ?? pricingPlans.FirstOrDefault(p => (p.Price ?? 0) == 0);

    private ProductDto? Studio =>
        pricingPlans.FirstOrDefault(p => p.Name.Contains("Studio", StringComparison.OrdinalIgnoreCase));

    // The premium card maps to a "Creator" product based on the billing toggle,
    // falling back to any paid non-Studio plan if the expected name is missing.
    private ProductDto? Premium
    {
        get
        {
            var name = billing switch
            {
                "monthly" => "Creator Monthly",
                "yearly" => "Creator Yearly",
                "lifetime" => "Creator One-Time",
                _ => "Creator Monthly"
            };
            return pricingPlans.FirstOrDefault(p => string.Equals(p.Name, name, StringComparison.OrdinalIgnoreCase))
                ?? pricingPlans.FirstOrDefault(p =>
                    (p.Price ?? 0) > 0 && !p.Name.Contains("Studio", StringComparison.OrdinalIgnoreCase));
        }
    }

    private string PremiumTag => billing switch
    {
        "lifetime" => "Pay once, yours forever",
        "yearly" => "Best value — save 20%",
        _ => "Unlimited, cancel anytime"
    };

    private string PremiumPriceSuffix => billing switch
    {
        "lifetime" => "one-time",
        "yearly" => "/year",
        _ => "/month"
    };

    private string PremiumCtaLabel => billing == "lifetime" ? "Get lifetime access" : "Go Premium";

    private string PremiumFootNote => billing switch
    {
        "lifetime" => "One payment · lifetime access · no subscription",
        "yearly" => "Billed yearly · cancel anytime",
        _ => "Billed monthly · cancel anytime"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadPricingPlans();
        await LoadPayPalAvailability();

        // Check authentication status
        var authState = await _globalAuth.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            var returnUrl = _navManager.ToBaseRelativePath(_navManager.Uri);
            if (!string.IsNullOrEmpty(returnUrl) && returnUrl != "/")
            {
                await _storageService.SetItemAsync("returnUrl", returnUrl);
            }
        }
    }

    private void SetBilling(string period)
    {
        billing = period;
        StateHasChanged();
    }

    private async Task LoadPricingPlans()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var response = await _productsApi.GetProducts();

            if (response.IsSuccessStatusCode && response.Content != null)
            {
                pricingPlans = response.Content;

                // Convert prices to user's currency
                foreach (var product in pricingPlans)
                {
                    if (product.Price.HasValue && product.Price > 0)
                    {
                        var currencyResult = await _currencyDisplay.GetDisplayCurrencyAsync(
                            product.Price.Value,
                            product.Currency ?? "UGX");

                        if (currencyResult.IsSuccess)
                        {
                            displayPrices[product.Id] = currencyResult.Data;
                        }
                    }
                    else
                    {
                        displayPrices[product.Id] = new CurrencyDisplayInfo
                        {
                            Amount = 0,
                            CurrencyCode = "UGX",
                            FormattedAmount = "Free",
                            IsConverted = false
                        };
                    }
                }
            }
            else
            {
                _logger.LogError("Failed to load products from API");
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = "Failed to load pricing plans. Please refresh the page.",
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading pricing plans");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "Failed to load pricing plans. Please refresh the page.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetProductDisplayName(ProductDto product)
    {
        return product.Name switch
        {
            "Creator Monthly" => "Premium (Monthly)",
            "Creator Yearly" => "Premium (Yearly −20%)",
            "Creator One-Time" => "Premium (Lifetime)",
            _ => product.Name
        };
    }

    private CurrencyDisplayInfo GetDisplayPrice(ProductDto product)
    {
        return displayPrices.ContainsKey(product.Id)
            ? displayPrices[product.Id]
            : new CurrencyDisplayInfo
            {
                Amount = product.Price ?? 0,
                FormattedAmount = product.Price.HasValue ? $"UGX {product.Price.Value:N0}" : "Free",
                CurrencyCode = "UGX",
                IsConverted = false
            };
    }

    private async Task SelectPlan(ProductDto? product)
    {
        if (product is null) return;

        // Check authentication
        var authState = await _globalAuth.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            selectedProduct = product;
            showLoginModal = true;
            StateHasChanged();
            return;
        }

        selectedProduct = product;

        // Free plan - no payment needed
        if (product.Price == 0 || product.Price == null)
        {
            _modalService.Show(new ModalOptionDto
            {
                Title = "You're on Free",
                Message = "The Free plan is yours — 2 song analyses every day. Paste a link and start playing!",
                ButtonText = "Explore songs",
                OptionType = OptionType.Success
            });
            _navManager.NavigateTo("/discover");
            return;
        }

        // Studio plan - contact sales
        if (product.Name.Contains("Studio", StringComparison.OrdinalIgnoreCase))
        {
            _modalService.Show(new ModalOptionDto
            {
                Title = "Contact Sales",
                Message = "Our team will help you get your band, church or team set up on Studio. We'll reach out within 24 hours.",
                ButtonText = "Continue",
                OptionType = OptionType.Confirmation,
                Context = new ModalContext
                {
                    ActionType = "ContactSales",
                    Data = product
                },
                OnConfirmCallback = async () =>
                {
                    _logger.LogInformation("Contact sales request for Studio plan");
                    await Task.CompletedTask;
                }
            });
            return;
        }

        // Paid plan → let the buyer pick a payment method.
        OpenCheckout(product);
    }

    private async Task LoadPayPalAvailability()
    {
        try
        {
            var resp = await _payPalApi.GetConfig();
            payPalEnabled = resp.IsSuccessStatusCode && resp.Content?.Enabled == true;
        }
        catch
        {
            payPalEnabled = false;
        }

        try
        {
            var resp = await _pesaPalApi.GetConfig();
            pesaPalEnabled = resp.IsSuccessStatusCode && resp.Content?.Enabled == true;
        }
        catch
        {
            pesaPalEnabled = false;
        }
    }

    private void OpenCheckout(ProductDto product)
    {
        selectedProduct = product;
        // Open on a gateway that's actually usable so the buyer lands on an enabled tab.
        checkoutGateway = payPalEnabled ? "paypal" : "pesapal";
        showCheckoutModal = true;
        StateHasChanged();
    }

    private void SetGateway(string gateway)
    {
        checkoutGateway = gateway;
        StateHasChanged();
    }

    private void CloseCheckoutModal()
    {
        showCheckoutModal = false;
        StateHasChanged();
    }

    private async Task ContinueWithPesaPal()
    {
        showCheckoutModal = false;
        StateHasChanged();
        if (selectedProduct != null)
            await InitiatePayment(selectedProduct);
    }

    private async Task HandlePayPalSuccess()
    {
        showCheckoutModal = false;
        StateHasChanged();

        // Premium is granted server-side at capture; a full reload re-reads the
        // fresh billing state so the whole app reflects the upgrade immediately.
        _modalService.Show(new ModalOptionDto
        {
            Title = "You're Premium! 🎉",
            Message = "Your payment was successful. Enjoy unlimited song analyses.",
            ButtonText = "Start exploring",
            OptionType = OptionType.Success,
            OnConfirmCallback = () =>
            {
                _navManager.NavigateTo("/discover", forceLoad: true);
                return Task.CompletedTask;
            }
        });
        await Task.CompletedTask;
    }

    private Task HandlePayPalError(string message)
    {
        _modalService.Show(new ModalOptionDto
        {
            Title = "Payment Issue",
            Message = string.IsNullOrWhiteSpace(message)
                ? "Your PayPal payment could not be completed. Please try again."
                : message,
            ButtonText = "Close",
            OptionType = OptionType.Error
        });
        return Task.CompletedTask;
    }

    private async Task HandleLoginSuccess()
    {
        // Close login modal
        showLoginModal = false;
        StateHasChanged();

        // Proceed to checkout if a product was selected
        if (selectedProduct != null)
        {
            await SelectPlan(selectedProduct);
        }
        await Task.CompletedTask;
    }

    private void CloseLoginModal()
    {
        showLoginModal = false;
        selectedProduct = null;
        StateHasChanged();
    }

    private async Task InitiatePayment(ProductDto product)
    {
        isProcessing = true;
        StateHasChanged();

        try
        {
            var user = await _globalAuth.GetAuthenticatedUserAsync();
            if (!user.IsSuccess || user.Data == null)
            {
                throw new Exception("User authentication failed");
            }
            UpdateUserProfileOutDto userData = new();
            var userDataResult = await _usersApi.GetUserProfile(user.Data.Id!);
            if (userDataResult.IsSuccessStatusCode)
            {
                userData = userDataResult.Content!;
            }
            else
            {
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = "Failed to retrieve user profile. Please try again.",
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
                return;
            }
            var amount = product.Price ?? 0;
            var description = GetPaymentDescription(product);
            var countryCode = _currencyDisplay.GetCountryCode();

            var initiateDto = new InitiatePesaPalDto
            {
                ProductId = product.Id,
                CustomerId = userData.Id,
                Amount = amount,
                Description = description,
                BillingAddress = new BillingAddress
                {
                    EmailAddress = userData.Email ?? "",
                    PhoneNumber = userData.PhoneNumber ?? "",
                    CountryCode = countryCode,
                    FirstName = userData.FirstName ?? "",
                    LastName = userData.LastName ?? "",
                    City = "Kampala"
                },
                CallbackUrl = $"{_navManager.BaseUri}pricing?payment=success&productId={product.Id}",
                IpnCallbackUrl = $"{_navManager.BaseUri}api/PesaPal/ipn-callback"
            };

            var response = await _pesaPalApi.InitiatePesaPalPayment(initiateDto);

            if (!response.IsSuccessStatusCode || response.Content == null)
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                throw new Exception($"Failed to initiate payment: {errorMessage}");
            }

            paymentRedirectUrl = response.Content.RedirectUrl;
            showPaymentModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error initiating payment for product {ProductId}", product.Id);
            _modalService.Show(new ModalOptionDto
            {
                Title = "Payment Error",
                Message = $"Failed to initiate payment: {ex.Message}. Please try again.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private string GetPaymentDescription(ProductDto product)
    {
        if (product.Period == BillingPeriod.forever)
        {
            return $"{GetProductDisplayName(product)} - One-Time Payment (Lifetime Access)";
        }

        return $"{GetProductDisplayName(product)} - {GetBillingLabel(product.Period)} Subscription";
    }

    private string GetBillingLabel(BillingPeriod? period)
    {
        return period switch
        {
            BillingPeriod.daily => "day",
            BillingPeriod.monthly => "month",
            BillingPeriod.biannually => "6 months",
            BillingPeriod.yearly => "year",
            BillingPeriod.biennially => "2 years",
            BillingPeriod.forever => "lifetime",
            _ => "month"
        };
    }

    private async Task ScrollToPlans()
    {
        await JsRt.InvokeVoidAsync("eval", "document.querySelector('.pricing-cards').scrollIntoView({ behavior: 'smooth' })");
    }

    private void ClosePaymentModal()
    {
        showPaymentModal = false;
        paymentRedirectUrl = string.Empty;
        StateHasChanged();
    }

}
