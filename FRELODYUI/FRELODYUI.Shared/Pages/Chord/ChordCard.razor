@inject ILogger<ChordCard> _logger

<div class="chord-grid">
    @foreach (var chord in Chords)
    {
        var preloaded = chord.Id is not null
            ? ChartsByChordId?.GetValueOrDefault(chord.Id)
            : null;
        <div class="chord-card" @key="chord.Id">
            <div class="chord-card-thumb">
                <ChordCarousel Size="CarouselSize.Medium"
                               Chord="@chord"
                               PreloadedCharts="@preloaded"
                               ShowActions="false" />
            </div>
            <div class="chord-card-body">
                <div class="chord-card-meta">
                    <h5 class="chord-card-title">@chord.ChordName</h5>
                    <span class="chord-card-skill @SkillClass(chord.Difficulty)">
                        @GetDifficultyText(chord.Difficulty)
                    </span>
                </div>
                <div class="chord-card-actions">
                    <button class="chord-card-icon-btn" title="View details"
                            @onclick="() => NavigateToDetails(chord.Id)">
                        <i class="bi bi-eye"></i>
                    </button>
                    <button class="chord-card-icon-btn" title="Edit chord"
                            @onclick="async () => await HandleEditChord(chord)">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button class="chord-card-icon-btn chord-card-icon-btn-danger" title="Delete chord"
                            @onclick="() => HandleDeleteChord(chord)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(error))
{
    <div class="chord-grid-error">@error</div>
}

@code {
    [Parameter] public List<ChordDto> Chords { get; set; } = new();
    // Optional lookup so the parent can pre-supply each chord's charts (avoids the
    // N+1 fetch storm from per-card ChordCarousel calls on /chords).
    [Parameter] public Dictionary<string, List<ChordChartEditDto>>? ChartsByChordId { get; set; }
    [Parameter] public EventCallback<ChordDto> OnSetToDelete { get; set; }
    [Parameter] public EventCallback<ChordDto> OnSetOpenChordEdit { get; set; }
    [Parameter] public EventCallback OnRefreshRequested { get; set; }

    private string error = string.Empty;

    /// <summary>Backwards-compat hook so parents that previously called Refresh() still work.</summary>
    public Task Refresh(string? searchTerm = null) => OnRefreshRequested.InvokeAsync();

    private async Task HandleEditChord(ChordDto chord) => await OnSetOpenChordEdit.InvokeAsync(chord);
    private void HandleDeleteChord(ChordDto chord) => OnSetToDelete.InvokeAsync(chord);

    private void NavigateToDetails(string? chordId)
    {
        _logger.LogInformation($"Navigating to chord details: {chordId}");
        _navManager.NavigateTo($"/chords/{chordId}");
    }

    private static string GetDifficultyText(ChordDifficulty? difficulty) => difficulty switch
    {
        ChordDifficulty.Easy => "Beginner",
        ChordDifficulty.Medium => "Intermediate",
        ChordDifficulty.Advanced => "Advanced",
        ChordDifficulty.Expert => "Expert",
        _ => "Unknown"
    };

    private static string SkillClass(ChordDifficulty? difficulty) => difficulty switch
    {
        ChordDifficulty.Easy => "chord-card-skill-easy",
        ChordDifficulty.Medium => "chord-card-skill-medium",
        ChordDifficulty.Advanced => "chord-card-skill-advanced",
        ChordDifficulty.Expert => "chord-card-skill-expert",
        _ => "chord-card-skill-unknown"
    };
}
