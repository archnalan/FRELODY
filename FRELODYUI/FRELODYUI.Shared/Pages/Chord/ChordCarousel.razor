@using Microsoft.Extensions.Configuration
@inject ILogger<ChordCarousel> _logger
@inject IConfiguration Configuration

@if (IsLoading || isLoading)
{
    <div class="chord-carousel @SizeClass chord-carousel--ghost">
        <div class="chord-carousel-ghost-img"></div>
    </div>
}
else if (Charts.Count > 0)
{
    <div id="@CarouselId" class="chord-carousel @SizeClass">
        <div class="chord-carousel-stage">
            @{
                var chart = Charts[_currentChartIndex];
            }
            @RenderChart(chart)

            @if (Charts.Count > 1)
            {
                <button type="button"
                        class="chord-carousel-nav chord-carousel-nav-prev"
                        aria-label="Previous chart"
                        @onclick="PreviousChart">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <button type="button"
                        class="chord-carousel-nav chord-carousel-nav-next"
                        aria-label="Next chart"
                        @onclick="NextChart">
                    <i class="bi bi-chevron-right"></i>
                </button>
            }
        </div>

        @if (Charts.Count > 1)
        {
            <div class="chord-carousel-indicators" role="tablist">
                @for (int i = 0; i < Charts.Count; i++)
                {
                    var idx = i;
                    <button type="button"
                            class="chord-carousel-dot @(idx == _currentChartIndex ? "is-active" : null)"
                            role="tab"
                            aria-label="@($"Chart {idx + 1}")"
                            @onclick="() => GoToChart(idx)"></button>
                }
            </div>
        }

        @if (ShowActions)
        {
            <div class="chord-carousel-actions">
                <button type="button" class="chord-carousel-action-btn" title="Add new chart"
                        @onclick="@(() => AddChart(Chord?.Id))">
                    <i class="bi bi-plus-lg"></i>
                </button>
                @if (CurrentChart != null)
                {
                    <button type="button" class="chord-carousel-action-btn" title="Edit current chart"
                            @onclick="@(() => EditChart(CurrentChart.Id))">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button type="button" class="chord-carousel-action-btn chord-carousel-action-danger" title="Delete current chart"
                            @onclick="@(() => DeleteChart(CurrentChart.Id))">
                        <i class="bi bi-trash"></i>
                    </button>
                }
            </div>
        }
    </div>
}
else
{
    <div class="chord-carousel @SizeClass">
        <div class="chord-carousel-stage">
            <div class="chord-chart-placeholder">
                <i class="bi bi-music-note-list"></i>
                <span>No chart yet</span>
            </div>
        </div>
        @if (ShowActions)
        {
            <div class="chord-carousel-actions">
                <button type="button" class="chord-carousel-action-btn chord-carousel-action-primary"
                        @onclick="@(() => AddChart(Chord?.Id ?? string.Empty))">
                    <i class="bi bi-plus-lg me-1"></i> Add chart
                </button>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string ChordId { get; set; } = string.Empty;
    [Parameter] public ChordDto Chord { get; set; } = default!;
    [Parameter] public CarouselSize Size { get; set; } = CarouselSize.Medium;
    [Parameter] public bool ShowActions { get; set; } = true;
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string CarouselId { get; set; } = "chordCarousel";

    private List<ChordChartEditDto> Charts { get; set; } = new();
    private const string PlaceholderImagePath = "/_content/FRELODYUI.Shared/images/no_image_placeholder.png";
    private int _currentChartIndex = 0;
    private bool isLoading = true;
    private string? ApiBaseUrl = "https://localhost:7077";

    private ChordChartEditDto? CurrentChart => Charts.Count > 0 && _currentChartIndex >= 0 && _currentChartIndex < Charts.Count
       ? Charts[_currentChartIndex]
       : null;

    private string SizeClass => Size switch
    {
        CarouselSize.Small => "carousel-sm",
        CarouselSize.Medium => "carousel-md",
        CarouselSize.Large => "carousel-lg",
        CarouselSize.Popover => "carousel-popover",
        _ => "carousel-md"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Chord != null && !string.IsNullOrEmpty(Chord.Id))
            {
                await LoadCharts(Chord.Id);
            }
            else if (!string.IsNullOrEmpty(ChordId))
            {
                await LoadChord(ChordId);
                await LoadCharts(ChordId);
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error initializing ChordCarousel component");
        }
        finally
        {
            isLoading = false;
        }
    }

    private RenderFragment RenderChart(ChordChartEditDto chart) => __builder =>
    {
        if (chart.Source == ChordSource.Drawing)
        {
            if (!string.IsNullOrEmpty(chart.RenderedSvg))
            {
                <div class="chord-chart-frame chord-chart-frame-drawing">
                    @((MarkupString)chart.RenderedSvg!)
                </div>
            }
            else if (chart.ChordData is not null)
            {
                <div class="chord-chart-frame chord-chart-frame-drawing">
                    <ChordPreview Chart="chart.ChordData" />
                </div>
            }
            else
            {
                @RenderPlaceholder()
            }
        }
        else if (!string.IsNullOrEmpty(chart.FilePath))
        {
            <div class="chord-chart-frame chord-chart-frame-image">
                <img src="@DisplayImage(chart.FilePath!)"
                     alt="@Chord?.ChordName"
                     class="chord-chart-img" />
            </div>
        }
        else
        {
            @RenderPlaceholder()
        }
    };

    private RenderFragment RenderPlaceholder() => __builder =>
    {
        <div class="chord-chart-placeholder">
            <i class="bi bi-music-note-list"></i>
            <span>No chart</span>
        </div>
    };

    public async Task LoadChord(string chordId)
    {
        try
        {
            var response = await _chordsApi.GetChordById(chordId);
            if (response.IsSuccessStatusCode) Chord = response.Content!;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading chord");
        }
    }

    public async Task LoadCharts(string chordId)
    {
        try
        {
            var response = await _chordChartsApi.GetChartsByChordId(chordId);
            if (response.IsSuccessStatusCode) Charts = response.Content!;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading charts");
        }
    }

    private string DisplayImage(string filePath)
    {
        if (filePath.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return filePath;
        if (!string.IsNullOrEmpty(ApiBaseUrl))
            return $"{ApiBaseUrl}/{filePath.TrimStart('/')}";
        return filePath.StartsWith('/') ? filePath : $"/{filePath}";
    }

    private void NextChart()
    {
        if (Charts.Count > 1)
            _currentChartIndex = (_currentChartIndex + 1) % Charts.Count;
    }

    private void PreviousChart()
    {
        if (Charts.Count > 1)
            _currentChartIndex = _currentChartIndex == 0 ? Charts.Count - 1 : _currentChartIndex - 1;
    }

    private void GoToChart(int index)
    {
        if (index >= 0 && index < Charts.Count)
            _currentChartIndex = index;
    }

    private void AddChart(string? chordId)
        => _navManager.NavigateTo($"/chord-charts/create/{chordId}");

    private void EditChart(string chartId)
        => _navManager.NavigateTo($"/chord-charts/edit/{chartId}");

    private async Task DeleteChart(string chartId)
    {
        _modalService.Show(new ModalOptionDto
        {
            Title = "Delete Chart",
            Message = "Are you sure you want to delete this chart?",
            DangerText = "This action cannot be undone!",
            OptionType = OptionType.Warning,
            Context = new ModalContext { ActionType = "DeleteChart", Data = chartId },
            OnConfirmCallback = async () =>
            {
                var chartToRemove = Charts.FirstOrDefault(c => c.Id == chartId);
                if (chartToRemove == null) return;
                var response = await _chordChartsApi.DeleteChordChart(chartId);
                if (response.IsSuccessStatusCode)
                {
                    Charts.Remove(chartToRemove);
                    if (_currentChartIndex >= Charts.Count) _currentChartIndex = Math.Max(0, Charts.Count - 1);
                }
                else
                {
                    var errorMsg = _apiResponseHandler.GetApiErrorMessage(response);
                    _modalService.Show(new ModalOptionDto
                    {
                        Title = "Error",
                        Message = $"Failed to delete chart. {errorMsg}",
                        OptionType = OptionType.Error,
                        Context = new ModalContext { ActionType = "DeleteChart", Data = chartId }
                    });
                }
                StateHasChanged();
            }
        });
        await Task.CompletedTask;
    }
}
