@page "/playlists"
@page "/playlists/{CollectionId}"
@using FRELODYUI.Shared.Pages.Play.Components
@inject ILogger<SongPlaylist> _logger
@implements IDisposable

<div class="container-fluid h-100" style="max-width:55rem;justify-self:center">
    <div class="container text-center mt-3">
        <!-- Header -->
        @if (ShowActions)
        {
            <div class="text-center top-0" style="z-index:5">
                @if (!IsLandingContext)
                {
                    <h3 class="m-3">Playlists</h3>
                }
                <!-- Search Bar -->
                <div class="rounded-3 border shadow p-3 mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <div class="flex-grow-1 position-relative">
                            <input type="text"
                                   class="form-control ps-5 rounded-3"
                                   placeholder="Search playlists..."
                                   @bind-value="searchQuery"
                                   @bind-value:event="oninput"
                                   @bind-value:after="OnSearchInput" />
                            <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                        </div>
                        <button class="btn btn-primary rounded-3" @onclick="CreateNewPlaylist">
                            <i class="bi bi-plus-lg me-1"></i>
                            <span class="d-none d-sm-inline">New</span>
                        </button>
                    </div>
                </div>

            </div>
        }

        @if (isLoading)
        {
            <FRELODYUI.Shared.Pages.PlaceHolders.SongPlaylistPlaceholder ActiveView="ActiveView" />
        }
        else
        {
            <!-- My Playlists Section -->
            @if (myPlaylists.Any())
            {
                <div class="w-100 mb-4">
                    <div class="d-flex align-items-center gap-2 mb-2 px-1">
                        <i class="bi bi-collection" style="color: var(--text-secondary)"></i>
                        <h6 class="mb-0 fw-semibold" style="color: var(--text-primary)">My Playlists</h6>
                        <span class="badge rounded-pill" style="background: var(--bg-active); font-size: 0.7rem;">@myPlaylists.Count</span>
                    </div>
                    <div class="playlists-container">
                        @{
                            var myFilter = myPlaylists.Where(c => string.IsNullOrEmpty(searchQuery) ||
                                c.Playlist.Title?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) == true ||
                                c.Playlist.Theme?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) == true ||
                                c.Songs.Any(s => s.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)));
                        }
                        @foreach (var colSong in myFilter)
                        {
                            <PlaylistFolder Collection="colSong"
                                            ShowActionButtons="ShowActions"
                                            IsExpanded="expandedCollections.Contains(colSong.Playlist.Id)"
                                            OnToggle="() => ToggleCollection(colSong.Playlist.Id)"
                                            OnEdit="() => EditPlaylist(colSong)"
                                            OnRefresh="LoadPlaylists"
                                            OnAddSong="() => OpenAddSongModal(colSong.Playlist.Id)"/>
                        }
                        @if (!myFilter.Any())
                        {
                            <div class="text-center my-3">
                                <i class="bi bi-search text-muted"></i>
                                <small class="text-muted ms-1">No matches in your playlists</small>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (!explorePlaylists.Any())
            {
                <!-- Empty State (no playlists at all) -->
                <div class="text-center my-5 p-5">
                    <i class="bi bi-music-note-list fs-1 text-muted"></i>
                    <h5 class="mt-3">No Playlists Yet</h5>
                    @if (ShowActions)
                    {
                        <p class="text-muted">Create your first playlist to organize songs for performances</p>
                        <button class="btn btn-primary mt-3" @onclick="CreateNewPlaylist">
                            <i class="bi bi-plus-lg me-2"></i>Create Playlist
                        </button>
                    }
                    else
                    {
                        <p class="text-muted">Your playlists will be listed here.</p>
                    }
                </div>
            }

            <!-- Explore Playlists Section -->
            @if (explorePlaylists.Any())
            {
                <div class="w-100">
                    <div class="d-flex align-items-center gap-2 mb-2 px-1">
                        <i class="bi bi-globe2" style="color: var(--text-secondary)"></i>
                        <h6 class="mb-0 fw-semibold" style="color: var(--text-primary)">Explore</h6>
                        <span class="badge rounded-pill" style="background: var(--text-muted); font-size: 0.7rem;">@explorePlaylists.Count</span>
                    </div>
                    <div class="playlists-container">
                        @{
                            var exploreFilter = explorePlaylists.Where(c => string.IsNullOrEmpty(searchQuery) ||
                                c.Playlist.Title?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) == true ||
                                c.Playlist.Theme?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) == true ||
                                c.Songs.Any(s => s.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)));
                        }
                        @foreach (var colSong in exploreFilter)
                        {
                            <PlaylistFolder Collection="colSong"
                                            ShowActionButtons="false"
                                            IsExpanded="expandedCollections.Contains(colSong.Playlist.Id)"
                                            OnToggle="() => ToggleCollection(colSong.Playlist.Id)"
                                            IsReadOnly="true"
                                            OnClone="() => ClonePlaylist(colSong.Playlist.Id)"
                                            OnRefresh="LoadPlaylists" />
                        }
                        @if (!exploreFilter.Any())
                        {
                            <div class="text-center my-3">
                                <i class="bi bi-search text-muted"></i>
                                <small class="text-muted ms-1">No matches in explore playlists</small>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        <!-- Moving Mode Banner -->
        @if (movingContext != null)
        {
            <div class="position-fixed bottom-0 start-50 translate-middle-x mb-3 p-3 bg-primary text-white rounded-3 shadow-lg" style="z-index:1000; max-width:90vw;">
                <div class="d-flex align-items-center gap-3">
                    <i class="bi bi-arrow-left-right fs-4"></i>
                    <div class="flex-grow-1">
                        <div class="fw-bold">Moving: @movingContext.SongTitle</div>
                        <small>Select a destination playlist</small>
                    </div>
                    <button class="btn btn-light btn-sm" @onclick="CancelMove">Cancel</button>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modals -->
@if (showPlaylistModal)
{
    <PlaylistEditModal IsVisible="showPlaylistModal"
                      Collection="editingCollection"
                      OnSave="SavePlaylist"
                      OnCancel="ClosePlaylistModal" />
}

<SearchModal @ref="searchModalRef" OnResultSelected="HandleSongSelected" />

<MessageToast ShowToast="@showSuccessMessage" ToastMessage="@successMessage" Type="ToastType.Success" />

@code {
    [Parameter] public string? CollectionId { get; set; }
    [Parameter] public bool ShowActions { get; set; } = true;
    [Parameter] public ActiveView ActiveView { get; set; } = ActiveView.Collapsed;

    private List<PlaylistSongs> myPlaylists = new();
    private List<PlaylistSongs> explorePlaylists = new();
    private bool isLoading = true;
    private string searchQuery = string.Empty;
    private HashSet<string> expandedCollections = new();
    private string? currentUserId;

    // Editing state
    private bool showPlaylistModal = false;
    private PlaylistDto editingCollection = new();

    // Moving song between playlists
    private MovingContext? movingContext;

    // Debounce
    private CancellationTokenSource? _debounceCts;
    private const int SearchDebounceMs = 500;

    // Search modal state
    private SearchModal? searchModalRef;
    private string? activeCollectionId;
    private bool showSuccessMessage = false;
    private string successMessage = string.Empty;
    private bool IsAddingSong = false;
    private bool IsRemovingSong = false;

    private bool IsLandingContext => _navManager.Uri.Contains("/landing/", StringComparison.OrdinalIgnoreCase) ||
        _navManager.Uri.EndsWith("/landing", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var user = await _globalAuth.GetAuthenticatedUserAsync();
        if (user.IsSuccess && user.Data != null)
        {
            currentUserId = user.Data.Id;
        }

        await LoadPlaylists();

        // Auto-expand if navigated to specific collection
        if (!string.IsNullOrEmpty(CollectionId))
        {
            expandedCollections.Add(CollectionId);
        }
        await ApplyViewState(ActiveView);
    }

    private async Task LoadPlaylists()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            if (string.IsNullOrEmpty(currentUserId))
            {
                // Still load public playlists for unauthenticated users
                var publicResponse = await _playlistsApi.GetPublicPlaylists();
                if (publicResponse.IsSuccessStatusCode && publicResponse.Content != null)
                {
                    explorePlaylists = publicResponse.Content;
                }
                myPlaylists = new();
                return;
            }

            // Load user playlists
            var userResponse = await _playlistsApi.GetUserPlaylists(currentUserId);
            if (userResponse.IsSuccessStatusCode && userResponse.Content != null)
            {
                myPlaylists = userResponse.Content;
                await ApplyViewState(ActiveView);
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(userResponse);
                _logger.LogError("Error loading playlists: {Error}", errorMessage);
            }

            // Load public/explore playlists (excluding user's own)
            var exploreResponse = await _playlistsApi.GetPublicPlaylists(currentUserId);
            if (exploreResponse.IsSuccessStatusCode && exploreResponse.Content != null)
            {
                explorePlaylists = exploreResponse.Content;
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading playlists");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "Failed to load playlists.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
        finally
        {
            isLoading = false;
            _modalService.Close();
            StateHasChanged();
        }
    }

    public async Task ApplyViewState(ActiveView? view = ActiveView.Collapsed)
    {
        if (view == ActiveView.Expanded)
        {
            foreach (var collection in myPlaylists)
            {
                if (!string.IsNullOrEmpty(collection.Playlist.Id))
                {
                    expandedCollections.Add(collection.Playlist.Id);
                }
            }
        }
        else if (view == ActiveView.Collapsed)
        {
            var specificId = CollectionId;
            expandedCollections.Clear();
            if (!string.IsNullOrEmpty(specificId))
            {
                expandedCollections.Add(specificId);
            }
        }
        StateHasChanged();
        await Task.CompletedTask;
    }

    private void ToggleCollection(string collectionId)
    {
        if (expandedCollections.Contains(collectionId))
        {
            expandedCollections.Remove(collectionId);
        }
        else
        {
            expandedCollections.Add(collectionId);
        }
        StateHasChanged();
    }

    private void CreateNewPlaylist()
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            ShowAuthenticationRequired();
            return;
        }

        editingCollection = new PlaylistDto
        {
            IsPublic = true,
            IsFeatured = false
        };
        showPlaylistModal = true;
    }

    private void EditPlaylist(PlaylistSongs collection)
    {
        editingCollection = collection.Playlist;
        showPlaylistModal = true;
    }

    private async Task SavePlaylist(PlaylistDto collection)
    {
        await LoadPlaylists();
        ClosePlaylistModal();
    }

    private void ClosePlaylistModal()
    {
        showPlaylistModal = false;
        editingCollection = new();
    }


    private void InitiateSongMove(string sourceCollectionId, string songId)
    {
        var collection = myPlaylists.FirstOrDefault(c => c.Playlist.Id == sourceCollectionId);
        var song = collection?.Songs.FirstOrDefault(s => s.Id == songId);

        if (song != null)
        {
            movingContext = new MovingContext
            {
                SourceCollectionId = sourceCollectionId,
                SongId = songId,
                SongTitle = song.Title
            };
            StateHasChanged();
        }
    }

    private void CancelMove()
    {
        movingContext = null;
        StateHasChanged();
    }

    private async Task ExecuteSongMove(string destinationCollectionId)
    {
        if (movingContext == null) return;
        IsRemovingSong = true;
        try
        {
            // Remove from source
            await _playlistsApi.RemoveSongFromPlaylist(movingContext.SourceCollectionId, movingContext.SongId);

            // Add to destination (This might need a new API endpoint to add single song)
            // For now, we'll need to update the entire collection
            var destCollection = myPlaylists.FirstOrDefault(c => c.Playlist.Id == destinationCollectionId);
            if (destCollection != null)
            {
                var createDto = new PlaylistCreateDto
                {
                    Title = destCollection.Playlist.Title,
                    SongIds = destCollection.Songs.Select(s => s.Id).Append(movingContext.SongId).ToList(),
                    Theme = destCollection.Playlist.Theme,
                    Curator = destCollection.Playlist.Curator,
                    SheduledDate = DateTimeOffset.Now
                };

                await _playlistsApi.UpdatePlaylist(destinationCollectionId, destCollection.Playlist);
            }

            movingContext = null;
            await LoadPlaylists();
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error moving song between playlists");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "Failed to move song.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
        finally
        {
            IsRemovingSong = false;
        }
    }

    private async Task OpenAddSongModal(string collectionId)
    {
        activeCollectionId = collectionId;
        if (searchModalRef != null)
        {
            await searchModalRef.Open();
        }
    }

    private async Task HandleSongSelected(SearchResult selectedSong)
    {
        IsAddingSong = true;
        if (string.IsNullOrEmpty(activeCollectionId) || selectedSong == null)
            return;

        var targetPlaylist = myPlaylists.FirstOrDefault(c => c.Playlist.Id == activeCollectionId);
        if (targetPlaylist != null && targetPlaylist.Songs.Any(s => s.Id == selectedSong.Id))
        {
            _modalService.Show(new ModalOptionDto
            {
                Title = "Song Already Exists",
                Message = "This song is already in the playlist.",
                ButtonText = "Close",
                OptionType = OptionType.Info
            });
            activeCollectionId = null;
            return;
        }

        try
        {
            var response = await _playlistsApi.AddSongToPlaylist(activeCollectionId, selectedSong.Id);

            if (response.IsSuccessStatusCode)
            {
                await LoadPlaylists();
                await ShowSuccessMessage("Song added to playlist successfully.");

                // Ensure the collection stays expanded
                if (!expandedCollections.Contains(activeCollectionId))
                {
                    expandedCollections.Add(activeCollectionId);
                }
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error adding song to playlist");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "An error occurred while adding the song to the playlist.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
        finally
        {
            activeCollectionId = null;
            IsAddingSong = false;
            if (searchModalRef != null)
            {
                searchModalRef.Close();
            }
        }
    }

    private async Task OnSearchInput()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(SearchDebounceMs, _debounceCts.Token);
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // Expected when cancelled
        }
    }

    private void ShowAuthenticationRequired()
    {
        _modalService.Show(new ModalOptionDto
        {
            Title = "Login Required",
            Message = "Please log in to manage playlists.",
            HyperlinkText = "Go to Login",
            ButtonText = "Close",
            OptionType = OptionType.Info,
            OnConfirmCallback = () =>
            {
                _navManager.NavigateTo("/login");
                return Task.CompletedTask;
            }
        });
    }

    private async Task ClonePlaylist(string playlistId)
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            ShowAuthenticationRequired();
            return;
        }

        try
        {
            var response = await _playlistsApi.ClonePlaylist(playlistId, currentUserId);
            if (response.IsSuccessStatusCode)
            {
                await ShowSuccessMessage("Playlist copied to your library!");
                await LoadPlaylists();
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error cloning playlist");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "Failed to copy playlist.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
    }

    private async Task GoBack()
    {
        await JsRt.InvokeVoidAsync("goBack");
    }

    private async Task ShowSuccessMessage(string message)
    {
        successMessage = message;
        showSuccessMessage = true;
        StateHasChanged();

        await Task.Delay(3000);
        showSuccessMessage = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
    }
}