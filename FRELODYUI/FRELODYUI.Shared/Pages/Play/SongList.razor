@using SortDirection = FRELODYAPP.Dtos.SubDtos.SortDirection
@inject ILogger<SongList> _logger
@implements IDisposable

@if (ViewStyle == ActiveView.Expanded)
{
    <div class="song-table-card">
        @if (_isInitialLoading)
        {
            <FRELODYUI.Shared.Pages.PlaceHolders.SongListPlaceholder ActiveView="ActiveView.Expanded" ShowHeader="true" Count="8" />
        }
        else if (_pageItems.Count == 0)
        {
            <div class="song-empty">
                <i class="bi bi-music-note-list"></i>
                <p class="mb-0">
                    @(string.IsNullOrWhiteSpace(_searchTerm)
                        ? "No songs yet."
                        : $"No songs match “{_searchTerm}”.")
                </p>
            </div>
        }
        else
        {
            <div class="song-table-scroll @(_isPageLoading ? "is-loading" : "")">
                <table class="song-table">
                    <thead>
                        <tr>
                            <th class="st-col-check" @onclick="() => ToggleSort(SongListSortField.SongNumber)">
                                <span class="st-th st-th--center @(SortClass(SongListSortField.SongNumber))">#</span>
                            </th>
                            <th class="st-col-title" @onclick="() => ToggleSort(SongListSortField.Title)">
                                <span class="st-th @(SortClass(SongListSortField.Title))">Title</span>
                            </th>
                            <th class="st-col-meta st-col-md" @onclick="() => ToggleSort(SongListSortField.Category)">
                                <span class="st-th @(SortClass(SongListSortField.Category))">Category</span>
                            </th>
                            <th class="st-col-meta st-col-lg" @onclick="() => ToggleSort(SongListSortField.Artist)">
                                <span class="st-th @(SortClass(SongListSortField.Artist))">Artist</span>
                            </th>
                            <th class="st-col-rating st-col-sm" @onclick="() => ToggleSort(SongListSortField.Rating)">
                                <span class="st-th st-th--center @(SortClass(SongListSortField.Rating))">Rating</span>
                            </th>
                            <th class="st-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var song in _pageItems)
                        {
                            var songId = song.Id ?? string.Empty;
                            var rowSelected = IsSelected(songId);
                            <tr @key="song.Id" class="@(rowSelected ? "st-row--selected" : "")">
                                <td class="st-col-check">
                                    <button type="button"
                                            class="st-check @(rowSelected ? "st-check--on" : "")"
                                            title="@(rowSelected ? "Deselect" : "Select")"
                                            @onclick="() => ToggleSongSelection(songId)">
                                        @if (rowSelected)
                                        {
                                            <i class="bi bi-check-circle-fill"></i>
                                        }
                                        else
                                        {
                                            <span class="st-check__num">@(song.SongNumber > 0 ? song.SongNumber.ToString() : "–")</span>
                                        }
                                    </button>
                                </td>

                                <td class="st-col-title">
                                    <a class="st-title-cell"
                                       href="javascript:void(0)"
                                       title="@song.Title"
                                       @onclick="() => HandleSongClick(songId)"
                                       @onclick:preventDefault>
                                        <span class="st-title-text">@song.Title</span>
                                        @{
                                            var subArtist = song.WrittenBy ?? song.ArtistName;
                                        }
                                        @if (!string.IsNullOrWhiteSpace(subArtist))
                                        {
                                            <span class="st-title-sub d-lg-none">@subArtist</span>
                                        }
                                    </a>
                                </td>

                                <td class="st-col-meta st-col-md">
                                    @{
                                        var category = song.CategoryName ?? song.AlbumTitle;
                                    }
                                    @if (!string.IsNullOrWhiteSpace(category))
                                    {
                                        <span class="st-badge">@category</span>
                                    }
                                    else
                                    {
                                        <span class="st-muted">–</span>
                                    }
                                </td>

                                <td class="st-col-meta st-col-lg">
                                    <span class="st-artist">@(song.WrittenBy ?? song.ArtistName ?? "—")</span>
                                </td>

                                <td class="st-col-rating st-col-sm">
                                    @if (song.Rating.HasValue && song.Rating > 0)
                                    {
                                        <span class="st-rating">
                                            <i class="bi bi-star-fill"></i>
                                            <span>@song.Rating.Value.ToString("0.#")</span>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="st-muted">–</span>
                                    }
                                </td>

                                <td class="st-col-actions">
                                    @if (!IsInSelectionMode)
                                    {
                                        <span class="st-actions" @onclick:stopPropagation>
                                            <button class="row-action-btn" title="Play" @onclick="() => OnSongDisplay(songId)">
                                                <i class="bi bi-play-fill"></i>
                                            </button>
                                            <button class="row-action-btn" title="Details" @onclick="() => NavigateToDetails(songId)">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                            <button class="row-action-btn" title="Share" disabled="@isGeneratingLink" @onclick="() => ShareLink(songId)">
                                                <i class="bi bi-upload"></i>
                                            </button>
                                            @if (!string.IsNullOrEmpty(currentUserId) && song.CreatedBy == currentUserId)
                                            {
                                                <button class="row-action-btn row-action-btn--danger" title="Delete" @onclick="() => RemoveSong(songId)">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            }
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* ─────────── Pager ─────────── *@
            <div class="song-pager">
                <div class="song-pager__info">
                    @if (_isPageLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                    }
                    <span>
                        <strong>@RangeStart.ToString("N0")</strong>–<strong>@RangeEnd.ToString("N0")</strong>
                        of <strong>@_totalItems.ToString("N0")</strong>
                    </span>
                </div>

                @if (_totalPages > 1)
                {
                    <div class="song-pager__nav" role="navigation" aria-label="Pagination">
                        <button class="pager-btn" title="First page"
                                disabled="@(_currentPage <= 1 || _isPageLoading)"
                                @onclick="() => GoToPage(1)">
                            <i class="bi bi-chevron-double-left"></i>
                        </button>
                        <button class="pager-btn" title="Previous page"
                                disabled="@(_currentPage <= 1 || _isPageLoading)"
                                @onclick="() => GoToPage(_currentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>

                        @foreach (var p in GetPageWindow())
                        {
                            @if (p < 0)
                            {
                                <span class="pager-ellipsis">…</span>
                            }
                            else
                            {
                                <button class="pager-btn @(p == _currentPage ? "pager-btn--active" : "")"
                                        disabled="@_isPageLoading"
                                        @onclick="() => GoToPage(p)">
                                    @p
                                </button>
                            }
                        }

                        <button class="pager-btn" title="Next page"
                                disabled="@(_currentPage >= _totalPages || _isPageLoading)"
                                @onclick="() => GoToPage(_currentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                        <button class="pager-btn" title="Last page"
                                disabled="@(_currentPage >= _totalPages || _isPageLoading)"
                                @onclick="() => GoToPage(_totalPages)">
                            <i class="bi bi-chevron-double-right"></i>
                        </button>
                    </div>
                }

                <div class="song-pager__size">
                    <label for="st-page-size">Rows</label>
                    <select id="st-page-size" @bind="PageSize" disabled="@_isPageLoading">
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
            </div>
        }
    </div>
}
else
{
    @* ─────────── Card / grid view ─────────── *@
    @if (_isInitialLoading)
    {
        <FRELODYUI.Shared.Pages.PlaceHolders.SongListPlaceholder ActiveView="ActiveView.Collapsed" Count="6" />
    }
    else
    {
        <div class="row">
            @foreach (var song in _cardItems)
            {
                <div class="col-12 col-md-6 col-lg-4 mb-4"
                     @key="song.Id"
                     @onclick="() => HandleSongClick(song.Id ?? string.Empty)"
                     @onpointerdown="@(e => HandlePointerDown(song.Id ?? string.Empty, e))"
                     @onpointerup="HandlePointerUp"
                     @onpointercancel="HandlePointerUp"
                     @onpointerleave="HandlePointerUp"
                     style="cursor:pointer; position:relative;">
                    <div class="card h-100 shadow-sm @(IsSelected(song.Id ?? "") ? "border-success border-2" : "")"
                         style="border-radius:0.5rem">
                        @if (IsSelected(song.Id ?? ""))
                        {
                            <div class="position-absolute top-0 end-0 m-2" style="z-index:1">
                                <i class="bi bi-check-circle-fill text-success fs-4"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div class="d-flex justify-content-between mb-3">
                                <h5 class="card-title mb-3">
                                    <span>@(song.SongNumber > 0 ? song.SongNumber.ToString() : "").</span>
                                    <span class="ms-2">@song.Title</span>
                                </h5>
                                @if (!IsInSelectionMode)
                                {
                                    <span class="cursor-pointer text-muted ms-2"
                                          title="Share this song"
                                          @onclick="() => ShareLink(song.Id)"
                                          @onclick:stopPropagation
                                          disabled="@isGeneratingLink">
                                        <i class="bi bi-upload"></i>
                                    </span>
                                }
                            </div>
                            <div>
                                <span class="font-weight-light text-muted">By @(song.WrittenBy ?? song.ArtistName ?? "unknown")</span>
                            </div>
                            <div class="d-flex flex-column flex-md-row justify-content-end mt-3 gap-2">
                                <SongRating SongId="@song.Id" ShowSummary="true" ShowPanel="false" />
                                @if (!IsInSelectionMode)
                                {
                                    <div class="d-flex justify-content-center gap-2">
                                        <button class="btn btn-outline-primary btn-sm"
                                                @onclick="() => NavigateToDetails(song.Id)"
                                                @onclick:stopPropagation>
                                            <i class="bi bi-list"></i>
                                        </button>
                                        <button class="btn btn-primary btn-sm" @onclick="() => OnSongDisplay(song.Id)" @onclick:stopPropagation>
                                            <i class="bi bi-play-fill"></i>
                                        </button>
                                        @if (!string.IsNullOrEmpty(currentUserId) && song.CreatedBy == currentUserId)
                                        {
                                            <button class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => RemoveSong(song.Id)"
                                                    @onclick:stopPropagation>
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (_cardHasMore || _isCardLoadingMore)
        {
            <div class="d-flex justify-content-center my-3">
                <button type="button"
                        class="btn btn-outline-secondary btn-sm"
                        disabled="@_isCardLoadingMore"
                        @onclick="LoadMoreCardsAsync">
                    @if (_isCardLoadingMore)
                    {
                        <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                        <span>Loading…</span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-down-circle me-2"></i>
                        <span>Load more (@(_cardTotal - _cardItems.Count) left)</span>
                    }
                </button>
            </div>
        }

        @if (_cardItems.Count == 0)
        {
            <div class="text-center text-muted my-5">
                <i class="bi bi-music-note-list fs-1 d-block mb-2"></i>
                <span>No songs found.</span>
            </div>
        }
    }
}

@if (showSuccessMessage)
{
    <div class="position-absolute top-0 translate-middle-x mt-2" style="max-width:500px; z-index: 2000;">
        <div class="toast align-items-center show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @successMessage
                </div>
                <button type="button" class="btn-close me-2 m-auto" @onclick="() => showSuccessMessage = false" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public ActiveView ViewStyle { get; set; }
    [Parameter] public ViewMode ViewMode { get; set; }
    [Parameter] public EventCallback<string> OnSongLongPress { get; set; }
    [Parameter] public EventCallback OnSelectionModeChanged { get; set; }
    [Parameter] public EventCallback OnAuthenticationRequired { get; set; }
    [Parameter] public HashSet<string> SelectedSongIds { get; set; } = new();

    private string? currentUserId;
    private bool IsFromLanding = false;
    private string error = string.Empty;

    private string _searchTerm = string.Empty;
    private bool _isInitialLoading = true;
    private bool isGeneratingLink = false;
    private bool showSuccessMessage = false;
    private string successMessage = string.Empty;

    // ─────────── Table (Expanded) view state — server-side pagination ───────────
    // Only the current page is ever materialised in the DOM, so the list scales
    // to millions of songs without virtualization (and without its flicker).
    private List<SongListItemDto> _pageItems = new();
    private int _currentPage = 1;
    private int _pageSize = 25;
    private int _totalItems = 0;
    private bool _isPageLoading = false;
    private SongListSortField? _sortField = null;
    private bool _sortAsc = true;

    private int _totalPages => _totalItems <= 0 ? 0 : (int)Math.Ceiling(_totalItems / (double)_pageSize);
    private int RangeStart => _totalItems == 0 ? 0 : ((_currentPage - 1) * _pageSize) + 1;
    private int RangeEnd => Math.Min(_currentPage * _pageSize, _totalItems);

    private int PageSize
    {
        get => _pageSize;
        set
        {
            if (value == _pageSize) return;
            _pageSize = value <= 0 ? 25 : value;
            _ = LoadPageAsync(1);
        }
    }

    // Card view state
    private List<SongListItemDto> _cardItems = new();
    private int _cardOffset = 0;
    private int _cardTotal = 0;
    private bool _cardHasMore = true;
    private bool _isCardLoadingMore = false;
    private const int CardPageSize = 24;

    // Long press state (card view only)
    private System.Threading.Timer? _longPressTimer;
    private string? _currentPressedSongId;
    private bool _isLongPressTriggered = false;
    private const int LongPressDurationMs = 500;
    private bool IsInSelectionMode => SelectedSongIds?.Any() ?? false;

    protected override async Task OnInitializedAsync()
    {
        IsFromLanding = _heroDataService.GetRenderOrigin();
        var user = await _globalAuth.GetAuthenticatedUserAsync();
        if (user.IsSuccess && user.Data != null)
        {
            currentUserId = user.Data.Id;
        }

        if (ViewStyle == ActiveView.Collapsed)
        {
            await LoadInitialCardsAsync();
        }
        else
        {
            await LoadPageAsync(1);
        }
    }

    public async Task SetActiveView(ActiveView changeStyle)
    {
        if (ViewStyle == changeStyle) return;

        _isInitialLoading = true;
        ViewStyle = changeStyle;
        StateHasChanged();

        if (changeStyle == ActiveView.Collapsed)
        {
            await LoadInitialCardsAsync();
        }
        else
        {
            await LoadPageAsync(1);
        }
    }

    public async Task SearchTermChanged(string searchTerm)
    {
        _searchTerm = searchTerm ?? string.Empty;

        if (ViewStyle == ActiveView.Expanded)
        {
            await LoadPageAsync(1);
        }
        else
        {
            await LoadInitialCardsAsync();
        }
    }

    public async Task Refresh()
    {
        error = string.Empty;

        if (ViewStyle == ActiveView.Expanded)
        {
            await LoadPageAsync(_currentPage);
        }
        else
        {
            await LoadInitialCardsAsync();
        }
    }

    public async Task ExitSelectionMode()
    {
        SelectedSongIds?.Clear();
        await OnSelectionModeChanged.InvokeAsync();
        StateHasChanged();
    }

    // ─────────────────────── Table data + paging ───────────────────────

    private async Task LoadPageAsync(int page)
    {
        if (page < 1) page = 1;

        _isPageLoading = true;
        if (_pageItems.Count == 0) _isInitialLoading = true;
        StateHasChanged();

        try
        {
            var offset = (page - 1) * _pageSize;
            var sortDir = _sortAsc ? SortDirection.Asc : SortDirection.Desc;
            var (items, total) = await FetchPageAsync(offset, _pageSize, _sortField, sortDir);

            // If the requested page fell off the end (e.g. after deletes), snap to the last page.
            if (items.Count == 0 && total > 0 && page > 1)
            {
                var lastPage = (int)Math.Ceiling(total / (double)_pageSize);
                if (page > lastPage)
                {
                    await LoadPageAsync(lastPage);
                    return;
                }
            }

            _pageItems = items;
            _totalItems = total;
            _currentPage = page;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error fetching song page.");
            error = $"Error fetching songs: {ex.Message}";
        }
        finally
        {
            _isInitialLoading = false;
            _isPageLoading = false;
            StateHasChanged();
        }
    }

    private async Task GoToPage(int page)
    {
        if (page < 1) page = 1;
        if (_totalPages > 0 && page > _totalPages) page = _totalPages;
        if (page == _currentPage || _isPageLoading) return;
        await LoadPageAsync(page);
    }

    private async Task ToggleSort(SongListSortField field)
    {
        if (_isPageLoading) return;

        if (_sortField == field)
            _sortAsc = !_sortAsc;
        else
        {
            _sortField = field;
            _sortAsc = true;
        }

        await LoadPageAsync(1);
    }

    private string SortClass(SongListSortField field)
        => _sortField == field ? (_sortAsc ? "st-th--asc" : "st-th--desc") : string.Empty;

    private IEnumerable<int> GetPageWindow()
    {
        var total = _totalPages;
        if (total <= 0) yield break;

        var shown = new SortedSet<int> { 1, total };
        for (var p = _currentPage - 1; p <= _currentPage + 1; p++)
        {
            if (p >= 1 && p <= total) shown.Add(p);
        }

        var prev = 0;
        foreach (var p in shown)
        {
            if (prev != 0 && p - prev > 1) yield return -1; // ellipsis marker
            yield return p;
            prev = p;
        }
    }

    private async Task<(List<SongListItemDto> Items, int Total)> FetchPageAsync(
        int offset, int limit, SongListSortField? sortBy, SortDirection sortDir, CancellationToken ct = default)
    {
        var query = new SongListQuery
        {
            Offset = offset,
            Limit = limit <= 0 ? 10 : limit,
            Search = string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
            SortBy = sortBy,
            SortDir = sortDir,
        };

        var response = await _songsApi.GetSongList(query);
        var page = response?.Content;
        return (page?.Data ?? new List<SongListItemDto>(), page?.TotalSize ?? 0);
    }

    // ─────────────────────── Card data fetching ───────────────────────

    private async Task LoadInitialCardsAsync()
    {
        _isInitialLoading = true;
        _cardItems.Clear();
        _cardOffset = 0;
        _cardTotal = 0;
        _cardHasMore = true;
        StateHasChanged();

        await FetchCardPageAsync();

        _isInitialLoading = false;
        StateHasChanged();
    }

    private async Task LoadMoreCardsAsync()
    {
        if (_isCardLoadingMore || !_cardHasMore) return;
        await FetchCardPageAsync();
        StateHasChanged();
    }

    private async Task FetchCardPageAsync()
    {
        if (_isCardLoadingMore) return;
        _isCardLoadingMore = true;

        try
        {
            var (items, total) = await FetchPageAsync(_cardOffset, CardPageSize, sortBy: null, sortDir: SortDirection.Asc);
            if (items.Count > 0)
                _cardItems.AddRange(items);

            _cardTotal = total;
            _cardOffset = _cardItems.Count;
            _cardHasMore = _cardItems.Count < _cardTotal;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error fetching card page.");
            error = $"Error fetching songs: {ex.Message}";
            _cardHasMore = false;
        }
        finally
        {
            _isCardLoadingMore = false;
        }
    }

    // ─────────────────────── Selection / long press ───────────────────────

    private bool IsSelected(string songId) => SelectedSongIds?.Contains(songId) ?? false;

    private async Task ToggleSongSelection(string songId)
    {
        if (string.IsNullOrEmpty(songId)) return;

        // Auth gate matches long-press behaviour
        if (string.IsNullOrEmpty(currentUserId))
        {
            await OnAuthenticationRequired.InvokeAsync();
            return;
        }

        await OnSongLongPress.InvokeAsync(songId);
        await OnSelectionModeChanged.InvokeAsync();
        StateHasChanged();
    }

    private void HandlePointerDown(string songId, PointerEventArgs e)
    {
        _currentPressedSongId = songId;
        _isLongPressTriggered = false;
        _longPressTimer?.Dispose();
        _longPressTimer = new System.Threading.Timer(
            _ => InvokeAsync(() => TriggerLongPress(songId)),
            null,
            LongPressDurationMs,
            Timeout.Infinite);
    }

    private void HandlePointerUp()
    {
        _longPressTimer?.Dispose();
        _longPressTimer = null;
        _currentPressedSongId = null;
    }

    private async Task TriggerLongPress(string songId)
    {
        if (_currentPressedSongId != songId) return;

        _isLongPressTriggered = true;

        if (string.IsNullOrEmpty(currentUserId))
        {
            await OnAuthenticationRequired.InvokeAsync();
            HandlePointerUp();
            _isLongPressTriggered = false;
            return;
        }

        await OnSongLongPress.InvokeAsync(songId);
        await OnSelectionModeChanged.InvokeAsync();
        HandlePointerUp();
    }

    private async Task HandleSongClick(string songId)
    {
        if (string.IsNullOrEmpty(songId)) return;

        // Give the long-press timer a chance to fire first (card view)
        await Task.Delay(50);

        if (_isLongPressTriggered)
        {
            _isLongPressTriggered = false;
            return;
        }

        if (IsInSelectionMode)
        {
            await ToggleSongSelection(songId);
        }
        else
        {
            OnSongDisplay(songId);
        }
    }

    // ─────────────────────── Actions ───────────────────────

    private void NavigateToDetails(string? id)
    {
        if (string.IsNullOrEmpty(id)) return;
        _navManager.NavigateTo($"/player/details/{id}");
    }

    private void OnSongDisplay(string? songId)
    {
        if (string.IsNullOrEmpty(songId) || IsInSelectionMode) return;

        try
        {
            _ = Task.Run(async () =>
            {
                try
                {
                    await _storageService.SetItemAsync("ActiveView", ViewStyle);
                    await _storageService.SetItemAsync("ViewMode", ViewMode);
                    await _playHistoryApi.LogSongPlay(songId, "SongList");
                }
                catch (Exception ex)
                {
                    _logger.LogWarning(ex, "Failed to log song play from list for song {SongId}", songId);
                }
            });

            _navManager.NavigateTo(IsFromLanding ? $"/songs/landing/{songId}" : $"/songs/{songId}");
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error navigating to song.");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "An error occurred while trying to display the song.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
    }

    private void RemoveSong(string? songId)
    {
        if (string.IsNullOrEmpty(songId)) return;

        _modalService.Show(new ModalOptionDto
        {
            Title = "Delete Song",
            Message = "Are you sure you want to delete this song?",
            DangerText = "This action cannot be undone.",
            ButtonText = "Delete",
            OptionType = OptionType.Confirmation,
            Context = new ModalContext { ActionType = "DeleteSong", Data = songId },
            OnConfirmCallback = async () =>
            {
                var response = await _songsApi.DeleteSong(songId);
                if (response.IsSuccessStatusCode)
                {
                    await Refresh();
                }
                else
                {
                    var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                    _modalService.Show(new ModalOptionDto
                    {
                        Title = "Error Deleting Song",
                        Message = errorMessage,
                        ButtonText = "Close",
                        OptionType = OptionType.Error
                    });
                }
            }
        });
    }

    private async Task ShareLink(string? songId)
    {
        if (string.IsNullOrEmpty(songId)) return;

        isGeneratingLink = true;
        StateHasChanged();

        try
        {
            var url = IsFromLanding
                ? _navManager.ToAbsoluteUri($"/songs/landing/{songId}").ToString()
                : _navManager.ToAbsoluteUri($"/songs/{songId}").ToString();
            await _clipboardService.CopyToClipboardAsync(url);
            await ShowSuccessMessage("Share link copied to clipboard!");
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error copying share link for song {SongId}", songId);
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "An error occurred while copying the share link.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
        finally
        {
            isGeneratingLink = false;
            StateHasChanged();
        }
    }

    private async Task ShowSuccessMessage(string message)
    {
        successMessage = message;
        showSuccessMessage = true;
        StateHasChanged();

        await Task.Delay(3000);
        showSuccessMessage = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        _longPressTimer?.Dispose();
    }
}
