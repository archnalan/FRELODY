@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject ILogger<SongList> _logger
@implements IDisposable

@if (_isTransitioning)
{
    <FRELODYUI.Shared.Pages.PlaceHolders.SongListPlaceholder ActiveView="ViewStyle" ShowHeader="true" Count="@(ViewStyle == ActiveView.Expanded ? 8 : 6)" />
}
else
{
    <div class="@(ViewStyle == ActiveView.Expanded ? "song-table-card" : "")">
    @if (ViewStyle == ActiveView.Expanded)
    {
        <div class="song-table-header">
            <span class="song-row__num">#</span>
            <span class="song-row__title">Title</span>
            <span class="song-row__meta d-none d-md-flex">Category</span>
            <span class="song-row__meta d-none d-lg-flex">Artist</span>
            <span class="song-row__rating d-none d-sm-flex">Rating</span>
            <span class="song-row__actions"></span>
        </div>
    }

    @* Shimmer overlay: stays visible until first data batch arrives *@
    @if (_isLoadingData)
    {
        <div class="song-loading-overlay">
            <FRELODYUI.Shared.Pages.PlaceHolders.SongListPlaceholder ActiveView="ViewStyle" Count="@(ViewStyle == ActiveView.Expanded ? 8 : 6)" />
        </div>
    }

    <div class="@(ViewStyle == ActiveView.Collapsed ? "row" : "")" style="@(_isLoadingData ? "height:0;overflow:hidden" : "")">
    <Virtualize @key="RefreshKey" 
                Context="song"
                ItemsProvider="ProvideSongsAsync"
                ItemSize="@(ViewStyle == ActiveView.Expanded ? 56 : 170)"
                OverscanCount="3"
                @ref="_virtualize">
        <ItemContent>
            @if (ViewStyle == ActiveView.Expanded)
            {
            <!-- ── List / tabular row ── -->
            <div class="song-row @(IsSelected(song.Id ?? "") ? "song-row--selected" : "")"
                 @onclick="@(() => HandleSongClick(song.Id ?? ""))"
                 @onpointerdown="@(e => HandlePointerDown(song.Id ?? "", e))"
                 @onpointerup="@(() => HandlePointerUp())"
                 @onpointercancel="@(() => HandlePointerUp())"
                 @onpointerleave="@(() => HandlePointerUp())">

                @if (IsSelected(song.Id ?? ""))
                {
                    <span class="song-row__check"><i class="bi bi-check-circle-fill text-success"></i></span>
                }
                else
                {
                    <span class="song-row__num">@(song.SongNumber > 0 ? song.SongNumber.ToString() : "–")</span>
                }

                <span class="song-row__title" title="@song.Title">@song.Title</span>

                <span class="song-row__meta d-none d-md-flex" title="@(song.CategoryName ?? song.AlbumTitle ?? "–")">
                    @(song.CategoryName ?? song.AlbumTitle ?? "–")
                </span>

                <span class="song-row__meta d-none d-lg-flex" title="@(song.WrittenBy ?? song.ArtistName ?? "–")">
                    @(song.WrittenBy ?? song.ArtistName ?? "–")
                </span>

                <span class="song-row__rating d-none d-sm-flex">
                    @if (song.Rating.HasValue && song.Rating > 0)
                    {
                        <i class="bi bi-star-fill"></i>
                        <span>@song.Rating.Value.ToString("0.#")</span>
                    }
                    else
                    {
                        <span class="text-muted">–</span>
                    }
                </span>

                @if (!IsInSelectionMode)
                {
                    <span class="song-row__actions" @onclick:stopPropagation>
                        <button class="row-action-btn" title="Play" @onclick="@(() => OnSongDisplay(song.Id))">
                            <i class="bi bi-play-fill"></i>
                        </button>
                        <button class="row-action-btn" title="Details" @onclick="@(() => NavigateToDetails(song.Id))">
                            <i class="bi bi-info-circle"></i>
                        </button>
                        <button class="row-action-btn" title="Share" @onclick="@(() => ShareLink(song.Id))" disabled="@isGeneratingLink">
                            <i class="bi bi-upload"></i>
                        </button>
                        @if (!string.IsNullOrEmpty(currentUserId) && song.CreatedBy == currentUserId)
                        {
                            <button class="row-action-btn row-action-btn--danger" title="Delete" @onclick="@(() => RemoveSong(song.Id))">
                                <i class="bi bi-trash3"></i>
                            </button>
                        }
                    </span>
                }
            </div>
        }
        else
        {
            <!-- ── Grid / card view ── -->
            <div class="col-12 col-md-6 col-lg-4 mb-4"
                 @onclick="@(() => HandleSongClick(song.Id ?? ""))"
                 @onpointerdown="@(e => HandlePointerDown(song.Id ?? "", e))"
                 @onpointerup="@(() => HandlePointerUp())"
                 @onpointercancel="@(() => HandlePointerUp())"
                 @onpointerleave="@(() => HandlePointerUp())"
                 style="cursor:pointer; position:relative;">
                <div class="card h-100 shadow-sm @(IsSelected(song.Id ?? "") ? "border-success border-2" : "")"
                     style="border-radius:0.5rem">
                    @if (IsSelected(song.Id ?? ""))
                    {
                        <div class="position-absolute top-0 end-0 m-2" style="z-index:1">
                            <i class="bi bi-check-circle-fill text-success fs-4"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div class="d-flex justify-content-between mb-3">
                            <h5 class="card-title mb-3">
                                <span>@(song.SongNumber > 0 ? song.SongNumber.ToString() : "").</span>
                                <span class="ms-2">@song.Title</span>
                            </h5>
                            @if (!IsInSelectionMode)
                            {
                                <span class="cursor-pointer text-muted ms-2"
                                      title="Share this song"
                                      @onclick="() => ShareLink(song.Id)"
                                      @onclick:stopPropagation
                                      disabled="@isGeneratingLink">
                                    <i class="bi bi-upload"></i>
                                </span>
                            }
                        </div>
                        <div>
                            <span class="font-weight-light text-muted">By @(song.WrittenBy ?? song.ArtistName ?? "unknown")</span>
                        </div>
                        <div class="d-flex flex-column flex-md-row justify-content-end mt-3 gap-2">
                            <SongRating SongId="@song.Id" ShowSummary="true" ShowPanel="false" />
                            @if (!IsInSelectionMode)
                            {
                                <div class="d-flex justify-content-center gap-2">
                                    <button class="btn btn-outline-primary btn-sm"
                                            @onclick="() => NavigateToDetails(song.Id)"
                                            @onclick:stopPropagation>
                                        <i class="bi bi-list"></i>
                                    </button>
                                    <button class="btn btn-primary btn-sm" @onclick="@(() => OnSongDisplay(song.Id))"><i class="bi bi-play-fill"></i></button>
                                    @if (!string.IsNullOrEmpty(currentUserId) && song.CreatedBy == currentUserId)
                                    {
                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick="() => RemoveSong(song.Id)"
                                                @onclick:stopPropagation>
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </ItemContent>
    <Placeholder>
        <FRELODYUI.Shared.Pages.PlaceHolders.SongListPlaceholder ActiveView="ViewStyle" IsSingleItem="true" />
    </Placeholder>
</Virtualize>
    </div>
    </div>
}

@if (showSuccessMessage)
{
    <div class="position-absolute top-0 translate-middle-x mt-2" style="max-width:500px; z-index: 2000;">
        <div class="toast align-items-center show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @successMessage
                </div>
                <button type="button" class="btn-close me-2 m-auto" @onclick="() => showSuccessMessage = false" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<DialogModal IsVisible="_modalService.IsModalVisible"
             Modal="@_modalService.CurrentModal"
             OnCloseModal="CloseModal"
             OnConfirmModal="ConfirmModal" />

@code {
    [Parameter] public ActiveView ViewStyle { get; set; }
    [Parameter]public ViewMode ViewMode { get; set; }
    [Parameter] public EventCallback<string> OnSongLongPress { get; set; }
    [Parameter] public EventCallback OnSelectionModeChanged { get; set; }
    [Parameter] public EventCallback OnAuthenticationRequired { get; set; }
    [Parameter] public HashSet<string> SelectedSongIds { get; set; } = new();

    private string error = string.Empty;
    private bool IsNavigating = false;
    private bool IsFromLanding = false;
    private string? currentUserId;

    private string _searchTerm = string.Empty;
    private string RefreshKey = Guid.NewGuid().ToString();

    private Virtualize<SongListItemDto>? _virtualize;
    private bool isGeneratingLink = false;
    private bool isLoading = false;
    private bool showSuccessMessage = false;
    private string successMessage = string.Empty;

    // Long press state
    private System.Threading.Timer? _longPressTimer;
    private string? _currentPressedSongId;
    private bool _isLongPressTriggered = false;
    private const int LongPressDurationMs = 500;
    private bool IsInSelectionMode => SelectedSongIds?.Any() ?? false;

    protected override async Task OnInitializedAsync()
    {
        IsFromLanding = _heroDataService.GetRenderOrigin();
        var user = await _globalAuth.GetAuthenticatedUserAsync();
        if (user.IsSuccess && user.Data != null)
        {
            currentUserId = user.Data.Id;
        }
    }

    private bool _isTransitioning = false;
    private bool _isLoadingData = true;

    public async Task SetActiveView(ActiveView changeStyle)
    {
        if (ViewStyle == changeStyle) return;
        _isTransitioning = true;
        ViewStyle = changeStyle;
        StateHasChanged();
        await Task.Delay(80);
        _isLoadingData = true;
        RefreshKey = Guid.NewGuid().ToString();
        _isTransitioning = false;
        StateHasChanged();
    }

    private bool IsSelected(string songId) => SelectedSongIds?.Contains(songId) ?? false;

    private void HandlePointerDown(string songId, PointerEventArgs e)
    {
        _currentPressedSongId = songId;
        _isLongPressTriggered = false;
        _longPressTimer?.Dispose();
        _longPressTimer = new System.Threading.Timer(
            _ => InvokeAsync(() => TriggerLongPress(songId)),
            null,
            LongPressDurationMs,
            Timeout.Infinite
        );
    }

    private void HandlePointerUp()
    {
        _longPressTimer?.Dispose();
        _longPressTimer = null;
        _currentPressedSongId = null;
    }

    private async Task TriggerLongPress(string songId)
    {
        if (_currentPressedSongId == songId)
        {
            _isLongPressTriggered = true;

            // Check if user is authenticated before allowing selection
            if (string.IsNullOrEmpty(currentUserId))
            {
                await OnAuthenticationRequired.InvokeAsync();
                _longPressTimer?.Dispose();
                _longPressTimer = null;
                _isLongPressTriggered = false;
                return;
            }

            await OnSongLongPress.InvokeAsync(songId);
            await OnSelectionModeChanged.InvokeAsync();
            _longPressTimer?.Dispose();
            _longPressTimer = null;
        }
    }

    private async Task HandleSongClick(string songId)
    {
        // Wait a bit to see if this was a long press
        await Task.Delay(50);

        // If long press was triggered, ignore the click
        if (_isLongPressTriggered)
        {
            _isLongPressTriggered = false;
            return;
        }

        // If we're in selection mode, toggle selection
        if (IsInSelectionMode)
        {
            await ToggleSongSelection(songId);
        }
        else
        {
            // Normal behavior - navigate to song
            OnSongDisplay(songId);
        }
    }

    private async Task ToggleSongSelection(string songId)
    {
        await OnSongLongPress.InvokeAsync(songId);
        
        // If all songs are deselected, exit selection mode
        if (!IsInSelectionMode)
        {
            await OnSelectionModeChanged.InvokeAsync();
        }
        
        StateHasChanged();
    }

    public async Task ExitSelectionMode()
    {
        SelectedSongIds?.Clear();
        await OnSelectionModeChanged.InvokeAsync();
        StateHasChanged();
    }

    private async ValueTask<ItemsProviderResult<SongListItemDto>> ProvideSongsAsync(ItemsProviderRequest request)
    {
        try
        {
            error = string.Empty;

            var offset = request.StartIndex;
            var limit = request.Count <= 0 ? 10 : request.Count;

            if (!string.IsNullOrWhiteSpace(_searchTerm))
            {
                var response = await _songsApi.SearchSongList(_searchTerm, offset, limit);
                var page = response?.Content;
                var items = page?.Data ?? new List<SongListItemDto>();
                var total = page?.TotalSize ?? 0;

                if (offset == 0 && _isLoadingData)
                {
                    _isLoadingData = false;
                    await InvokeAsync(StateHasChanged);
                }

                return new ItemsProviderResult<SongListItemDto>(items, total);
            }
            else
            {
                var response = await _songsApi.GetSongList(offset, limit);
                var page = response?.Content;
                var items = page?.Data ?? new List<SongListItemDto>();
                var total = page?.TotalSize ?? 0;

                if (offset == 0 && _isLoadingData)
                {
                    _isLoadingData = false;
                    await InvokeAsync(StateHasChanged);
                }

                return new ItemsProviderResult<SongListItemDto>(items, total);
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error fetching songs during virtualization.");
            error = $"Error fetching songs: {ex.Message}";
            _isLoadingData = false;
            return new ItemsProviderResult<SongListItemDto>(Array.Empty<SongListItemDto>(), 0);
        }
    }

    private void RemoveSong(string? songId)
    {
        if(!string.IsNullOrEmpty(songId))
        {
            _modalService.Show(new ModalOptionDto
            {
                Title = "Delete Song",
                Message = "Are you sure you want to delete this song?",
                DangerText = "This action cannot be undone.",
                ButtonText = "Delete",
                OptionType = OptionType.Confirmation,
                Context = new ModalContext { ActionType = "DeleteSong", Data = songId }
            });
        }         
    }

    public async Task SearchTermChanged(string searchTerm)
    {
        _searchTerm = searchTerm;
        _isLoadingData = true;
        RefreshKey = Guid.NewGuid().ToString();
        await Task.CompletedTask;
        StateHasChanged();
    }

    private async Task Refresh()
    {
        error = string.Empty;
        if (_virtualize is not null)
            await _virtualize.RefreshDataAsync();
    }

    private void NavigateToDetails(string id)
    {
        _navManager.NavigateTo($"/player/details/{id}");
    }

    private void NavigateToPlay(string id)
    {
        _navManager.NavigateTo($"/player/{id}");
    }

    private void OnSongDisplay(string songId)
    {
        // Don't navigate if there are selected songs (we're in selection mode)
        if (IsInSelectionMode) return;

        try
        {
            IsNavigating = true;
            StateHasChanged();
            // Log the song play from list (fire and forget)
            _ = Task.Run(async () =>
          {
              try
              {
                  await _storageService.SetItemAsync("ActiveView", ViewStyle);
                  await _storageService.SetItemAsync("ViewMode", ViewMode);
                  await _playHistoryApi.LogSongPlay(songId, "SongList");
              }
              catch (Exception ex)
              {
                  _logger.LogWarning(ex, "Failed to log song play from list for song {SongId}", songId);
              }
          });
            if (IsFromLanding)
            {
                _navManager.NavigateTo($"/songs/landing/{songId}");
            }
            else
            {
                _navManager.NavigateTo($"/songs/{songId}");                
            }
        }
        catch (Exception ex)
        {
            _logger.LogError($"Error navigating to song: {ex.Message}");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "An error occurred while trying to display the song.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
        finally
        {
            IsNavigating = false;
            StateHasChanged();
        }
    }
    
    private async Task ShareLink(string songId)
    {
        isGeneratingLink = true;
        StateHasChanged();

        try
        {
            var shareLink = await _shareService.GenerateShareLinkAsync(songId);
            if (shareLink != null)
            {
                await _clipboardService.CopyToClipboardAsync(shareLink.ShareUrl);
                await ShowSuccessMessage("Share link copied to clipboard!");
            }
            else
            {
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Share Link Error",
                    Message = "Failed to generate share link. Please try again later.",
                    ButtonText = "Close",
                    OptionType = OptionType.Error,
                    Context = new ModalContext
                    {
                        ActionType = "GenerateShareLink",
                        Data = "Share link generation failed for song ID: " + songId
                    }
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error generating share link for song {SongId}", songId);
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "An error occurred while generating the share link.",
                ButtonText = "Close",
                OptionType = OptionType.Error,
                Context = new ModalContext
                {
                    ActionType = "GenerateShareLink",
                    Data = ex.Message
                }
            });
        }
        finally
        {
            isGeneratingLink = false;
            StateHasChanged();
        }
    }
    
    private async Task ShowSuccessMessage(string message)
    {
        successMessage = message;
        showSuccessMessage = true;
        StateHasChanged();

        // Auto-hide after 3 seconds
        await Task.Delay(3000);
        showSuccessMessage = false;
        StateHasChanged();
    }

    private async Task ConfirmModal()
    {
        if (_modalService.CurrentModal?.Context?.ActionType == "DeleteSong")
        {
            var response = await _songsApi.DeleteSong(_modalService.CurrentModal.Context.Data?.ToString() ?? string.Empty);

            if(response.IsSuccessStatusCode)
            {
                await Refresh();
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error Deleting Song",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        else
        {
            _modalService.Close();
        }
        await CloseModal();
    }

    private async Task CloseModal()
    {
        await Task.Delay(100);
        _modalService.Close();
        StateHasChanged();
    }

    public void Dispose()
    {
        _longPressTimer?.Dispose();
    }
}
