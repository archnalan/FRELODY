    {
        _toastService.OnToast -= OnToastChanged;
        chordScale = null;
        originalChords = null;
        autoScrollTimer?.Dispose();
        popoverTimer?.Dispose();
        _chartRefetchCts?.Cancel();
        _chartRefetchCts?.Dispose();
        autoScrollTimer = null;
        popoverTimer = null;
        dotNetRef?.Dispose();
        try { JsRt.InvokeVoidAsync("songFullscreen.dispose"); } catch { }
    }
