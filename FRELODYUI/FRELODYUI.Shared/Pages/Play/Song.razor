@using FRELODYSHRD.Dtos.SubDtos
@using FRELODYUI.Shared.Pages.Chord
@using FRELODYUI.Shared.Pages.Play.Components
@inject ILogger<Song> _logger
@implements IDisposable

<div class="song-container" @ref="songContainerRef">
    @if (!isLoading && song != null && !isFullscreen)
    {
        <!-- Header: back, title, share -->
        <div class="song-header">
            <button class="header-action-btn back-btn" @onclick="GoBack" title="Go back">
                <i class="bi bi-chevron-left"></i>
            </button>

            <div class="song-title-section" style="font-family:@fontFamily">
                <div class="song-title-wrapper">
                    @if (song.SongNumber.HasValue)
                    {
                        <span class="song-number">#@song.SongNumber.Value.ToString("D3")</span>
                    }
                    <h1 class="song-title">@song.Title</h1>
                </div>
                <SongRating SongId="@SongId" ShowSummary="true" ShowPanel="false" />
            </div>

            <div class="header-actions">
                <div class="dropdown">
                    <button class="btn btn-primary dropdown-toggle"
                            type="button"
                            id="shareDropdownButton"
                            @onclick="ToggleDropdown"
                            aria-expanded="@showShareDropdown"
                            title="Share">
                        <i class="bi bi-upload me-1"></i>
                        <span class="d-none d-sm-inline">Share</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end @(showShareDropdown ? "show" : "")"
                         aria-labelledby="shareDropdownButton">
                        <ShareDropdown Song="song"
                                       ShareLinkUrl="@shareLinkUrl"
                                       OnActionCompleted="CloseShareDropdown"
                                       OnCustomizeSong="(songId) => CustomizeSong(songId)" />
                    </div>
                </div>
            </div>
        </div>

        @if (showShareDropdown)
        {
            <button class="share-dropdown-backdrop"
                    type="button"
                    aria-label="Close share menu"
                    @onclick="CloseShareDropdown"></button>
        }
    }

    <!-- Main Playback Area — always rendered so the fullscreen element stays in DOM during song loads -->
    <div class="song-playback-area @(isFullscreen ? "playback-fullscreen" : "")" @ref="songContentRef">
        @if (isLoading)
        {
            <div class="ssm-loading-inline">
                <div class="spinner-border text-primary" role="status"></div>
                <p>Loading song...</p>
            </div>
        }
        else if (song != null)
        {
            <!-- Sticky Controls Bar -->
            <div class="controls-bar">
                <div class="controls-bar-inner">
                    @* Song title — shown only in fullscreen, before the control groups *@
                    @if (isFullscreen && song != null)
                    {
                        <div class="cb-song-title my-2" title="@song.Title">
                            @if (song.SongNumber.HasValue)
                            {
                                <span class="cb-song-number">#@song.SongNumber.Value.ToString("D3")</span>
                            }
                            <span class="cb-song-name">@song.Title</span>
                        </div>
                        <div class="control-separator"></div>
                    }

                    <!-- Autoscroll -->
                    <div class="control-group">
                        <button class="control-action-btn @(isAutoScrolling ? "active" : "")"
                                @onclick="ToggleAutoScroll"
                                title="@(isAutoScrolling ? "Stop autoscroll" : "Start autoscroll")">
                            <i class="bi bi-@(isAutoScrolling ? "pause-fill" : "play-fill")"></i>
                        </button>
                        <div class="control-wrapper">
                            <label class="control-label">Scroll</label>
                            <div class="control-buttons">
                                <button class="control-btn" @onclick="() => AdjustScrollSpeed(-0.5)" disabled="@(scrollSpeed <= 0)">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <span class="control-value">@scrollSpeed.ToString("0.0")</span>
                                <button class="control-btn" @onclick="() => AdjustScrollSpeed(0.5)" disabled="@(scrollSpeed >= 5)">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    @if (songDisplayMode != SongDisplay.LyricsOnly && originalChords != null && originalChords.Length > 0)
                    {
                        <div class="control-separator"></div>

                        <!-- Transpose -->
                        <div class="control-group">
                            <button class="control-reset-btn" @onclick="ResetTranspose" title="Reset transpose">
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </button>
                            <div class="control-wrapper">
                                <label class="control-label">Transpose</label>
                                <div class="control-buttons">
                                    <button class="control-btn" @onclick="DecreaseTranspose" disabled="@(transpose <= -12)">
                                        <i class="bi bi-dash"></i>
                                    </button>
                                    <span class="control-value">@transpose</span>
                                    <button class="control-btn" @onclick="IncreaseTranspose" disabled="@(transpose >= 12)">
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Capo -->
                        <div class="control-group">
                            <div class="control-wrapper">
                                <label class="control-label">Capo</label>
                                <div class="control-buttons">
                                    <button class="control-btn" @onclick="DecreaseCapo" disabled="@(capo <= 0)">
                                        <i class="bi bi-dash"></i>
                                    </button>
                                    <span class="control-value">@capo</span>
                                    <button class="control-btn" @onclick="IncreaseCapo" disabled="@(capo >= 12)">
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </div>
                            </div>
                            <button class="control-reset-btn" @onclick="ResetCapo" title="Reset capo">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                        </div>
                    }

                    <div class="control-separator d-none d-sm-block"></div>

                </div>
                <!-- Right-side actions -->
                <div class="controls-bar-actions">
                    <button class="control-action-btn" @onclick="ToggleSettingsDropdown"
                            title="Display settings">
                        <i class="bi bi-@(showSettingsDropdown ? "x-lg" : "sliders")"></i>
                    </button>
                    @if (isFullscreen)
                    {
                        <button class="control-action-btn" @onclick="ExitFullscreen" title="Exit fullscreen">
                            <i class="bi bi-fullscreen-exit"></i>
                        </button>
                    }
                    else
                    {
                        <button class="control-action-btn" @onclick="EnterFullscreen" title="Fullscreen">
                            <i class="bi bi-arrows-fullscreen"></i>
                        </button>
                    }
                </div>

                @if (showSettingsDropdown)
                {
                    <div class="settings-palette" @ref="settingsPaletteRef">
                        <SongSettings UserId="@currentUserId"
                                      SongId="@SongId"
                                      OnSettingsChanged="OnSettingsPreview"
                                      OnScrollSpeedChanged="OnScrollSpeedPreview"
                                      OnSettingsSaved="OnSettingsSaved"
                                      OnClose="CloseSettingsDropdown" />
                    </div>
                }
            </div>

            <!-- Wrapper is position:relative so FABs (position:absolute; bottom/right) anchor to
             the content height in both normal and fullscreen scroll modes. -->
            <div class="song-scroll-body">

                <!-- Chord Charts Section -->
                @if (!isFullscreen && showCharts && uniqueSongChords.Any() && songDisplayMode != SongDisplay.LyricsOnly)
                {
                    <div class="chord-charts-section">
                        <div class="chord-charts-header">
                            <h5 class="chord-charts-title">
                                <i class="bi bi-music-note-list"></i>
                                Song Chords
                                <span class="chord-count-badge">@uniqueSongChords.Count</span>
                            </h5>
                            <button class="toggle-grid-btn" @onclick="ToggleChordGrid"
                                    title="@(showChordGrid ? "Show slider" : "Show all")">
                                <i class="bi bi-@(showChordGrid ? "list" : "grid-3x3")"></i>
                            </button>
                        </div>

                        @if (isRefetchingCharts)
                        {
                            @if (showChordGrid)
                            {
                                <div class="chord-charts-grid">
                                    @for (int g = 0; g < uniqueSongChords.Count; g++)
                                    {
                                        <div class="chord-chart-card">
                                            <div class="chord-chart-name-ghost"></div>
                                            <ChordCarousel IsLoading="true"
                                                           Size="CarouselSize.Medium"
                                                           ShowActions="false"
                                                           CarouselId="@($"ghost-carousel-{g}")" />
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="chord-charts-slider">
                                    <button class="slider-nav-btn slider-prev" disabled>
                                        <i class="bi bi-chevron-left"></i>
                                    </button>
                                    <div class="chord-charts-track">
                                        @for (int g = 0; g < uniqueSongChords.Count; g++)
                                        {
                                            <div class="chord-chart-card">
                                                <div class="chord-chart-name-ghost"></div>
                                                <ChordCarousel IsLoading="true"
                                                               Size="CarouselSize.Medium"
                                                               ShowActions="false"
                                                               CarouselId="@($"ghost-carousel-{g}")" />
                                            </div>
                                        }
                                    </div>
                                    <button class="slider-nav-btn slider-next" disabled>
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                </div>
                            }
                        }
                        else if (showChordGrid)
                        {
                            <div class="chord-charts-grid">
                                @foreach (var chord in transposedChords)
                                {
                                    <div class="chord-chart-card" @key="chord.Id ?? chord.ChordName">
                                        <h6 class="chord-chart-name">@chord.ChordName</h6>
                                        <ChordCarousel Chord="@chord"
                                                       Size="CarouselSize.Medium"
                                                       ShowActions="false"
                                                       CarouselId="@($"inline-carousel-{chord.Id ?? chord.ChordName}")" />
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="chord-charts-slider">
                                <button class="slider-nav-btn slider-prev" @onclick="ScrollChartsLeft"
                                        disabled="@(chordScrollPosition <= 0)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <div class="chord-charts-track" @ref="chordChartsTrackRef">
                                    @foreach (var chord in transposedChords)
                                    {
                                        <div class="chord-chart-card" @key="chord.Id ?? chord.ChordName">
                                            <h6 class="chord-chart-name">@chord.ChordName</h6>
                                            <ChordCarousel Chord="@chord"
                                                           Size="CarouselSize.Medium"
                                                           ShowActions="false"
                                                           CarouselId="@($"inline-carousel-{chord.Id ?? chord.ChordName}")" />
                                        </div>
                                    }
                                </div>
                                <button class="slider-nav-btn slider-next" @onclick="ScrollChartsRight">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        }
                    </div>
                }

                <!-- Song Content -->
                <div class="song-content" style="@GetSongContentStyle()">
                    @if (song.SongParts?.Any() == true)
                    {
                        foreach (var verse in song.SongParts.OrderBy(v => v.PartNumber))
                        {
                            <div class="verse-section">
                                @if (showVerseTitles)
                                {
                                    <h4 class="verse-title">
                                        Verse @verse.PartNumber.ToString("D2")
                                    </h4>
                                }
                                @if (verse.LyricLines?.Any() == true)
                                {
                                    foreach (var line in verse.LyricLines.OrderBy(l => l.LyricLineOrder))
                                    {
                                        <div class="lyric-line">
                                            @if (line.LyricSegments?.Any() == true)
                                            {
                                                foreach (var segment in line.LyricSegments.OrderBy(s => s.LyricOrder))
                                                {
                                                    <div class="lyric-segment @GetChordDisplayClass()">
                                                        @if (segment.Chord != null &&
                                                            (songDisplayMode == SongDisplay.LyricsAndChords
                                                            || songDisplayMode == SongDisplay.LyricsAndChordsAndCharts))
                                                        {
                                                            <span class="chord @GetChordAlignmentClass(segment)"
                                                                  style="@GetChordStyle()"
                                                                  @onmouseenter="(e) => ShowChordPopover(segment.Chord, e)"
                                                                  @onmouseleave="HandleChordMouseLeave">
                                                                @GetTransposedChordName(segment.Chord.ChordName)
                                                            </span>
                                                        }
                                                        <span class="lyric" style="@GetLyricStyle()">
                                                            @segment.Lyric
                                                        </span>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                    }
                </div>

                <!-- Song Search FAB — visible in both normal and fullscreen -->
                <button class="search-fab" @onclick="OpenSongSearch" title="Search songs">
                    <i class="bi bi-search"></i>
                </button>

                @if (!isFullscreen)
                {
                    <button class="maximize-fab" @onclick="EnterFullscreen" title="Enter fullscreen">
                        <i class="bi bi-arrows-fullscreen"></i>
                    </button>
                }
            </div> @* close song-scroll-body *@

            <!-- Chord Popover (outside song-scroll-body so position:absolute stays relative to song-playback-area) -->
            @if (showChordPopover && hoveredChord != null)
            {
                <div class="chord-popover-overlay"
                     style="top: @(popoverTop)px; left: @(popoverLeft)px;"
                     @onmouseenter="() => isMouseOverPopover = true"
                     @onmouseleave="HideChordPopover">
                    <div class="chord-popover-content">
                        <ChordCarousel Chord="@hoveredChord"
                                       Size="CarouselSize.Popover"
                                       ShowActions="false"
                                       CarouselId="@($"popover-carousel-{hoveredChord.Id}")" />
                    </div>
                </div>
            }
        }
        @* end song != null — SongSearchModal and toast stay outside so they persist through loads *@

        <!-- Song Search Modal — always in DOM so it survives song loads in fullscreen -->
        <SongSearchModal @ref="_songSearchModal" OnSongSelected="NavigateToSong" />

        <!-- Fullscreen Toast Portal
             Rendered inside song-playback-area so it appears within the native Fullscreen API layer.
             position:fixed children of a fullscreen element position relative to the fullscreen viewport. -->
        @if (isFullscreen && _toastService.IsVisible)
        {
            <div class="toast-container position-fixed top-0 start-50 translate-middle-x pt-2" style="z-index: 99999;">
                <div class="toast align-items-center text-bg-@ToastBsClass() border-0 show"
                     role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body d-flex align-items-center gap-2">
                            <i class="bi @ToastIcon()"></i>
                            @_toastService.Message
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto"
                                @onclick="_toastService.Hide" aria-label="Close"></button>
                    </div>
                </div>
            </div>
        }
    </div> @* Close song-playback-area *@

    @if (!isLoading && song != null && !isFullscreen)
    {
        <div class="song-rating">
            <SongRating SongId="@SongId" ShowSummary="false" ShowPanel="true" />
        </div>
    }
</div>

@if (_modalService.IsModalVisible)
{
    <DialogModal IsVisible="true"
                 Modal="@_modalService.CurrentModal"
                 OnCloseModal="CloseModal"
                 OnConfirmModal="ConfirmModal" />
}

@code {
    [Parameter] public string SongId { get; set; } = string.Empty;

    private SongSearchModal? _songSearchModal;
    private async Task OpenSongSearch() { if (_songSearchModal != null) await _songSearchModal.Open(); }
    private void NavigateToSong(string songId)
    {
        var isLanding = _navManager.Uri.Contains("/landing/", StringComparison.OrdinalIgnoreCase);
        var path = isLanding ? $"/songs/landing/{songId}" : $"/songs/{songId}";
        _navManager.NavigateTo(path);
    }

    private SongDto? song;
    private bool isLoading = true;
    private string? loadedSongId;
    private DotNetObjectReference<Song>? dotNetRef;
    private int transpose = 0;
    private int capo = 0;
    private Dictionary<string, int>? chordScale;
    private string[]? originalChords;
    private string? currentUserId;
    private ElementReference songContainerRef;
    private ElementReference chordChartsTrackRef;
    private string shareLinkUrl = string.Empty;

    // Display Settings
    private bool showSettingsDropdown = false;
    private int chordFontSize = 14;
    private int lyricFontSize = 18;
    private string fontFamily = "system-ui, -apple-system, 'Montserrat', Roboto, sans-serif";
    private SongDisplay songDisplayMode = SongDisplay.LyricsAndChordsAndCharts;
    private ChordDisplay chordDisplayMode = ChordDisplay.Above;
    private bool showVerseTitles = false;
    private string? chordColor = null;
    private string? lyricColor = null;

    // Fullscreen
    private bool isFullscreen = false;
    private ElementReference songContentRef;
    private ElementReference settingsPaletteRef;
    private bool _scrollToTopAfterLoad = false;

    // Autoscroll
    private System.Threading.Timer? autoScrollTimer;
    private bool isAutoScrolling = false;
    private double scrollSpeed = 1.5;
    private const string ApiBaseUrl = "https://localhost:7077";

    // Chord Charts
    private List<ChordDto> uniqueSongChords = new();
    private List<ChordDto> transposedChords = new();
    private bool isRefetchingCharts;
    private CancellationTokenSource? _chartRefetchCts;
    private bool showChordGrid = false;
    private int chordScrollPosition = 0;

    // Chord Popover
    private bool showChordPopover = false;
    private ChordDto? hoveredChord;
    private int currentChartIndex = 0;
    private double popoverTop = 0;
    private double popoverLeft = 0;
    private bool isMouseOverPopover = false;
    private System.Threading.Timer? popoverTimer;

    private bool showCharts => songDisplayMode == SongDisplay.LyricsAndChordsAndCharts;
    private bool showShareDropdown = false;

    protected override Task OnInitializedAsync()
    {
        _toastService.OnToast += OnToastChanged;
        return base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            shareLinkUrl = _navManager.Uri;
            try
            {
                await JsRt.InvokeVoidAsync("smoothScrollBy", 0);
                dotNetRef = DotNetObjectReference.Create(this);
                await JsRt.InvokeVoidAsync("songFullscreen.registerEscHandler", dotNetRef);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "JavaScript functions not loaded properly");
            }
        }

        if (_scrollToTopAfterLoad)
        {
            _scrollToTopAfterLoad = false;
            try { await JsRt.InvokeVoidAsync("scrollToTop"); }
            catch (Exception ex) { _logger.LogError(ex, "scrollToTop failed"); }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(SongId) && SongId != loadedSongId)
            await LoadSong();

        var userResult = await _globalAuth.GetAuthenticatedUserAsync();
        if (userResult.IsSuccess && userResult.Data != null)
        {
            currentUserId = userResult.Data.Id;
        }

        await LoadUserDisplaySettings();
    }

    private async Task LoadUserDisplaySettings()
    {
        try
        {
            SettingDto? settings = null;

            if (!string.IsNullOrEmpty(currentUserId))
            {
                var response = await _settingsApi.GetUserSettings(currentUserId);
                if (response.IsSuccessStatusCode && response.Content != null)
                    settings = response.Content;
            }
            else
            {
                settings = await _storageService.GetItemAsync<SettingDto>("DisplaySettings");
            }

            if (settings != null)
            {
                ApplySettingsDto(settings);
            }

            if (!string.IsNullOrEmpty(SongId))
            {
                var key = $"SongSettings_{SongId}";
                var songSettings = await _storageService.GetItemAsync<Dictionary<string, double>>(key);
                if (songSettings != null && songSettings.ContainsKey("scrollSpeed"))
                {
                    scrollSpeed = songSettings["scrollSpeed"];
                }
                else
                {
                    var oldSettings = await _storageService.GetItemAsync<Dictionary<string, int>>(key);
                    if (oldSettings != null && oldSettings.ContainsKey("scrollSpeed"))
                    {
                        scrollSpeed = (double)oldSettings["scrollSpeed"];
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading user display settings");
        }
    }

    private void ApplySettingsDto(SettingDto settings)
    {
        chordFontSize = int.TryParse(settings.ChordFontSize, out var cfs) ? cfs : 14;
        lyricFontSize = int.TryParse(settings.LyricFontSize, out var lfs) ? lfs : 18;
        fontFamily = settings.ChordFont ?? fontFamily;
        songDisplayMode = settings.SongDisplay ?? SongDisplay.LyricsAndChordsAndCharts;
        chordDisplayMode = settings.ChordDisplay ?? ChordDisplay.Above;
        showVerseTitles = settings.ShowVerseTitles ?? false;
        chordColor = settings.ChordColor;
        lyricColor = settings.LyricColor;
    }

    private void OnSettingsPreview(SettingDto settings)
    {
        ApplySettingsDto(settings);
        StateHasChanged();
    }

    private void OnScrollSpeedPreview(double newSpeed)
    {
        scrollSpeed = newSpeed;
        StateHasChanged();
    }

    private void OnSettingsSaved(SettingDto settings)
    {
        ApplySettingsDto(settings);
        CloseSettingsDropdown();
        StateHasChanged();
    }

    private async Task ToggleSettingsDropdown()
    {
        showSettingsDropdown = !showSettingsDropdown;
        StateHasChanged();
        if (showSettingsDropdown)
        {
            await Task.Yield();
            await JsRt.InvokeVoidAsync("initDraggablePalette", settingsPaletteRef);
        }
    }

    private void CloseSettingsDropdown()
    {
        showSettingsDropdown = false;
        StateHasChanged();
    }

    private void AdjustScrollSpeed(double delta)
    {
        scrollSpeed = Math.Clamp(scrollSpeed + delta, 0, 5);
        StateHasChanged();
    }

    private async Task EnterFullscreen()
    {
        isFullscreen = true;
        StateHasChanged();
        await JsRt.InvokeVoidAsync("songFullscreen.enter", songContentRef);
    }

    private async Task ExitFullscreen()
    {
        isFullscreen = false;
        StateHasChanged();
        await JsRt.InvokeVoidAsync("songFullscreen.exit");
    }

    [JSInvokable]
    public void OnEscapePressed()
    {
        if (!isFullscreen) return;
        isFullscreen = false;
        StateHasChanged();
    }

    private async Task ToggleAutoScroll()
    {
        isAutoScrolling = !isAutoScrolling;

        if (isAutoScrolling)
        {
            var atBottom = await JsRt.InvokeAsync<bool>("isAtBottom");
            if (atBottom)
            {
                await JsRt.InvokeVoidAsync("scrollToTop");
                await Task.Delay(100);
            }

            StartAutoScroll();
        }
        else
        {
            StopAutoScroll();
        }

        StateHasChanged();
    }

    private void StartAutoScroll()
    {
        autoScrollTimer?.Dispose();

        autoScrollTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                if (!isAutoScrolling) return;

                var atBottom = await JsRt.InvokeAsync<bool>("isAtBottom");
                if (atBottom)
                {
                    StopAutoScroll();
                    isAutoScrolling = false;
                    StateHasChanged();
                    return;
                }

                double scrollAmount = scrollSpeed * 5;
                await JsRt.InvokeVoidAsync("smoothScrollBy", (int)Math.Round(scrollAmount));
            });
        }, null, 0, 100);
    }

    private void StopAutoScroll()
    {
        autoScrollTimer?.Dispose();
        autoScrollTimer = null;
    }

    private void ToggleChordGrid()
    {
        showChordGrid = !showChordGrid;
        StateHasChanged();
    }

    private async Task ScrollChartsLeft()
    {
        chordScrollPosition -= 200;
        await JsRt.InvokeVoidAsync("scrollElement", chordChartsTrackRef, chordScrollPosition);
    }

    private async Task ScrollChartsRight()
    {
        chordScrollPosition += 200;
        await JsRt.InvokeVoidAsync("scrollElement", chordChartsTrackRef, chordScrollPosition);
    }

    private async Task ShowChordPopover(ChordDto chord, MouseEventArgs e)
    {
        popoverTimer?.Dispose();

        // Resolve to the currently displayed (possibly transposed) chord so the
        // popover shows the same charts as the chord-charts-section.
        var transposedName = GetTransposedChordName(chord.ChordName);

        // First try the already-resolved transposedChords list (populated post-debounce).
        var chordToLoad = transposedChords
            .FirstOrDefault(c => c.ChordName.Equals(transposedName, StringComparison.OrdinalIgnoreCase));

        // If not found (still within debounce window or chord not in DB list), search the API directly
        // so we never fall back to the pre-transposition chord's charts.
        if (chordToLoad == null && !transposedName.Equals(chord.ChordName, StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                var searchResp = await _chordsApi.SearchChords(transposedName, 0, 5);
                if (searchResp.IsSuccessStatusCode && searchResp.Content?.Data?.Any() == true)
                {
                    chordToLoad = searchResp.Content.Data
                        .FirstOrDefault(c => c.ChordName.Equals(transposedName, StringComparison.OrdinalIgnoreCase))
                        ?? searchResp.Content.Data.First();
                }
            }
            catch { /* silently ignore — popover simply won't show */ }
        }

        // Fallback to original chord only when there is no transposition at all
        chordToLoad ??= chord;

        // Only fetch if the chord has a known ID; placeholders (not in DB yet) have no charts.
        hoveredChord = string.IsNullOrEmpty(chordToLoad.Id)
            ? null
            : await LoadChordWithCharts(chordToLoad.Id);

        if (hoveredChord != null)
        {
            currentChartIndex = 0;
            var popoverHeight = 150;
            var popoverWidth = 85;

            popoverTop = e.ClientY - popoverHeight - 15;
            popoverLeft = e.ClientX - (popoverWidth / 2);

            if (popoverTop < 10)
                popoverTop = e.ClientY + 15;

            if (popoverLeft < 10)
                popoverLeft = 10;

            showChordPopover = true;
            StateHasChanged();
        }
    }

    private void HandleChordMouseLeave()
    {
        popoverTimer?.Dispose();
        popoverTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                if (!isMouseOverPopover)
                    HideChordPopover();
            });
        }, null, 300, Timeout.Infinite);
    }

    private void HideChordPopover()
    {
        showChordPopover = false;
        isMouseOverPopover = false;
        hoveredChord = null;
        currentChartIndex = 0;
        StateHasChanged();
    }

    private void NextChartImage()
    {
        if (hoveredChord?.ChordCharts != null && currentChartIndex < hoveredChord.ChordCharts.Count - 1)
        {
            currentChartIndex++;
            StateHasChanged();
        }
    }

    private void PreviousChartImage()
    {
        if (currentChartIndex > 0)
        {
            currentChartIndex--;
            StateHasChanged();
        }
    }

    private void SetChartIndex(int index)
    {
        currentChartIndex = index;
        StateHasChanged();
    }

    private async Task<ChordDto?> LoadChordWithCharts(string chordId)
    {
        try
        {
            var response = await _chordsApi.GetChordById(chordId);
            if (response.IsSuccessStatusCode)
                return response.Content;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading chord with charts");
        }
        return null;
    }

    private string GetChordChartImage(ChordChartDto chart)
    {
        if (string.IsNullOrEmpty(chart.FilePath)) return "/_content/FRELODYUI.Shared/images/no_image_placeholder.png";
        if (chart.FilePath.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return chart.FilePath;
        return $"{ApiBaseUrl}/{chart.FilePath.TrimStart('/')}";
    }

