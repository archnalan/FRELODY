    private async Task LoadSong()
    {
        loadedSongId = SongId;
        isLoading = true;
        StateHasChanged();

        try
        {
            var response = await _songsApi.GetSongWithChordsById(SongId);

            if (response.IsSuccessStatusCode)
            {
                if (!response.IsSuccessful && response.Content == null)
                {
                    response = await _shareApi.GetSharedSong(SongId);
                    if (!response.IsSuccessStatusCode)
                    {
                        var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                        ShowErrorMessage($"Failed to load song: {errorMessage}");
                    }
                }

                song = response.Content;
                InitializeChordScale();
                ExtractUniqueChords();
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                ShowErrorMessage($"Failed to load song: {errorMessage}");
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading song with ID: {SongId}", SongId);
            ShowErrorMessage("An unexpected error occurred");
        }
        finally
        {
            isLoading = false;
            if (isFullscreen) _scrollToTopAfterLoad = true;
            StateHasChanged();
        }
    }

    private void InitializeChordScale()
    {
        if (song?.SongParts?.Any() == true)
        {
            var chords = song.SongParts
                .SelectMany(part => part.LyricLines ?? Enumerable.Empty<LyricLineDto>())
                .SelectMany(line => line.LyricSegments ?? Enumerable.Empty<LyricSegmentDto>())
                .Where(segment => segment.Chord != null)
                .Select(segment => segment.Chord!.ChordName)
                .Distinct()
                .ToArray();

            if (chords.Length > 0)
            {
                chordScale = ChordTransposer.DetermineScale(chords);
                originalChords = chords;
            }
        }
    }

    private void ExtractUniqueChords()
    {
        if (song?.SongParts?.Any() == true)
        {
            uniqueSongChords = song.SongParts
                .SelectMany(part => part.LyricLines ?? Enumerable.Empty<LyricLineDto>())
                .SelectMany(line => line.LyricSegments ?? Enumerable.Empty<LyricSegmentDto>())
                .Where(segment => segment.Chord != null)
                .Select(segment => segment.Chord!)
                .GroupBy(c => c.ChordName)
                .Select(g => g.First())
                .ToList();

            // Initialize displayed chords to originals; RefetchTransposedChords will replace when transposed
            transposedChords = uniqueSongChords.ToList();
        }
    }

    private string GetTransposedChordName(string originalChordName)
    {
        if (chordScale == null || string.IsNullOrEmpty(originalChordName))
            return originalChordName;

        var totalSemitones = transpose - capo;
        return ChordTransposer.TransposeChord(originalChordName, totalSemitones, chordScale);
    }

    private void IncreaseTranspose() { if (transpose < 12) { transpose++; _ = RefetchTransposedChords(); } }
    private void DecreaseTranspose() { if (transpose > -12) { transpose--; _ = RefetchTransposedChords(); } }
    private void IncreaseCapo() { if (capo < 12) { capo++; _ = RefetchTransposedChords(); } }
    private void DecreaseCapo() { if (capo > 0) { capo--; _ = RefetchTransposedChords(); } }
    private void ResetTranspose() { transpose = 0; _ = RefetchTransposedChords(); }
    private void ResetCapo() { capo = 0; _ = RefetchTransposedChords(); }

    private async Task RefetchTransposedChords()
    {
        _chartRefetchCts?.Cancel();
        _chartRefetchCts = new CancellationTokenSource();
        var token = _chartRefetchCts.Token;

        var totalSemitones = transpose - capo;

        // No transposition — restore originals immediately without any network call
        if (totalSemitones == 0)
        {
            isRefetchingCharts = false;
            transposedChords = uniqueSongChords.ToList();
            StateHasChanged();
            return;
        }

        isRefetchingCharts = true;
        StateHasChanged();

        try
        {
            // Debounce: wait before firing so rapid +/− taps only resolve once
            await Task.Delay(300, token);

            var resolved = new List<ChordDto>();
            foreach (var chord in uniqueSongChords)
            {
                if (token.IsCancellationRequested) break;

                var transposedName = GetTransposedChordName(chord.ChordName);
                try
                {
                    var response = await _chordsApi.SearchChords(transposedName, 0, 5);
                    if (response.IsSuccessStatusCode && response.Content?.Data?.Any() == true)
                    {
                        // Prefer an exact name match; fall back to first result if none
                        var match = response.Content.Data
                            .FirstOrDefault(c => c.ChordName.Equals(transposedName, StringComparison.OrdinalIgnoreCase))
                            ?? response.Content.Data.First();
                        resolved.Add(match);
                    }
                    else
                    {
                        // Chord not in DB yet — show placeholder with correct name
                        resolved.Add(new ChordDto { ChordName = transposedName });
                    }
                }
                catch
                {
                    resolved.Add(new ChordDto { ChordName = transposedName });
                }
            }

            if (!token.IsCancellationRequested)
                transposedChords = resolved;
        }
        catch (TaskCanceledException) { }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                isRefetchingCharts = false;
                StateHasChanged();
            }
        }
    }

