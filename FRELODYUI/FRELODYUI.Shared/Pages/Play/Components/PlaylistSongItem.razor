@inject ILogger<PlaylistSongItem> _logger    

<div class="psi-item" @onclick="@(() => OnSongDisplay(Song.Id))">
    @if (IsDraggable)
    {
        <span class="psi-drag-handle" @onclick:stopPropagation title="Drag to reorder">
            <i class="bi bi-grip-vertical"></i>
        </span>
    }
    <span class="psi-number">
        @((Song.SongNumber.HasValue ? Song.SongNumber.Value : 0).ToString("000"))
    </span>

    <div class="psi-info">
        <span class="psi-title">@Song.Title</span>
        @if (!string.IsNullOrEmpty(Song.WrittenBy))
        {
            <span class="psi-artist">@Song.WrittenBy</span>
        }
    </div>

    @if (ShowActionBtns)
    {
        <button class="psi-menu-btn" @ref="menuBtnRef" type="button"
                @onclick="ToggleMenu" @onclick:stopPropagation
                title="Song actions">
            <i class="bi bi-three-dots"></i>
        </button>
    }
</div>

@if (menuOpen)
{
    <div class="psi-menu-backdrop" @onclick="CloseMenu"></div>
    <ul class="dropdown-menu show" style="@menuStyle">
        <li>
            <button class="dropdown-item" @onclick="() => { CloseMenu(); OnSongDisplay(Song.Id); }">
                <i class="bi bi-play-fill me-2"></i>Play
            </button>
        </li>
        <li>
            <button class="dropdown-item" @onclick="async () => { CloseMenu(); await OnShare.InvokeAsync(); }">
                <i class="bi bi-link-45deg me-2"></i>Share
            </button>
        </li>
        <li><hr class="dropdown-divider"></li>
        <li>
            <button class="dropdown-item text-danger" @onclick="async () => { CloseMenu(); await OnRemove.InvokeAsync(); }">
                <i class="bi bi-x-lg me-2"></i>Remove
            </button>
        </li>
    </ul>
}

@code {
    [Parameter] public ActiveView ActiveView { get; set; }
    [Parameter] public PlaylistSongDto Song { get; set; } = new();
    [Parameter] public EventCallback OnRemove { get; set; }
    [Parameter] public EventCallback OnShare { get; set; }
    [Parameter] public bool ShowActionBtns { get; set; } = true;
    [Parameter] public bool IsDraggable { get; set; } = false;

    private bool menuOpen;
    private string menuStyle = "";
    private ElementReference menuBtnRef;

    private async Task ToggleMenu()
    {
        if (menuOpen) { CloseMenu(); return; }
        var rect = await JsRt.InvokeAsync<BoundingRect>("getBoundingClientRect", menuBtnRef);
        var vp = await JsRt.InvokeAsync<ViewportSize>("getViewportDimensions");
        double top = rect.Bottom + 4;
        double right = vp.Width - rect.Right;
        if (top + 200 > vp.Height) top = Math.Max(8, rect.Top - 200);
        menuStyle = $"position:fixed;top:{(int)top}px;right:{(int)right}px;z-index:1050;display:block;";
        menuOpen = true;
    }

    private void CloseMenu() => menuOpen = false;

    private record BoundingRect(double Top, double Left, double Bottom, double Right, double Width, double Height);
    private record ViewportSize(double Width, double Height);

    private bool IsLandingContext => _navManager.Uri.Contains("/landing/", StringComparison.OrdinalIgnoreCase) ||
        _navManager.Uri.EndsWith("/landing", StringComparison.OrdinalIgnoreCase);

    private void OnSongDisplay(string songId)
    {
        _ = Task.Run(async () =>
            {
                try
                {
                    await _storageService.SetItemAsync("ActiveView", ActiveView);
                    await _storageService.SetItemAsync("ViewMode", ViewMode.Playlists);
                    await _playHistoryApi.LogSongPlay(songId, "Playlist");
                }
                catch (Exception ex)
                {
                    _logger.LogWarning(ex, "Failed to log song play from playlists page {SongId}", songId);
                }
            });
        if (IsLandingContext)
        {
            _navManager.NavigateTo($"/songs/landing/{songId}");
        }
        else
        {
            _navManager.NavigateTo($"/songs/{songId}");
        }
    }

}
