@using FRELODYSHRD.Dtos.SubDtos
@using FRELODYSHRD.Dtos
@inject ILogger<SongSettings> _logger

@if (isLoading)
{
    <div class="settings-loading">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span>Loading...</span>
    </div>
}
else
{
    <div class="settings-header palette-drag-handle">
        <h6><i class="bi bi-sliders me-1"></i>Settings</h6>
        <button class="close-btn" type="button" @onclick="OnClose">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <div class="settings-content">
        <!-- Autoscroll Speed -->
        <div class="settings-row">
            <label class="settings-label"><i class="bi bi-speedometer2"></i> Speed</label>
            <div class="settings-inline-control">
                <input type="range" class="settings-range" min="0" max="5" step="0.5"
                       value="@scrollSpeed"
                       @oninput="OnScrollSpeedInput"
                       @onclick:stopPropagation />
                <span class="slider-value">@scrollSpeed.ToString("0.0")x</span>
            </div>
        </div>

        <!-- Chord Font Size -->
        <div class="settings-row">
            <label class="settings-label"><i class="bi bi-type"></i> Chord</label>
            <div class="settings-inline-control">
                <input type="range" class="settings-range" min="10" max="32" step="1"
                       value="@chordFontSize"
                       @oninput="OnChordFontSizeInput"
                       @onclick:stopPropagation />
                <span class="slider-value">@(chordFontSize)px</span>
            </div>
        </div>

        <!-- Lyric Font Size -->
        <div class="settings-row">
            <label class="settings-label"><i class="bi bi-text-paragraph"></i> Lyric</label>
            <div class="settings-inline-control">
                <input type="range" class="settings-range" min="12" max="40" step="1"
                       value="@lyricFontSize"
                       @oninput="OnLyricFontSizeInput"
                       @onclick:stopPropagation />
                <span class="slider-value">@(lyricFontSize)px</span>
            </div>
        </div>

        <!-- Display Mode -->
        <div class="settings-row">
            <label class="settings-label"><i class="bi bi-eye"></i> Mode</label>
            <div class="segmented-control" @onclick:stopPropagation>
                <button class="segment-btn @(songDisplayMode == SongDisplay.LyricsAndChordsAndCharts ? "active" : "")"
                        @onclick="() => SetDisplayMode(SongDisplay.LyricsAndChordsAndCharts)" title="Full">
                    <i class="bi bi-music-note-list"></i>
                </button>
                <button class="segment-btn @(songDisplayMode == SongDisplay.LyricsAndChords ? "active" : "")"
                        @onclick="() => SetDisplayMode(SongDisplay.LyricsAndChords)" title="Chords + Lyrics">
                    <i class="bi bi-music-note-beamed"></i>
                </button>
                <button class="segment-btn @(songDisplayMode == SongDisplay.LyricsOnly ? "active" : "")"
                        @onclick="() => SetDisplayMode(SongDisplay.LyricsOnly)" title="Lyrics only">
                    <i class="bi bi-text-left"></i>
                </button>
            </div>
        </div>

        <!-- Chord Display Position -->
        @if (songDisplayMode != SongDisplay.LyricsOnly)
        {
            <div class="settings-row">
                <label class="settings-label"><i class="bi bi-music-note"></i> Pos</label>
                <div class="segmented-control segmented-sm" @onclick:stopPropagation>
                    <button class="segment-btn @(chordDisplayMode == ChordDisplay.Above ? "active" : "")"
                            @onclick="() => SetChordDisplay(ChordDisplay.Above)">
                        Above
                    </button>
                    <button class="segment-btn @(chordDisplayMode == ChordDisplay.Inline ? "active" : "")"
                            @onclick="() => SetChordDisplay(ChordDisplay.Inline)">
                        Inline
                    </button>
                </div>
            </div>
        }

        <!-- Font Family -->
        <div class="settings-row">
            <label class="settings-label"><i class="bi bi-fonts"></i> Font</label>
            <select class="settings-select" value="@fontFamily" @onchange="OnFontFamilyChanged" @onclick:stopPropagation>
                <option value="system-ui, -apple-system, 'Segoe UI'">System</option>
                <option value="'Georgia', serif">Georgia</option>
                <option value="'Arial', sans-serif">Arial</option>
                <option value="'Courier New', monospace">Courier</option>
                <option value="'Times New Roman', serif">Times</option>
                <option value="'Kanit','Helvetica Neue', 'Helvetica', 'Arial', 'sans-serif'">Kanit</option>
                <option value="'Montserrat', sans-serif">Montserrat</option>
            </select>
        </div>

        <!-- Show Verse Titles Toggle -->
        <div class="settings-row">
            <label class="settings-label" for="showVerseTitlesToggle"><i class="bi bi-card-heading"></i> Titles</label>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch"
                       id="showVerseTitlesToggle"
                       checked="@showVerseTitles"
                       @onchange="OnShowVerseTitlesChanged"
                       @onclick:stopPropagation />
            </div>
        </div>
    </div>

    <div class="settings-footer">
        <button class="save-settings-btn" @onclick="HandleSave" @onclick:stopPropagation disabled="@isSaving">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            else
            {
                <i class="bi bi-check-circle me-1"></i>
            }
            Save
        </button>
    </div>
}

@code {
    [Parameter] public string? UserId { get; set; }
    [Parameter] public string? SongId { get; set; }
    [Parameter] public EventCallback<SettingDto> OnSettingsSaved { get; set; }
    [Parameter] public EventCallback<SettingDto> OnSettingsChanged { get; set; }
    [Parameter] public EventCallback<double> OnScrollSpeedChanged { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool isLoading = true;
    private bool isSaving = false;
    private bool hasLoaded = false;
    private bool isInitialized = false;

    // Local settings state
    private double scrollSpeed = 1.5;
    private int chordFontSize = 14;
    private int lyricFontSize = 18;
    private string fontFamily = "system-ui, -apple-system, 'Montserrat', Roboto, sans-serif";
    private SongDisplay songDisplayMode = SongDisplay.LyricsAndChordsAndCharts;
    private ChordDisplay chordDisplayMode = ChordDisplay.Above;
    private bool showVerseTitles = false;

    protected override async Task OnParametersSetAsync()
    {
        if (!hasLoaded)
        {
            await LoadSettings();
            hasLoaded = true;
            isInitialized = true;
        }
    }

    private async Task LoadSettings()
    {
        isLoading = true;
        try
        {
            if (!string.IsNullOrEmpty(UserId))
            {
                var response = await _settingsApi.GetUserSettings(UserId);
                if (response.IsSuccessStatusCode && response.Content != null)
                {
                    ApplySettings(response.Content);
                }
            }
            else
            {
                var storedSettings = await _storageService.GetItemAsync<SettingDto>("DisplaySettings");
                if (storedSettings != null)
                {
                    ApplySettings(storedSettings);
                }
            }

            // Load song-specific scroll speed
            if (!string.IsNullOrEmpty(SongId))
            {
                var key = $"SongSettings_{SongId}";
                var songSettings = await _storageService.GetItemAsync<Dictionary<string, double>>(key);
                if (songSettings != null && songSettings.ContainsKey("scrollSpeed"))
                {
                    scrollSpeed = songSettings["scrollSpeed"];
                }
                else
                {
                    var oldSettings = await _storageService.GetItemAsync<Dictionary<string, int>>(key);
                    if (oldSettings != null && oldSettings.ContainsKey("scrollSpeed"))
                    {
                        scrollSpeed = (double)oldSettings["scrollSpeed"];
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading settings");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplySettings(SettingDto settings)
    {
        chordFontSize = int.TryParse(settings.ChordFontSize, out var cfs) ? cfs : 14;
        lyricFontSize = int.TryParse(settings.LyricFontSize, out var lfs) ? lfs : 18;
        fontFamily = settings.ChordFont ?? fontFamily;
        songDisplayMode = settings.SongDisplay ?? SongDisplay.LyricsAndChordsAndCharts;
        chordDisplayMode = settings.ChordDisplay ?? ChordDisplay.Above;
        showVerseTitles = settings.ShowVerseTitles ?? false;
    }

    private SettingDto BuildSettingDto()
    {
        return new SettingDto
        {
            ChordFontSize = chordFontSize.ToString(),
            LyricFontSize = lyricFontSize.ToString(),
            ChordFont = fontFamily,
            LyricFont = fontFamily,
            SongDisplay = songDisplayMode,
            ChordDisplay = chordDisplayMode,
            ShowVerseTitles = showVerseTitles
        };
    }

    private async Task NotifyChanged()
    {
        if (!isInitialized) return;
        await OnSettingsChanged.InvokeAsync(BuildSettingDto());
    }

    private async Task HandleSave()
    {
        try
        {
            isSaving = true;
            var settings = BuildSettingDto();

            if (!string.IsNullOrEmpty(UserId))
            {
                settings.CreatedBy = UserId;
                var response = await _settingsApi.CreateOrUpdateUserSettings(settings);
                if (!response.IsSuccessStatusCode)
                {
                    _modalService.Show(new ModalOptionDto
                    {
                        Title = "Error",
                        Message = "Failed to save settings",
                        ButtonText = "OK",
                        OptionType = OptionType.Error
                    });
                    return;
                }
            }
            else
            {
                await _storageService.SetItemAsync("DisplaySettings", settings);
            }

            // Save song-specific scroll speed
            if (!string.IsNullOrEmpty(SongId))
            {
                var songSettings = new Dictionary<string, double> { { "scrollSpeed", scrollSpeed } };
                await _storageService.SetItemAsync($"SongSettings_{SongId}", songSettings);
            }

            await OnSettingsSaved.InvokeAsync(settings);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error saving settings");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "Failed to save settings",
                ButtonText = "OK",
                OptionType = OptionType.Error
            });
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task OnScrollSpeedInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val))
            scrollSpeed = val;
        if (isInitialized)
            await OnScrollSpeedChanged.InvokeAsync(scrollSpeed);
    }

    private async Task OnChordFontSizeInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            chordFontSize = Math.Clamp(val, 10, 32);
        await NotifyChanged();
    }

    private async Task OnLyricFontSizeInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            lyricFontSize = Math.Clamp(val, 12, 40);
        await NotifyChanged();
    }

    private async Task SetDisplayMode(SongDisplay mode)
    {
        songDisplayMode = mode;
        await NotifyChanged();
    }

    private async Task SetChordDisplay(ChordDisplay mode)
    {
        chordDisplayMode = mode;
        await NotifyChanged();
    }

    private async Task OnFontFamilyChanged(ChangeEventArgs e)
    {
        fontFamily = e.Value?.ToString() ?? fontFamily;
        await NotifyChanged();
    }

    private async Task OnShowVerseTitlesChanged(ChangeEventArgs e)
    {
        showVerseTitles = (bool)(e.Value ?? false);
        await NotifyChanged();
    }
}
