@inject ILogger<PlaylistFolder> _logger

<div class="pf-folder">
    <!-- Folder Header -->
    <div class="pf-header @(IsExpanded ? "pf-expanded" : "")" @onclick="HandleToggle" role="button" tabindex="0">
        <i class="bi @(IsExpanded ? "bi-chevron-down" : "bi-chevron-right") pf-chevron"></i>

        <div class="pf-info">
            <span class="pf-name">@Collection.Playlist.Title</span>
            @if (!string.IsNullOrEmpty(Collection.Playlist.Theme) || !string.IsNullOrEmpty(Collection.Playlist.Curator))
            {
                <span class="pf-meta">
                    @if (!string.IsNullOrEmpty(Collection.Playlist.Theme))
                    {
                        <span>@Collection.Playlist.Theme</span>
                    }
                    @if (!string.IsNullOrEmpty(Collection.Playlist.Curator))
                    {
                        <span>&middot; @Collection.Playlist.Curator</span>
                    }
                </span>
            }
        </div>

        <span class="pf-count">@Collection.Songs.Count</span>

        @if (ShowActionButtons && !IsReadOnly)
        {
            <button class="pf-menu-btn" @ref="menuBtnRef" type="button"
                    @onclick="ToggleMenu" @onclick:stopPropagation
                    title="More actions">
                <i class="bi bi-three-dots-vertical"></i>
            </button>
        }
        else if (IsReadOnly)
        {
            <button class="pf-menu-btn" @onclick="() => OnClone.InvokeAsync()" @onclick:stopPropagation
                    title="Copy to my playlists">
                <i class="bi bi-copy"></i>
            </button>
        }
    </div>

    @if (menuOpen)
    {
        <div class="pf-menu-backdrop" @onclick="CloseMenu"></div>
        <ul class="dropdown-menu show" style="@menuStyle">
            <li>
                <button class="dropdown-item" @onclick="() => { CloseMenu(); NavigateToDetail(); }">
                    <i class="bi bi-list-ul me-2"></i>View Details
                </button>
            </li>
            <li>
                <button class="dropdown-item" @onclick="async () => { CloseMenu(); await OnEdit.InvokeAsync(); }">
                    <i class="bi bi-pencil me-2"></i>Edit
                </button>
            </li>
            <li>
                <button class="dropdown-item" @onclick="() => { CloseMenu(); SharePlaylist(Collection.Playlist.Id); }">
                    <i class="bi bi-link-45deg me-2"></i>Share
                    @if (HasRestrictedSongs)
                    {
                        <i class="bi bi-exclamation-triangle-fill text-warning ms-1" title="Contains non-public songs"></i>
                    }
                </button>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <button class="dropdown-item text-danger" @onclick="() => { CloseMenu(); DeletePlaylist(Collection); }">
                    <i class="bi bi-trash me-2"></i>Delete
                </button>
            </li>
        </ul>
    }

    <!-- Expanded Content -->
    @if (IsExpanded)
    {
        <div class="pf-body">
            @if (!string.IsNullOrEmpty(Collection.Playlist.Description))
            {
                <p class="pf-description">@Collection.Playlist.Description</p>
            }

            @if (HasRestrictedSongs && !IsReadOnly)
            {
                <div class="pf-restricted-notice">
                    <i class="bi bi-info-circle me-1"></i>
                    <span>Some songs are private/protected and won't be visible when shared. Update their access to Public first.</span>
                </div>
            }

            @if (Collection.Songs.Any())
            {
                <div class="pf-song-list">
                    @foreach (var song in Collection.Songs)
                    {
                        var isRestricted = song.Access != null && song.Access != FRELODYSHRD.Dtos.SubDtos.Access.Public;
                        <div class="@(isRestricted ? "pf-song-restricted" : "")">
                            <PlaylistSongItem Song="song"
                                              ShowActionBtns="@(ShowActionButtons && !IsReadOnly)"
                                              OnRemove="() => RemoveSongFromPlaylist(Collection.Playlist.Id, song.Id)"
                                              OnShare="() => ShareSong(song.Id)" />
                            @if (isRestricted && !IsReadOnly)
                            {
                                <div class="pf-restricted-badge">
                                    <i class="bi bi-lock-fill"></i>
                                    <span>@(song.Access == FRELODYSHRD.Dtos.SubDtos.Access.Private ? "Private" : "Protected")</span>
                                    <button class="pf-make-public-btn" @onclick="() => PreviewAndMakePublic(song.Id)" @onclick:stopPropagation title="Preview & make public">
                                        <i class="bi bi-globe me-1"></i>Make Public
                                    </button>
                                </div>
                            }
                            else if (isRestricted)
                            {
                                <div class="pf-restricted-badge">
                                    <i class="bi bi-lock-fill"></i>
                                    <span>@(song.Access == FRELODYSHRD.Dtos.SubDtos.Access.Private ? "Private" : "Protected")</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="pf-footer">
                    <button class="pf-footer-btn" @onclick="NavigateToDetail" @onclick:stopPropagation>
                        <i class="bi bi-list-ul me-1"></i>View Full Playlist
                    </button>
                    @if (ShowActionButtons && !IsReadOnly)
                    {
                        <button class="pf-footer-btn pf-add-btn" @onclick="() => OnAddSong.InvokeAsync()" @onclick:stopPropagation>
                            <i class="bi bi-plus me-1"></i>Add Song
                        </button>
                    }
                    else if (IsReadOnly)
                    {
                        <button class="pf-footer-btn pf-add-btn" @onclick="() => OnClone.InvokeAsync()" @onclick:stopPropagation>
                            <i class="bi bi-copy me-1"></i>Copy Playlist
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="pf-empty">
                    <i class="bi bi-music-note"></i>
                    <span>No songs yet</span>
                    @if (ShowActionButtons && !IsReadOnly)
                    {
                        <button class="pf-footer-btn pf-add-btn" @onclick="() => OnAddSong.InvokeAsync()" @onclick:stopPropagation>
                            <i class="bi bi-plus-circle me-1"></i>Add Song
                        </button>
                    }
                </div>
            }
        </div>
    }
</div>

<SongDataPreview @ref="songPreviewRef"
                 IsVisible="showSongPreview"
                 SongData="previewSongData"
                 ConfirmButtonText="Make Public"
                 OnCancel="HandlePreviewCancel"
                 OnSave="HandleMakePublicConfirm" />

<MessageToast ShowToast="@showSuccessMessage" ToastMessage="@successMessage" Type="ToastType.Success" />

@code {
    [Parameter] public PlaylistSongs Collection { get; set; } = new();
    [Parameter] public bool IsExpanded { get; set; }
    [Parameter] public EventCallback OnToggle { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback OnAddSong { get; set; }
    [Parameter] public EventCallback OnClone { get; set; }
    [Parameter] public bool ShowActionButtons { get; set; } = true;
    [Parameter] public bool IsReadOnly { get; set; } = false;

    private bool isGeneratingLink = false;
    private bool menuOpen;
    private string menuStyle = "";
    private ElementReference menuBtnRef;

    private bool showSuccessMessage = false;
    private string successMessage = string.Empty;

    private bool HasRestrictedSongs => Collection.Songs.Any(s =>
        s.Access != null && s.Access != FRELODYSHRD.Dtos.SubDtos.Access.Public);

    // Song preview state
    private SongDataPreview? songPreviewRef;
    private bool showSongPreview = false;
    private SimpleSongCreateDto? previewSongData;
    private string? previewSongId;

    private void HandleToggle()
    {
        OnToggle.InvokeAsync();
    }

    private async Task ToggleMenu()
    {
        if (menuOpen) { CloseMenu(); return; }
        var rect = await JsRt.InvokeAsync<BoundingRect>("getBoundingClientRect", menuBtnRef);
        var vp = await JsRt.InvokeAsync<ViewportSize>("getViewportDimensions");
        double top = rect.Bottom + 4;
        double right = vp.Width - rect.Right;
        if (top + 200 > vp.Height) top = Math.Max(8, rect.Top - 200);
        menuStyle = $"position:fixed;top:{(int)top}px;right:{(int)right}px;z-index:1050;display:block;";
        menuOpen = true;
    }

    private void CloseMenu() => menuOpen = false;

    private record BoundingRect(double Top, double Left, double Bottom, double Right, double Width, double Height);
    private record ViewportSize(double Width, double Height);

    private bool IsLandingContext => _navManager.Uri.Contains("/landing/", StringComparison.OrdinalIgnoreCase) ||
        _navManager.Uri.EndsWith("/landing", StringComparison.OrdinalIgnoreCase);

    private void NavigateToDetail()
    {
        var path = IsLandingContext
            ? $"/playlists/landing/{Collection.Playlist.Id}/detail"
            : $"/playlists/{Collection.Playlist.Id}/detail";
        _navManager.NavigateTo(path);
    }

    private async Task ShareSong(string songId)
    {
        try
        {
            var shareLink = await _shareService.GenerateShareLinkAsync(songId);
            if (shareLink != null)
            {
                await _clipboardService.CopyToClipboardAsync(shareLink.ShareUrl);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Link Copied",
                    Message = "Song share link copied to clipboard!",
                    ButtonText = "OK",
                    OptionType = OptionType.Success
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error sharing song");
        }
    }

    private async void SharePlaylist(string playlistId)
    {
        if (HasRestrictedSongs)
        {
            _modalService.Show(new ModalOptionDto
            {
                Title = "Sharing Warning",
                Message = "This playlist contains private or protected songs that won't be visible to others. Would you like to share anyway?",
                DangerText = "Recipients will only see public songs in the shared link.",
                ButtonText = "Share Anyway",
                OptionType = OptionType.Confirmation,
                OnConfirmCallback = async () => await ExecuteSharePlaylist(playlistId)
            });
            return;
        }

        await ExecuteSharePlaylist(playlistId);
    }

    private async Task ExecuteSharePlaylist(string playlistId)
    {
        isGeneratingLink = true;
        StateHasChanged();

        try
        {
            var shareLink = await _shareService.GeneratePlaylistShareLinkAsync(playlistId);
            if (shareLink != null)
            {
                await _clipboardService.CopyToClipboardAsync(shareLink.ShareUrl);
                await ShowSuccessMessage("Share link copied to clipboard!");
            }
            else
            {
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Share Link Error",
                    Message = "Failed to generate share link. Please try again later.",
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error generating share link for playlist {PlaylistId}", playlistId);
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "An error occurred while generating the share link.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
        finally
        {
            isGeneratingLink = false;
            StateHasChanged();
        }
    }

    private void DeletePlaylist(PlaylistSongs collection)
    {
        var collectionId = collection.Playlist.Id;
        _modalService.Show(new ModalOptionDto
        {
            Title = "Delete Playlist",
            Message = $"Are you sure you want to delete '{collection.Playlist.Title}'?",
            DangerText = $"This will remove the playlist and all its {collection.Songs.Count} songs.",
            ButtonText = "Delete",
            OptionType = OptionType.Confirmation,
            OnConfirmCallback = () => ExecuteDeletePlaylist(collectionId)
        });
    }

    private void RemoveSongFromPlaylist(string collectionId, string songId)
    {
        _modalService.Show(new ModalOptionDto
        {
            Title = "Remove Song",
            Message = "Remove this song from the playlist?",
            ButtonText = "Remove",
            OptionType = OptionType.Confirmation,
            OnConfirmCallback = () => ExecuteRemoveSong(collectionId, songId)
        });
    }

    private async Task ExecuteDeletePlaylist(string collectionId)
    {
        try
        {
            var response = await _playlistsApi.DeletePlaylist(collectionId);

            if (response.IsSuccessStatusCode)
            {
                await ShowSuccessMessage("Playlist deleted successfully.");
                await OnRefresh.InvokeAsync();
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error deleting playlist");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "Failed to delete playlist.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
    }

    private async Task ExecuteRemoveSong(string collectionId, string songId)
    {
        try
        {
            var response = await _playlistsApi.RemoveSongFromPlaylist(collectionId, songId);

            if (response.IsSuccessStatusCode)
            {
                await ShowSuccessMessage("Song removed from playlist.");
                await OnRefresh.InvokeAsync();
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error removing song from playlist");
        }
    }

    private async Task PreviewAndMakePublic(string songId)
    {
        try
        {
            var response = await _songsApi.GetSongWithChordsById(songId);
            if (!response.IsSuccessStatusCode || response.Content == null)
            {
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = "Failed to load song details.",
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
                return;
            }

            var song = response.Content;
            previewSongId = songId;
            previewSongData = MapSongToPreview(song);
            showSongPreview = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading song {SongId} for preview", songId);
        }
    }

    private SimpleSongCreateDto MapSongToPreview(SongDto song)
    {
        var segments = new List<SegmentCreateDto>();

        if (song.SongParts != null)
        {
            foreach (var part in song.SongParts.OrderBy(p => p.PartNumber))
            {
                if (part.LyricLines == null) continue;
                foreach (var line in part.LyricLines.OrderBy(l => l.LyricLineOrder))
                {
                    if (line.LyricSegments == null) continue;
                    foreach (var seg in line.LyricSegments.OrderBy(s => s.LyricOrder))
                    {
                        segments.Add(new SegmentCreateDto
                        {
                            Id = seg.Id,
                            Lyric = seg.Lyric,
                            ChordId = seg.ChordId,
                            ChordName = seg.Chord?.ChordName,
                            ChordAlignment = seg.ChordAlignment,
                            LineNumber = line.LyricLineOrder,
                            PartNumber = part.PartNumber,
                            PartName = part.PartName ?? SongSection.Verse,
                            LyricOrder = seg.LyricOrder
                        });
                    }
                }
            }
        }

        return new SimpleSongCreateDto
        {
            Title = song.Title,
            SongNumber = song.SongNumber,
            SongLyrics = segments
        };
    }

    private async Task HandleMakePublicConfirm()
    {
        if (string.IsNullOrEmpty(previewSongId)) return;

        try
        {
            var response = await _songsApi.MarkSongAccessStatus(previewSongId, FRELODYSHRD.Dtos.SubDtos.Access.Public);
            if (response.IsSuccessStatusCode)
            {
                showSongPreview = false;
                previewSongData = null;
                await ShowSuccessMessage("Song is now public.");
                await OnRefresh.InvokeAsync();
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error making song {SongId} public", previewSongId);
        }
        finally
        {
            previewSongId = null;
        }
    }

    private void HandlePreviewCancel()
    {
        showSongPreview = false;
        previewSongData = null;
        previewSongId = null;
        StateHasChanged();
    }

    private async Task ShowSuccessMessage(string message)
    {
        successMessage = message;
        showSuccessMessage = true;
        StateHasChanged();

        // Auto-hide after 3 seconds
        await Task.Delay(3000);
        showSuccessMessage = false;
        StateHasChanged();
    }

}