@page "/playlists/landing/{PlaylistId}/detail"
@layout LandingLayout

@if (Shared)
{
    <CascadingAuthenticationState>
        <AuthorizeView>
            <NotAuthorized>
                <div class="share-cta-bar">
                    <div class="share-cta-inner">
                        <span class="share-cta-text">
                            <i class="bi bi-music-note-list me-2"></i>
                            Sign up free to create your own playlists and save songs.
                        </span>
                        <div class="share-cta-actions">
                            <a href="/register" class="btn btn-sm btn-primary">Sign up free</a>
                            <a href="/login?returnUrl=@Uri.EscapeDataString(_navManager.ToBaseRelativePath(_navManager.Uri))" class="btn btn-sm btn-outline-secondary">Sign in</a>
                        </div>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </CascadingAuthenticationState>
}

<PlaylistDetail PlaylistId="@PlaylistId" ShowActions="true" IsLandingView="true" />

@code {
    [Parameter] public string PlaylistId { get; set; } = string.Empty;
    [SupplyParameterFromQuery(Name = "shared")] public bool Shared { get; set; }
}
