@page "/playlists/{PlaylistId}/detail"
@using FRELODYUI.Shared.Pages.Play.Components
@using FRELODYUI.Shared.Pages.Common
@using FRELODYUI.Shared.Pages.PlaceHolders
@inject ILogger<PlaylistDetail> _logger
@implements IDisposable

<div class="container-fluid position-relative pd-page">
    <div class="container py-4" style="max-width: 55rem;">
        
        @if (isLoading)
        {
            <PlaylistDetailPlaceholder />
        }
        else if (playlistCollection != null)
        {
            <!-- Header with Back Button -->
            <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
                <div class="d-flex align-items-center gap-3">
                    <div class="ms-2">
                        <button class="btn btn-outline-primary" @onclick="GoBack">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </div>
                    <h3 class="mb-0" style="color: var(--text-primary)">@playlistCollection.Playlist.Title</h3>
                </div>
                
                @if (ShowActions)
                {
                    <!-- Actions Dropdown -->
                    <div class="dropdown" style="position:relative;">
                        <button class="btn btn-link text-muted p-1" 
                                type="button" 
                                @onclick="ToggleActionsMenu" @onclick:stopPropagation
                                title="More actions">
                            <i class="bi bi-three-dots-vertical fs-5"></i>
                        </button>
                        @if (actionsMenuOpen)
                        {
                            <div class="dropdown-backdrop" style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:1040;" @onclick="CloseActionsMenu"></div>
                            <ul class="dropdown-menu dropdown-menu-end show" style="position:absolute;right:0;z-index:1050;">
                                @if (IsOwner)
                                {
                                    <li>
                                        <button class="dropdown-item" @onclick="() => { CloseActionsMenu(); EditPlaylist(); }">
                                            <i class="bi bi-pencil me-2"></i>Edit Playlist
                                        </button>
                                    </li>
                                }
                                <li>
                                    <button class="dropdown-item" @onclick="async () => { CloseActionsMenu(); await SharePlaylist(); }">
                                        <i class="bi bi-share me-2"></i>Share Playlist
                                        @if (HasRestrictedSongs)
                                        {
                                            <i class="bi bi-exclamation-triangle-fill text-warning ms-1"></i>
                                        }
                                    </button>
                                </li>
                                @if (IsOwner)
                                {
                                    <li>
                                        <button class="dropdown-item" @onclick="async () => { CloseActionsMenu(); await AddSongToPlaylist(); }">
                                            <i class="bi bi-plus-circle me-2"></i>Add Song
                                        </button>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <button class="dropdown-item text-danger" @onclick="() => { CloseActionsMenu(); DeletePlaylist(); }">
                                            <i class="bi bi-trash me-2"></i>Delete Playlist
                                        </button>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                }
            </div>

            <!-- Playlist Information -->
            <div class="pd-info-strip mb-3">
                @if (isEditingInfo && IsOwner)
                {
                    <div class="pd-edit-form">
                        <div class="pd-edit-row">
                            <input type="text" class="form-control form-control-sm" @bind="editTitle" placeholder="Title" />
                            <input type="text" class="form-control form-control-sm" @bind="editTheme" placeholder="Theme" />
                        </div>
                        <textarea class="form-control form-control-sm" rows="1" @bind="editDescription" placeholder="Description (optional)"></textarea>
                        <div class="pd-edit-row">
                            <input type="date" class="form-control form-control-sm" @bind="editPlaylistDate" />
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditInfo">Cancel</button>
                                <button class="btn btn-sm btn-primary" @onclick="SavePlaylistInfo">
                                    <i class="bi bi-check-lg me-1"></i>Save
                                </button>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="pd-info-row">
                        <div class="pd-info-meta">
                            @if (!string.IsNullOrEmpty(playlistCollection.Playlist.Description))
                            {
                                <span class="pd-info-desc">@playlistCollection.Playlist.Description</span>
                            }
                            <div class="pd-info-tags">
                                @if (!string.IsNullOrEmpty(playlistCollection.Playlist.Theme))
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary">@playlistCollection.Playlist.Theme</span>
                                }
                                <span class="badge @(playlistCollection.Playlist.IsPublic == true ? "bg-success bg-opacity-10 text-success" : "bg-secondary bg-opacity-10 text-secondary")">
                                    <i class="bi @(playlistCollection.Playlist.IsPublic == true ? "bi-globe" : "bi-lock") me-1"></i>@(playlistCollection.Playlist.IsPublic == true ? "Public" : "Private")
                                </span>
                                <span class="pd-info-count">@playlistCollection.Songs.Count song@(playlistCollection.Songs.Count != 1 ? "s" : "")</span>
                            </div>
                            <div class="pd-info-sub">
                                @if (!string.IsNullOrEmpty(playlistCollection.Playlist.Curator))
                                {
                                    <span><i class="bi bi-person me-1"></i>@playlistCollection.Playlist.Curator</span>
                                }
                                @if (playlistCollection.Playlist.PlaylistDate.HasValue)
                                {
                                    <span><i class="bi bi-calendar-event me-1"></i>@playlistCollection.Playlist.PlaylistDate.Value.ToString("MMM dd, yyyy")</span>
                                }
                            </div>
                        </div>
                        @if (IsOwner)
                        {
                            <button class="btn btn-sm btn-link text-muted p-0" @onclick="StartEditInfo" title="Edit info">
                                <i class="bi bi-pencil"></i>
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- Search Bar -->
            @if (playlistCollection.Songs.Any())
            {
                <div class="pd-search mb-3">
                    <div class="pd-search-row">
                        <div class="position-relative flex-grow-1">
                            <input type="text"
                                   class="form-control form-control-sm ps-5 rounded-3"
                                   placeholder="Search songs..."
                                   @bind-value="searchQuery"
                                   @bind-value:event="oninput"
                                   @bind-value:after="OnSearchInput" />
                            <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="font-size:0.8rem"></i>
                        </div>
                        @if (ShowActions && IsOwner)
                        {
                            <button class="btn btn-sm btn-primary rounded-3" @onclick="AddSongToPlaylist" title="Add song">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        }
                    </div>
                </div>
            }
            
            <!-- Songs List -->
            @if (filteredSongs.Any())
            {
                @if (ShowActions && IsOwner && filteredSongs.Any(s => !string.IsNullOrEmpty(s.Key)))
                {
                    <!-- Global Transpose Strip -->
                    <div class="pd-global-transpose mb-2">
                        <span class="pd-gt-label"><i class="bi bi-music-note-list me-1"></i>All Keys</span>
                        <div class="pd-gt-controls">
                            <button class="pd-gt-btn" @onclick="GlobalTransposeDown" title="Transpose all down">
                                <i class="bi bi-dash"></i>
                            </button>
                            <span class="pd-gt-value @(globalTransposeOffset != 0 ? "pd-gt-active" : "")">
                                @(globalTransposeOffset >= 0 ? "+" : "")@globalTransposeOffset
                            </span>
                            <button class="pd-gt-btn" @onclick="GlobalTransposeUp" title="Transpose all up">
                                <i class="bi bi-plus"></i>
                            </button>
                            @if (globalTransposeOffset != 0)
                            {
                                <button class="pd-gt-reset" @onclick="ResetGlobalTranspose" title="Reset all">
                                    <i class="bi bi-arrow-counterclockwise"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
                @if (ShowActions && IsOwner && string.IsNullOrEmpty(searchQuery))
                {
                    <SortableList Items="filteredSongs"
                                  Handle=".psi-drag-handle"
                                  Class="pd-songs-list"
                                  Group="@($"detail-{PlaylistId}")"
                                  OnUpdate="HandleSongReorder">
                        <SortableItemTemplate>
                            <PlaylistSongItem Song="context"
                                              ShowActionBtns="true"
                                              ShowTransposeControls="true"
                                              IsDraggable="true"
                                              ActiveView="ActiveView"
                                              OnRemove="() => RemoveSongFromPlaylist(context.Id)"
                                              OnShare="() => ShareSong(context.Id)"
                                              OnTransposeChanged="HandleTransposeChanged"/>
                        </SortableItemTemplate>
                    </SortableList>
                }
                else
                {
                    <div class="pd-songs-list">
                        @foreach (var song in filteredSongs)
                        {
                            <PlaylistSongItem Song="song"
                                              ShowActionBtns="@(ShowActions && IsOwner)"
                                              ActiveView="ActiveView"
                                              OnRemove="() => RemoveSongFromPlaylist(song.Id)"
                                              OnShare="() => ShareSong(song.Id)"/>
                        }
                    </div>
                }
            }
            else if (!string.IsNullOrEmpty(searchQuery))
            {
                <!-- No Search Results -->
                <div class="text-center my-5 p-5">
                    <i class="bi bi-search fs-1" style="color: var(--text-muted)"></i>
                    <h5 class="mt-3" style="color: var(--text-primary)">No songs match "@searchQuery"</h5>
                    <button class="btn btn-primary mt-3" @onclick="ClearSearch">
                        Clear Search
                    </button>
                </div>
            }
            else
            {
                <!-- Empty Playlist State -->
                <div class="text-center my-5 p-5">
                    <i class="bi bi-music-note fs-1" style="color: var(--text-muted)"></i>
                    <h5 class="mt-3" style="color: var(--text-primary)">No Songs Yet</h5>
                    @if (ShowActions && IsOwner)
                    {
                        <p style="color: var(--text-muted)">Add songs to this playlist to get started</p>
                        <button class="btn btn-primary mt-3" @onclick="AddSongToPlaylist">
                            <i class="bi bi-plus-circle me-2"></i>Add Song
                        </button>
                    }
                    else
                    {
                        <p style="color: var(--text-muted)">This playlist doesn't have any songs yet</p>
                    }
                </div>
            }

            <!-- Moving Mode Banner -->
            @if (movingContext != null)
            {
                <div class="position-fixed bottom-0 start-50 translate-middle-x mb-3 p-3 bg-primary text-white rounded-3 shadow-lg" style="z-index:1000; max-width:90vw;">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-arrow-left-right fs-4"></i>
                        <div class="flex-grow-1">
                            <div class="fw-bold">Moving: @movingContext.SongTitle</div>
                            <small>Select a different playlist from the playlists page</small>
                        </div>
                        <button class="btn btn-light btn-sm" @onclick="CancelMove">Cancel</button>
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Playlist Not Found -->
            <div class="text-center my-5 p-5">
                <i class="bi bi-exclamation-triangle fs-1 text-warning"></i>
                <h5 class="mt-3">Playlist Not Found</h5>
                <p class="text-muted">The playlist you're looking for doesn't exist or has been deleted.</p>
                <button class="btn btn-primary mt-3" @onclick="GoBack">
                    <i class="bi bi-chevron-left me-2"></i>Go Back
                </button>
            </div>
        }
    </div>
</div>

<!-- Modals -->
@if (showPlaylistModal)
{
    <PlaylistEditModal IsVisible="showPlaylistModal"
                      Collection="playlistCollection?.Playlist ?? new()"
                      OnSave="SavePlaylist"
                      OnCancel="ClosePlaylistModal" />
}

<SearchModal @ref="searchModalRef" OnResultSelected="HandleSongSelected" />

<MessageToast ShowToast="@showSuccessMessage" ToastMessage="@successMessage" Type="ToastType.Success" />

@code {
    [Parameter] public ActiveView ActiveView { get; set; }
    [Parameter] public string PlaylistId { get; set; } = string.Empty;
    [Parameter] public bool ShowActions { get; set; } = true;
    [Parameter] public bool IsLandingView { get; set; } = false;

    private PlaylistSongs? playlistCollection;
    private List<PlaylistSongDto> filteredSongs = new();
    private bool isLoading = true;
    private string searchQuery = string.Empty;
    private string? currentUserId;

    // Editing state
    private bool showPlaylistModal = false;

    // Inline editing state
    private bool isEditingInfo = false;
    private string editTitle = string.Empty;
    private string? editDescription;
    private string? editTheme;
    private DateTime? editPlaylistDate;

    // Moving song between playlists
    private MovingContext? movingContext;

    // Debounce
    private CancellationTokenSource? _debounceCts;
    private const int SearchDebounceMs = 500;

    // Search modal state
    private SearchModal? searchModalRef;
    private bool showSuccessMessage = false;
    private string successMessage = string.Empty;

    // Actions menu
    private bool actionsMenuOpen = false;

    // Global transpose
    private int globalTransposeOffset = 0;

    private bool IsOwner => !string.IsNullOrEmpty(currentUserId) && playlistCollection != null &&
        (playlistCollection.Playlist.CreatedBy == currentUserId || playlistCollection.Playlist.Curator == currentUserId);

    private void ToggleActionsMenu() => actionsMenuOpen = !actionsMenuOpen;
    private void CloseActionsMenu() => actionsMenuOpen = false;

    private bool HasRestrictedSongs => playlistCollection?.Songs.Any(s =>
        s.Access != null && s.Access != FRELODYSHRD.Dtos.SubDtos.Access.Public) ?? false;
    
    private bool IsLandingContext
    {
        get
        {
            if (IsLandingView) return true;

            // Use BaseRelativePath to reliably determine if we're at the app root or landing routes.
            var relative = _navManager.ToBaseRelativePath(_navManager.Uri ?? string.Empty);

            // Root of the app returns empty string => treat as landing/home.
            if (string.IsNullOrEmpty(relative)) return true;

            // Normalize and trim any trailing slashes for comparisons.
            relative = relative.Trim('/');

            if (relative.Equals("landing", StringComparison.OrdinalIgnoreCase) ||
                relative.StartsWith("landing/", StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }

            return false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var user = await _globalAuth.GetAuthenticatedUserAsync();
        if (user.IsSuccess && user.Data != null)
        {
            currentUserId = user.Data.Id;
        }

        await LoadPlaylist();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!isLoading && playlistCollection?.Playlist.Id != PlaylistId)
        {
            await LoadPlaylist();
        }
    }

    private async Task LoadPlaylist()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            if (string.IsNullOrEmpty(PlaylistId))
            {
                return;
            }

            // If in landing context, the PlaylistId may be a share token — resolve via share API first
            if (IsLandingContext)
            {
                var sharedResponse = await _shareApi.GetSharedPlaylist(PlaylistId);
                if (sharedResponse.IsSuccessStatusCode && sharedResponse.Content != null)
                {
                    playlistCollection = sharedResponse.Content;
                    filteredSongs = playlistCollection.Songs.ToList();
                    globalTransposeOffset = playlistCollection.Playlist.GlobalTranspose;
                    return;
                }
            }

            // Try to load directly by playlist ID (works for authenticated views or if token matched a playlist ID)
            var response = await _playlistsApi.GetPlaylistById(PlaylistId);

            if (response.IsSuccessStatusCode && response.Content != null)
            {
                playlistCollection = response.Content;
                filteredSongs = playlistCollection.Songs.ToList();
                globalTransposeOffset = playlistCollection.Playlist.GlobalTranspose;
            }
            else if (!string.IsNullOrEmpty(currentUserId))
            {
                // Fallback: try loading from user playlists
                var userResponse = await _playlistsApi.GetUserPlaylists(currentUserId);
                if (userResponse.IsSuccessStatusCode && userResponse.Content != null)
                {
                    playlistCollection = userResponse.Content.FirstOrDefault(p => p.Playlist.Id == PlaylistId);
                    if (playlistCollection != null)
                    {
                        filteredSongs = playlistCollection.Songs.ToList();
                        globalTransposeOffset = playlistCollection.Playlist.GlobalTranspose;
                    }
                }
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _logger.LogError("Error loading playlist: {Error}", errorMessage);
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error loading playlist");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "Failed to load playlist.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
        finally
        {
            isLoading = false;
            InitializeSongTransposes(filteredSongs);
            StateHasChanged();
        }
    }

    private static void InitializeSongTransposes(List<PlaylistSongDto> songs)
    {
        foreach (var s in songs.Where(s => s.Transpose == null && !string.IsNullOrEmpty(s.Key)))
            s.Transpose = ChordTransposer.Delta(s.Key, s.OriginalKey);
    }

    private void EditPlaylist()
    {
        if (playlistCollection != null)
        {
            showPlaylistModal = true;
        }
    }

    private async Task SavePlaylist(PlaylistDto collection)
    {
        await LoadPlaylist();
        ClosePlaylistModal();
    }

    private void ClosePlaylistModal()
    {
        showPlaylistModal = false;
    }

    private void StartEditInfo()
    {
        if (playlistCollection == null) return;
        editTitle = playlistCollection.Playlist.Title ?? string.Empty;
        editDescription = playlistCollection.Playlist.Description;
        editTheme = playlistCollection.Playlist.Theme;
        editPlaylistDate = playlistCollection.Playlist.PlaylistDate;
        isEditingInfo = true;
    }

    private void CancelEditInfo()
    {
        isEditingInfo = false;
    }

    private async Task SavePlaylistInfo()
    {
        if (playlistCollection == null) return;

        var updated = playlistCollection.Playlist;
        updated.Title = editTitle;
        updated.Description = editDescription;
        updated.Theme = editTheme;
        updated.PlaylistDate = editPlaylistDate;

        try
        {
            var response = await _playlistsApi.UpdatePlaylist(updated.Id, updated);
            if (response.IsSuccessStatusCode)
            {
                isEditingInfo = false;
                await ShowSuccessMessage("Playlist updated.");
                await LoadPlaylist();
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error updating playlist info");
        }
    }

    private async Task HandleSongReorder((int oldIndex, int newIndex) indices)
    {
        if (indices.oldIndex == indices.newIndex) return;

        var item = filteredSongs[indices.oldIndex];
        filteredSongs.RemoveAt(indices.oldIndex);
        filteredSongs.Insert(indices.newIndex, item);

        // Sync back to the source collection
        if (playlistCollection != null)
        {
            playlistCollection.Songs.Clear();
            playlistCollection.Songs.AddRange(filteredSongs);
        }

        StateHasChanged();

        try
        {
            var songIds = filteredSongs.Select(s => s.Id).ToList();
            await _playlistsApi.ReorderPlaylistSongs(PlaylistId, songIds);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error persisting song reorder");
        }
    }

    private async Task HandleTransposeChanged((string songId, int transpose) args)
    {
        try
        {
            await _playlistsApi.UpdatePlaylistSongTranspose(PlaylistId, args.songId, args.transpose);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error updating transpose for song {SongId}", args.songId);
        }
    }

    private async Task GlobalTransposeDown()
    {
        if (globalTransposeOffset <= -11) return;
        globalTransposeOffset--;
        await ApplyGlobalTranspose();
    }

    private async Task GlobalTransposeUp()
    {
        if (globalTransposeOffset >= 11) return;
        globalTransposeOffset++;
        await ApplyGlobalTranspose();
    }

    private async Task ResetGlobalTranspose()
    {
        globalTransposeOffset = 0;
        await ApplyGlobalTranspose();
    }

    private async Task ApplyGlobalTranspose()
    {
        foreach (var song in filteredSongs.Where(s => !string.IsNullOrEmpty(s.Key)))
        {
            song.Transpose = ChordTransposer.Delta(song.Key, song.OriginalKey) + globalTransposeOffset;
        }

        if (playlistCollection != null)
        {
            foreach (var song in playlistCollection.Songs.Where(s => !string.IsNullOrEmpty(s.Key)))
            {
                song.Transpose = ChordTransposer.Delta(song.Key, song.OriginalKey) + globalTransposeOffset;
            }
        }

        StateHasChanged();

        // Persist all in background
        try
        {
            var tasks = filteredSongs
                .Where(s => !string.IsNullOrEmpty(s.Key))
                .Select(s => _playlistsApi.UpdatePlaylistSongTranspose(PlaylistId, s.Id, s.Transpose ?? 0));
            await Task.WhenAll(tasks);

            // Persist global transpose on the playlist itself
            await _playlistsApi.UpdatePlaylistGlobalTranspose(PlaylistId, globalTransposeOffset);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error applying global transpose");
        }
    }

    private async Task SharePlaylist()
    {
        if (playlistCollection == null) return;

        if (HasRestrictedSongs)
        {
            _modalService.Show(new ModalOptionDto
            {
                Title = "Sharing Warning",
                Message = "This playlist contains private or protected songs that won't be visible to others. Would you like to share anyway?",
                DangerText = "Recipients will only see public songs in the shared link.",
                ButtonText = "Share Anyway",
                OptionType = OptionType.Confirmation,
                OnConfirmCallback = async () => await ExecuteSharePlaylist()
            });
            return;
        }

        await ExecuteSharePlaylist();
    }

    private async Task ExecuteSharePlaylist()
    {
        if (playlistCollection == null) return;

        try
        {
            var url = IsLandingContext
                ? _navManager.ToAbsoluteUri($"/playlists/landing/{playlistCollection.Playlist.Id}/detail").ToString()
                : _navManager.ToAbsoluteUri($"/playlists/{playlistCollection.Playlist.Id}/detail").ToString();
            await _clipboardService.CopyToClipboardAsync(url);
            await ShowSuccessMessage("Share link copied to clipboard!");
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error copying share link for playlist {PlaylistId}", PlaylistId);
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "An error occurred while generating the share link.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
    }

    private async Task AddSongToPlaylist()
    {
        if (searchModalRef != null)
        {
            await searchModalRef.Open();
        }
    }

    private async Task HandleSongSelected(SearchResult selectedSong)
    {
        if (string.IsNullOrEmpty(PlaylistId) || selectedSong == null)
            return;

        // Optimistically add to local list immediately
        var newSong = new PlaylistSongDto
        {
            Id = selectedSong.Id,
            Title = selectedSong.Title,
            SongNumber = selectedSong.SongNumber,
            WrittenBy = selectedSong.Artist,
            SortOrder = (playlistCollection?.Songs.Count ?? 0) + 1,
            DateScheduled = DateTimeOffset.UtcNow
        };

        playlistCollection?.Songs.Add(newSong);
        filteredSongs = playlistCollection?.Songs.ToList() ?? filteredSongs;
        StateHasChanged();

        try
        {
            var response = await _playlistsApi.AddSongToPlaylist(PlaylistId, selectedSong.Id);

            if (response.IsSuccessStatusCode)
            {
                await ShowSuccessMessage("Song added to playlist.");
                // Background refresh to pick up Key and accurate data
                _ = RefreshSongList();
            }
            else
            {
                // Rollback optimistic add
                playlistCollection?.Songs.Remove(newSong);
                filteredSongs = playlistCollection?.Songs.ToList() ?? filteredSongs;
                StateHasChanged();

                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            // Rollback optimistic add
            playlistCollection?.Songs.Remove(newSong);
            filteredSongs = playlistCollection?.Songs.ToList() ?? filteredSongs;
            StateHasChanged();

            _logger.LogError(ex, "Error adding song to playlist");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "An error occurred while adding the song to the playlist.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
    }

    private async Task RefreshSongList()
    {
        try
        {
            Refit.IApiResponse<PlaylistSongs>? response = null;

            if (IsLandingContext)
            {
                var sharedResponse = await _shareApi.GetSharedPlaylist(PlaylistId);
                if (sharedResponse.IsSuccessStatusCode && sharedResponse.Content != null)
                    response = sharedResponse;
            }

            response ??= await _playlistsApi.GetPlaylistById(PlaylistId);

            if (response.IsSuccessStatusCode && response.Content != null)
            {
                playlistCollection = response.Content;
                filteredSongs = playlistCollection.Songs.ToList();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            _logger.LogWarning(ex, "Background song list refresh failed");
        }
    }

    private void DeletePlaylist()
    {
        if (playlistCollection == null) return;
        var playlistId = playlistCollection.Playlist.Id;

        _modalService.Show(new ModalOptionDto
        {
            Title = "Delete Playlist",
            Message = $"Are you sure you want to delete '{playlistCollection.Playlist.Title}'?",
            DangerText = $"This will remove the playlist and all its {playlistCollection.Songs.Count} songs.",
            ButtonText = "Delete",
            OptionType = OptionType.Confirmation,
            OnConfirmCallback = () => ExecuteDeletePlaylist(playlistId)
        });
    }

    private async Task ExecuteDeletePlaylist(string playlistId)
    {
        try
        {
            var response = await _playlistsApi.DeletePlaylist(playlistId);

            if (response.IsSuccessStatusCode)
            {
                await ShowSuccessMessage("Playlist deleted successfully.");
                await Task.Delay(1000);
                await GoBack();
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error deleting playlist");
            _modalService.Show(new ModalOptionDto
            {
                Title = "Error",
                Message = "Failed to delete playlist.",
                ButtonText = "Close",
                OptionType = OptionType.Error
            });
        }
    }

    private void RemoveSongFromPlaylist(string songId)
    {
        var song = filteredSongs.FirstOrDefault(s => s.Id == songId);
        if (song == null) return;

        _modalService.Show(new ModalOptionDto
        {
            Title = "Remove Song",
            Message = $"Remove '{song.Title}' from this playlist?",
            ButtonText = "Remove",
            OptionType = OptionType.Confirmation,
            OnConfirmCallback = () => ExecuteRemoveSong(songId)
        });
    }

    private async Task ExecuteRemoveSong(string songId)
    {
        try
        {
            var response = await _playlistsApi.RemoveSongFromPlaylist(PlaylistId, songId);

            if (response.IsSuccessStatusCode)
            {
                await ShowSuccessMessage("Song removed from playlist.");
                await LoadPlaylist();
            }
            else
            {
                var errorMessage = _apiResponseHandler.GetApiErrorMessage(response);
                _modalService.Show(new ModalOptionDto
                {
                    Title = "Error",
                    Message = errorMessage,
                    ButtonText = "Close",
                    OptionType = OptionType.Error
                });
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error removing song from playlist");
        }
    }

    private async Task ShareSong(string songId)
    {
        try
        {
            var url = IsLandingContext
                ? _navManager.ToAbsoluteUri($"/songs/landing/{songId}").ToString()
                : _navManager.ToAbsoluteUri($"/songs/{songId}").ToString();
            await _clipboardService.CopyToClipboardAsync(url);
            await ShowSuccessMessage("Song share link copied to clipboard!");
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error sharing song");
        }
    }

    private void InitiateSongMove(string songId)
    {
        var song = filteredSongs.FirstOrDefault(s => s.Id == songId);

        if (song != null)
        {
            movingContext = new MovingContext
            {
                SourceCollectionId = PlaylistId,
                SongId = songId,
                SongTitle = song.Title
            };
            StateHasChanged();
        }
    }

    private void CancelMove()
    {
        movingContext = null;
        StateHasChanged();
    }

    private void OpenSong(string songId)
    {
                _ = Task.Run(async () =>
        {
           try
           {
               await _storageService.SetItemAsync("ActiveView", ActiveView);
               await _storageService.SetItemAsync("ViewMode", ViewMode.Playlists);
               await _playHistoryApi.LogSongPlay(songId, "SongList");
           }
           catch (Exception ex)
           {
               _logger.LogWarning(ex, "Failed to log song play from list for song {SongId}", songId);
           }
        });
        if (IsLandingContext)
            _navManager.NavigateTo($"/songs/landing/{songId}");
        else
            _navManager.NavigateTo($"/songs/{songId}");
    }

    private async Task OnSearchInput()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(SearchDebounceMs, _debounceCts.Token);
            ApplySearch();
        }
        catch (TaskCanceledException)
        {
            // Expected when cancelled
        }
    }

    private void ApplySearch()
    {
        if (playlistCollection == null) return;

        if (string.IsNullOrEmpty(searchQuery))
        {
            filteredSongs = playlistCollection.Songs.ToList();
        }
        else
        {
            filteredSongs = playlistCollection.Songs
                .Where(s => s.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                           (s.WrittenBy?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false))
                .ToList();
        }

        StateHasChanged();
    }

    private void ClearSearch()
    {
        searchQuery = string.Empty;
        ApplySearch();
    }

    private async Task GoBack()
    {
        await _storageService.SetItemAsync("ExpandedPlaylistId", PlaylistId);
        await JsRt.InvokeVoidAsync("goBack");
    }

    private void ShowAuthenticationRequired()
    {
        var returnUrl = Uri.EscapeDataString(_navManager.Uri);
        _modalService.Show(new ModalOptionDto
        {
            Title = "Login Required",
            Message = "Please log in to view playlists.",
            HyperlinkText = "Go to Login",
            ButtonText = "Close",
            OptionType = OptionType.Info,
            OnConfirmCallback = () =>
            {
                _navManager.NavigateTo($"/login?returnUrl={returnUrl}");
                return Task.CompletedTask;
            }
        });
    }

    private async Task ShowSuccessMessage(string message)
    {
        successMessage = message;
        showSuccessMessage = true;
        StateHasChanged();

        // Auto-hide after 3 seconds
        await Task.Delay(3000);
        showSuccessMessage = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
    }
}