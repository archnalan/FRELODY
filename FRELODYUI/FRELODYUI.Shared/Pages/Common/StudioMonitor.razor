@using FRELODYUI.Shared.Services
@inject ISongExtractionAiService _aiService

<div class="ii-monitor-outer">
    @if (Song != null)
    {
        <div class="mon-card">
            <button class="mon-btn-close" @onclick="OnClear" title="Clear" type="button">
                <i class="bi bi-x-lg"></i>
            </button>
            <div class="mon-header">
                <div class="mon-title-block">
                    @if (Song.SongNumber.HasValue)
                    {
                        <span class="mon-song-number">@Song.SongNumber</span>
                    }
                    <h3 class="mon-song-title">@Song.Title</h3>
                    <span class="mon-source-badge badge-extracted">Draft</span>
                </div>
                <div class="mon-actions">
                    @* Edit dropdown (Bootstrap) — AI Refine + Customize *@
                    <div class="dropdown">
                        <button class="mon-btn dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false"
                                disabled="@isRefining">
                            <i class="bi bi-pencil-square"></i>
                            <span>Edit</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @if (_aiService.IsAvailable)
                            {
                                <li>
                                    <button class="dropdown-item" type="button"
                                            disabled="@isRefining"
                                            @onclick="RefineWithAi">
                                        @if (isRefining)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"
                                                  style="width:0.85rem;height:0.85rem;border-width:2px;"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-stars me-2"></i>
                                        }
                                        AI Refine
                                    </button>
                                </li>
                            }
                            <li>
                                <button class="dropdown-item" type="button" @onclick="CustomizeSong"
                                        disabled="@isRefining">
                                    <i class="bi bi-sliders me-2"></i>
                                    Customize
                                </button>
                            </li>
                        </ul>
                    </div>
                    @* Play / Saving / Save button *@
                    @if (isSaving)
                    {
                        <button class="mon-btn mon-btn--play" disabled type="button">
                            <span class="spinner-border spinner-border-sm"
                                  style="width:0.85rem;height:0.85rem;border-width:2px;"></span>
                            <span>Saving…</span>
                        </button>
                    }
                    else if (!string.IsNullOrEmpty(savedSongId))
                    {
                        <a class="mon-btn mon-btn--play @(isRefining ? "disabled" : "")" href="/songs/@savedSongId"
                           @onclick:preventDefault="@isRefining">
                            @if (isRefining)
                            {
                                <span class="spinner-border spinner-border-sm"
                                      style="width:0.85rem;height:0.85rem;border-width:2px;"></span>
                                <span>Refining…</span>
                            }
                            else
                            {
                                <i class="bi bi-play-fill"></i>
                                <span>Play</span>
                            }
                        </a>
                    }
                    else if (!IsAuthenticated)
                    {
                        <button class="mon-btn mon-btn--play" type="button" @onclick="PlayPreview">
                            <i class="bi bi-play-fill"></i>
                            <span>Play</span>
                        </button>
                    }
                    else
                    {
                        <button class="mon-btn mon-btn--save" type="button" @onclick="SaveSong"
                                disabled="@isRefining">
                            <i class="bi bi-floppy"></i>
                            <span>Save</span>
                        </button>
                    }
                </div>
            </div>

            @if (Song.SongLyrics != null && Song.SongLyrics.Count > 0)
            {
                <div class="mon-lyrics-grid">
                    @foreach (var lineGroup in Song.SongLyrics
                            .GroupBy(s => s.LineNumber)
                            .OrderBy(g => g.Key))
                    {
                        <div class="mon-lyric-line">
                            @foreach (var seg in lineGroup.OrderBy(s => s.LyricOrder))
                            {
                                <div class="mon-segment @(string.IsNullOrEmpty(seg.ChordName) ? "" : "has-chord")">
                                    <span class="mon-chord @GetChordAlignmentClass(seg)">
                                        @(seg.ChordName ?? "\u00a0")
                                    </span>
                                    <span class="mon-lyric">@seg.Lyric</span>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="mon-stats">
                    <span><i class="bi bi-list-ol"></i> @Song.SongLyrics.Select(s => s.LineNumber).Distinct().Count() lines</span>
                    <span><i class="bi bi-puzzle"></i> @Song.SongLyrics.Count segments</span>
                    <span><i class="bi bi-music-note"></i> @Song.SongLyrics.Count(s => !string.IsNullOrEmpty(s.ChordName)) chords</span>
                </div>
            }
            else
            {
                <div class="mon-empty-lyrics">
                    <i class="bi bi-music-note-list"></i>
                    <p>No lyrics or chords extracted. Try a different format.</p>
                </div>
            }
        </div>
    }
    else if (DatabaseSong != null)
    {
        <div class="mon-card">
            <button class="mon-btn-close" @onclick="OnClear" title="Clear" type="button">
                <i class="bi bi-x-lg"></i>
            </button>
            <div class="mon-header">
                <div class="mon-title-block">
                    <h3 class="mon-song-title">@DatabaseSong.Title</h3>
                    <span class="mon-source-badge badge-database">Library</span>
                </div>
                <div class="mon-actions">
                    <button class="mon-btn mon-btn--open"
                            @onclick="OpenDatabaseSong"
                            title="Open in player"
                            type="button">
                        <i class="bi bi-play-circle"></i>
                        <span>Open</span>
                    </button>
                </div>
            </div>

            @if (DatabaseSong.SongParts?.Any() == true)
            {
                <div class="mon-lyrics-grid">
                    @foreach (var verse in DatabaseSong.SongParts.OrderBy(v => v.PartNumber))
                    {
                        @if (verse.LyricLines?.Any() == true)
                        {
                            @foreach (var line in verse.LyricLines.OrderBy(l => l.LyricLineOrder))
                            {
                                <div class="mon-lyric-line">
                                    @if (line.LyricSegments?.Any() == true)
                                    {
                                        @foreach (var segment in line.LyricSegments.OrderBy(s => s.LyricOrder))
                                        {
                                            <div class="mon-segment @(segment.Chord != null ? "has-chord" : "")">
                                                <span class="mon-chord">
                                                    @(segment.Chord?.ChordName ?? "\u00a0")
                                                </span>
                                                <span class="mon-lyric">@segment.Lyric</span>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public SimpleSongCreateDto? Song { get; set; }
    [Parameter] public SongDto? DatabaseSong { get; set; }
    [Parameter] public MonitorSource Source { get; set; }
    [Parameter] public bool IsAuthenticated { get; set; }
    [Parameter] public string? PastedText { get; set; }
    [Parameter] public string? ScannedImageBase64 { get; set; }
    [Parameter] public EventCallback OnClearRequested { get; set; }
    [Parameter] public EventCallback OnPlayPreview { get; set; }

    private bool isSaving;
    private bool isRefining;
    private string? savedSongId;
    private SimpleSongCreateDto? _previousSong;

    protected override async Task OnParametersSetAsync()
    {
        // Auto-save when a new extracted Song arrives
        if (Song != null && !ReferenceEquals(Song, _previousSong))
        {
            _previousSong = Song;
            savedSongId = null;
            if (IsAuthenticated)
            {
                PrepareSegments();
                savedSongId = await PerformSaveSong();
            }
        }
        else if (Song == null)
        {
            _previousSong = null;
            savedSongId = null;
        }
    }

    private async Task OnClear() => await OnClearRequested.InvokeAsync();

    private async Task RefineWithAi()
    {
        if (!IsAuthenticated)
        {
            await _storageService.SetItemAsync("studioResumeText", PastedText ?? "");
            _navManager.NavigateTo("/login?returnUrl=/studio");
            return;
        }

        if (Song?.SongLyrics == null || !_aiService.IsAvailable) return;

        isRefining = true;
        StateHasChanged();

        try
        {
            var refined = await _aiService.RefineExtractionAsync(PastedText ?? "", Song.SongLyrics, ScannedImageBase64);
            Song.SongLyrics = refined;

            if (!string.IsNullOrEmpty(savedSongId))
            {
                PrepareSegments();
                await _songsApi.UpdateSong(savedSongId, Song);
            }
        }
        catch (Exception ex)
        {
            _modalService.Show(new ModalOptionDto
            {
                Title = "AI Refinement Error",
                Message = $"Could not refine extraction: {ex.Message}",
                ButtonText = "OK",
                Context = new ModalContext { ActionType = "aiError" }
            });
        }
        finally
        {
            isRefining = false;
            StateHasChanged();
        }
    }

    private async Task SaveSong()
    {
        if (!IsAuthenticated)
        {
            await _storageService.SetItemAsync("studioResumeText", PastedText ?? "");
            _navManager.NavigateTo("/login?returnUrl=/studio");
            return;
        }

        if (Song == null) return;
        PrepareSegments();
        if (string.IsNullOrEmpty(savedSongId))
            savedSongId = await PerformSaveSong();
        if (!string.IsNullOrEmpty(savedSongId))
        {
            _modalService.Show(new ModalOptionDto
            {
                Title = "Song Saved",
                Message = $"Song '{Song.Title}' saved successfully!",
                ButtonText = "OK",
                OptionType = OptionType.Success,
                Context = new ModalContext { ActionType = "SongSaved" }
            });
        }
    }

    private async Task CustomizeSong()
    {
        if (!IsAuthenticated)
        {
            await _storageService.SetItemAsync("studioResumeText", PastedText ?? "");
            _navManager.NavigateTo("/login?returnUrl=/studio");
            return;
        }

        if (Song == null) return;
        PrepareSegments();
        var songId = !string.IsNullOrEmpty(savedSongId) ? savedSongId : await PerformSaveSong();
        if (songId != null)
            _navManager.NavigateTo($"/compose?songId={songId}");
    }

    private void OpenDatabaseSong()
    {
        if (DatabaseSong != null)
            _navManager.NavigateTo($"/songs/{DatabaseSong.Slug ?? DatabaseSong.Id}");
    }

    private void PrepareSegments()
    {
        if (Song?.SongLyrics == null) return;
        foreach (var seg in Song.SongLyrics)
        {
            if (seg.PartNumber <= 0)
            {
                seg.PartNumber = 1;
                seg.PartName = seg.PartName == SongSection.unknown ? SongSection.Verse : seg.PartName;
            }
        }
    }

    private async Task PlayPreview()
    {
        if (Song == null) return;
        PrepareSegments();
        await _storageService.SetItemAsync("previewSong", Song);
        await OnPlayPreview.InvokeAsync();
    }

    private async Task<string?> PerformSaveSong()
    {
        if (Song == null) return null;

        isSaving = true;
        StateHasChanged();
        try
        {
            var result = await _songsApi.CreateSong(Song);
            if (result.IsSuccessStatusCode && result.Content != null)
            {
                await _heroDataService.NotifyUserSongsChanged();
                return result.Content.Id;
            }

            var errorMessage = _apiResponseHandler.GetApiErrorMessage(result);
            _modalService.Show(new ModalOptionDto
            {
                Title = "Save Error",
                Message = errorMessage,
                ButtonText = "Close",
                OptionType = OptionType.Error,
                Context = new ModalContext { ActionType = "saveError" }
            });
            return null;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private string GetChordAlignmentClass(SegmentCreateDto seg)
    {
        return seg.ChordAlignment switch
        {
            Alignment.Center => "text-center",
            Alignment.Right => "text-end",
            _ => "text-start"
        };
    }

    public enum MonitorSource
    {
        Extracted,
        Database
    }
}
