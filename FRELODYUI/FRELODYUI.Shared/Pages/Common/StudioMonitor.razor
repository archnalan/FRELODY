@using FRELODYUI.Shared.Services
@inject ISongExtractionAiService _aiService

<div class="studio-monitor @(HasContent ? "studio-monitor--active" : "")">
    @if (Song != null)
    {
        <div class="monitor-card">
            <div class="monitor-header">
                <div class="monitor-title-block">
                    @if (Song.SongNumber.HasValue)
                    {
                        <span class="monitor-song-number">@Song.SongNumber</span>
                    }
                    <h3 class="monitor-song-title">@Song.Title</h3>
                    @if (Source == MonitorSource.Database)
                    {
                        <span class="monitor-source-badge badge-database">Library</span>
                    }
                    else
                    {
                        <span class="monitor-source-badge badge-extracted">Draft</span>
                    }
                </div>
                <div class="monitor-actions">
                    <button class="monitor-action-btn monitor-clear-btn" @onclick="OnClear" title="Clear">
                        <i class="bi bi-x-lg"></i>
                    </button>
                    @if (Source == MonitorSource.Extracted && _aiService.IsAvailable)
                    {
                        <button class="monitor-action-btn monitor-ai-btn"
                                disabled="@IsRefining"
                                @onclick="HandleRefine"
                                title="Refine with AI">
                            @if (IsRefining)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                <span>Refining...</span>
                            }
                            else
                            {
                                <i class="bi bi-stars"></i>
                                <span>AI Refine</span>
                            }
                        </button>
                    }
                    <button class="monitor-action-btn monitor-customize-btn"
                            disabled="@(IsSaving)"
                            @onclick="HandleCustomize"
                            title="Save & Customize">
                        <i class="bi bi-pencil-square"></i>
                        <span>Customize</span>
                    </button>
                    <button class="monitor-action-btn monitor-save-btn"
                            disabled="@(IsSaving)"
                            @onclick="HandleSave"
                            title="Save song">
                        @if (IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            <span>Saving...</span>
                        }
                        else
                        {
                            <i class="bi bi-save"></i>
                            <span>Save</span>
                        }
                    </button>
                </div>
            </div>

            @if (Song.SongLyrics != null && Song.SongLyrics.Count > 0)
            {
                <div class="monitor-lyrics-grid">
                    @foreach (var lineGroup in Song.SongLyrics
                            .GroupBy(s => s.LineNumber)
                            .OrderBy(g => g.Key))
                    {
                        <div class="monitor-lyric-line">
                            @foreach (var seg in lineGroup.OrderBy(s => s.LyricOrder))
                            {
                                <div class="monitor-segment @(string.IsNullOrEmpty(seg.ChordName) ? "" : "has-chord")">
                                    <span class="monitor-chord-name @GetChordAlignmentClass(seg)">
                                        @(seg.ChordName ?? "\u00A0")
                                    </span>
                                    <span class="monitor-lyric-text">@seg.Lyric</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="monitor-stats">
                    <span><i class="bi bi-list-ol"></i> @Song.SongLyrics.Select(s => s.LineNumber).Distinct().Count() lines</span>
                    <span><i class="bi bi-puzzle"></i> @Song.SongLyrics.Count segments</span>
                    <span><i class="bi bi-music-note"></i> @Song.SongLyrics.Count(s => !string.IsNullOrEmpty(s.ChordName)) chords</span>
                </div>
            }
            else
            {
                <div class="monitor-empty-lyrics">
                    <i class="bi bi-music-note-list"></i>
                    <p>No lyrics or chords extracted. Try a different format.</p>
                </div>
            }
        </div>
    }
    else if (DatabaseSong != null)
    {
        <div class="monitor-card">
            <div class="monitor-header">
                <div class="monitor-title-block">
                    <h3 class="monitor-song-title">@DatabaseSong.Title</h3>
                    <span class="monitor-source-badge badge-database">Library</span>
                </div>
                <div class="monitor-actions">
                    <button class="monitor-action-btn monitor-clear-btn" @onclick="OnClear" title="Clear">
                        <i class="bi bi-x-lg"></i>
                    </button>
                    <button class="monitor-action-btn monitor-customize-btn"
                            @onclick="HandleOpenSong"
                            title="Open in player">
                        <i class="bi bi-play-circle"></i>
                        <span>Open</span>
                    </button>
                </div>
            </div>

            @if (DatabaseSong.SongParts?.Any() == true)
            {
                <div class="monitor-lyrics-grid">
                    @foreach (var verse in DatabaseSong.SongParts.OrderBy(v => v.PartNumber))
                    {
                        @if (verse.LyricLines?.Any() == true)
                        {
                            @foreach (var line in verse.LyricLines.OrderBy(l => l.LyricLineOrder))
                            {
                                <div class="monitor-lyric-line">
                                    @if (line.LyricSegments?.Any() == true)
                                    {
                                        @foreach (var segment in line.LyricSegments.OrderBy(s => s.LyricOrder))
                                        {
                                            <div class="monitor-segment @(segment.Chord != null ? "has-chord" : "")">
                                                <span class="monitor-chord-name">
                                                    @(segment.Chord?.ChordName ?? "\u00A0")
                                                </span>
                                                <span class="monitor-lyric-text">@segment.Lyric</span>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public SimpleSongCreateDto? Song { get; set; }
    [Parameter] public SongDto? DatabaseSong { get; set; }
    [Parameter] public MonitorSource Source { get; set; }
    [Parameter] public bool IsRefining { get; set; }
    [Parameter] public bool IsSaving { get; set; }
    [Parameter] public EventCallback OnRefineRequested { get; set; }
    [Parameter] public EventCallback OnSaveRequested { get; set; }
    [Parameter] public EventCallback OnCustomizeRequested { get; set; }
    [Parameter] public EventCallback OnOpenSongRequested { get; set; }
    [Parameter] public EventCallback OnClearRequested { get; set; }

    private bool HasContent => Song != null || DatabaseSong != null;

    private async Task HandleRefine() => await OnRefineRequested.InvokeAsync();
    private async Task HandleSave() => await OnSaveRequested.InvokeAsync();
    private async Task HandleCustomize() => await OnCustomizeRequested.InvokeAsync();
    private async Task HandleOpenSong() => await OnOpenSongRequested.InvokeAsync();
    private async Task OnClear() => await OnClearRequested.InvokeAsync();

    private string GetChordAlignmentClass(SegmentCreateDto seg)
    {
        return seg.ChordAlignment switch
        {
            Alignment.Center => "text-center",
            Alignment.Right => "text-end",
            _ => "text-start"
        };
    }

    public enum MonitorSource
    {
        Extracted,
        Database
    }
}
