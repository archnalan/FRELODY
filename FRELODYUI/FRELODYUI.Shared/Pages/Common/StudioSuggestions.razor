@using FRELODYUI.Shared.Services
@inject IFormFactor FormFactor
@inject ISongExtractionAiService _aiService
@inject ICameraService _cameraService
@inject IOcrApi _ocrApi

<div class="studio-suggestions">
    @if (ShowSuggestions)
    {
        <div class="ss-panel">
            @if (string.IsNullOrEmpty(Query))
            {
                @if (RecentSearches.Any())
                {
                    <p class="ss-section-title">Recent</p>
                    <div class="ss-list">
                        @foreach (var (term, idx) in RecentSearches.Take(5).Select((t, i) => (t, i)))
                        {
                            <div class="ss-item @(SelectedIndex == idx ? "ss-item--active" : "")"
                                 @onclick="() => OnRecentSelected(term)">
                                <div class="ss-item-left">
                                    <div class="ss-item-text">
                                        <span class="ss-item-title">@term</span>
                                    </div>
                                </div>
                                <div class="ss-item-right">
                                    <span class="ss-badge ss-badge--recent">Recent</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="ss-empty">Search for songs or paste lyrics above</div>
                }
            }
            else if (IsLoading)
            {
                <div class="ss-list">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="ss-item ss-item--loading">
                            <div class="ss-item-left" style="flex:1;">
                                <div style="flex:1;">
                                    <div class="ss-skeleton" style="width:55%;"></div>
                                    <div class="ss-skeleton" style="width:35%;height:0.65rem;"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (Suggestions.Any())
            {
                <p class="ss-section-title">Songs</p>
                <div class="ss-list">
                    @for (int i = 0; i < Suggestions.Count; i++)
                    {
                        var suggestion = Suggestions[i];
                        var index = i;
                        <div class="ss-item @(index == SelectedIndex ? "ss-item--active" : "")"
                             @onclick="() => SelectSuggestion(suggestion)">
                            <div class="ss-item-left">
                                @if (suggestion.SongNumber.HasValue)
                                {
                                    <span class="ss-item-number">@suggestion.SongNumber</span>
                                }
                                <div class="ss-item-text">
                                    <span class="ss-item-title">@suggestion.Title</span>
                                    @if (!string.IsNullOrEmpty(suggestion.Artist))
                                    {
                                        <span class="ss-item-sub">@suggestion.Artist</span>
                                    }
                                </div>
                            </div>
                            <div class="ss-item-right">
                                @if (!string.IsNullOrEmpty(suggestion.Album))
                                {
                                    <span class="ss-item-album">@suggestion.Album</span>
                                }
                                <span class="ss-badge ss-badge--@suggestion.Source.ToString().ToLower()">
                                    @suggestion.Source
                                </span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="ss-empty">No songs found for &ldquo;@Query&rdquo;</div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string Query { get; set; } = string.Empty;
    [Parameter] public bool ShowSuggestions { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public List<StudioSuggestion> Suggestions { get; set; } = new();
    [Parameter] public List<string> RecentSearches { get; set; } = new();
    [Parameter] public int SelectedIndex { get; set; } = -1;
    [Parameter] public EventCallback<StudioSuggestion> OnSuggestionSelected { get; set; }
    [Parameter] public EventCallback<string> OnRecentSearchSelected { get; set; }

    private async Task SelectSuggestion(StudioSuggestion suggestion)
    {
        await OnSuggestionSelected.InvokeAsync(suggestion);
    }

    private async Task OnRecentSelected(string term)
    {
        await OnRecentSearchSelected.InvokeAsync(term);
    }
}
