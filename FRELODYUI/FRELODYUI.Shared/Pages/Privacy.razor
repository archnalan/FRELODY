@page "/privacy"
@layout LandingLayout

<PageTitle>Privacy Policy - FRELODY</PageTitle>

<!-- Hero -->
<section class="pv-hero">
    <div class="pv-shell">
        <span class="pv-eyebrow">Privacy Policy</span>
        <h1 class="pv-hero-title">Your music, your data, your control</h1>
        <p class="pv-hero-sub">
            We built FRELODY to help you learn songs — not to harvest your personal information.
            This policy explains what we collect, why, and how you stay in charge.
        </p>
        <p class="pv-effective">Effective date: 1 June 2026</p>
    </div>
</section>

<!-- Table of Contents -->
<section class="pv-toc-section">
    <div class="pv-shell">
        <nav class="pv-toc" aria-label="Policy sections">
            <h2 class="pv-toc-title">Contents</h2>
            <ol class="pv-toc-list">
                <li><a href="#about">About this policy</a></li>
                <li><a href="#collect">Information we collect</a></li>
                <li><a href="#use">How we use your information</a></li>
