<section class="pv-legal">
    <div class="pv-shell">
        <p class="pv-legal-text">
            <i class="bi bi-info-circle"></i>
            By using FRELODY you agree to our
            <a href="/terms">Terms of Service</a> and this Privacy Policy.
        </p>
    </div>
</section>
