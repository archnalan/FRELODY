@page "/studio"
@using FRELODYUI.Shared.Services

<PageTitle>Studio</PageTitle>

<div class="ii-page">
    <div class="ii-scroll-root">

        @* ── Auth pill header ── *@
        <header class="ii-header">
            <div class="ii-offer-pill">
                @if (isAuthenticated)
                {
                    <a href="/songs-library" class="ii-offer-btn">
                        <i class="bi bi-collection ii-offer-icon" aria-hidden="true"></i>
                        <span>My Library</span>
                    </a>
                }
                else
                {
                    <a href="/login?returnUrl=/studio" class="ii-offer-btn">
                        <i class="bi bi-star-fill ii-offer-icon" aria-hidden="true"></i>
                        <span>Sign in free</span>
                    </a>
                }
            </div>
        </header>

        <main class="ii-main">
            <div class="ii-landing">

                @* ── Splash headline ── *@
                <div class="ii-splash">
                    <div class="ii-splash-icon-wrap">
                        <span class="bi bi-easel ii-splash-icon" aria-hidden="true"></span>
                    </div>
                    <h1 class="ii-splash-heading k-display">Chord Flow</h1>
                    <p class="ii-splash-sub">Song Chord Lab</p>
                </div>

                @* ── Shared composer (textarea + URL detect + file + camera + suggestions) ── *@
                <div class="ii-composer-host">
                    <StudioImportPanel @ref="_importPanel"
                                       ShowDatabaseSearch="true"
                                       ShowFormatHint="true"
                                       CompactWhenIdle="true"
                                       HasContentBelow="@(extractedSong != null || databaseSong != null)"
                                       FileInputId="studioFileInput"
                                       MinRows="3"
                                       OnSongExtracted="HandleSongExtracted"
                                       OnDatabaseSuggestionSelected="HandleDatabaseSuggestion"
                                       ProcessingStateChanged="HandleProcessingStateChanged" />
                </div>

                @* ── Monitor: extracted or database song ── *@
                @if (extractedSong != null || databaseSong != null)
                {
                    <div class="ii-monitor-wrap" @ref="monitorWrapRef" tabindex="-1">
                        <StudioMonitor Song="@extractedSong"
                                       DatabaseSong="@databaseSong"
                                       Source="@monitorSource"
                                       IsAuthenticated="@isAuthenticated"
                                       PastedText="@(_importPanel?.pastedText)"
                                       ScannedImageBase64="@(_importPanel?.scannedImageBase64)"
                                       OnClearRequested="ClearMonitor"
                                       OnPlayPreview="HandlePlayPreview" />
                    </div>
                }

                @* ── Empty state: starter cards ── *@
                @if (extractedSong == null && databaseSong == null && !_isProcessing)
                {
                    <div class="ii-starter-wrap">
                        <section class="ii-starter" aria-label="Get started">
                            <ul class="ii-starter-list">
                                <li>
                                    <button type="button" class="ii-starter-btn" @onclick="ShowRecentSearches">
                                        <i class="bi bi-search ii-starter-leading"></i>
                                        <span class="ii-starter-text">
                                            <span class="ii-starter-title">Search by song title</span>
                                            <span class="ii-starter-desc">Find any song from the library by title or artist</span>
                                        </span>
                                        <i class="bi bi-arrow-up-right ii-starter-arrow"></i>
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="ii-starter-btn" @onclick="InsertExampleText">
                                        <i class="bi bi-text-paragraph ii-starter-leading"></i>
                                        <span class="ii-starter-text">
                                            <span class="ii-starter-title">Paste with inline chords</span>
                                            <span class="ii-starter-desc">[Am]Amazing [F]Grace, how [C]sweet the [G]sound</span>
                                        </span>
                                        <i class="bi bi-arrow-up-right ii-starter-arrow"></i>
                                    </button>
                                </li>
                                <li>
                                    <label for="studioFileInput" class="ii-starter-btn" style="cursor:pointer;">
                                        <i class="bi bi-file-earmark-arrow-up ii-starter-leading"></i>
                                        <span class="ii-starter-text">
                                            <span class="ii-starter-title">Upload a file</span>
                                            <span class="ii-starter-desc">Import lyrics from a .pdf, .txt, or .docx file</span>
                                        </span>
                                        <i class="bi bi-arrow-up-right ii-starter-arrow"></i>
                                    </label>
                                </li>
                                @if (_importPanel?.IsCameraAvailable == true)
                                {
                                    <li>
                                        <button type="button" class="ii-starter-btn" @onclick="TriggerScan">
                                            <i class="bi bi-camera ii-starter-leading"></i>
                                            <span class="ii-starter-text">
                                                <span class="ii-starter-title">Scan a song sheet</span>
                                                <span class="ii-starter-desc">Use your camera to capture and extract chords</span>
                                            </span>
                                            <i class="bi bi-arrow-up-right ii-starter-arrow"></i>
                                        </button>
                                    </li>
                                }
                            </ul>
                        </section>
                    </div>
                }

            </div>
        </main>
    </div>
</div>

@code {
    // ── State ──
    private bool isAuthenticated;
    private bool _isProcessing;
    private bool _shouldScrollToMonitor;
    private ElementReference monitorWrapRef;
    private StudioImportPanel? _importPanel;

    // ── Monitor data ──
    private SimpleSongCreateDto? extractedSong;
    private SongDto? databaseSong;
    private StudioMonitor.MonitorSource monitorSource = StudioMonitor.MonitorSource.Extracted;

    protected override async Task OnInitializedAsync()
    {
        var authState = await _globalAuth.GetAuthenticationStateAsync();
        isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var resumeText = await _storageService.GetItemAsync<string>("studioResumeText");
                if (!string.IsNullOrEmpty(resumeText))
                {
                    _importPanel?.SetText(resumeText);
                    await _storageService.RemoveItemAsync("studioResumeText");
                }
            }
            catch { }
        }

        if (_shouldScrollToMonitor)
        {
            _shouldScrollToMonitor = false;
            if (monitorWrapRef.Id != null)
                await JsRt.InvokeVoidAsync("scrollToElementStart", monitorWrapRef);
        }
    }

    // ── Panel callbacks ──
    private void HandleProcessingStateChanged(bool busy)
    {
        _isProcessing = busy;
        StateHasChanged();
    }

    private async Task HandleSongExtracted(StudioImportPanel.SongExtractionResult result)
    {
        extractedSong = result.Song;
        databaseSong = null;
        monitorSource = StudioMonitor.MonitorSource.Extracted;
        _shouldScrollToMonitor = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleDatabaseSuggestion(StudioSuggestion suggestion)
    {
        if (suggestion.Source == SuggestionSource.Database && !string.IsNullOrWhiteSpace(suggestion.Id))
        {
            _navManager.NavigateTo($"/songs/{suggestion.Id}");
            return;
        }

        // Fallback for non-database suggestions
        var response = await _songsApi.GetSongWithChordsById(suggestion.Id);
        if (response.IsSuccessStatusCode && response.Content != null)
        {
            databaseSong = response.Content;
            extractedSong = null;
            monitorSource = StudioMonitor.MonitorSource.Database;
            _shouldScrollToMonitor = true;
        }

        StateHasChanged();
    }

    // ── Starter cards ──
    private async Task ShowRecentSearches()
    {
        if (_importPanel != null)
            await _importPanel.ShowRecentSearchesAsync();
    }

    private void InsertExampleText()
    {
        _importPanel?.SetText("[Am]Amazing [F]Grace, how [C]sweet the [G]sound");
    }

    private async Task TriggerScan()
    {
        if (_importPanel != null)
            await _importPanel.TriggerScanAsync();
    }

    // ── Monitor handlers ──
    private void HandlePlayPreview()
    {
        var isLanding = _navManager.Uri.Contains("/landing", StringComparison.OrdinalIgnoreCase);
        var path = isLanding ? "/songs/landing/preview" : "/songs/preview";
        _navManager.NavigateTo(path);
    }

    private void ClearMonitor()
    {
        extractedSong = null;
        databaseSong = null;
        _importPanel?.Reset();
        StateHasChanged();
    }
}
