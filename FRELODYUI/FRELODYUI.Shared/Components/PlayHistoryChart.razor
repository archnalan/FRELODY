@using System.Linq
@inject IJSRuntime JS
@implements IAsyncDisposable

<div id="@_chartId" class="play-history-chart-container">
    @if (Data == null || !Data.Any())
    {
        <div class="empty-chart">
            <p class="text-muted">No data available</p>
        </div>
    }
</div>

@code {
    [Parameter] public Dictionary<DateTime, int>? Data { get; set; }

    private IJSObjectReference? _module;
    private readonly string _chartId = $"phc-{Guid.NewGuid():N}";
    private Dictionary<DateTime, int>? _lastRenderedData;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/FRELODYUI.Shared/Components/PlayHistoryChart.razor.js");
        }

        if (_module != null && Data?.Any() == true && !ReferenceEquals(Data, _lastRenderedData))
        {
            _lastRenderedData = Data;
            var sorted = Data.OrderBy(d => d.Key).Take(30).ToList();
            var labels = sorted.Select(d => d.Key.ToString("MMM dd")).ToArray();
            var values = sorted.Select(d => d.Value).ToArray();
            await _module.InvokeVoidAsync("renderChart", _chartId, labels, values);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module != null)
        {
            try { await _module.InvokeVoidAsync("destroyChart", _chartId); } catch { }
            try { await _module.DisposeAsync(); } catch { }
        }
    }
}
