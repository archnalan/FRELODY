@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        @if (IsSidebarCollapsed)
        {
            <div class="logo-collapse-zone desktop-only">
                <a class="navbar-brand d-flex align-items-center gap-2 logo-home-link" href="/">
                    <img src="_content/FRELODYUI.Shared/fet_melody_logo.png" alt="Frelody" class="nav-logo-img" />
                </a>
                <button class="sidebar-expand-btn" @onclick="OnToggleSidebar" title="Expand sidebar" aria-label="Expand sidebar">
                    <i class="bi bi-layout-sidebar"></i>
                </button>
            </div>
        }
        @* Mobile always sees expanded brand; desktop sees it only when not collapsed *@
        <a class="navbar-brand d-flex align-items-center gap-2 logo-home-link @(IsSidebarCollapsed ? "mobile-only" : "")" href="/">
            <img src="_content/FRELODYUI.Shared/fet_melody_logo.png" alt="Frelody" class="nav-logo-img" />
            <span class="nav-brand-text">FRELODY</span>
        </a>
        <button class="sidebar-collapse-toggle d-desktop-flex" @onclick="OnToggleSidebar" title="@(IsSidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")" aria-label="@(IsSidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")">
            <i class="bi @(IsSidebarCollapsed ? "bi-layout-sidebar" : "bi-layout-sidebar-reverse")"></i>
        </button>
        <button class="mobile-drawer-close" @onclick="HandleCloseMobile" aria-label="Close menu">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
</div>

<CascadingAuthenticationState>
<div class="nav-scrollable">
    <div class="nav-items-scrollable">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/studio" Match="NavLinkMatch.All">
                <span class="bi bi-easel-nav-menu" aria-hidden="true"></span>
                <span class="nav-label">Studio</span>
                <span class="ms-auto compose-alert-dot"
                      data-bs-toggle="tooltip"
                      title="Popular"></span>
            </NavLink>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/dashboard" Match="NavLinkMatch.All">
                        <span class="bi bi-card-list-nav-menu" aria-hidden="true"></span> 
                        <span class="nav-label">Dashboard</span>
                        <span class="ms-auto compose-alert-dot"
                                  data-bs-toggle="tooltip"
                                  title="Popular"></span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link align-items-center" href="/songs-library" Match="NavLinkMatch.Prefix">
                        <span class="bi bi-collection-play-fill-nav-menu" aria-hidden="true"></span> <span class="nav-label">Library</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link align-items-center" href="/playlists" Match="NavLinkMatch.Prefix">
                            <span class="bi bi-music-note-list-nav-menu" aria-hidden="true"></span> <span class="nav-label">Playlists</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="compose" Match="NavLinkMatch.Prefix">
                            <span class="bi bi-pencil-square-nav-menu" aria-hidden="true"></span> 
                            <span class="nav-label">Compose</span>
                            <span class="ms-auto compose-alert-dot"
                                  data-bs-toggle="tooltip"
                                  title="Popular"></span>
                    </NavLink>
                </div>
                @* <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/chords" Match="NavLinkMatch.Prefix">
                            <span class="bi bi-sliders-nav-menu" aria-hidden="true"></span> <span class="nav-label">Chords</span>
                    </NavLink>
                </div> *@

                @* ── Your Songs (collapsible, expanded mode only) ── *@
                @if (hasUserSongs)
                {
                <div class="nav-your-songs @(IsSidebarCollapsed ? "collapsed-hidden" : "")">
                    <button class="your-songs-toggle" @onclick="ToggleYourSongs" type="button">
                        <span class="your-songs-label">Your Songs</span>
                        <i class="bi bi-chevron-@(isYourSongsExpanded ? "up" : "down") your-songs-chevron"></i>
                    </button>
                    @if (isYourSongsExpanded)
                    {
                        <div class="your-songs-list" data-songs-scroll>
                            @if (userSongs.Any())
                            {
                                @foreach (var group in GroupedSongs)
                                {
                                    <div class="your-songs-date-group">
                                        <button class="your-songs-date-toggle" @onclick="() => ToggleDateGroup(group.Key)" type="button">
                                            <span class="your-songs-date-label">@group.Key</span>
                                            <span class="your-songs-date-count">@group.Value.Count</span>
                                            <i class="bi bi-chevron-@(IsDateGroupExpanded(group.Key) ? "up" : "down") your-songs-date-chevron"></i>
                                        </button>
                                        @if (IsDateGroupExpanded(group.Key))
                                        {
                                            @foreach (var song in group.Value)
                                            {
                                                <div class="your-songs-item-wrapper @(activeSongMenuId == song.IdString ? "menu-open" : "") @(IsActiveSong(song.IdString) ? "active" : "")">
                                                    @if (renamingSongId == song.IdString)
                                                    {
                                                        <div class="your-songs-rename-row">
                                                            <input class="your-songs-rename-input" @bind="renameValue"
                                                                   @bind:event="onchange"
                                                                   @onkeydown="HandleRenameKeyDown"
                                                                   @onblur="HandleRenameBlur" />
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        @if (song.ValueSubText == "pinned")
                                                        {
                                                            <i class="bi bi-pin-fill your-songs-pin-icon"></i>
                                                        }
                                                        <a class="your-songs-item" href="/songs/@song.IdString" @onclick="() => SelectSong(song.IdString)">
                                                            <span class="your-songs-title">@song.ValueText</span>
                                                        </a>
                                                        <button class="your-songs-more-btn" @onclick="() => ToggleSongMenu(song.IdString)" @onclick:stopPropagation type="button">
                                                            <i class="bi bi-three-dots"></i>
                                                        </button>
                                                    }
                                                    @if (activeSongMenuId == song.IdString)
                                                    {
                                                        <div class="your-songs-context-menu" @onclick:stopPropagation>
                                                            <button type="button" @onclick="() => ShareSong(song)"><i class="bi bi-share"></i> Share</button>
                                                            <button type="button" @onclick="() => PinSong(song)"><i class="bi @(song.ValueSubText == "pinned" ? "bi-pin-fill" : "bi-pin")"></i> @(song.ValueSubText == "pinned" ? "Unpin" : "Pin")</button>
                                                            <button type="button" @onclick="() => StartRenameSong(song)"><i class="bi bi-pencil"></i> Rename</button>
                                                            <button type="button" @onclick="() => ArchiveSongItem(song)"><i class="bi bi-archive"></i> Archive</button>
                                                            <button type="button" class="ctx-danger" @onclick="() => ConfirmDeleteSong(song)"><i class="bi bi-trash3"></i> Delete</button>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                                @* Ghost skeleton placeholders while loading more *@
                                @if (isLoadingSongs)
                                {
                                    @for (int i = 0; i < 3; i++)
                                    {
                                        <div class="your-songs-ghost">
                                            <div class="ghost-line"></div>
                                        </div>
                                    }
                                }
                            }
                            else if (isLoadingSongs)
                            {
                                @for (int i = 0; i < 5; i++)
                                {
                                    <div class="your-songs-ghost">
                                        <div class="ghost-line"></div>
                                    </div>
                                }
                            }
                            else
                            {
                                <span class="your-songs-empty">No songs yet</span>
                            }
                        </div>
                    }
                </div>
                }

            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <button class="nav-link theme-icon-btn w-100" @onclick="ToggleTheme" title="Toggle theme">
                        <span class="theme-icon-wrapper">
                            @if (isDarkTheme)
                            {
                                <i class="bi bi-sun-fill theme-icon"></i>
                            }
                            else
                            {
                                <i class="bi bi-moon-fill theme-icon"></i>
                            }
                        </span>
                        <span class="nav-label">@(isDarkTheme ? "Light mode" : "Dark mode")</span>
                    </button>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
    <AuthorizeView>
        <Authorized>
            @{
                var firstName = context.User.FindFirst("FirstName")?.Value;
                var lastName = context.User.FindFirst("LastName")?.Value;
                var fullName = firstName + " " + lastName;
                var displayName = fullName.Length > 15 ? fullName.Substring(0, 15) + "..." : fullName;
            }
            <div class="nav-footer">
                <div class="nav-item px-3 dropdown dropup">
                    <button class="nav-link dropdown-toggle w-100 d-flex justify-content-between align-items-center" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="user-avatar-circle me-2">
                            <span>
                                @(firstName?.FirstOrDefault())@(lastName?.FirstOrDefault())
                            </span>
                        </div>
                        <span class="nav-label">@displayName</span>
                    </button>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" href="/">
                                <i class="bi bi-house-door"></i><span class="nav-label">Home</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/user-profile/@(context.User.FindFirst("UserId")?.Value)">
                                <i class="bi bi-person"></i><span class="nav-label">View Profile</span>
                            </a>
                        </li>
                        @* @if (isPremiumUser)
                        {
                            <li>
                                <a class="dropdown-item" href="/users">
                                    <i class="bi bi-people"></i><span class="nav-label">Accounts</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="my-2">
                                <span class="ms-3 disabled text-muted"
                                      style="cursor: pointer;">
                                    <i class="bi bi-people"></i><span class="nav-label">Accounts</span>
                                </span>
                                <i class="bi bi-stars icon-premium"
                                   data-bs-toggle="tooltip"
                                   title="Premium Feature"></i>
                            </li>
                        } *@
                        <li class="form-check form-switch mx-3">
                            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckChecked"
                                   checked="@(!isDarkTheme)" @onchange="ToggleTheme">
                            <label class="form-check-label" for="switchCheckChecked" @onclick:preventDefault><span class="nav-label">Theme</span></label>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><button class="dropdown-item text-danger border-0 bg-transparent w-100 text-start" @onclick="TriggerLogout">
                            <i class="bi bi-box-arrow-right"></i><span class="nav-label">Log out</span>
                        </button></li>
                    </ul>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="nav-footer">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/login">
                        <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span> <span class="nav-label">Login</span>
                    </NavLink>
                </div>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>
</CascadingAuthenticationState>



@code {
    private bool isDarkTheme = false;
    private bool isPremiumUser;

    // Your Songs state
    private bool isYourSongsExpanded;
    private bool isLoadingSongs;
    private bool hasMoreSongs;
    private bool hasUserSongs;
    private List<ComboBoxDto> userSongs = new();
    private int songsOffset;
    private const int SongsPageSize = 15;

    // Context menu & rename state
    private string? activeSongMenuId;
    private string? renamingSongId;
    private string renameValue = "";
    private bool _isCommittingRename;
    private DotNetObjectReference<NavMenu>? _selfRef;
    private bool _scrollObserverAttached;

    [Parameter] public bool IsSidebarCollapsed { get; set; }
    [Parameter] public EventCallback OnToggleSidebar { get; set; }
    [Parameter] public EventCallback OnCloseMobileDrawer { get; set; }

    // Date group expansion state & selected song for active highlight
    private HashSet<string> expandedDateGroups = new();
    private string? selectedSongId;

    private IEnumerable<ComboBoxDto> SortedSongs =>
        userSongs.OrderByDescending(s => s.ValueSubText == "pinned").ThenBy(s => userSongs.IndexOf(s));

    private Dictionary<string, List<ComboBoxDto>> GroupedSongs
    {
        get
        {
            var now = DateTimeOffset.UtcNow;
            var today = now.Date;
            var yesterday = today.AddDays(-1);
            var lastWeekStart = today.AddDays(-7);

            var groups = new Dictionary<string, List<ComboBoxDto>>();

            foreach (var song in SortedSongs)
            {
                var date = (song.DateModified ?? song.DateCreated)?.Date;
                var category = date switch
                {
                    not null when date == today => "Today",
                    not null when date == yesterday => "Yesterday",
                    not null when date >= lastWeekStart => "Last week",
                    _ => "Recent"
                };

                if (!groups.ContainsKey(category))
                    groups[category] = new();

                groups[category].Add(song);
            }

            // Ensure consistent ordering of categories
            var ordered = new Dictionary<string, List<ComboBoxDto>>();
            foreach (var key in new[] { "Today", "Yesterday", "Last week", "Recent" })
            {
                if (groups.TryGetValue(key, out var list))
                    ordered[key] = list;
            }
            return ordered;
        }
    }

    private bool IsDateGroupExpanded(string groupKey) => expandedDateGroups.Contains(groupKey);

    private void ToggleDateGroup(string groupKey)
    {
        if (!expandedDateGroups.Remove(groupKey))
            expandedDateGroups.Add(groupKey);
    }

    private bool IsActiveSong(string? songId) =>
        !string.IsNullOrEmpty(songId) &&
        (songId == selectedSongId || _navManager.Uri.Contains($"/songs/{songId}", StringComparison.OrdinalIgnoreCase));

    private void SelectSong(string? songId)
    {
        selectedSongId = songId;
        CloseContextMenu();
    }

    private void SyncSelectedSongFromUrl()
    {
        var uri = _navManager.Uri;
        var match = userSongs.FirstOrDefault(s => !string.IsNullOrEmpty(s.IdString) && uri.Contains($"/songs/{s.IdString}", StringComparison.OrdinalIgnoreCase));
        selectedSongId = match?.IdString;
    }

    private void OnNavLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        SyncSelectedSongFromUrl();
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnInitializedAsync()
    {
        var resp = await _globalAuth.IsPremiumUser();
        isPremiumUser = resp.IsSuccess && resp.Data;

        var savedTheme = await _storageService.GetItemAsync<string>("Theme");
        if (!string.IsNullOrEmpty(savedTheme))
        {
            isDarkTheme = savedTheme == "dark";
            await ApplyTheme(savedTheme);
        }

        // Sync selected song from current URL
        SyncSelectedSongFromUrl();
        _navManager.LocationChanged += OnNavLocationChanged;
        _heroDataService.OnUserSongsChanged += OnUserSongsChanged;

        // Pre-check if the user has any songs to decide whether to show "Your Songs"
        try
        {
            var songsCheck = await _songsApi.GetUserSongs(0, 1);
            hasUserSongs = songsCheck.IsSuccessStatusCode && songsCheck.Content?.TotalSize > 0;
        }
        catch { hasUserSongs = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (isYourSongsExpanded && hasMoreSongs && !_scrollObserverAttached)
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            try
            {
                await JsRt.InvokeVoidAsync("eval", @"
                    if (!window.__setupSongsScroll) {
                        window.__setupSongsScroll = function(dotNetRef) {
                            const list = document.querySelector('[data-songs-scroll]');
                            if (!list || list.__scrollSetup) return;
                            list.__scrollSetup = true;
                            list.addEventListener('scroll', function() {
                                if (list.scrollTop + list.clientHeight >= list.scrollHeight - 30) {
                                    dotNetRef.invokeMethodAsync('OnScrolledToEnd');
                                }
                            });
                        };
                    }
                    // Close context menu when clicking anywhere outside
                    if (!window.__navSongsClickAway) {
                        window.__navSongsClickAway = true;
                        document.addEventListener('click', function(e) {
                            const wrapper = e.target.closest('.your-songs-item-wrapper');
                            const menu = e.target.closest('.your-songs-context-menu');
                            if (!wrapper && !menu) {
                                const ref = window.__navSongsDotNetRef;
                                if (ref) ref.invokeMethodAsync('CloseContextMenuFromJs');
                            }
                        });
                    }
                    window.__navSongsDotNetRef = dotNetRef;");
                await JsRt.InvokeVoidAsync("__setupSongsScroll", _selfRef);
                _scrollObserverAttached = true;
            }
            catch { /* SSR or prerender — ignore */ }
        }
    }

    [JSInvokable]
    public async Task OnScrolledToEnd()
    {
        if (!isLoadingSongs && hasMoreSongs)
        {
            await LoadSongs(reset: false);
        }
    }

    private async Task ToggleYourSongs()
    {
        isYourSongsExpanded = !isYourSongsExpanded;
        if (isYourSongsExpanded && !userSongs.Any() && !isLoadingSongs)
        {
            await LoadSongs(reset: true);
            // Auto-expand the first group that has songs
            var firstGroup = GroupedSongs.Keys.FirstOrDefault();
            if (firstGroup != null)
                expandedDateGroups.Add(firstGroup);
        }
        if (!isYourSongsExpanded)
        {
            _scrollObserverAttached = false;
            activeSongMenuId = null;
            renamingSongId = null;
        }
    }

    private async Task LoadSongs(bool reset)
    {
        isLoadingSongs = true;
        StateHasChanged();

        try
        {
            if (reset) { songsOffset = 0; userSongs.Clear(); }
            var result = await _songsApi.GetUserSongs(songsOffset, SongsPageSize);
            if (result.IsSuccessStatusCode && result.Content?.Data != null)
            {
                userSongs.AddRange(result.Content.Data);
                songsOffset += result.Content.Data.Count;
                hasMoreSongs = result.Content.HasMore;
                hasUserSongs = result.Content.TotalSize > 0;
            }
        }
        catch { /* Silently fail — non-critical UI feature */ }
        finally
        {
            isLoadingSongs = false;
            _scrollObserverAttached = false; // re-attach after new content
            StateHasChanged();
        }
    }

    // ── Context menu ──
    [JSInvokable]
    public void CloseContextMenuFromJs()
    {
        if (activeSongMenuId != null)
        {
            activeSongMenuId = null;
            renamingSongId = null;
            StateHasChanged();
        }
    }

    private void CloseContextMenu()
    {
        activeSongMenuId = null;
        renamingSongId = null;
    }

    private void ToggleSongMenu(string? songId)
    {
        activeSongMenuId = activeSongMenuId == songId ? null : songId;
        renamingSongId = null;
    }

    private async Task ShareSong(ComboBoxDto song)
    {
        activeSongMenuId = null;
        try
        {
            var link = await _shareService.GenerateShareLinkAsync(song.IdString!);
            if (link != null)
            {
                await _shareService.NotifyLinkCopiedAsync();
            }
        }
        catch { /* ignore share errors */ }
    }

    private async Task PinSong(ComboBoxDto song)
    {
        activeSongMenuId = null;
        try
        {
            bool isPinned = song.ValueSubText == "pinned";
            var result = await _songsApi.MarkSongFavoriteStatus(song.IdString!, !isPinned);
            if (result.IsSuccessStatusCode)
            {
                song.ValueSubText = isPinned ? null : "pinned";
                StateHasChanged();
            }
        }
        catch { /* ignore */ }
    }

    private void StartRenameSong(ComboBoxDto song)
    {
        activeSongMenuId = null;
        renamingSongId = song.IdString;
        renameValue = song.ValueText ?? "";
    }

    private async Task HandleRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await JsRt.InvokeVoidAsync("eval", "document.querySelector('.your-songs-rename-input')?.blur()");
        }
        else if (e.Key == "Escape")
        {
            renamingSongId = null;
            _isCommittingRename = false;
        }
    }

    private async Task HandleRenameBlur()
    {
        if (!_isCommittingRename && renamingSongId != null)
        {
            await CommitRename();
        }
    }

    private async Task CommitRename()
    {
        if (_isCommittingRename) return;
        _isCommittingRename = true;

        if (string.IsNullOrWhiteSpace(renamingSongId) || string.IsNullOrWhiteSpace(renameValue))
        {
            renamingSongId = null;
            _isCommittingRename = false;
            return;
        }

        var songId = renamingSongId;
        try
        {
            var result = await _songsApi.RenameSong(songId, renameValue.Trim());
            if (result.IsSuccessStatusCode)
            {
                var song = userSongs.FirstOrDefault(s => s.IdString == songId);
                if (song != null) song.ValueText = renameValue.Trim();
            }
        }
        catch { /* ignore */ }
        finally
        {
            renamingSongId = null;
            _isCommittingRename = false;
            StateHasChanged();
        }
    }

    private async Task ArchiveSongItem(ComboBoxDto song)
    {
        activeSongMenuId = null;
        try
        {
            var result = await _songsApi.ArchiveSong(song.IdString!);
            if (result.IsSuccessStatusCode)
            {
                userSongs.Remove(song);
                if (!userSongs.Any()) hasUserSongs = false;
                StateHasChanged();
            }
        }
        catch { /* ignore */ }
    }

    private void ConfirmDeleteSong(ComboBoxDto song)
    {
        activeSongMenuId = null;
        var songId = song.IdString!;
        var modalOptions = new ModalOptionDto
        {
            Title = "Delete Song",
            Message = $"Are you sure you want to delete \"{song.ValueText}\"? This action cannot be undone.",
            ButtonText = "Delete",
            OptionType = OptionType.Warning,
            Context = new ModalContext { ActionType = "DeleteSong", Data = songId },
            OnConfirmCallback = async () => await HandleDeleteSong(songId)
        };
        _modalService.Show(modalOptions);
    }

    private async Task HandleDeleteSong(string songId)
    {
        try
        {
            var result = await _songsApi.DeleteSong(songId);
            if (result.IsSuccessStatusCode)
            {
                var song = userSongs.FirstOrDefault(s => s.IdString == songId);
                if (song != null) userSongs.Remove(song);
                if (!userSongs.Any()) hasUserSongs = false;
                StateHasChanged();
            }
        }
        catch { /* ignore */ }
    }

    private void TriggerLogout()
    {
        var modalOptions = new ModalOptionDto
        {
            Title = "Confirm Logout",
            Message = "Are you sure you want to log out?",
            ButtonText = "Logout",
            OptionType = OptionType.Warning,
            Context = new ModalContext { ActionType = "LogoutUser" },
            OnConfirmCallback = async () => await LogoutUser()
        };
        _modalService.Show(modalOptions);
    }

    private async Task LogoutUser()
    {
        await _globalAuth.MarkUserAsLoggedOutAsync();
        _navManager.NavigateTo("/login", replace: true);
    }

    private async Task ToggleTheme()
    {
        isDarkTheme = !isDarkTheme;
        var theme = isDarkTheme ? "dark" : "light";
        await ApplyTheme(theme);
        await _storageService.SetItemAsync("Theme", theme);
    }

    private async Task HandleCloseMobile()
    {
        await OnCloseMobileDrawer.InvokeAsync();
    }

    private async Task ApplyTheme(string theme)
    {
        await JsRt.InvokeVoidAsync("eval",
            $"document.documentElement.setAttribute('data-bs-theme', '{theme}')");
    }

    private async Task OnUserSongsChanged()
    {
        hasUserSongs = true;
        await LoadSongs(reset: true);
        // Auto-expand first date group so the new song is visible
        var firstGroup = GroupedSongs.Keys.FirstOrDefault();
        if (firstGroup != null)
            expandedDateGroups.Add(firstGroup);
        if (!isYourSongsExpanded)
            isYourSongsExpanded = true;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _navManager.LocationChanged -= OnNavLocationChanged;
        _heroDataService.OnUserSongsChanged -= OnUserSongsChanged;
        _selfRef?.Dispose();
    }
}

