@using System.Security;
@using System.Text.Json;
@inherits LayoutComponentBase
@implements IDisposable

<div class="page @(isSidebarCollapsed ? "sidebar-collapsed" : "")">
    @* ── Mobile top bar ── *@
    <header class="mobile-topbar">
        <button class="mobile-hamburger" @onclick="ToggleMobileDrawer" aria-label="Toggle menu">
            <i class="bi bi-list fs-5"></i>
        </button>
        <a class="mobile-brand" href="/">
            <img src="_content/FRELODYUI.Shared/fet_melody_logo.png" alt="Frelody" class="mobile-logo-img" />
            <span class="mobile-brand-text">FRELODY</span>
        </a>
    </header>

    @* ── Mobile drawer overlay ── *@
    @if (isMobileDrawerOpen)
    {
        <div class="mobile-overlay" @onclick="CloseMobileDrawer"></div>
    }

    <div class="sidebar @(isMobileDrawerOpen ? "drawer-open" : "")">
        <NavMenu IsSidebarCollapsed="isSidebarCollapsed"
                 OnToggleSidebar="ToggleSidebar"
                 OnCloseMobileDrawer="CloseMobileDrawer" />
    </div>

    <main>
        <article class="content px-2 px-sm-4 overflow-auto">
            <GlobalErrorBoundary @ref="errorBoundaryRef">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    @{
                        var errorId = GenerateErrorId();
                        var details = GetErrorDetails(ex);
                    }
                    <ErrorDialog Visible="true"
                                 Title="@details.Title"
                                 Message="@details.Message"
                                 ErrorId="@errorId"
                                 CanRetry="@details.CanRetry"
                                 Exception="@ex"
                                 OnRetry="RecoverPage"
                                 OnReload="HardReload" />
                </ErrorContent>
            </GlobalErrorBoundary>
        </article>
    </main>
</div>

<!-- Global Error Fallback -->
<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@* ── Global modal portal: rendered outside .page to escape all stacking contexts ── *@

<!-- Global Toast -->
<div class="toast-container position-fixed top-0 start-50 translate-middle-x pt-2" style="z-index: 100001;">
    <div class="toast align-items-center text-bg-@ToastBsClass() border-0 @(_toastService.IsVisible ? "show" : "")"
         role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <i class="bi @ToastIcon()"></i>
                @_toastService.Message
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto"
                    @onclick="_toastService.Hide" aria-label="Close"></button>
        </div>
    </div>
</div>

@if (_modalService.IsModalVisible)
{
    <DialogModal IsVisible="true"
                 Modal="@_modalService.CurrentModal"
                 OnCloseModal="CloseGlobalModal"
                 OnConfirmModal="ConfirmGlobalModal" />
}

@code{
    private GlobalErrorBoundary errorBoundaryRef = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    private bool isSidebarCollapsed = true;
    private bool isMobileDrawerOpen;

    protected override async Task OnInitializedAsync()
    {
        var savedSidebar = await _storageService.GetItemAsync<string>("SidebarCollapsed");
        isSidebarCollapsed = string.IsNullOrEmpty(savedSidebar) || savedSidebar == "true";
        _navManager.LocationChanged += OnLocationChanged;
        _modalService.OnShow += OnModalStateChanged;
        _modalService.OnClose += OnModalStateChanged;
        _toastService.OnToast += OnToastChanged;
    }

    private async Task ToggleSidebar()
    {
        isSidebarCollapsed = !isSidebarCollapsed;
        await _storageService.SetItemAsync("SidebarCollapsed", isSidebarCollapsed ? "true" : "false");
    }

    private void ToggleMobileDrawer()
    {
        isMobileDrawerOpen = !isMobileDrawerOpen;
    }

    private void CloseMobileDrawer()
    {
        isMobileDrawerOpen = false;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (isMobileDrawerOpen)
        {
            isMobileDrawerOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _navManager.LocationChanged -= OnLocationChanged;
        _modalService.OnShow -= OnModalStateChanged;
        _modalService.OnClose -= OnModalStateChanged;
        _toastService.OnToast -= OnToastChanged;
    }

    private void OnModalStateChanged() => InvokeAsync(StateHasChanged);
    private void OnToastChanged() => InvokeAsync(StateHasChanged);

    private string ToastBsClass() => _toastService.Type switch
    {
        ToastType.Error => "danger",
        ToastType.Warning => "warning",
        ToastType.Info => "info",
        _ => "success"
    };

    private string ToastIcon() => _toastService.Type switch
    {
        ToastType.Error => "bi-x-circle-fill",
        ToastType.Warning => "bi-exclamation-triangle-fill",
        ToastType.Info => "bi-info-circle-fill",
        _ => "bi-check-circle-fill"
    };

    private void RecoverPage()
    {
        errorBoundaryRef?.Recover();
    }

    private async Task HardReload()
    {
#if ANDROID || IOS || MACCATALYST || WINDOWS
        Application.Current.Quit();
        await Task.CompletedTask; // platform-specific restart handled elsewhere
#else
        await JS.InvokeVoidAsync("location.reload");
#endif
    }

private (string Title, string Message, bool CanRetry) GetErrorDetails(Exception ex) =>
    ex switch
    {
        // Network / API
        HttpRequestException => ("Network Error", "Unable to reach the server.", true),
        TimeoutException => ("Timeout", "The request took too long.", true),
        TaskCanceledException => ("Request Cancelled", "The request was cancelled (possibly due to timeout).", true),

        // Auth / Permissions
        UnauthorizedAccessException => ("Access Denied", "You are not authorized.", false),
        SecurityException => ("Security Error", "Your action is restricted by security settings.", false),

        // Input / Data
        ArgumentNullException => ("Missing Input", "A required field was not provided.", true),
        ArgumentException => ("Invalid Input", "Please verify your input.", true),
        FormatException => ("Format Error", "Data is not in the expected format.", true),
        JsonException => ("Data Error", "Failed to process server response.", true),

        // State / Logic
        InvalidOperationException => ("Operation Failed", "Cannot complete the operation now.", true),
        NotSupportedException => ("Unsupported Action", "This feature isn’t available in your environment.", false),

        // UI / MAUI-specific
        NullReferenceException => ("Unexpected Error", "Something wasn’t initialized correctly.", true),
        MissingMethodException => ("Component Error", "A required method was not found in the UI component.", false),
        
        // IO / File System
        FileNotFoundException => ("Missing File", "A required file could not be found.", false),
        DirectoryNotFoundException => ("Missing Folder", "A required directory could not be found.", false),
        IOException => ("File Error", "There was a problem accessing a file or resource.", true),

        // Fallback
        _ => ("Unexpected Error", "Something went wrong on this page.", true)
    };

    private string GenerateErrorId() =>
        $"ERR-{DateTime.UtcNow:yyyyMMdd}-{Guid.NewGuid().ToString("N")[..8].ToUpper()}";

    private async Task CloseGlobalModal()
    {
        var closeCallback = _modalService.CurrentModal?.OnCloseCallback;
        await Task.Delay(100);
        _modalService.Close();
        if (closeCallback != null)
            await closeCallback();
        StateHasChanged();
    }

    private async Task ConfirmGlobalModal()
    {
        var callback = _modalService.CurrentModal?.OnConfirmCallback;
        _modalService.Close();
        if (callback != null)
            await callback();
        StateHasChanged();
    }
}