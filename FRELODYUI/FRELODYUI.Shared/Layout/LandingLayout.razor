@using static FRELODYUI.Shared.Pages.Common.SearchModal
@inherits LayoutComponentBase
@implements IDisposable

<div class="app-shell d-flex flex-column vh-100">
    <!-- Header -->
    <header class="app-header sticky-top">
        <div class="app-header-inner">

            <!-- LEFT -->
            <div class="left-group">
                <button class="icon-btn d-lg-none" @onclick="ToggleDrawer" aria-label="Toggle menu">
                    <i class="bi bi-list"></i>
                </button>

                <a class="brand" href="/">
                    <span class="brand-fre">FRE</span><span class="brand-lody">LODY</span>
                </a>
            </div>

            <!-- CENTER (DESKTOP NAV LINKS) -->
            <nav class="center-nav d-none d-lg-flex">
                <a href="/" class="@NavActive("/")">Songs</a>
                <a href="/studio/landing" class="@NavActive("/studio/landing")">Studio</a>
                <a href="/pricing" class="@NavActive("/pricing")">Pricing</a>
                <a href="/playlists/landing" class="@NavActive("/playlists/landing")">Playlists</a>
            </nav>

            <!-- RIGHT -->
            <div class="right-group">
                <button class="search-trigger" @onclick="OpenSearchModal" aria-label="Search">
                    <kbd class="search-kbd d-none d-lg-inline">Ctrl+K</kbd>
                    <i class="bi bi-search-heart"></i>
                </button>

                <button class="icon-btn" @onclick="ToggleTheme" aria-label="Toggle theme">
                    <i class="bi @(isDarkTheme ? "bi-sun-fill" : "bi-moon-fill")"></i>
                </button>

                <CascadingAuthenticationState>
                    <AuthorizeView>
                        <Authorized>
                            @{
                                var firstName = context.User.FindFirst("FirstName")?.Value;
                                var lastName = context.User.FindFirst("LastName")?.Value;
                                var userId = context.User.FindFirst("UserId")?.Value;
                            }
                            <div class="dropdown">
                                <button class="user-avatar" type="button"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                    <span>@(firstName?.FirstOrDefault())@(lastName?.FirstOrDefault())</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="/user-profile/@userId">
                                            <i class="bi bi-person me-2"></i>View Profile
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" href="/studio">
                                            <i class="bi bi-easel me-2"></i>Chord Flow
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/dashboard">
                                            <i class="bi bi-speedometer2 me-2"></i>Dashboard
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/playlists">
                                            <i class="bi bi-music-note-list me-2"></i>Playlists
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <button class="dropdown-item text-danger" @onclick="LogoutUser">
                                            <i class="bi bi-box-arrow-right me-2"></i>Log out
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </Authorized>
                        <NotAuthorized>
                            <button class="icon-btn signin-btn" @onclick="NavigateToLogin" aria-label="Sign in">
                                <i class="bi bi-person-circle"></i>
                            </button>
                        </NotAuthorized>
                    </AuthorizeView>
                </CascadingAuthenticationState>
            </div>

        </div>
    </header>

    <!-- Mobile Drawer -->
    <div class="app-drawer @(isDrawerOpen ? "open" : "")" @onclick:stopPropagation>
        <div class="drawer-header">
            <a class="brand" href="/">
                <span class="brand-fre">FRE</span><span class="brand-lody">LODY</span>
            </a>
            <button class="icon-btn" @onclick="CloseDrawer" aria-label="Close menu">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <nav class="drawer-nav">
            <a href="/" class="@NavActive("/")" @onclick="CloseDrawer">
                <i class="bi bi-music-note-beamed me-2"></i>Songs
            </a>
            <a href="/studio/landing" class="@NavActive("/studio/landing")" @onclick="CloseDrawer">
                <i class="bi bi-easel me-2"></i>Studio
            </a>
            <a href="/pricing" class="@NavActive("/pricing")" @onclick="CloseDrawer">
                <i class="bi bi-tag me-2"></i>Pricing
            </a>
            <a href="/playlists/landing" class="@NavActive("/playlists/landing")" @onclick="CloseDrawer">
                <i class="bi bi-music-note-list me-2"></i>Playlists
            </a>
        </nav>
    </div>

    @if (isDrawerOpen)
    {
        <div class="drawer-backdrop show" @onclick="CloseDrawer"></div>
    }

    <!-- Body Content (Scrollable) -->
    <main class="app-body flex-grow-1 overflow-auto">
        <GlobalErrorBoundary @ref="errorBoundaryRef">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                @{
                    var errorId = GenerateErrorId();
                    var details = GetErrorDetails(ex);
                }
                <ErrorDialog Visible="true"
                             Title="@details.Title"
                             Message="@details.Message"
                             ErrorId="@errorId"
                             CanRetry="@details.CanRetry"
                             Exception="@ex"
                             OnRetry="RecoverPage"
                             OnReload="HardReload" />
            </ErrorContent>
        </GlobalErrorBoundary>
    </main>

    <!-- Footer -->
    <footer class="app-footer py-2">
        <div class="container-fluid px-4">
            <div class="row gy-2">
                <div class="col-12 col-md-6">
                    <p class="text-center small mb-0 d-none d-md-block">
                        Your ultimate music companion. Explore, play, and share songs with ease.
                    </p>
                </div>
                <div class="col-12 col-md-6">
                    <p class="text-center small mb-0">
                        &copy; @DateTime.Now.Year FRELODY. All rights reserved.
                    </p>
                </div>
            </div>
        </div>
    </footer>
</div>

<!-- Global Toast -->
<div class="toast-container position-fixed top-0 start-50 translate-middle-x pt-2" style="z-index: 100001;">
    <div class="toast align-items-center text-bg-@ToastBsClass() border-0 @(_toastService.IsVisible ? "show" : "")"
         role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <i class="bi @ToastIcon()"></i>
                @_toastService.Message
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto"
                    @onclick="_toastService.Hide" aria-label="Close"></button>
        </div>
    </div>
</div>

<SearchModal @ref="searchModalRef"
             OnSearch="HandleSearch"
             OnResultSelected="HandleResultSelected" />

@if (_modalService.IsModalVisible)
{
    <DialogModal IsVisible="true"
                 Modal="@_modalService.CurrentModal"
                 OnCloseModal="CloseGlobalModal"
                 OnConfirmModal="ConfirmGlobalModal" />
}
@code {
    private GlobalErrorBoundary errorBoundaryRef = default!;
    private bool isDarkTheme = false;
    private bool isDrawerOpen = false;
    private SearchModal? searchModalRef = default!;

    protected override async Task OnInitializedAsync()
    {
        var theme = await _storageService.GetItemAsync<string>("Theme");
        isDarkTheme = theme == "dark";

        if (isDarkTheme)
        {
            await ApplyTheme("dark");
        }

        _toastService.OnToast += OnToastChanged;
        _navManager.LocationChanged += OnLocationChanged;
        _modalService.OnShow += OnModalStateChanged;
        _modalService.OnClose += OnModalStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRt.InvokeVoidAsync("setupSearchShortcut");
        }
    }

    private async Task HandleSearch()
    {
        await Task.CompletedTask;
    }

    private async Task HandleResultSelected(SearchResult songResult)
    {
        _navManager.NavigateTo($"/songs/landing/{songResult.Id}");
        await Task.CompletedTask;
    }

    private async Task OpenSearchModal()
    {
        if (searchModalRef != null)
        {
            await searchModalRef.Open();
        }
    }

    private void ToggleDrawer() => isDrawerOpen = !isDrawerOpen;
    private void CloseDrawer() => isDrawerOpen = false;

    private async Task ToggleTheme()
    {
        isDarkTheme = !isDarkTheme;
        var theme = isDarkTheme ? "dark" : "light";
        await ApplyTheme(theme);
        await _storageService.SetItemAsync("Theme", theme);
    }

    private async Task ApplyTheme(string theme)
    {
        await JsRt.InvokeVoidAsync("eval",
            $"document.documentElement.setAttribute('data-bs-theme', '{theme}')");
    }

    private void NavigateToLogin()
    {
        var currentPath = _navManager.ToBaseRelativePath(_navManager.Uri);
        var returnUrl = string.IsNullOrEmpty(currentPath) || currentPath == "login" || currentPath == "register"
            ? ""
            : $"?returnUrl={Uri.EscapeDataString("/" + currentPath)}";
        _navManager.NavigateTo($"/login{returnUrl}");
    }

    private async Task LogoutUser()
    {
        await _globalAuth.MarkUserAsLoggedOutAsync();
        _navManager.NavigateTo("/login", replace: true);
    }

    private void RecoverPage()
    {
        errorBoundaryRef?.Recover();
    }

    private async Task HardReload()
    {
#if ANDROID || IOS || MACCATALYST || WINDOWS
        Application.Current.Quit();
        await Task.CompletedTask;
#else
        await JsRt.InvokeVoidAsync("location.reload");
#endif
    }

    private (string Title, string Message, bool CanRetry) GetErrorDetails(Exception ex) =>
        ex switch
        {
            HttpRequestException => ("Network Error", "Unable to reach the server.", true),
            TimeoutException => ("Timeout", "The request took too long.", true),
            TaskCanceledException => ("Request Cancelled", "The request was cancelled.", true),
            UnauthorizedAccessException => ("Access Denied", "You are not authorized.", false),
            ArgumentNullException => ("Missing Input", "A required field was not provided.", true),
            ArgumentException => ("Invalid Input", "Please verify your input.", true),
            InvalidOperationException => ("Operation Failed", "Cannot complete the operation now.", true),
            _ => ("Unexpected Error", "Something went wrong.", true)
        };

    private string GenerateErrorId() =>
        $"ERR-{DateTime.UtcNow:yyyyMMdd}-{Guid.NewGuid().ToString("N")[..8].ToUpper()}";

    public void Dispose()
    {
        _toastService.OnToast -= OnToastChanged;
        _navManager.LocationChanged -= OnLocationChanged;
        _modalService.OnShow -= OnModalStateChanged;
        _modalService.OnClose -= OnModalStateChanged;
    }

    private void OnToastChanged() => InvokeAsync(StateHasChanged);
    private void OnModalStateChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private string NavActive(string href)
    {
        var relativePath = _navManager.ToBaseRelativePath(_navManager.Uri);
        var path = "/" + relativePath.Split('?')[0].Split('#')[0].TrimEnd('/');

        if (href == "/")
            return path == "/" || path.StartsWith("/songs") ? "active" : "";

        return path.StartsWith(href, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    private string ToastBsClass() => _toastService.Type switch
    {
        ToastType.Error => "danger",
        ToastType.Warning => "warning",
        ToastType.Info => "info",
        _ => "success"
    };

    private string ToastIcon() => _toastService.Type switch
    {
        ToastType.Error => "bi-x-circle-fill",
        ToastType.Warning => "bi-exclamation-triangle-fill",
        ToastType.Info => "bi-info-circle-fill",
        _ => "bi-check-circle-fill"
    };

    private async Task CloseGlobalModal()
    {
        var closeCallback = _modalService.CurrentModal?.OnCloseCallback;
        await Task.Delay(100);
        _modalService.Close();
        if (closeCallback != null)
            await closeCallback();
        StateHasChanged();
    }

    private async Task ConfirmGlobalModal()
    {
        var callback = _modalService.CurrentModal?.OnConfirmCallback;
        _modalService.Close();
        if (callback != null)
            await callback();
        StateHasChanged();
    }
}