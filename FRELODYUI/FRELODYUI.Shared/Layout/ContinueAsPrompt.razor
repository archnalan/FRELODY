@implements IAsyncDisposable

@* Non-intrusive, dismissible "Continue as <name>" prompt shown to signed-out visitors.
   • Returning FRELODY users get a chip that silently revives their session (refresh token),
     falling back to Google One Tap if the refresh token has expired.
   • Everyone else (incl. brand-new visitors with a Google session) is offered Google's
     own One Tap card. Never blocks the page; remembers dismissal for the page load. *@

@if (_visible && _remembered is not null)
{
    <div class="cap" role="dialog" aria-label="Continue signing in">
        <button class="cap-close" @onclick="Dismiss" aria-label="Dismiss">
            <i class="bi bi-x-lg"></i>
        </button>
        <div class="cap-avatar" aria-hidden="true">@Initials</div>
        <div class="cap-body">
            <span class="cap-label">Continue as</span>
            <span class="cap-name">@DisplayName</span>
            @if (!string.IsNullOrEmpty(_remembered.Email))
            {
                <span class="cap-email">@_remembered.Email</span>
            }
        </div>
        <button class="cap-go" @onclick="ContinueAsync" disabled="@_busy" aria-label="Continue">
            @if (_busy)
            {
                <span class="cap-spinner" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-right"></i>
            }
        </button>
    </div>
}

@code {
    // Remembers dismissal for this layout's lifetime (persists across same-layout
    // navigations). Instance-scoped on purpose — a static field would leak across
    // Blazor Server circuits and suppress the prompt for every user.
    private bool _dismissedThisLoad;

    private bool _visible;
    private bool _busy;
    private RememberedUser? _remembered;

    private DotNetObjectReference<ContinueAsPrompt>? _ref;
    private IJSObjectReference? _module;

    private string DisplayName =>
        string.Join(" ", new[] { _remembered?.FirstName, _remembered?.LastName }
            .Where(s => !string.IsNullOrWhiteSpace(s)));

    private string Initials
    {
        get
        {
            var f = _remembered?.FirstName?.FirstOrDefault();
            var l = _remembered?.LastName?.FirstOrDefault();
            var s = $"{(f.HasValue ? f.Value.ToString() : "")}{(l.HasValue ? l.Value.ToString() : "")}";
            return string.IsNullOrEmpty(s) ? "?" : s.ToUpperInvariant();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _dismissedThisLoad) return;
        if (!await _localStorage.IsStorageAvailableAsync()) return;

        // Already signed in → nothing to offer.
        var state = await _globalAuth.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true) return;

        _ref ??= DotNetObjectReference.Create(this);

        _remembered = await _globalAuth.GetRememberedUserAsync();
        if (_remembered is not null && !string.IsNullOrWhiteSpace(DisplayName))
        {
            _visible = true;
            StateHasChanged();
        }
        else
        {
            // No local memory → let Google One Tap offer "Continue as <Google account>".
            await StartGoogleOneTapAsync(null);
        }
    }

    private async Task ContinueAsync()
    {
        if (_busy || _remembered is null) return;
        _busy = true;
        StateHasChanged();
        try
        {
            // 1) Silent revive via refresh token.
            if (!string.IsNullOrEmpty(_remembered.RefreshToken) && !string.IsNullOrEmpty(_remembered.Token))
            {
                var resp = await _authApi.RefreshToken(new RefreshTokenDto
                {
                    AccessToken = _remembered.Token,
                    RefreshToken = _remembered.RefreshToken
                });
                if (resp.IsSuccessStatusCode && resp.Content is not null)
                {
                    await _globalAuth.MarkUserAsAuthenticatedAsync(resp.Content);
                    _visible = false;
                    _toastService.Show($"Welcome back, {_remembered.FirstName}.", ToastType.Success);
                    StateHasChanged();
                    return;
                }
            }

            // 2) Refresh token gone/expired → fall back to Google One Tap, hinting their email.
            await StartGoogleOneTapAsync(_remembered.Email);
        }
        catch
        {
            _toastService.Show("Couldn't sign you in automatically. Please use Sign in.", ToastType.Error);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task StartGoogleOneTapAsync(string? loginHint)
    {
        try
        {
            var cfg = await _authApi.GetGoogleOAuthConfig();
            var clientId = cfg.IsSuccessStatusCode ? cfg.Content?.ClientId : null;
            if (string.IsNullOrEmpty(clientId)) return;

            _ref ??= DotNetObjectReference.Create(this);
            _module ??= await JsRt.InvokeAsync<IJSObjectReference>(
                "import", "./_content/FRELODYUI.Shared/continueAuth.js");
            await _module.InvokeVoidAsync("initOneTap", clientId, _ref, loginHint);
        }
        catch { /* best-effort: prompt is a progressive enhancement */ }
    }

    [JSInvokable]
    public async Task OnGoogleCredential(string credential)
    {
        if (string.IsNullOrEmpty(credential)) return;
        _busy = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var resp = await _authApi.GoogleOneTap(new GoogleOneTapRequestDto { Credential = credential });
            if (resp.IsSuccessStatusCode && resp.Content is not null)
            {
                await _globalAuth.MarkUserAsAuthenticatedAsync(resp.Content);
                _visible = false;
                _toastService.Show($"Signed in as {resp.Content.User?.FirstName}.", ToastType.Success);
            }
            else
            {
                _toastService.Show("Google sign-in failed. Please try again.", ToastType.Error);
            }
        }
        catch
        {
            _toastService.Show("Google sign-in failed. Please try again.", ToastType.Error);
        }
        finally
        {
            _busy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task Dismiss()
    {
        _visible = false;
        _dismissedThisLoad = true;
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("cancel"); } catch { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
            {
                try { await _module.InvokeVoidAsync("cancel"); } catch { }
                await _module.DisposeAsync();
            }
        }
        catch { }
        _ref?.Dispose();
    }
}
